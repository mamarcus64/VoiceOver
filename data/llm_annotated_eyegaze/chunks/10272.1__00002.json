  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "So one day-- Tell me where the school was.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The school was in the city by the name of Chust, C-H-U-S-T-- Chust.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "It was a large city.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I started in September, 1st of September, to go to school, but I'm not sure I made two months in the school.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I had to go there Friday evening, to Chust, because I had to go to high school on Saturday, too, on the sabbath, in order not to violate sabbath.",
      "word_count": 29
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And I was raised in an orthodox religious family.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I had to go there and sleep over in Chust in my aunt's house.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Aunt's name was Miriam.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Last name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Leibowitz ?].",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I'm not sure it's [?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Leibowitz ?].",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "That's what I think, it [? was Leibowitz. ?]",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So what I remember is one Friday night, I wake up in the middle of the night with a big noise of Czech soldiers marching towards a military camp located not far from my aunt.",
      "word_count": 35
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And I was wondering what is going on?",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Such a [INAUDIBLE], such a [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "So in the morning, I went to school, and I found on the main entrance of the school a sign-- handwritten sign-- the school, the class, will be closed until further note due to the general mobilization of the military forces, which will be staged at the school.",
      "word_count": 48
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So this was my last day in school-- the mobilization of Czechoslovakia due to the crisis, which took place in 1938.",
      "word_count": 21
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "When Hitler met Chamberlain, the prime minister of Britain, and Deladier, prime minister of France, they agreed to sacrifice part of Czechoslovakia in order for Hitler not to invade Czechoslovakia.",
      "word_count": 30
    }
  ],
