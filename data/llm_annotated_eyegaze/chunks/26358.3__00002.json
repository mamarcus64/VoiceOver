{
  "stem": "26358.3",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "My boyfriend figured I need to go see my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "He can not take more.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I can't take that more.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "And I went, came in to my cousin's in the apartment.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "And I saw my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "The lice where the bandage was-- the hospital sent him-- after five days they sent him to my cousins, from the hospital to my cousin in ghetto.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "The lice was so big walking around off his arm.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The bandage was small.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I start to holler at my cousin.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I say, why you not took him in hospital, change the bandages?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "It's four weeks the same bandages.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "It's infection and everything.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I took my brother of the back, my back.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And took him in hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Was like a block from my cousin's where they was there.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I took him in hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I came in in hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "The nurse said, what you want here?",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I said, I want a bucket of water with alcohol.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I want your change in clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "You have here plenty of clothes.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I don't have a clothes there to change him.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I say, I want clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I want a bucket of water with alcohol.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "I want you.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And I want The doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "How come the doctor not told my brother to come changing the bandages?",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "And I want to see the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "[SHOUTING]",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "She said, who you are to tell me what to do?",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I say, I am from the concentration camp.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I Gestapo.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I said, I've been-- went to hell.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And I want you right now.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And she say, I haven't no time for you.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I went to her, catched her by the shirt.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I shaked her.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I was strong.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I was not a weak little girl.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And I shaked her.",
      "word_count": 4
    }
  ],
