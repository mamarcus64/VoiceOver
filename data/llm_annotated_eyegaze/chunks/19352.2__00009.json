  "sentences_input": [
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "To Treblinka.",
      "word_count": 2
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "'41.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "194--",
      "word_count": 1
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "1941.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "It was about April.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Was-- it was cold.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 2,
      "text": "So cold.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "And we was-- we walked.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "We had to go through a little forest.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "And one time-- [INAUDIBLE] was the main SS man in this factory-- factories.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "Three-- it was three factories.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "And he had a son.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "And he had two big dogs, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 5,
      "text": "The German shepherd.",
      "word_count": 3
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 6,
      "text": "And when we walked, [PAUSES FOR 3 SECONDS] he let the dogs go.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 7,
      "text": "And-- and he jump.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 8,
      "text": "And I said, you run.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 9,
      "text": "I will stay because I like dogs, and they will stay with me.",
      "word_count": 13
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 10,
      "text": "And they came over.",
      "word_count": 4
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 11,
      "text": "And they-- he beat me in my behind.",
      "word_count": 8
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 12,
      "text": "And that's it.",
      "word_count": 3
    }
  ],
