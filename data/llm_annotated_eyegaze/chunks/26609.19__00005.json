{
  "stem": "26609.19",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "I knew no one there.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And I was a stranger there with so many people.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And everybody hated me, because I didn't want to marry him.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He was serious about.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] Get a stranger.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And I don't know him at all, who he is and what is in him.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Get married.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Then I thought, look, to myself, there must be a hospital here and doctors.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "So many people, there's a hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And so I went there.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I asked someone, could you tell me where the hospital is?",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I went there.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "At the first door, I knocked.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And there was a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I came in, introduced myself.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I said, I am from [?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Filt ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Nuremberg. ?] And through the paper, I found out I had a lost-- I told the story, my husband, the whole family.",
      "word_count": 22
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "My child was in terrible circumstances.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "But she's alive.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "She's here with a man who has the same name as I but no relative at all.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And he wants to marry me.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Otherwise, he doesn't want to give my child.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He sent the police here.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "And he hid her.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And since I'm here, I haven't seen her even.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I can't say anything.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "Is she mine, or is she not mine?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "So he says, that is a story.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "It goes around, we all laugh.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And we heard of a man, a Mehr, like you.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "We heard the story that he once came a woman from somewhere else.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And he wants-- we didn't know who it is-- marry her.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "And she doesn't want to marry.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And it goes around.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And everybody laughs.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "I said, now you know the story.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "That's me.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "Oh, that's different.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "Why didn't you come the first thing to us?",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "I said, because I didn't suspect anything.",
      "word_count": 7
    }
  ],
