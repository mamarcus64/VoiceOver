{
  "stem": "6803.1",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 23,
      "text": "And around 8 o'clock in the morning, they served us a-- a conserve with meat-- with meat-- and a piece of bread.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 24,
      "text": "No water.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 25,
      "text": "Very salty.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 26,
      "text": "The meat was salty like hell.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 27,
      "text": "And they kept us in the wagon in the sun, under the sun, a whole day, and not given us a drop of water.",
      "word_count": 24
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 28,
      "text": "Everybody was going crazy.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 29,
      "text": "We didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 30,
      "text": "We didn't have no water.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "They take us from Plaszow to Mauthausen.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know we gonna go to Mauthausen.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "But we were on the train--",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "--to go somewhere.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And when-- at night, as the train started to go, and I remember even then, I was so thirsty.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know what-- I'm going out my mind.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And I have a little bot-- a little cup or something.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And I urinate in the cup.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And I thought, maybe I'm gonna drink a little-- you know.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And I drank it, and I threw up.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't take it.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "By the morning, we stopped somewhere in the station.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "They opened up the wagon, the doors.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And the SS was waiting for us-- some SS.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "They came up with the beat-- beat with the sticks.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And beat us.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And they accused us, what we did something.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And one man, a Jewish man, I remember, he says, [SPEAKING GERMAN].",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "He started to scream.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "He said, I didn't do nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "He just-- he accused him of something.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "He says, I'm here.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] do.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I got my name. ?] What?",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "I didn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "You have a nerve!",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "What-- you-- he started beat him, beat him, until he beat him to death in front of us.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "In front of us.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "And then we-- we knew already about what's going on.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 10,
      "text": "And then the SS were waiting outside.",
      "word_count": 7
    }
  ],
