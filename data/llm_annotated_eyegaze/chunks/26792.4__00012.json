  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "So Vaboulis says in case there is a house search or what, I can present a passport.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "But it's a different picture and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "It was a different age and all that.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In the building company, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And then, see, he got another place for the railway station for the rail, if people wanted to travel, black marketers, they needed a special permit and he got them the permits for money, for 50 deutschmark.",
      "word_count": 37
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And they came to our house and they brought us food, which I of course gave to small Russian children who were-- who were evacuated to Latvia, were hungry, et cetera.",
      "word_count": 31
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "That's a different story.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Well anyway, we could put even some money aside for which we bought gold because we wanted, sooner or later, we wanted to find ways how to get away.",
      "word_count": 29
    }
  ],
