  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I think [PAUSES FOR 3 SECONDS] my parents were very fortunate in finding friends of friends who knew where-- how I could get to Ger-- to England.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "There was a-- they had found a school where a-- well, in England, there had been an appeal.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I found this out afterwards.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "But-- in fact, fairly recently-- when after Kristallnacht, I mean, when the English-- some of the English people in charge realized what was going on, they wanted to save the young people.",
      "word_count": 32
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "They decided at least if we can't save the grownups, let's save some of the young people.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And they organized these famous kinder transports.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Kinder transporter.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "That's fine with me because I have to go to the bathroom.",
      "word_count": 12
    }
  ],
