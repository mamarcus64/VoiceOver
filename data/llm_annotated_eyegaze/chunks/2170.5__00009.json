{
  "stem": "2170.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.2,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 92,
      "text": "In the middle of the room is sitting a KGB lieutenant, a young guy in the 20s.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 93,
      "text": "With his stars, I knew right away.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 94,
      "text": "And I come to the table and he says, sit down.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 95,
      "text": "Tell me how you came to Moscow.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 96,
      "text": "He didn't want it directly.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 97,
      "text": "And he's holding the [? proposk, ?] the paper with the passport.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "How did you came to Moscow?",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You, as a Russian citizen, did not know that to come to Moscow you have to have a permit from us, an invitation.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Otherwise you are not allowed to be over here.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "So when he told me this, and do you know he says, I can send you right away to Siberia?",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Do you know what you did?",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "So when he was talking to me like this I made believe I don't understand Russian too much, and I start to speak Polish.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Because I speak Polish.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And he says, why, you don't speak Russian God bless you.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And I said, well, I-- I am Polish.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "I speak Polish better than Russian.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "But he says, you are so smart that this passport, you see, and the [? proposk ?], you knew how to get.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "But a [? proposk-- ?] a permit you did not know how to get?",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "How did you get your passport?",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "You are smart.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "You get out of this room within minutes.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And within 24-- 21 hours, you have to leave Moscow.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "If you don't leave Moscow within 21 hours, you'll be arrested and sent away.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "Get out.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "So on the right side was a door, not that the door was open.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And I run in the other room and this girl, his secretary was sitting there and she's holding her hands by the head.",
      "word_count": 23
    }
  ],
