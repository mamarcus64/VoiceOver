{
  "stem": "543.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Or you have to let me go with her, or she has to come with me.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Or let her come with me.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And he looked me over.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And he said, no.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "He said, your mother can stay easily on the truck.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "You have to walk.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "You're young.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "You're a strong woman.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "You can walk.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And it is far.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "He said, you'll see your mother later, and you know, and let her go.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "My mother stays in the truck.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "I see the truck driving away, slowly with my mother telling me that the truck is no good, on her fingers.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "And I staying there and couldn't get her off.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "So that was unbelievable.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "My father was on the other side with my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "I couldn't see him anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 24,
      "text": "They was most probably go away right away too.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 25,
      "text": "So my brother and my, my husband ride together.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So we stayed in the line by-- in a big line.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And suddenly, Mengele comes out, and put, with his little stick, took me out, took my sister-in-law out, and about 40 people.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "He said, those 40 people come with the SS, and the two SS.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And we had to go somewhere.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "So they took us in Auschwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Now, there was two [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "There was one, Birkenau.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "The women's [NON-ENGLISH] was Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "I went to Auschwitz, where the-- where the men were.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "So they took us there, and there was a little [NON-ENGLISH], a little thing.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And they took us away.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "And they took our-- I had a wedding band, and I don't-- nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 12,
      "text": "And they took us off and out.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 13,
      "text": "And you had to take all your clothes off.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 14,
      "text": "They took away all your jewelery, whatever you were--",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I had-- yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "The most was already in-- yeah, jewelry.",
      "word_count": 7
    }
  ],
