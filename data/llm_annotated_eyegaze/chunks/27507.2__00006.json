  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And her sister went back to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "So they disappeared.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And other family members went to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And finally, there were in this flat only one of my aunts, who was a painter, one of the sisters of my mother, and my father and myself and my grandmother and maybe one other aunt.",
      "word_count": 36
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I'm not quite sure.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Now, in Bialystok, I heard on the whole-- I-- I think I quite enjoyed it.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I learned quite a bit of Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I was going to Russian-- to Russian [PAUSES FOR 2 SECONDS] official ceremonies that are in the theater.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I remember that was kind of a theater spectacle for the children, I think, where the whole row of young pioneers appeared in the-- in their white shirts and red scarves.",
      "word_count": 31
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And they were singing.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And people were aware, of course, that things will not stay as they were, because the one song that I learned then, and the one song that the pioneers were-- were singing, which I still remember, is [POLISH], if tomorrow the war breaks out, If tomorrow the breaks out, if tomorrow we have to march, if the dark force-- force is on the border, and so on, then we will all stand together to defend the countrymen, something like that.",
      "word_count": 80
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And I learned all kinds of Russian poems.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I was on the way to become quite-- quite a integrated Soviet citizen.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "But it didn't happen, because my father decided finally as well to cross over to Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "As my mother went already, he-- it was more or less obvious that we will try as well to go to Warsaw.",
      "word_count": 22
    }
  ],
