{
  "stem": "7188.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "My sister was taken away in Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "Something cattle-- I think cattle cars?",
      "word_count": 6
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember, really.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 3,
      "text": "I really don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 4,
      "text": "We came together to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "It was  in the daytime, early morning.",
      "word_count": 7
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "We were all black.",
      "word_count": 4
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 2,
      "text": "They were from coals, the trains, the cars.",
      "word_count": 8
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 3,
      "text": "And we came out all black, that the German, said, what did you bring me some garbage here?",
      "word_count": 18
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] He said the strong, the healthy, they'll do work.",
      "word_count": 13
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 5,
      "text": "So they took us to showers, gave us a shower.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "Arbeit macht frei.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Work will let you free.",
      "word_count": 5
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "When you work, you'll get free.",
      "word_count": 6
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "The selection was there to older people, younger people.",
      "word_count": 9
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "There was over-selection.",
      "word_count": 3
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "They took pictures.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Germans.",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "After they took us out from the shower, they got pictures.",
      "word_count": 11
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "They cut our hair off, completely bald, anyplace.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 3,
      "text": "Sterilize us like--",
      "word_count": 3
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean, sterilized you?",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "They get all kind of junk on the body.",
      "word_count": 9
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "You shouldn't have germs, or something.",
      "word_count": 6
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "And then they let us lay on the-- night and a day, I think, we were laying without blankets in the camp.",
      "word_count": 22
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "They sterilized everything.",
      "word_count": 3
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 4,
      "text": "You shouldn't be no germs, nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "'43?",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "It was springtime.",
      "word_count": 3
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "I was still with my sister, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we slept together too.",
      "word_count": 5
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "Well, the clothes.",
      "word_count": 3
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "Whatever they gave us.",
      "word_count": 4
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "This was clothes from the transport which Jews, they'd bring into the camps.",
      "word_count": 13
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "We didn't wear the [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 2,
      "text": "We wore regular clothes they gave us.",
      "word_count": 7
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 3,
      "text": "One was long, and one was short-sleeve.",
      "word_count": 7
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 4,
      "text": "One was a right shoes, and one was a left shoes.",
      "word_count": 11
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 5,
      "text": "They gave you clothes in the camp, in Auschwitz.",
      "word_count": 9
    }
  ],
