{
  "stem": "19939.5",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 16.2,
  "sentences_input": [
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "So then I went.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And the thing was going slow, again, through something.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And my uncle, we are corresponding.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "He sent me even some German marks.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And he sent me some addresses of people that survived in Munich.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And so we were going with this train to Krakow, probably, back to Krakow.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "And I had some names of people, Jewish people, that would help me from Krakow to go to join him.",
      "word_count": 20
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "And the, the train stopped in Munich for the night.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "So I picked myself up from Munich.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I said, I'm not going back to Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "And I left the train, left all my things.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "And I walked at night to this Munich.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I was never there.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 5,
      "text": "I took the tramway.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 6,
      "text": "I had some money.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 7,
      "text": "I still spoke German.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 8,
      "text": "I found these people there.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 9,
      "text": "They're-- they lived in an apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 10,
      "text": "And I have to say it again, because this is part that I was damaged.",
      "word_count": 15
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 11,
      "text": "I come in.",
      "word_count": 3
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 12,
      "text": "And they had a, a-- what is it?",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 13,
      "text": "There was no light-- a short, right?",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Right, and I, I opened the door.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "I said, this is [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "I come in.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "And they survived hidden in a cellar somewhere.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "And the mother is lighting candles, the Sabbath candles.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "I thought that I'm dreaming.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "How, how stupid are they?",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "How can they go on with this Jewish, with this something?",
      "word_count": 11
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "It was such a shock.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "I didn't want any part of this anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "So these people, you know, they found out.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "They took a little, little-- some little truck or something they're hired.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 6,
      "text": "They came back with me to the train.",
      "word_count": 8
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 7,
      "text": "I took some of the things.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 8,
      "text": "And they were shocked, too, this friend of mine, this teacher, right?",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 9,
      "text": "You just leaving like this?",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 10,
      "text": "How can you do this something?",
      "word_count": 6
    }
  ],
