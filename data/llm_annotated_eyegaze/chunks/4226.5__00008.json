{
  "stem": "4226.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 27,
      "text": "We got an alarm and, and some fighter planes came.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 28,
      "text": "Or fighter bombers, whatever they had that time.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 29,
      "text": "And they dropped a few bombs on the station.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 30,
      "text": "We, we were-- I was with my friends on, on the bank, sitting, laying on the bank and watching the station more or less protected from the river bank.",
      "word_count": 29
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 31,
      "text": "And when that was over, we-- I had some Maggi soup cubes from-- German ones-- from the canteen.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 32,
      "text": "And they-- someone had a match.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 33,
      "text": "I didn't have matches on me.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 34,
      "text": "And we took this-- that [INAUDIBLE] or whatever from, from inside and warmed the soup.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 35,
      "text": "Took water from the river and in, in the two-liter jug which I carried, put the Maggi in and boiled the soup.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 36,
      "text": "Put a brick next to the track.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 37,
      "text": "Piece of rock, a brick.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 38,
      "text": "Put the fire underneath and boiled it up and made the soup.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 39,
      "text": "It was good and warm.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 40,
      "text": "And we were there about-- next, next the night came and early morning.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 41,
      "text": "Then they, they got the locomotive and started everybody in the wagon.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 42,
      "text": "They locked us in.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 43,
      "text": "You could--",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Not cattle.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Coal car, meter forty.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "You had to sit on that straw.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "And woven thing-- you wouldn't even put your head out through there.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "It was woven.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And I was approximately over the middle of, of the-- maybe was 20 carriages.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And they whistled.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "They closed up and moved off.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And we got to another station not too far.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Was only, could have been 7:00 or-- between 7:00 and 9:00 in the morning when the locomotive got hit by one of these low flying aircraft.",
      "word_count": 26
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And we only knew some were injured in the first two carriages behind.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "The locomotive-- they pierced the thing, steam whistling, lost all the power.",
      "word_count": 12
    }
  ],
