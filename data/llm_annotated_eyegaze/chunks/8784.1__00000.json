{
  "stem": "8784.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Sol Urbach.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Last name is U-R-B-A-C-H.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "At times during the war, I would be known as Solomon, but in this country I have use Sol, S-O-L.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Solomon, right.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I'm born on October 25, 1925.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "I was born in Kalwaria-Zebrzydowski.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Spelling of that town is Kalwaria, K-A-L-W-A-R-I-A dash Zebrzydowski-- Z-E-B-R-Z-Y-D-O-W-S-K-I-- in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Kalwaria would be about 30 kilometers from Krakow.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I, I I was raised-- I was born in Kalwaria and my, my putting together of events lead me to believe I was there up to the age of three.",
      "word_count": 30
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "At the age of three, my family has decided to move from Kalwaria.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, we would have been just three children, the two older ones and I was-- a brother, sister, and I would be the third one.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "When we were three children, my family has decided to move to Romania where there was a sister of my mother's who lived there and she reported of the good fortune and good things that are happening to them in Romania, so my parents upped from Poland and went to Romania.",
      "word_count": 51
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And we lived in Romania for the next five years, from 1928 to 1933.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "This was in Sadagura, which is the-- a-- the other side of the river from Chernivtsi, which today falls into Ukraine, but at that time it was Romania.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I remember some things, very few things.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "But I remember that we used to live across from a-- what was a rabbi's castle or a rabbi's court like.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "He would have been known as the Sadagura rabbi.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And I remember living there.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "I remember the one trolley car that was running in Chernivtsi itself.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "But I don't remember many more things from Romania.",
      "word_count": 9
    }
  ],
