{
  "stem": "14900.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "You also had a quota to meet.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "You had to get out X number.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "The production was important.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "My mother was on the main floor.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "I was on the top floor.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "Couldn't see out the windows, they were so filthy and full of grime.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "No heat in the winter, [PAUSES FOR 3 SECONDS] no air in the summer.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "It was a hell hole.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 19,
      "text": "And I worked day in and day out.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "And I can't tell you if there was a day off.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "I cannot remember.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "But in exchange for that, we now had three ration cards.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "And my mother and I, on the job, every day at noon, got a bowl of soup.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "There were no coffee breaks.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "You had no rights.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "[PAUSES FOR 3 SECONDS] Eventually in 1942-- I just found it at [INAUDIBLE], in the record book of the Lodz Ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "I think it was September 12, 1942, they were already having roundups in the ghetto, shipping people out to concentration camps and gas chambers.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "There was a roundup.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "I was told to hide in the rafters above our attic.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "There were two other youngsters with me, because we were too young, and we'd be taken.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "My grandma refused to hide.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "She didn't want to jeopardize the children.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "[PAUSES FOR 5 SECONDS] I laid in this space for an eternity, with spiders crawling on my face, vermin, rats scurrying around, pitch black.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "Someone just put up this tall ladder.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "And then they shut the trap door, told us not to move, not to breathe, not to say a word, not to sneeze.",
      "word_count": 23
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "Our lives depended on it.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "And if the Germans didn't find us, someone would come and get us when it was safe.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "I heard the ladder being put up what seemed a lifetime later.",
      "word_count": 12
    }
  ],
