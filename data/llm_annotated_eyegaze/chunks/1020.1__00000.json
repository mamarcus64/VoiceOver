{
  "stem": "1020.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Isidore Hollander.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I-S-A-D-O-R-E H-O-L-L-A-N-D-E-R.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Hollander.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And my Yiddish nomer was Yitzhak Doff.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "When I was  born, it was spelled in French.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Actually, my name-- my parents' name was the spelling H-O-L-E-N-D-E-R, I was born in Paris.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And my mother received me after birth with my birth certificate, H-O-L-L-A-N-E-D-E-R.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And coming to the United States, we changed the name as it is now.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "1920.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I'm going to be 75 July 26.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents came to Paris 1919.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was born 1920.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And then, my father became ill.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He was told that he is not going to survive.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Those years was very hardship in France, in Paris, to be buried in a Jewish cemetery.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "So as my father was raised as an orthodox, he wanted to go back home to Poland.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "A matter of fact, when he left and I was age three-- 1923-- he only lived two weeks, and he passed away.",
      "word_count": 22
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "That's why we stayed in Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My mother never went back to France.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were coming back to Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Four years-- I was with my mother up to age seven.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And my mother went through with us, with me and a sister of mine-- an older sister, which she's perished-- a lot of not good four years.",
      "word_count": 27
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And finally, she found somebody to get married after being four years a widow.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And it happen the stepfather wasn't too much agreeable with my mother to keep us at home, me and my sister.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "So my mother gave me away to an orphanage, to a Jewish orphanage, in hometown of Bendin.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Which, thanks to those good years that I was in the orphanage, I was raised as a mensch.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "I was educated in Yiddish and the Polish language.",
      "word_count": 9
    }
  ],
