{
  "stem": "512.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name?",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name was Malka Menglovitz.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I was both in March 4, 1926 in Bilky.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "At the time, it was Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Bilky was a small community, mostly farming, and this was about all.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "It had about 300 Jews in the community-- very primitive.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "It was mostly Gentiles.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Well, my family-- my father, David Menglovitz, was a butcher.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And he was also, during the summer, he was in the produce.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "He would buy them and ship them all over Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "Life was primitive.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "My mother, Regina Pascowitz, she came from a neighboring community, a very wealthy family.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "My grandfather in those years, he was head of a bank.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And but he-- her father passed away when she was married.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I never-- I never knew my grandfather from my mother's side, only my grandmother.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And they had-- she had six sisters and three brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "They-- all the sisters except one here in the United States perished.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "And life was primitive, but we didn't know any better, so it was accepted.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And my, my father's aim was to leave the community.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "His brothers were in the-- his brothers and-- two brothers and two sisters were here in the United States already, and his aim was very much to leave.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "My mother objected to it because she would never leave her family.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "She was very, very attached to her mother, and she was a widow who lived alone.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "So she always-- I remember as a very young child, that she said that she would never leave while her mother is alive, even though she had a sister in the United States.",
      "word_count": 33
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And that's the only sister that survived.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Did you have brothers and sisters?",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I had-- I'm the oldest.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "I had-- we were six children.",
      "word_count": 6
    }
  ],
