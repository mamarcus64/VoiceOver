{
  "stem": "23626.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I remember a lot of them coming into our home and having tea and cookies with my mother.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And I-- I played with the children.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "As it turned out to be, later, I was very disappointed because they didn't accept us as our-- as friends anymore.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "But as a child, I did have pleasant memories.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And those few families, those Jewish families that we lived with, none of them are alive.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "I never seen them after the war anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "I searched and asked but no one is around.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I remember when we were in the ghetto and-- and when the deportations started to become so frequent, my oldest sister, Sydell, tried to take my mother out of the ghetto and save them--",
      "word_count": 34
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Before the ghetto?",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I remember my parents always worrying about my oldest sister going out at night, not to be too safe for her.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "She was already a teenager, and she would come-- go out with her friends.",
      "word_count": 14
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And-- and I-- I remember, as a child, hearing my parents wondering if she will come home safe.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And that-- I thought, why are they worried?",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Well, they were worried because the antisemitism in Poland was rather severe.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And, you know, no one was really that safe.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So I have noticed my parents being concerned about my sister staying out or-- or going in the neighborhood where maybe it-- it wasn't so safe for her.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "Do you remember, at that time, anybody being mean to you, or--",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Not to me, no.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I did not experience anything like that as a child.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "I called myself a child because I felt I was a child, yes.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I-- I personally, now, I don't remember anything that would be directed toward me.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "No.",
      "word_count": 1
    }
  ],
