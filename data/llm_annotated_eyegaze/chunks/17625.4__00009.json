      "sentence_idx_in_seg": 2,
      "text": "He was bloody from-- from head to toe.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And he says to-- to-- to this girl-- this-- this-- he was the underscharfuhrer, under him.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
