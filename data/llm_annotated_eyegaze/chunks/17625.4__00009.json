    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "One was Kitt.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "The other one was another name.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
