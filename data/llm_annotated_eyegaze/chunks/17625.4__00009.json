    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "No, no, hats.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "But-- but with-- with-- with the black corduroy, you know, around to this here, but officers.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "What his name?",
