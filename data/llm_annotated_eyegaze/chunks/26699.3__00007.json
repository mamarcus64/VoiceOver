  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "One of them ended in a asylum and died there.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "Another one is in Israel, also in very poor mental conditions after being abused there.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "[PAUSES FOR 9 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "After I finished the three years of this gymnasium, the [non-English speech], I went to the last four years, which were the proper high school.",
      "word_count": 25
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] I had a tradition in my family, on my mother's family, of engineers.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "So they advised me to go to a technical school, technical high school, and I listened to them.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "My inclination was also technical.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I like mathematics, and I liked physics, and I wanted always to copy one of my mother's brothers, was for me an example, who is an electrical engineer.",
      "word_count": 28
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So I went to a technical school for architecture, where I studied for four years.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And at the age of 17, I became a qualified architectural technician.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I had a [non-English speech] there.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "I passed the [non-Enlish speech].",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And then, I went to the technical university for civil engineering.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "It was a normal followup.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "Had your father started a new business?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He couldn't start a new business after 1948.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "He started a new business after we arrived in Bucharest in 1944.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So from '44 to '48, he had [PAUSES FOR 3 SECONDS] a wholesaling store for fabrics in Bucharest, which was nationalized in 1948 when the communists took power.",
      "word_count": 28
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Then, he became an employee, like the rest of the country.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was a government employee.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Private business disappeared totally, including doctors' rooms, for instance.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "It was nothing but government employment.",
      "word_count": 6
    }
  ],
