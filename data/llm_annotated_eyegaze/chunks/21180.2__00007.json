{
  "stem": "21180.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I told this we will-- why we couldn't stay over to be hidden.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "So we went out and they put us-- [PAUSES FOR 3 SECONDS] and they send it-- they came Germans.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "They put us up on the train, took us-- they took us to the train, and from the train immediately to Auschwitz.",
      "word_count": 22
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "You know, you heard a lot of things.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Somebody, for example-- maybe I was more understanding.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And personally, I didn't talk to him.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, I greet him.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "He came to see by us for our work.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "He had-- was working with me a person, which he owned obligation to him.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And he want to help him.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "What is the help?",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "He couldn't give me my extra bread once in a month, or once a week, or once when I came.",
      "word_count": 20
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And he says he should come to see him.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And he was this little-- he was from Poznaiski.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "A gentile from the-- from Poznaiski.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "Poznaiski was, how do I say?",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "In Europe-- like, here I would say-- how do I say?",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "The richest people in Europe.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "They had factories, textile factories.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "And he was a gentile.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "He was convert by the German [INAUDIBLE] home in Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "His father was already convert.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But since he worked before the war by him, he wants to show his attitude good to him.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "But he was an antisemitist, Poznaiski.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "He was in ghetto, this friend who knew him.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But with me, we was living very good, because he needs me and I need him.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "Should live over-- we thought we're going to live over.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "He-- they sent him to Auschwitz the same thing like me.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I was in a distribution of food.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So my department-- everybody got a card.",
      "word_count": 7
    }
  ],
