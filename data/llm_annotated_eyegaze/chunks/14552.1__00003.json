{
  "stem": "14552.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And then her sister remained in America.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "And she went back to Europe.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "And she missed her mother very much.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "They were very close.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "In the United States.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And she remembered that her mother fainted at the boat.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And she just couldn't get that out of her mind.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And she returned.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "She couldn't-- the memory of her mother's fainting was very clear in her mind.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And she couldn't get that out.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "She couldn't forget that.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And so she came back.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And that was interesting that how my father met her because she was taking back some message from someone.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And my father has gone to Szerednye to-- to pick up that message.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And when he met her, he fell in love with her.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And they got married.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "So the message--",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "--was good.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I can't-- they were-- they, they must have married 1912 or '11.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I had an oldest brother, who was the only talented person in the family.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "He, he played the violin.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "He was a violin player, [LAUGHS] and he wrote music.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And he performed.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And he was a-- he was forever working on his music.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And the house had a lot of sounds.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "There was the mandolin, the violin, and the zither.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "And the-- we, we enjoyed music.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "And we had the kind of house that we didn't have a telephone, so the people didn't call that-- can I see you?",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "They just knocked on the door.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "And they came in.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And they-- we were-- had food.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And we had games.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And we were reading the Yiddish books, the Sholem Aleichem and the Chaim Nachman Bialik books, these-- they were reading in the evening.",
      "word_count": 23
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "There was no television, of course.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "So we were occupied on the weekends with the-- with the fun of music and reading and eating.",
      "word_count": 18
    }
  ],
