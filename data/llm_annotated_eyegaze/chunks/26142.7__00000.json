  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--Michael Jackson.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And we were starting with the-- we were continuing the story of Isaak Zummer.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Right This man, Isaak Zummer, I-- I call him.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I wrote his name as the [NON-ENGLISH]-- the angel that helps.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "As he-- as I said, he-- first he said, you eat.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Sit down.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Eat.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And we told him that we-- we have-- my brother, Moshe has two-- a wife and two children that are in Istichka, in that widow's home.",
      "word_count": 26
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "He says-- he says, he knows where it is.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "He knows where-- he said to us-- [PAUSES FOR 3 SECONDS] --he said, my brothers, he said, you must disappear tonight yet-- from here, because your life is in danger.",
      "word_count": 30
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "I have somebody.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "I have a man that has a boat.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "I am going over there.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "And this man will-- will-- ferry you over the Dniester River tonight.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "You must disappear tonight, yet.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Because if they come tomorrow, they send-- they will send-- send you to [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And that's-- [PAUSES FOR 4 SECONDS] and we said, how are you?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "You are responsible?",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "How are you going to do it?",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "He said, you are six souls and I'm only one.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "This man didn't have-- I didn't see a woman in this house.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He didn't have a beard.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He was walking [NON-ENGLISH] means without-- without a hat.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "In other words, he was not religious.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "But he was [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "He said, you are a plurality.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "You are a [NON-ENGLISH], and-- and I'm only one.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "So don't worry about me.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Well, I'll cope with the situation.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "It took an hour or so.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And he came back.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And he told us that he has a man for us that will come-- 12 o'clock at night to the place in Istichka-- to that place.",
      "word_count": 26
    }
  ],
