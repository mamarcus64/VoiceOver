{
  "stem": "747.4",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 25,
      "text": "And they following day we arrived to a camp-- Ravensbruck.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 26,
      "text": "Well, it was a great welcoming committee, didn't wait for us.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 27,
      "text": "And the first two days we were spending in a tent, with no food.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 28,
      "text": "And it was raining, and this was-- I still have a rheumatism, I feel in my bones.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 29,
      "text": "We were sleeping on the frozen ground, without any cover.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 30,
      "text": "And we got a coat in Ravensbruck-- a coat.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 31,
      "text": "And after three weeks being under observation, there I always had a-- a mischief.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 32,
      "text": "There were a lot of lice there.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 33,
      "text": "And we were lying-- by that time it was the end of November, and it was cold, and was-- we went-- just went out to the roll call in the evening, morning and the evening, And nothing to do during the day.",
      "word_count": 42
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So we're lying in our bed, and this started the lice epidemic.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I scratched my stomach.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And this was itchy.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And I started to scratch more.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And I had a red spot there.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "So then one day, they-- we were gathered for an inspection, took us into the hospital.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "And they were recruiting a group of women-- 1,000 women-- to send to-- I didn't know at that time where-- to go to work in a factory.",
      "word_count": 27
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "So when the doctor came to me, he saw the red spots, put me on the side.",
      "word_count": 17
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "My friends knew that, if I will be left in Ravensbruck alone, I will never make it.",
      "word_count": 17
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "So they get a contact with a Hungarian woman was working there in the hospital, who's Mengele had made experiment on, and gave her male-- male hormones.",
      "word_count": 27
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And this woman grew a long, black beard.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Her voice changed, and she was miserable.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She didn't have anything to shave with.",
      "word_count": 7
    }
  ],
