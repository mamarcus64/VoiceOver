  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Her name is Claire.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Her maiden name was Skolnick and her father was a cantor.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "She was born in Philadelphia already here.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Oh, a funny thing if you're interested.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "There was a guy who was a very close friend of mine.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "We were friends in Shanghai, and then Japan, and then Lithuania as refugees.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And he went-- came here and went to Canada.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "He settled in Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So he and I-- once he comes a year.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And we are still two single guys.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And we meet and-- oh, oh.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] What are you [? come? ?] He says, I came for a [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I'm getting older.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "I'm getting old and it's no longer a joke.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I want a [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "OK, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Will you?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "He said somebody [INAUDIBLE], and I'm supposed to meet the girl.",
