{
  "stem": "3361.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "And he gave me $4,200 in that time-- $4,200 and go in business.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "It was a lot of money.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "But, still, I couldn't buy a decent business.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "I had to buy it with merchandise, you know, and the business.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "So I boughted a store.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "But if you didn't order the-- a bread or a milk, they didn't have for you.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "You had to order day before.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 22,
      "text": "Then they had the bread for you or the milk for you.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "So this kind of business, she, she couldn't-- she was running the business.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "The husband was a nothing, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "But he-- she was running the business.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I bought that business.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I took apart everything.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I built my own shelves.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "I built everything.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "I took in a new refrigerator.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I start-- and, and that salesman came to me to sell me the-- but want to lend me money.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He came to me for an order.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "He came to me.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And I gave him an order.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "I gave him an order for $1,500.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And I wa-- I'm ready to open the store.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "But I didn't have the merchandise yet.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "I called up the company.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And I said, I gave you an order, gave you to sale-- to that salesman an order.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "And I didn't get the merchandise.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "I'm ready to open.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "I cannot open without the merchandise.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "And I prepared that time a lot of sugar, because I want to give away the sugar with low cost price in order the customer should come in for the sugar.",
      "word_count": 31
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "But they have to buy $5 minimum with that bag sugar.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And I prepared a lot of sugar to give away, below cost price.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "And then start the Korean War.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "This was in 1951.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "The Korean War started.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 23,
      "text": "And I-- the people coming in-- yeah.",
      "word_count": 7
    }
  ],
