{
  "stem": "3984.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "But they-- when-- when the people-- like-- like-- you know, if the people going to the synagogue, or they went with the-- the [NON-ENGLISH], with the bears, and you know the people went with [NON-ENGLISH] outside, and with payot.",
      "word_count": 39
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "You know what is payot?",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And the people start to make [NON-ENGLISH]-- make problems.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And this people, this gentile people-- the man that worked in the-- area, that know everything, that something is very wrong, that they can make for the Jewish people something very wrong.",
      "word_count": 32
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "They told for my mother that they can take me to-- to hide me.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I don't know nothing about this.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "My mother was afraid to tell me.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "I don't want to leave nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "But he-- he want help for her-- herself to do something.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And he-- he-- he felt my mother was felt that if she can take somebody, and to save somebody, perhaps she can do it something.",
      "word_count": 25
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "So she take my mother.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "And she-- they told the plan, what they want to do with me-- to behind me-- to behind.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And my mother afraid to tell for the little children too, because the little children can speak-- speak out.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And the gentile was near to us-- you know, this side and this side.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "Like we live here, and the other side is gentile.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "The other side is gentile.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And they start in '43-- right away they-- they start to be mean, even the-- even the-- the-- the--",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "--neighbors.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And she was afraid too.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "There I was afraid, because everybody know what going on in-- in our little town-- everybody.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "They know what going on.",
      "word_count": 5
    }
  ],
