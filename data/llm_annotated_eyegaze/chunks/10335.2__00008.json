    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 2,
      "text": "It's a long time, about 50 years.",
      "word_count": 7
    },
    {
      "segment_idx": 154,
      "sentence_idx_in_seg": 3,
      "text": "See I was supposed to come over here before.",
