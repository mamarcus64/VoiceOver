  "sentences_input": [
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "No, with Israel a difference [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "You see, Israel this time was in war.",
      "word_count": 8
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "And I want to go Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 3,
      "text": "Well, I got there.",
      "word_count": 4
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 4,
      "text": "Israel told me, no, you no can go.",
      "word_count": 8
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 5,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 6,
      "text": "Because my wife got the boy, the son.",
      "word_count": 8
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "I tell them, what I can do?",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "I don't want to be over here.",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 2,
      "text": "Well, make application to the American's Council down at the Israeli council.",
      "word_count": 12
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 3,
      "text": "Israeli Council told me, you want in?",
      "word_count": 7
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 4,
      "text": "You ready.",
      "word_count": 2
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 5,
      "text": "I came in and 10 minutes you got the passport.",
      "word_count": 10
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "My wife told me no, not yet.",
      "word_count": 7
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 1,
      "text": "I go to the American Council.",
      "word_count": 6
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 2,
      "text": "American Council told them, no.",
      "word_count": 5
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 3,
      "text": "I can not give you because you are a communist.",
      "word_count": 10
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 4,
      "text": "I'm a communist.",
      "word_count": 3
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "The why me, a communist?",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "I get up in the Nazi camp, and I'm a communist?",
      "word_count": 11
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 2,
      "text": "No, and I can't go.",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 3,
      "text": "I go by, Israeli called me come on.",
      "word_count": 8
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 4,
      "text": "I give you the passport.",
      "word_count": 5
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 5,
      "text": "So, what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "No, what's happened, I have to wait another year.",
      "word_count": 9
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "And after this, they give me, they call me up.",
      "word_count": 10
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 2,
      "text": "Come on, I give you the passport--",
      "word_count": 7
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "United States.",
      "word_count": 2
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "Not me.",
      "word_count": 2
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 1,
      "text": "A lot of people like that were like that.",
      "word_count": 9
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 1,
      "text": "That, I was the husband.",
      "word_count": 5
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "My son.",
      "word_count": 2
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my son.",
      "word_count": 3
    },
    {
      "segment_idx": 147,
      "sentence_idx_in_seg": 1,
      "text": "Not that-- she never got married before, no.",
      "word_count": 8
    },
    {
      "segment_idx": 148,
      "sentence_idx_in_seg": 0,
      "text": "He was born in Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 149,
      "sentence_idx_in_seg": 0,
      "text": "From Germany, I go to Italy.",
      "word_count": 6
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 0,
      "text": "Yeah-- no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 150,
      "sentence_idx_in_seg": 1,
      "text": "In Italy, I live in a private house.",
      "word_count": 8
    },
    {
      "segment_idx": 151,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 0,
      "text": "Because I like it better from Germany go to Italy.",
      "word_count": 10
    },
    {
      "segment_idx": 152,
      "sentence_idx_in_seg": 1,
      "text": "And Italy it was better to go over here.",
      "word_count": 9
    },
    {
      "segment_idx": 153,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, yeah.",
