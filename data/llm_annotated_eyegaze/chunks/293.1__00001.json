{
  "stem": "293.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "When he finish 18-- when he was 18 years of age and finished high school, he went to America in 1905 [PAUSES FOR 3 SECONDS] because the family has relatives, cousins, and uncles someplace in New York.",
      "word_count": 37
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "I never found them.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Lately, I'm getting now some feeding back that they are from the family of Cracow Pfefferberg.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "My father spent seven years in America.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "Their family was wealthy here in America, but they give him a chance only to stay with them about a month, and then they said, you are on your own.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "He got a job in Metropolitan Opera in New York, in the chorus.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "He has a beautiful tenor voice, and he was singing over there.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "He-- he came back because as the oldest son-- his father got gravely ill in the 1912, and my father returned to support the family.",
      "word_count": 25
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And my grandfather-- I never knew my grandfather from my father's side because I was born in 1913.",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He died 1912, but I was-- my name, Leopold, is after my grandfather from my father's side.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "My sister was born in 1916, and her name was after the grandmother from my mother's side.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And their name was Pauline.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My-- when my father-- I don't know exactly, because still was a very young man in his 20s.",
      "word_count": 18
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "He came back, and he met by coincident his future wife, who also was from very prominent Jewish family, middle class family, [PAUSES FOR 3 SECONDS] from family name Goldfluss.",
      "word_count": 30
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Moses Goldfluss was my grandfather.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "All very well situated.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They got married, and I was born in a short time, about exactly nine or ten months after [LAUGHS] they got married.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "Because I was-- they married in 1912, and I was born in in 1913, in March.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My father.",
      "word_count": 2
    }
  ],
