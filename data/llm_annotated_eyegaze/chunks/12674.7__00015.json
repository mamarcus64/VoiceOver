{
  "stem": "12674.7",
  "chunk_idx": 15,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "But that I was able not to fold under it, under the pressure.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "Because this is-- I-- I cannot talk about something that happened to me without going, that's the way I react, unfortunately.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "I live through it, as I tell about it.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "I feel it.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "And the enormity of it frightens me, 24 hours a day.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "I think about it all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "I have an obsession with food.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "I think about food 24 hours a day.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "I cannot eat any.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "I know it will kill me if I eat as much as I want to.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "But I want to.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "Because I was so hungry for so long, that I'll never, ever-- no matter how full I am-- will I ever be able to mentally accept the fact that I have enough.",
      "word_count": 32
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "I know I will never ever need for anything or want for anything.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "I was able to make a life for myself, luckily, with the gifts that I guess, God gave me, to-- to make myself.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "I'm not wealthy.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "But I'm comfortable.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "I'll never be poor.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "But I will never able to believe that I will always have enough food.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 35,
      "text": "For the first six or seven years of my marriage, we threw out no food.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 36,
      "text": "Because to me, I had to know that there was enough food.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 37,
      "text": "My husband always used to say, comes the revolution, for six months, we'll be the only well-fed people.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 38,
      "text": "Because I filled up all the closets with food.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 39,
      "text": "I couldn't buy enough.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 40,
      "text": "I still buy too much sometimes.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 41,
      "text": "But I have come down.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 42,
      "text": "I have made myself.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 43,
      "text": "I-- I think that it is a miracle how much the human mind is able to with-- withstand without becoming unmanageable, without falling apart.",
      "word_count": 24
    }
  ],
