{
  "stem": "14708.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 59.4,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 30,
      "text": "I got the papers, and Jan arranged that.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 31,
      "text": "And my mother had also papers.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I had the name Eva Kriston, E-V-A K-R-I-S-T-O-N.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Hungarian.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Hungarian, of course.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Not just Jewish.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Not just Jewish, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "It was-- this person really lived in Miskolc.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "She didn't know about it.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "She was one year older than I am, so I had to remember that I am one year older.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So I got the papers, and Jan mentioned this already, that he left after the German occupation.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "He left Miskolc and went to Budapest.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And in May 26, I went after him to Budapest too.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Before that, we corresponded.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But of course, I couldn't get letters in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So in the tobacco factory, where I worked with two gypsy girls, I took always dresses to them.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I went to work in the morning with several dresses on myself, and then I gave it to them.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And they let me use their address, so Jan wrote the letters to their address, and they brought me Jan's letters.",
      "word_count": 21
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "So we were in contact, and I knew his address in Budapest.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And in May 26, at night, I escaped from the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "My father knew a police detective, and he gave him some money.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "And he came to our house and took me.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And we went to the railway station and with a night train, went to Budapest.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And at the railway station we departed.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "I didn't see him anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "As I heard from my father later on, just a few days later, he started to blackmail my father.",
      "word_count": 19
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "So much for the nice policeman.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My father was basically against it and didn't believe in it.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "My mother was standing in the middle of our apartment, and she said, how can I-- how can I just go?",
      "word_count": 21
    }
  ],
