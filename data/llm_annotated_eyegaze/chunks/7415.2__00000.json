{
  "stem": "7415.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "--grandmother.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "After we left Umschlagplatz, we didn't have a place to stay.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My older-- my older brother of my mother, Uncle Joseph was working for his school friend, a German, in some kind of place where they did fabricate German-- German uniforms.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And he tried to help my mother and me.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I remember that once he-- when he was putting me, I was covered by German uniforms.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Hiding.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And I was hungry and unhappy.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And Germans were just going and looking at their uniforms.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And if I will just move, I could be killed.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "I had-- I-- I was always hiding, even in-- being in ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And [PAUSES FOR 3 SECONDS] one day, my mother left the ghetto with me.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And when we left ghetto, there was a man who was blackmailing her right away, [LAUGHS] and she had to-- to pay something for not going back to-- to ghetto again.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And there was waiting Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "Maria who introduced herself as my grandmother.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And we were already on the-- in Warsaw, not in ghetto side.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, after the war, a long time after, I found out that she was a lover of my grandfather.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Maternal.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "The one who died.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "The one who jumped off the building.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No--",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "His-- his wife jumped--",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "--out of the-- of the building.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And he died of typhus.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Miss Maria, she loved my--",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "She replaced the grandmother who jumped-- jumped out of the window.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "She loved my grandfather, and had a child-- illegitimate child with him, who, at this time, it was something very embarrassing for a Catholic Polish woman.",
      "word_count": 26
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And she gave this child-- but I found out that after the war-- she gave her son to some peasants who brought him up.",
      "word_count": 24
    }
  ],
