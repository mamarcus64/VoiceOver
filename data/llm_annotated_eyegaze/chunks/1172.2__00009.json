  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] When we-- I moved to Lubeck, and my brother-in-law was very active in Jewish life.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "So we were.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I met a lot of important people.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I don't know if you remember the time when we had exodus, and the British sent the two boats back.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "That was near us, Hamburg, and they brought those people to a camp near Lubeck.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So we were very active working there.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "A lot of Israeli [PAUSES FOR 4 SECONDS] chalutzim-- not chalutzim-- but important Israeli leaders came, and British, and American.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "A lot of people came to help.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And finally, it was resolved, and people were-- did go to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And in 1946, [PAUSES FOR 4 SECONDS] there was a small Jewish community in Lubeck.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Every Sunday was a wedding, and everybody was invited to the wedding.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And one day, [INAUDIBLE] I met my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "His father was in the same town that I lived, and I knew him.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And one day, he-- my husband came from Russia to find his father.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "That's how we met.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And in 1947, his father remarried.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] And--",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "His mother, she died in the Warsaw ghetto, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And they, then was the time when the British gave affidavits to go to-- to Palestine then.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "So my husband volunteered to-- wanted to go to Palestine, because he had all his relatives and his younger brother who had survived concentration camp.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "But the Jewish agency told him, you're young, you can go on [? a later date, ?] but we'll give your parents the affidavit to go to Israel.",
      "word_count": 28
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "So they went to Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And my husband stayed in Lubeck.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "In 1949, we went for a visit to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And [PAUSES FOR 4 SECONDS] we, his father decided we should get married there.",
      "word_count": 14
    }
  ],
