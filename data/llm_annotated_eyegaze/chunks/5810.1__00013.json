  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And I remember my sister and myself trying to help him, because there was a-- a fight ensued.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "And somebody called the police.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 12,
      "text": "And the police in those days, at least some of them, most of them really, were working hand in hand with the Gestapo.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 13,
      "text": "And they arrested my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 14,
      "text": "He was turned over to the Gestapo, and then also was taken back to Malines, and to a concentration camp.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "And I never heard from him again.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So the only three that were left was my mother, my older sister-- she was six years older than I was-- and myself.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And I was at that time about seven or eight, I believe.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    }
  ],
