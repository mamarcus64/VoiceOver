{
  "stem": "26609.14",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "At the beginning, when they hit me, and they took me into the office where Gestapo, chief Gestapo was there, and the chief, and how they hit-- but these were SS men, not Gestapo.",
      "word_count": 34
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "He was Gestapo, sitting behind his desk, but he said nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He couldn't tell them, because also he was a top Gestapo man.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But SS had more to say than he himself.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "There were young man from the SS.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And they were awful.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "They tortured actual-- they tortured people.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And the first time they took me in, and ask me questions.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "But I didn't answer, because [INAUDIBLE] I don't understand German.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "They knew that Jews-- most Jews understand German.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "If it's a good German or bad German, but they could speak German.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And Poles couldn't.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "So I didn't answer.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "They hit me a few times in face.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] And I bleeded.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "But I didn't cry.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "I forgot to cry, how to cry.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And I think that helped me, because they knew that if a Jewish girl-- I was a girl there, they didn't know that I have a child.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "When they tortured them, they cried, and started to beg them.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I didn't.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I just thought millions of thoughts in a second, what will happen?",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "Will they kill me?",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Will I ever see my little child?",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "What will she do if they kill me alone there?",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Will the Polish woman keep her?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And-- but I didn't faint.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I was stronger than ever, not eating for such a long time, not even sleeping.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Standing, we slept standing, one woman against the other with the backs, because there was no room to sit down.",
      "word_count": 20
    }
  ],
