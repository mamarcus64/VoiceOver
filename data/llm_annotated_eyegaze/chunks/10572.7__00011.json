  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "In your great mercy, you made it possible that over 800 citizens of my hometown witnessed the dedication and consecration of a magnificent memorial, crowned by a bronze replica of the temple in Jerusalem as a memorial for those millions and as an admonition for a new generation who were there to ask for redemption.",
      "word_count": 55
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "In your great mercy, you made it possible for your humble servant to end his prayer on this cold night of November 9th, 1988.",
      "word_count": 24
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "[SPEAKING HEBREW]",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "In supporting some of my loyal friends, friends who risked their very existence at the time when they helped me, [PAUSES FOR 4 SECONDS] friends that now [PAUSES FOR 3 SECONDS] were the victims of this unbelievable madness that destroyed Germany and the rest of Europe [PAUSES FOR 3 SECONDS] because they had followed a mad man.",
      "word_count": 57
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I knew that [PAUSES FOR 3 SECONDS] these people who were now starving and starving to death, friends of mine, needed my help as I needed their help before.",
      "word_count": 30
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And I got-- last week, I got a phone call from a friend of mine in Hamburg to tell me that his wife had died at the age of almost 80.",
      "word_count": 31
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And she was with me as an unbelievable, loyal [PAUSES FOR 4 SECONDS] friend, and helped me through very, very dark years.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And when they were bombed out, Margie and I sent them blankets, and clothes, and food.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "And they told us, years later, if it wouldn't have been for those blankets, they never would have survived the cold winter.",
      "word_count": 22
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And [PAUSES FOR 3 SECONDS] I felt that I was doing only what they would have done for me in a similar situation.",
      "word_count": 23
    }
  ],
