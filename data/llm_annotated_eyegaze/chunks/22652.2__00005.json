{
  "stem": "22652.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And we-- it was in Montmorency, a little town outside of Paris, known for cherry trees.",
      "word_count": 16
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And it was a brief stay, maybe a month or two.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And then the-- a social worker came and picked me up and took me in Paris to the convent of Notre Dame de Sion, Notre Dame of Zion.",
      "word_count": 28
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed in the servant quarters, maybe 10 days.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I don't-- and there were a few Jewish girls.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And I-- there-- I-- there were three of us.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "There probably were more, but I remember we were three.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "There was the oldest one, Lilian.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Me-- Lilian was about 13, 14.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I was 10, 11.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And the youngest one was Elizabeth, and she was about six.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And we were there.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "It was a beautiful, beautiful convent.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I understand that de Gaulle sent his children there.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "A lot of wealthy children who wanted-- wealthy people who wanted their children to be well educated in an aristocratic fashion, knowing music, arts, literature, and manners, were sent there.",
      "word_count": 30
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "It was an exclusive school.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Absolutely gorgeous, with gorgeous grounds.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Castle-like, manor-like.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "Antique furniture, absolutely gorgeous.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "But we were in the servant quarters.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "I remember the young girls and older women always ironing, and washing, and mending, and dusting, and washing the floor.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "Was buzzing activity all the time.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "OK, well, after we stayed in the-- after we stayed in, in the convent in Paris a few days, the three of us, Lilian, myself, and Elizabeth, we were taken to the railway station in Paris and sent to Grenoble.",
      "word_count": 40
    }
  ],
