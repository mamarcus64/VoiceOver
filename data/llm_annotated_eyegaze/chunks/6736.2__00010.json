{
  "stem": "6736.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They said, for you to get the rationing, some of you people have to go to work for the Germans, to Krakow.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "To save our father, we said we're going to send my older brother.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "So my older brother went.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And he was taken to Krakow in a camp that Miller was the Lagerfuhrer.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "It was called [?",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Allach. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "In March they came again.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And they said, you still get eight rationing.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "You're a large family.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And because we didn't know nobody, maybe there was protectzia.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "They said, we need another one to go to the brick factory.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "So I went.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "We were five months together, but it was the toughest thing in my life to remember, when there was nothing to cook.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "I did-- and my mother would cook a few potatoes.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And we would say to her-- she would give everybody a little bit.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And we'd say, mother, why don't you eat?",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "She said, I'm not hungry.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS] The pain of our mother, that, uh, she has to see her children being hungry.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    }
  ],
