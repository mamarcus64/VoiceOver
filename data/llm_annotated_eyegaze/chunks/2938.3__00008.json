{
  "stem": "2938.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 3 SECONDS] They started shooting in fire bullets from every side of the camp.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "The camp must have had several thousand people.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "And they were German prisoners.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "German people, criminals, were there in the camp.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "They used to run the camps.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "They were in charge.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And they didn't care who they killed.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They killed everybody.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "While I was sleeping in bed, my next door neighbor, my boyfriend, got a bullet in the rear.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "And after five minutes, he was dead.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "I left him there, and I said to myself, what are we going to do?",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "I jumped down from the bed, ran out in the back of the camp-- the shooting came from the front and from the side.",
      "word_count": 24
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And in the back, there was a field-- a big, huge field.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And I saw some Germans there, knocking a hole in the wall.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "They had hammers.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "I say, fellows, what are you doing?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "And they say to me, look, they will kill till the last one.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "This camp will be gone in the next two, three hour.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "This is the only way to escape.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "They knocked out a hole in the back of the wall.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "And the fire almost hit us, and we still had a chance.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "Maybe 100, 150 people escaped.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "We ran out.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "Where can we go?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "We didn't know where to go.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "I went into an empty house where there were no Germans, two, three kilometers away.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "All I knew that I was not far away from two rivers.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 22,
      "text": "I don't remember the name of the rivers, but I think I was either near the Oder or near the Neisse.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 23,
      "text": "Oder or Neisse.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And when I escaped, I went into the German house.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "There was a radio and I listened to the radio right away.",
      "word_count": 12
    }
  ],
