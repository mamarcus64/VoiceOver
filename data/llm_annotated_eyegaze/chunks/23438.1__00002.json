{
  "stem": "23438.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.5,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 58,
      "text": "Maricia, ?] as we called her, was gorgeous.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 59,
      "text": "She was very fair, blue-eyed, lovely smile.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 60,
      "text": "She was gentle.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 61,
      "text": "She was a sports woman.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 62,
      "text": "She used-- used to take us kids ice skating in winter, horse riding in summer.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 63,
      "text": "[PAUSES FOR 4 SECONDS] She was also a doctor.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 64,
      "text": "And she married a doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 65,
      "text": "She had one daughter, Jan Karol, nine years my junior.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 66,
      "text": "Then there was the boy, Aleksander.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 67,
      "text": "He'd been sent to friends, to study.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 68,
      "text": "And he stayed there.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 69,
      "text": "He was an engineer.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 70,
      "text": "Somehow or else, he couldn't make a decent living.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 71,
      "text": "Their mother helped him all-- all of her life.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 72,
      "text": "They used to send their two girls for holidays to us.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 73,
      "text": "Because they couldn't give them a decent holiday.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 74,
      "text": "I really met him only after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 75,
      "text": "And I'll come to that later.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 76,
      "text": "The youngest girl, Eugenia-- we called her [?",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 77,
      "text": "Gilka-- ?] was lovely.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 78,
      "text": "She played the violin.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 79,
      "text": "She was a kindergarten teacher.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 80,
      "text": "She used to sing with us and play us little songs, and dance around.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 81,
      "text": "She got married in the late '30s.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 82,
      "text": "She had a little girl called Wanda, born on the 26th of August, 1939, six days before the war.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 83,
      "text": "[PAUSES FOR 6 SECONDS] I would like to-- here, to say a couple gems about the Markson family.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 84,
      "text": "[PAUSES FOR 4 SECONDS] There was a story that our great-great grandfather-- [PAUSES FOR 3 SECONDS] sorry, I'll stop here and start again.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 85,
      "text": "The family came from the northeast of Poland, Wilno and surrounds.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 86,
      "text": "It's now Lithuania.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 87,
      "text": "It used to be Poland, before the war.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 88,
      "text": "There was a story that our great-great grandfather, early in the last century, had a print shop, printed Polish books, which was really quite exceptional at the time.",
      "word_count": 28
    }
  ],
