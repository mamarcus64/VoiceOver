    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And I came to a farmhouse that was American zone.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And I knocked at the door, and I explained who I was.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And they took me in, gave me hot milk and hot blankets and they dried me and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "And then on foot and on railways, which were going-- some railways still worked.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "You know, most of the tracks had been bombed.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "I was trying to go always a little bit further, little bit further, little bit further, until the 22nd of August, I came to my hometown, Lingen.",
      "word_count": 27
    }
  ],
