{
  "stem": "1391.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "That was the police, the kapos from the Lodz ghetto, say, you don't see your mother, that she go run away away.",
      "word_count": 22
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "[SPEAKING NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "Because on the day, it was trains to Auschwitz, see?",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "But did you know that the trains were going to Auschwitz then?",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "No, I didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know this.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "But I know they kill, you see, because I saw what-they're doing.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Me, then they put mother off the wagon, [INAUDIBLE], and I go too off the, off the wagon.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "Meantime, I see the Polack bring the both kids by the ears to deliver the two boys.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And they say, [SPEAKING NON-ENGLISH] I stretch on the-- was other people hold me.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And they put them off the next wagon.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And when we come to Lodz, I was thinking I can meet them there.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "You know, I see they put with my mother with, with my sister, off another wagon.",
      "word_count": 16
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "And a couple told me, they're going of [NON-ENGLISH] I didn't know [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "Later, [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] if you can take much.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Right away, I come a little farther.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "But the, but the Gestapo stay [POLISH] Street.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "I meet a guy from our town, from Tuczyn.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] That camp, you come here?",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "You are so smart.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "How come you do?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] Yeah, I'm stupid.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "I'm stupid.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "But anyway, I do you a favor.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "It's called [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "[SPEAKING POLISH] that sound [SPEAKING POLISH] it mean vegetable, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "And everybody get three pounds potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "And he kissed me.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "And he have a son, was I saw that he was shot.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 15,
      "text": "And he say, he's living?",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 16,
      "text": "And I say.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 17,
      "text": "And he was thinking, I was, I was with him son, you see, together.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 18,
      "text": "And I lie.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "He took me off this.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He saved my life.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "He took me out.",
      "word_count": 4
    }
  ],
