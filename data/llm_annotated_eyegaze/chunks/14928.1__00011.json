  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, we were young children.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "We never lived through a war.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "But we knew it's not good for the Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "We knew before the, before the elections in Germany, if Hitler is going to come to power, it's not going to be good for the Jews, because we knew what he was writing, what he was writing in his books.",
      "word_count": 40
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "So-- and then there were older people.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I'll tell you.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "The man-- we had a cutter who was a very, very intelligent man.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "He must've been about 50 at that time.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "He had a daughter our age.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And he used to talk to us because we were about four or five workers.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "And he used to say, if war broke out, breaks out, you should all run towards Russia.",
      "word_count": 17
    }
  ],
