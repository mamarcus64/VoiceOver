{
  "stem": "6526.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name in the United States is Michael Kishel, M-I-C-H-A-E-L K-I-S-H-E-L.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was Majlech Kisielnicki.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I say it--",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I say it Majlech because it depends where you come from, whether you are a-- a Galitzianer or a Litvak.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I spell Majlech as M-A-J-L-E-C-H.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Kisielnicki was K-I-S-I-E-L-N-I-C-K-I.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had a name during the war time when I had to get myself a passport.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And the name was Miet Mieczyslaw the first name, but I don't remember what name I was second name.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "M-I-E-C-Z-Y-S-L-A-W.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "In Mietek was in during the war time, they called me at that time on the-- when I had the-- the-- as a-- as an Aryan-- Mietek, M-I-E-T-E-K.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My bir-- I was born on August 18, 1920, in Kalushin.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "At the present, I'm 75.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Kalushin in Polish was spelled K-A-L-U-S-C-Y-N.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Here, we'd spell it Kalushin K-A-L-U-S-H-I-N.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "That was in Poland, in state of Warsaw, or the county of Minsk Mazowiecki.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "County was in Polish is Powiat, P-O-W-I-A-T.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My pleasure.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "My family was born in Kalushin and their forefathers.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "I remember my grandfather, my both grandfathers, they were in Kalushin for many years.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, I remember my great grandmother from my mother's side.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "When she died-- before she died, she was laying in bed for quite a long time.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "She was about 100 years-- I believe 105 years old when she died.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I've seen her often when I came to visit my grandmother, as there was the place where she lived.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And as far as I know, they're all in Kalushin for many, many years.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My parents?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "My father's name was Mosha and my mother's name was Razel.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And Razel maiden name was Rzansky.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "In Poland, we spelled it Rzansky, R-Z-A-- with a sign-- N-S-K-Y.",
      "word_count": 11
    }
  ],
