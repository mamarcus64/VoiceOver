  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "My husband [PAUSES FOR 5 SECONDS] had left the University of Pennsylvania and volunteered to fight the war.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 8 SECONDS] Because his father had a drugstore, he didn't carry a gun.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "He was put right away in the medics.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And he landed in Normandy.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "He delivered a baby in Normandy, landing in Normandy, with his American Army.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "It's quite a story, but not now.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "And then he came to Antwerp, to the Scheldt, where he was there with the army unit and the medics unit.",
      "word_count": 21
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "He gave over 100 injections a day.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "He learned how to give them, I guess, there.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And he was, in America, educated as a very big patriot but as a Jew, a very dedicated Jew, not an Orthodox Jew, far from it.",
      "word_count": 26
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "And when he got to Europe, he decided he wants to see and he wants to hear what happened to the Jews.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And he-- in Antwerp, started looking for survivors.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "Somebody told him that there were a group of young boys and girls, 10 to 17 and so, who are meeting once a week in a little room.",
      "word_count": 28
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "And he decided to come to that little room and meet those young people who survived.",
      "word_count": 16
    }
  ],
