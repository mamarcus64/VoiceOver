{
  "stem": "3022.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.7,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 17,
      "text": "On Monday, June 6, which is in non-Jewish calendar, the secular Gregorian calendar, St.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 18,
      "text": "Norbert's Day.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 19,
      "text": "On June 6, I stepped down on American soil in New Orleans.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 20,
      "text": "On June 7, which is today, I arrived in Atlanta.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 21,
      "text": "There was another girl student from Marburg University.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 22,
      "text": "And two young woman from the HIAS waited for us at the station, the Atlanta railroad station.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 23,
      "text": "And they tried very hard in broken Yiddish to tell us who they are.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 24,
      "text": "And we told them, please do not bother yourself.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 25,
      "text": "We both speak English.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 26,
      "text": "You can speak English.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 27,
      "text": "They were so elated that they took us out for lunch.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 28,
      "text": "Although I wound up paying for lunch, because I wasn't about to have as the first thing happening to me in the United States of America, a woman pay for my food.",
      "word_count": 32
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 29,
      "text": "I had all of $15 with me, which a friend of mine gave me.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 30,
      "text": "It was on black market.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 31,
      "text": "He gave me $15, when I went to the United States.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 32,
      "text": "So I had some of the $15 with me.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 33,
      "text": "But I paid for the lunch.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 34,
      "text": "And this girl, the other student, was put up with some people.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 35,
      "text": "And I was being taken to-- she told me, I'm taking you to a house, where some refugees live.",
      "word_count": 19
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 36,
      "text": "And you going to be put up with a family of refugees.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 37,
      "text": "You're going to stay with them.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 38,
      "text": "And I was brought to a house.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 39,
      "text": "And when a woman opened the door-- this was somebody that I knew very well from Europe.",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 40,
      "text": "Not because she was from my hometown, which she was.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 41,
      "text": "But because after the liberation, she lived in the same town where my father lived, and I knew her husband.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 42,
      "text": "And so I was boarding with her.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 43,
      "text": "I gained 20 pounds in four weeks.",
      "word_count": 7
    }
  ],
