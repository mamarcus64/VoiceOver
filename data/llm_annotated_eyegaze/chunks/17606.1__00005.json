{
  "stem": "17606.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.0,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Then I joined and became student of-- a law student at Moshe University.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That was the easiest department to be accepted for a Jew.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Everything else, it-- if there are numerous clauses or numerous [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "We had only a quarter.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "So this, I-- I-- I was accepted on my own.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "And I studied law.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "Because we couldn't live in the Jewish academic house, only because we were-- I was from Warsaw.",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "That was only for out of-- for out of-- of the city.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And they were-- because I-- I was jealous of them, that they live on their-- and I could only-- I spent most of my free time over there.",
      "word_count": 28
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't too far.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I could take us a street car or even walk a little bit.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "It was about, I would say, 20 minutes walk.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Or the street car.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Surely.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "When I was a student?",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "Of course, I was already a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Of course, I had my friends from Betar, both-- of both sexes.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "I was always-- since the age of 14, all my friends out of school were Jewish.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Of course, I was already in Betar.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "That's when I joined, in 1929.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the-- to want to understand Jews in Warsaw, or Jewish Warsaw, the way we called it, one had to live there.",
      "word_count": 22
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "You wouldn't understand.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "It was a community-- I would say, a country by itself, Jewish Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Especially Jewish neighborhood.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "To go out Friday afternoon, look at the kids.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Freshly bathed.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "Dressed for Shabbat.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "It was really a pleasure to look at.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "[SPEAKING HEBREW], they say in-- in Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "To look at these kids in preparation of Shabbat.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "Stores closed.",
      "word_count": 2
    }
  ],
