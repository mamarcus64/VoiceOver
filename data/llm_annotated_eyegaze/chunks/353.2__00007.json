{
  "stem": "353.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "I came to one guy, and I told him, I would like him to help me out with my brother, to go to Kabel and work there.",
      "word_count": 27
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "So he said, OK, I can help you.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "But it is going to cost you money.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "So I said, don't worry about it.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "I will pay for it.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "So, like I told you before, I sold this watch.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "We made a date.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "I paid the money.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And he went to Kabel.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And he was in Kabel.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Then I was with-- when I came back, I was without no papers.",
      "word_count": 13
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So I decided-- there was no decision.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "There was announcement that they need young people, strong people to build a concentration camp, Plaszow.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I volunteered.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have no papers, so I volunteered.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "This volunteer kept me-- kept me alive.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And we were going-- going maybe five, six miles to Plaszow, from ghetto, every day, to build barracks there.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "When we built first three barracks, they didn't let us go to ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "We stood right in Plaszow.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And this name was Concentration Camp Plaszow.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "So as long as I was coming back to ghetto, I saw my wife.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "But after that, I lost completely connection with-- with ghetto in March 13.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I went to Plaszow on October.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "October 1940--",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "'40--",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "'03.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "'43.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And Plaszow ghetto-- no, October '42.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Plaszow ghetto was liquidated October-- March 13, 1943.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "In-- in Cracow.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the Cracow ghetto was--",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Ghetto was liquidated March 13.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "So I was in Plaszow from October to March.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So just a group of people who-- barackenbau.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "They called it barackenbau.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And we were building the barracks.",
      "word_count": 6
    }
  ],
