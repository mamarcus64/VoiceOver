{
  "stem": "9168.4",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Two of the reporters in my Detroit office-- the older reporters, husband and wife team-- went to-- to Dachau before I ever went over there and before the major trial started.",
      "word_count": 31
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And they reported these pretrial hearings in Dachau.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "But they did not come to Nuremberg to work on those trials.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "We did not interchange reporters there.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "When the Doctors' Trial began, and whenever, in the beginning, I went into that courtroom, [PAUSES FOR 3 SECONDS] I remember [PAUSES FOR 3 SECONDS] just especially the testimony.",
      "word_count": 29
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Taking the testimony.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I remember sitting there-- and across from me were the doctors, and the German defense counsel in front of them-- studying the faces of those doctors.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And I just had the feeling that I never saw such evil faces in my life.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And eyes.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "When you look at someone's eyes, there was a feeling of their resentment at even being there.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "It was just pervasive in that courtroom.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "With crimes against humanity, calculated genocide, with the performing experiments on the concentration camp inmates without their consent in the name of scientific medical [PAUSES FOR 3 SECONDS] research.",
      "word_count": 29
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "There were.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They-- these-- pardon me.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] There were 20 doctors and three medical assistants who were tried.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "All men and one woman.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I have them.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "You know, when we get to the-- the slides and the pictures.",
      "word_count": 12
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I cannot name them all off right now, but Karl Brandt was the-- the chief of the medical services.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He was the number one defendant, Hitler's personal physician.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "He was the doctor who set up all of the programs and all of the machinery [PAUSES FOR 3 SECONDS] for the medical experiments to be conducted at Auschwitz, Buchenwald, Dachau, Ravensbruck, Natzweiler and Sachsenhausen and other places.",
      "word_count": 38
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "But he was the top man.",
      "word_count": 6
    }
  ],
