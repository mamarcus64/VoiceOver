  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "So we arrive much, much less in our destination of Mauthausen.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "When we left Auschwitz, we had, I think, 150 grams of bread and some margarine.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "That's the only thing.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "I remember that I was walking in Linz, and was raining.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Was raining, and I-- I got down, and I put mud in my-- I was eating mud.",
      "word_count": 17
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "Mud.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
