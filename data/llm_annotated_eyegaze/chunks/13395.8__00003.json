{
  "stem": "13395.8",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.9,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "And after six weeks, I went to the embassy.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And when they wanted me to bring the baby-- and I still didn't realize why.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "When I brought the baby, they examined the baby for reflexes, whether she can hear, whether she can see, whether-- every little bone in her body was examined.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And then they gave me a visa.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "That means that if that baby had would have had any defect at all, I would have never been able to come to Canada.",
      "word_count": 24
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I arrived in February of 1953.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, my husband was already here.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And he rented an apartment on the third floor, on College Street.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "He had, already, a job as a carpenter.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I was determined that my mother will never work.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I found a job on Spadina, as an operator in a factory.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I didn't speak English.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "I didn't know inches.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I only knew centimeters.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "I could not work in my profession because I couldn't communicate.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "So I worked in a shop for three years.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "But then slowly, I took some work home from the-- from the factory, to supplement my income.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "I also had some survivor customers who weren't used to buying ready clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And so that also helped.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "My husband then start to do some contracting work.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "And he started to build some houses.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "And once he had built some houses, I-- and went into building apartments, I stepped in, into the business as well.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "I gave up my profession and began with, actually, interior decorating of the model suites, the model homes, designing the lobbies, and moved right in into construction, which I love.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I have one son who was born in 1956.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "His name is Jacob Bernard.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "He's named after my husband's grandparents, grandfathers.",
      "word_count": 7
    }
  ],
