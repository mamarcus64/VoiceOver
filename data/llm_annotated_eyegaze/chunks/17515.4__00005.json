{
  "stem": "17515.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 391.2,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "No nothing, no sick, no nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Many thousand.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Mostly.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Mostly.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "There are no-- no sick.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I was sick at that time because I have [INAUDIBLE] into my leg, but I was sick, yeah.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Because I was sick at the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "In the camp they were separated.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Woman was for the woman.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Men for the men.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Only with men, no women.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "We'd been transferred from Mauthausen by march to Gusen I and Gusen II.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "That's about a mile from Gusen I, Gusen II.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And many people died.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Many people been executed on the-- on the march.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Because whoever was sick was left, and weren't able to-- to keep the-- the line, been shot.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And have to believe it, but it was so often, a shot.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Every-- every couple minutes.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Could be 13.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Could be nine.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "There was so many-- there was hundred, hundred in-- in the Birkenau barracks.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "That was unbelievable.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "A number, on the Gusen, think-- I believe I had 40-- 44-- 805.",
      "word_count": 13
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "That's for [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And there was another one, 13,696.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Oh, oh the same-- same as-- in the cloth, in that there.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I believe together.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "In Mauthausen we'd have been like, only transferred.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "To-- to Gusen I, Gusen II, to work.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "On the stone, on the whole-- they call it-- in Steinberg, in German.",
      "word_count": 13
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "All day.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "We came to the barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "We wash ourself.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Then we wait for the line for the-- for the tea or coffee and a piece of bread, a piece of margarine.",
      "word_count": 22
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Mauthausen was-- was much worse than Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "More killing too.",
      "word_count": 3
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "There was one-- one Polish kapo, oh, he was prominent.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Prominent above prominent.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "You know prominent?",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "He was kapo, like oberscharfuhrer, a prisoner.",
      "word_count": 7
    }
  ],
