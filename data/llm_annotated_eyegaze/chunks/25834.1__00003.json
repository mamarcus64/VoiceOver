  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "I pay only 13, because my mark was good.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "In other words, my part was help family.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "My brother and sister, for example, my father pay 85 zloty per child, by my sister and my son-- my brother.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "And for me pay only $13, because I have the boat.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] Irina and Odon went to private school.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "That costs much more money and was very good school.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "In Poland, this time, was practice, if somebody can, and the child is good, send to the state school.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "And supposed to be the program, supposed to be a little bit better in state school.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "Myself, I not believe.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "Private school gymnasium was very, very good.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "If I can, right now, go back and think what my children, here, in United State, learn during high school and what we learn, I see two years' different in studying.",
      "word_count": 31
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 21,
      "text": "I mean, you finish gymnasium in Poland, before the war, mean you know much more like my children after finish high school here.",
      "word_count": 23
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 22,
      "text": "But that's private-- private opinion, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 23,
      "text": "And that's everybody like have the children in state school-- I mean gymnasium, because it costs less and the education was very good.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my favorites?",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "That's, you know, a very interesting question.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I go to technical way, technical subjects.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I was all the time good and good mathematician.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Only my favor was geography, travel.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And it's what I am doing, you know, now.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "If I can, I like go all over the world to where I never was before.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And during the-- my high school time, for me was the best geographic, economy, and this relation subject.",
      "word_count": 18
    },
    {
