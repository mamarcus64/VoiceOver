  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "I usually-- so we couldn't write anything and he couldn't say anything.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "So it was just-- all he would [INAUDIBLE] saying, I am OK.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "I'll survive.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "And don't worry about me.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "I'm healthy.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "That's all he could say.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "I'm OK.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 19,
      "text": "I will survive.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 20,
      "text": "And all we could say is we're OK.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 21,
      "text": "We're surviving.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 22,
      "text": "You know, nothing-- we couldn't say anything.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 23,
      "text": "And then, of course, the summer came and-- and all of the new things.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 24,
      "text": "Jews couldn't go anywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 25,
      "text": "You couldn't go to the park.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 26,
      "text": "You couldn't go to my pool.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 27,
      "text": "I couldn't go anywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 28,
      "text": "We couldn't go to the movies.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 29,
      "text": "We couldn't go to the theater.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 30,
      "text": "We couldn't go [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 31,
      "text": "We couldn't go anywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 32,
      "text": "[PAUSES FOR 3 SECONDS] So we were sort of like prisoners, anyway.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 33,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And finally, I got the news that I was able to-- I was going to get an appointment for the-- I think it was in, when was it?",
      "word_count": 28
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Was it September or October?",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Probably in October.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I got a notice that I should come to the consulate for my visa.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "The night before, I got a big sty in my eye.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "My eye was swollen like this.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And I put compressors on it, hot and cold.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And I-- I said to myself, they're going to take one look at me and they're not going to give me the visa.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "That was another worry.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "But I went there, and the doctor was fairly nice.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And he looked at me.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "He says, oh, you have a sty.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "He says, that's nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "My daughter gets them all the time.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "He says, use that and such and such a thing, and it will go away.",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "And he said OK.",
      "word_count": 4
    }
  ],
