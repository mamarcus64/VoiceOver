  "sentences_input": [
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "This was [INAUDIBLE], not far from Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "And this was the nicest time of my life.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "[LAUGHS]",
