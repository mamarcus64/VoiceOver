    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No, I was not a member, no.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "But I was treated very good there.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Yes, I meet my wife there, and I married.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "She worked there, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "She was a dietitian, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "I meet-- I meet the Bundist is fair and the Bundist society they must be famous, Dr.",
      "word_count": 17
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 2,
      "text": "Ivinska.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 3,
      "text": "Because she comes-- [PAUSES FOR 4 SECONDS] she comes from Belgium.",
      "word_count": 11
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 4,
      "text": "And I think the headquarters, of Bundist headquarters must be in Belgium, in Brussels.",
      "word_count": 14
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 5,
      "text": "And she come very often.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 6,
      "text": "And she visits the sanatorium.",
      "word_count": 5
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 7,
      "text": "Yes, she took some pictures for me too, when I was in Brussels, I just forgot about it.",
      "word_count": 18
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 8,
      "text": "I visited her after the war, I visit her.",
      "word_count": 9
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 9,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 10,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 11,
      "text": "[DRINKS] Yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "There was Gilinski.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "He was the head-- the head-- the head director, I don't know, and Brumberg, and Lazar Gilinskibotke.",
