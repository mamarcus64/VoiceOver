{
  "stem": "24242.6",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "Couple of times, I brought watches from Switzerland, and I sold it.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "I made some money.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "Then he send me with his wife to Canada, divorced his wife because she was Polish actress.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "She saved him through the war.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "They got divorced.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "I went to Montreal.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "With his wife, yeah, together on the same ship-- the same boat.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Exactly what I said.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "He said, you want to go to Canada?",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Ana is going.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He said-- he said, what are you worried?",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "I'm paying the tickets.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "Free ride to Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I said, fine.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And I'll get you, he says, a visa.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "I said, great.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "I'll go to Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "[LAUGHS] And this is the way I got to Canada.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Let's see.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I would say sometimes like '51.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I was in Canada.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I walk on the street.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Fellow taps me on my shoulders-- one of the fellows that we lived through the war together.",
      "word_count": 17
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Took me to his house again.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "Bedzer ?] family.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "They live in Florida.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "The first time?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "When I was in Canada, I bought myself a used car, and I went to America because I knew I have brothers here.",
      "word_count": 23
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "One sister I had here, I think I knew already.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "So I came here for a visit New Year's, [LAUGHS] until I spend all my money.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I was ashamed to tell my family that I'm broke.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So I had a tank of gas.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And wherever this tank of gas took me, back to Montreal.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I went to Montreal.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And there I got stuck just beyond the border.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I just crossed the border into Montreal.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Gas is out.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Stopped near a gas station.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I gave them the watch.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I said, should give me a couple of gallons of gas to get to Montreal.",
      "word_count": 15
    }
  ],
