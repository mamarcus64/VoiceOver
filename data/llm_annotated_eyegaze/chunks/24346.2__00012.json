{
  "stem": "24346.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "My brother died in the ghetto, after I left, of starvation.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "A young man who was only two years older than I was, he died of starvation.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "My mother was alive.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Because from the letter that I wrote-- we have very good here.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "We have food.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I can say-- remember, I said four years?",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "That was the day it turned on me with food.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I could say, many days, I was not hungry.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "But again, that wasn't due to what the Germans fed us.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "But they gave a sufficient diet, like, let me explain.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "Like, we got 250 grams of bread in the ghetto.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "They gave out, here, a day, 500 grams.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "So bread was already double the amount.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "However, we worked in an ammunition factory with Poles from the outside.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And, and, and we worked [INAUDIBLE], so when we left the ghetto, we had clothing.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And we could sell-- it was very important, that shirt, slacks-- we used to sell that and get money.",
      "word_count": 19
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "For that money, we could buy extra food.",
      "word_count": 8
    }
  ],
