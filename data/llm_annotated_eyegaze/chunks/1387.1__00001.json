{
  "stem": "1387.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "She was a trained and graduate nursery school teacher.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "They made a living from owning a [NON-ENGLISH SPEECH], a, a home that was rented out to people to sleep a night over, or a week.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "My mother used to bake and cook and do all kinds of chores.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "She was a exceptional housewife and cook.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "She had her own smoke house.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "She used to make her own ice cream.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And this was the way they made a living.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "With us in the house lived my grandmother, Leah, that passed away at a-- well, in her 80s-- in the beginning of the 80s in 1935.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 5 SECONDS] Zasow was a unique little town.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "There was many Jewish organizations.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "At the time I lived there, there were about 1,500 Jews living in a town for about 3,000, total population.",
      "word_count": 20
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry?",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Half or slightly over half was the Jew-- a Jewish population.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "Now, the, the people lived-- made a living out of [NON-ENGLISH SPEECH] They used to make the silver ornaments for the [NON-ENGLISH SPEECH] It was a unique place-- one and only place in the world that was making those [NON-ENGLISH SPEECH] The whole town was making a living from it until the Depression came.",
      "word_count": 54
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Those [NON-ENGLISH SPEECH] were sold mainly in the United States, where people could afford the expense.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The thread and the silver was brought from Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Now, I'll give you a little background story about my family.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "My great-grandfather was the one that came from Russia and settled in Zasow.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "He made a factory of people that were doing this kind of artisan's work-- this kind of artistic work, which was called [NON-ENGLISH SPEECH].",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And they were making these-- weaving those [NON-ENGLISH SPEECH].",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "He had three grandsons-- three sons-in-law.",
      "word_count": 6
    }
  ],
