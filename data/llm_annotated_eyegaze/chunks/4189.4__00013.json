{
  "stem": "4189.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "It was many years.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, it was actually only till 1981.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It was almost 36 years till we actually opened up and could really talk freely about it.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "At that time, there was a gathering of Holocaust survivors in Jerusalem.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And there was about 10,000 survivors that went to Jerusalem, including myself and my wife.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "We went to Jerusalem.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And we participated in this gathering.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And this was such a powerful gathering.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "There was people from all over the world.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "There were survivors that came from South Africa, from Brazil, from everywhere, all around the world-- from European countries, across the United States, from Canada, Argentina, Brazil.",
      "word_count": 27
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "And we met many people that we knew in the camps.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And we recognized each other.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And we really-- it was a, a gathering that gave us a relief.",
      "word_count": 13
    }
  ],
