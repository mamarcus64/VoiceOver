  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "She-- my girlfriend Mischka Biedermann.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody, because it was secret.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I told you before that we couldn't talk about it.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "This is finished-- I knew only three person and one instructor, who was unknown for me.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yes, this oath took-- one, one officer, I remember his name, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "But he's-- but he passed away many, many years ago.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And only this Mischka, my girlfriend-- and now she's living in Poland.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "She's bacteriologist.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I saw her.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "But she doesn't want to talk about it.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "You see, some people prefer to forget.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I, I think that was every couple days in different places, not in one place.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Because it could be suspicious, young girls coming in group.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "What for?",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "It was very difficult to, to keep secret in, in Warsaw this time.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Because we had many people who are watching only, maybe something they can make money or something.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Always, I was lying [LAUGHS] that I'm going to my additional class of geography.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "Or I'm going to make homework with my girlfriend.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "If you want, you can lie.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Not too-- not too long time because when I joined anti-- oath in army, [PAUSES FOR 3 SECONDS] after a couple months, it start to be uprising-- 1st of August, yeah, 1944.",
      "word_count": 32
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We finished this education about nursing, very simple nursing.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And next should be how to handle these weapons with ammunition.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Because these girls was not only for first help, but also as a, a [SIGHS] courier to, to be between officers and-- on barricades.",
      "word_count": 24
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It doesn't mean it was many process to, to learn.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "You see-- and before second teaching, get uprising.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "I was not in my group because lack of communication.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I stay in this place where my parents were.",
      "word_count": 10
    }
  ],
