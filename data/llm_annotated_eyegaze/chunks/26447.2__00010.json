{
  "stem": "26447.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "The bridge was-- stay all the time, was standing police and the Germans.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "What nobody will blow up the bridge or what they was thinking.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I cannot go through-- through the bridge.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I decided to go in another way that's will-- that will take me more-- more time.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "No, I think it will be more safer than to go to the bridge.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "It's come-- no, maybe by middle of the night.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It was maybe-- maybe by 12 o'clock at night, I begin to go out.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And come to the door, I cannot open the door.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "It's locked.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It was locked from the outside.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "I cannot open the door.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "What to do?",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "I come again on the top where the straw.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And if you know, they got covers-- the roofs with straw they make them.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I decided I will break the straw from the top to take and make a hole, and I will come down.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I take with me in the-- in-- in the barn, I take with me-- how it's-- that's-- pick.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 17 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Pitchfork.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I forgot that.",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I come down.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I begin to run.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "They run.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "I go across-- I went across the road, the highway, what the trucks went-- went.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "And to the forest, I got maybe half mile to run.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Believe me, the-- a quarter mile, or I don't know exactly.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "I was falling and get up, falling and get up.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And it's-- my face-- it's standing, the Germans, the police where they want to kill.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "I feel what I'm not dead and not in life.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "Until I run that's the-- and the time is going.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "I come to the forest from the-- from the houses, what-- what I was the barn.",
      "word_count": 16
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And I fall down.",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And I rest a little.",
      "word_count": 5
    }
  ],
