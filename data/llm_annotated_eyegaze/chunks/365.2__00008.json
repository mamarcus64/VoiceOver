{
  "stem": "365.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "There, they make a selection-- the old people, children, babies to one side, young people without proper jobs to another side, and those with the proper jobs sent away right away-- discharged to send out, to go back to work where they have to go.",
      "word_count": 45
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Now, I come up with my family together.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "So the Masha, the other sister, my mother are sent, right away, to one side.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And my father, my oldest brother, and myself to go-- to go out, because my father had papers, was worked for a German company, [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And I worked in the [NON-ENGLISH], and my oldest brother worked in the [NON-ENGLISH] then, so we had good papers.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "So my father ask him, where are they going?",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "They are going to be resettled.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "They are going to a farm somewheres.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "So my father says, I am not going without them.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "So he says, well, then you go with them-- sent my father with my mother and my sister.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "We never heard from them again.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "Apparently, they went straight to Auschwitz, were gassed.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I was sent home, and I continued to work in the [NON-ENGLISH], my oldest brother.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Eventually, I became sick.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "That was already in the fall, late September.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And I did not show up for work for about four days.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I developed what you call gastritis, something where I had constant diarrhea.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And I could not eat, could not keep down anything.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "I was picked up in the middle of the night by police, sent to a holding camp in [NON-ENGLISH], which was the neighboring town.",
      "word_count": 24
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And after a week, I was sent away to a forced labor camp, to Brande.",
      "word_count": 15
    }
  ],
