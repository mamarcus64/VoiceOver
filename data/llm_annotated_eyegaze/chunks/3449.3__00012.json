{
  "stem": "3449.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Before-- see we got a little bit jumped forth and back.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "It happens to be on my mind now.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "With the manger, we didn't finish that story.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "Because this is interesting.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "This is as close as we came to-- to being done with.",
      "word_count": 12
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "As we lay in that little place, in that little four by four, we started to get short of air, because there was no ventilation.",
      "word_count": 25
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "It was just running down, they came into the barn, and they go.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "Unfortunately they set-- they set up a little mini camp in the barn.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "It was a huge barn.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "And we could hear the voices.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "We could hear the Germans sitting there.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And it's getting less oxygen, less oxygen.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "We are starting to choke for air.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "Now my father can't speak anymore.",
      "word_count": 6
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "He's starting to choke.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "He would send us-- every time somebody [? yells ?] there was a little crack, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "A little crack.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "And we would [INHALING] breathe in the air.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "And then he would send up my sister there.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 8,
      "text": "And then he would hardly be able to make it up.",
      "word_count": 11
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 9,
      "text": "Then there was decision-making.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 10,
      "text": "Do we open it up, and-- and whatever they do with us?",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 11,
      "text": "Or do we die there?",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 12,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 13,
      "text": "So we decided we were going to die there.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 14,
      "text": "We weren't going to open it.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "And we were already starting to get unconscious.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "We didn't realize they left the-- the barn.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "They finally they packed up.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "They had a lunch or whatever, and then they left.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And that's when the farmer came running in.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "He knew there was no ventilation.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "And he opened up that door and he found us all unconscious.",
      "word_count": 12
    }
  ],
