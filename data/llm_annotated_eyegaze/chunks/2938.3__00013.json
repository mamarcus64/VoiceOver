  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "Were you in a displaced persons camp?",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "In Salzburg, Austria.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "In 1945, General Eisenhower came and opened up a military camp for us.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And we got together, maybe about 40 or 50 people.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And this was our first camp, an American camp.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "At the beginning, it was called Camp Riedenberg.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Riedenberg.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "We stayed there for several weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "After several weeks, they gave us a section of apartment buildings.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Five, six buildings, where they brought together about 600, 700 people from different camps.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And over there, we settled.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And the name of the camp was Camp New Palestine.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "It's a fact.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "From this camp, I got my passport to leave Europe.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "DP camp, New Palestine, which I have it with me.",
      "word_count": 10
    }
  ],
