  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And he was having-- when he was a-- he was a very handsome man, and he was also active in playing football.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "In football they got accident from playing football, and he lost a leg.",
      "word_count": 13
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "It was at a time they were so primitive, no antibiotics, nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "And they were operating him several times in his leg, he was still in his teens, and he lost his leg.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "Anyway, he was still looking-- going with a cane and he looked very attractive, and he was kind of intelligent.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "He was-- we used to know each other, like it's a small town after all, compared to America.",
      "word_count": 18
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "He would say, hi.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "I never was dating him, I never was-- He would say-- I would walk by, hi Mary, Mara, and something.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "And he knew my husband, also, from just, hi.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Now, he came in the ghetto, once before the rumors, brought me some bread, and became a little acquainted with him.",
      "word_count": 21
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "When it started those rumors, and people say, you have somebody you know, a Gentile?",
      "word_count": 15
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "You have someone, a Gentile?",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "The best thing is go and hide.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "Get out with the night, and that they will see, maybe it will come out nothing out of it.",
      "word_count": 19
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "And he said he's-- I should go-- he's going to take me with him.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I took my child, I didn't have much to wear, it was in a hot day.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Maybe in July, maybe August, and this I can remember, but I don't know the date.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "I took my child, he was hardly wearing a little-- a little overall without, and I was having only a-- excuse my expression-- panties and a bra, nothing with me.",
      "word_count": 30
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "I didn't take anything, I didn't have anything to take too much anyway, but perhaps another dress eventually.",
      "word_count": 18
    }
  ],
