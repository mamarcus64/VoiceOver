  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "We decided to come back to the place, to the house where-- [COUGHS] excuse me-- where we live.",
      "word_count": 18
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "When we came back in a couple days, they robbed the house.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "They take everything from the house.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "It's empty at all.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "Only the stayed the walls.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 11,
      "text": "We came and we saw like it's empty.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 12,
      "text": "It's not possible to stay in that house.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 13,
      "text": "And in Komarow, was living my mom-- my mother's sister with a family too.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 14,
      "text": "They said, you don't have where to live.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 15,
      "text": "Come-- come to us, and we will live together.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 16,
      "text": "That was done.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 17,
      "text": "We begin to live in the this now.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 18,
      "text": "And every day is worse and worse.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 19,
      "text": "It's become the Germans passed.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 20,
      "text": "We didn't got afraid for the Germans like it begin the Ukraine.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 21,
      "text": "They begin to do terrible things to us.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 22,
      "text": "It comes-- they begin.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 23,
      "text": "They come at night time.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 24,
      "text": "They take the-- now, for-- I-- I want to say a couple moments what they-- what they done to us.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 25,
      "text": "They will come in shoot near the house at night time.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 26,
      "text": "Then they take the father and a couple more men and me.",
      "word_count": 12
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 27,
      "text": "And they take us to the water.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 28,
      "text": "And they tell, go in the water with the clothes at night time.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 29,
      "text": "And they-- no, it's hard to tell you, to explain what they was doing without the Germans, without the Germans.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 30,
      "text": "That's-- the Germans, they passed.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 31,
      "text": "And the Germans stay in Kolki.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 32,
      "text": "That only in our village.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "That's the Ukrainians, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I-- I want to say, it's now, it's hard to say with all of them.",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "It was not all of them.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "I will tell you later on.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "It's what-- no, it was the bad ones.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And it was a couple good ones.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Now, what the problem?",
      "word_count": 4
    }
  ],
