  "elapsed_s": 2.1,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Brustman, who came in and met my husband and told him this story.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "He came to our house and told him this story, that he had a wife and three daughters.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And he was a good tailor.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] And the Germans took him to work for them as a tailor.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And his three daughters and wife were like everyone.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Once, he-- he was taken out of his place where he was working.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And he has got to look on how his wife, three daughters, my husband's wife with the child-- she was an opera singer.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "She held the child in her arms.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "And she held her head high and sang.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And they led them into the street, into the main street of Chelm, and killed them one by one.",
      "word_count": 19
    }
  ],
