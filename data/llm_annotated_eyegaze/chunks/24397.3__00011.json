  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "As a matter of fact, Charlie, the boy, who now has just retired, was here earlier this year.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "He has a daughter living in Ohio, so he was visiting there, and then he spent a week here.",
      "word_count": 19
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "His sister, whenever we go to England, we see her.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "She's been to Israel a couple of times.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And we correspond every few months, so we've kept in touch.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Personally, against me, no.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I've heard people say things.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I've heard people say things about just about every grouping that we have here.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "But more than that I-- I can't say I've felt.",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I've never been back.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of people have asked me that.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "At one time, I used to feel that the only way I want to return to Vienna is in a bomber.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "But I think lately, you know, I've kind of given way to curiosity, [PAUSES FOR 3 SECONDS] that maybe I wouldn't mind one day just looking at where we lived and-- but otherwise, I have no fond memories of people there to go to.",
      "word_count": 44
    }
  ],
