{
  "stem": "24466.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.1,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "He was from Kaunas, from Kovno, from Lithuania-- that he was a manufacturer, a owner of a-- a manufacturer from webbing things and so on.",
      "word_count": 25
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And he's in such a bad-- that he can't go to Kaunas.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "He not-- he is in Vilna.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "He's now in the ghetto and has to-- if it's possible if I could help him.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "I helped him too.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And I got those from him.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "Letters are written about the help I gave him.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "That was the time when I was in ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "And Kailis-- I helped a lot of people too.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "And amongst others, that is the main help what I gave is to the director of the Yeshiva, of the Vilna Yeshiva, Rabbi Lvowicz.",
      "word_count": 24
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "He was with his family and a few people from the Yeshiva.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "That was in Kailis already.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Lvowicz-- L-V-O-W-I-C-Z.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "From time to time, I was helping him out always with big amounts of money-- thousands of dollars.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "And I got-- actually, I left the whole original papers I wrote.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I got, because I hide them by one of the Poles, one of my friends-- Poles in-- in Vilna.",
      "word_count": 19
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And after the war, I got this out-- everything out.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And he-- really, I helped him a tremendous lot-- a tremendous lot.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "He was arrived in Kailis different time-- different-- whenever-- when I was giving him a sum of money, 1,000 of the-- 2,000, or something like that.",
      "word_count": 26
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "So he was always going on the attic and writing letters to his in-laws.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "One of them was the grand rabbi, [NON-ENGLISH] in Johannesburg.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Letters are written to his brothers-- a rabbi in Brooklyn, a rabbi in Brooklyn-- written-- written to his family a lot--",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "--telling them what is going on with him and what I was done to him.",
      "word_count": 15
    }
  ],
