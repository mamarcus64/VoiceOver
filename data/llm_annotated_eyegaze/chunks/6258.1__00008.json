    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Because, well, first, it was the elementary school, and then you have an exam and pass the exam in order to go to gymnasium.",
      "word_count": 24
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, one was Kollataj.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Well, later on.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It was K-O-L-L-A-T-A-J.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I don't know whether he was the rabbi of the synagogue, but he was the rabbi who was teaching us in school, in the state school.",
      "word_count": 26
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "It was the Rabbi Schmelkes, Schmelkes.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "S-C-H-M-E-L-K-E-S.",
      "word_count": 1
