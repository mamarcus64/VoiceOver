  "sentences_input": [
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And we went to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "With this cattle cart.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "And my mother was there.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "And my sister was there, and I.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "It seemed like ever.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Probably you know how long is it took a-- I don't know.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "It was like for months.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And I'm sure it was just few days, because it was very a lot of people.",
      "word_count": 16
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "We could not even sit down.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "We could not turn around.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "Every-- we had a small window.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "We had, I think, 130 people.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "And people get sick because was no oxygen.",
      "word_count": 8
    }
