{
  "stem": "304.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And every second was [SPEAKING POLISH] that I felt I'm getting crazy.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHTER] But I didn't dare to say anything.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And one-- next to me was a girl, a young girl about 20 years old.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And she had syphilis, not more, not less.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And I knew about syphilis.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "But I didn't know exactly what it is.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And she showed me how she looked, her body.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "She was all broken out.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And, and I, I said, how did you get it?",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "She said, there was a young man who-- and she was a dumb girl, really.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "I mean, not because she had syphilis, but she was dumb.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And she had such a funny face.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Maybe she-- I-- she wasn't normal.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "I said, what did you do?",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "How did you get it?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "She said a, a man came to her, and he  promised he will marry her.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And she slept with him.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And he had syphilis and infected her.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And then she was taken away one day and never heard from her again.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And then a young woman came in.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And she had an abscess on her leg with, with pus, and a lot.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "She was about a 28-year-old woman.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And she was very happy because she had two children.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "And she left her two children with non-Jewish families.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And she was full with hope that she will find them after the war.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "But she was very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And the doctor looked at her and couldn't do anything.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "He said, there is one thing I could try.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "If you will be good, I can put you on under hypnosis.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And I have a little pocket knife.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "That's all what I can do, try to open it.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "And she was ready.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "She said, anything, just save my life.",
      "word_count": 7
    }
  ],
