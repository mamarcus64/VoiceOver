{
  "stem": "24544.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "He was the whole residence, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And carts and horses and everything.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "So it was a big.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "It looked it was a rich, surrounding-- rich house that we had.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "And we have good name.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, we have a-- a woman in the kitchen who helped out everything.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And we have a lady who came for the washing day and the ironing day again.",
      "word_count": 16
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "But this time, we didn't made our own bread, because we have a bakery two houses from us.",
      "word_count": 18
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "So it was a big step for us.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "It was almost called luxury.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "He wasn't politically involved until 1944, April the 4th.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Because the German came in March, the 19.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "I was in a movie in Miskolc with one or two boyfriends.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And all of the sudden, the movie closed, get dark.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And somebody came in and announced just the German--",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Soldier just occupied Budapest.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And they are in the way to Miskolc and all over Hungary.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "That was March 19.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So I-- and everything get dark.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "And I was on my bike.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "So I left the movie and the boys.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "And I went home.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "And my family was in the kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "That was March.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "It's cold time yet.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "That was the family room.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "And my father, [INAUDIBLE], was playing cards with friends.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "And I said, don't play any more.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 6,
      "text": "We are in big trouble.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 7,
      "text": "The German occupying Hungary.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "And one of the friend said, put together his hand, and said, Lilika, please do your lie?",
      "word_count": 17
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I hope you lie.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "It's not true.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Because we are going die, all of us.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Everybody started to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And everybody went home.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "So then next day we were in Felsozolca. 4th of April, four gendarme came to our house.",
      "word_count": 17
    }
  ],
