{
  "stem": "17867.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 24.0,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And she comes across all these names that she knows.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "And she immediately started making phone calls.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "My mother had a brother in New Jersey, a sister in California, and another brother here in Maine.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And the phone calls were just going from one to another.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "It was just like a relay thing, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "And things started working immediately and they started saying, we have to get her out of there.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "And we received a telegram saying, we have your name, we're getting papers, don't do anything, don't go anywhere.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "We're going to take you to America.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "And that was like [PAUSES FOR 3 SECONDS] an unbelievable thing that could have possibly happened, but it happened.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And this is when we started-- she took me out of there and she said, my child will not be going.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "We're going to America.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "The golden country, land of opportunity.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "They made out papers for us.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And they had to sign with the American government that they will not be-- the government will not be responsible for us, that our family will take on all responsibility as far as housing, clothing, a place to live, and they'll get a job for us.",
      "word_count": 46
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "They will take on everything just so they can come out.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No, no, we would have been Israelis.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I would have been talking Hebrew to you now.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "No, we would have been Israelis, absolutely.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "My mother, my mother always knew.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "She always when she had to make another try.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "She just had to try.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, she never had the opportunity before.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "But she wanted to try and see, not knowing where they were or what cities they were at.",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "She just placed an ad and hoped that somebody, somewhere would see it.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And that's exactly what happened.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Cattle boat.",
      "word_count": 2
    }
  ],
