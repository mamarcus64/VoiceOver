    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "She said because I introduced him to this man, this Englishman, who's suspected of being a spy.",
      "word_count": 17
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And I only wanted him to do a family tree.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And [PAUSES FOR 3 SECONDS] it took a long time for my mother to recover.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "Klaus, you had mentioned that your parents were packing in preparation to leave.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They were all packed already.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I mean, not everything.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Not the beds, not the linens, not the chinaware.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "But the paintings and the living room furniture was crated to be shipped to Canada.",
      "word_count": 15
    }
  ],
