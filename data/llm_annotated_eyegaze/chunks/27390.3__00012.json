  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "And in the morning, my mother and my sister went along to the headquarters of the Jewish administration to find out what happened to my father.",
      "word_count": 26
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So when they came along there, there were already a lot of women there.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And this-- for the first time, my mother met this-- his name was Chaim Rumkowski.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And he was the-- appointed by the Germans to be the leader of the Jews in Lodz.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "By that time, it wasn't called Lodz anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "It was called Litzmannstadt.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "They changed the name.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "When they annexed the city to the Reich, they changed all the names of the streets and of the town.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "They called it Litzmannstadt.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "So they gave him the title, the eldest of the Juden of Litzmannstatd, the oldest of-- the eldest-- the eldest of the Jews of the Litzmannstadt ghetto.",
      "word_count": 27
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "So--",
      "word_count": 1
    }
  ],
