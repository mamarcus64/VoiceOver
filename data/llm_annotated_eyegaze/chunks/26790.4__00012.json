  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But my permit was not, was not good written.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "The name, the name was not good.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I send them back.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And at that time was a, was a law.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "If you want to come to Australia, you must have 40 [INAUDIBLE] in the bank.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "This mean you, you will not, you will be able to carry on by yourself, don't have to be on security.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So I start to write letters.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And I, and I didn't get, get any answer.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But was my uncle that time have died.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And my cousin was in the army.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "I [? didn't. ?] The president from the, from the Yiddish, Yiddish committee in Szczecin.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We were in Szczecin.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "He was speaking English and writing English.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "I give him 50 zloties.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "He write a letter for me to the Victoria police.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And [? are ?] written, I ask him to send me the addresses for my friend, for my this, or from all of it.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "I got-- in two weeks time, I got a letter back, a reply.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I got the letter here.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "I would like to-- it is possible to.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Arrived, what?",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In '46.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "'46.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "I can't remember what month.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "No, only the, only the [?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "HIAS, ?] the Yiddish organization in America.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They helped me.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "At '96, I got the permit, '46.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "In 1948, we left Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "We come, come from, from-- I come to Paris from Chelm, from Szczecin.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We went to, to Paris.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And from Paris, we went to Belgium.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "From Belgium, we come here with an [? airplane ?] [INAUDIBLE], like.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "1948.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, first stop, it was in-- first stop was in, in Cyprus.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I can't remember, but three or four stops.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "At that time was not Fiji, was [INAUDIBLE].",
