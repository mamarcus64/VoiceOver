{
  "stem": "26983.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 48.6,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "They were selected on the spot.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "And only few peoples--",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "--went to the camps.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "All mothers and children till the age of 16 went automatically to the gas chamber.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Everyone who was over, more or less, 40-- because in Auschwitz, that was more-- if you were 35, 40, you looked like a 61, and you were not anymore capable to work.",
      "word_count": 32
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "You were sent automatically to the gas.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "So only this tiny, little group--",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And we came with everyone-- and soon you will understand why-- with old people, children, and sick people.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "We went to the sauna.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Now we came still with our clothes and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Now we had to take off our clothes and put it-- like if somebody comes to a prison, if you saw it in pictures, you had a huge bag, and you put all your belongings into the prison.",
      "word_count": 38
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "We had to get naked.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And then we could see what is going around.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "Maybe there was another transport, and so on.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And I remember I saw-- and we had still some food with us, which we had in our pockets, because, you know, we were very clever where to put-- so we ate something.",
      "word_count": 33
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And some of this-- it was a ration.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And must have been somebody with a longer time got hold of a piece of wurst-- of sausage.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And he made a bite.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "And the SS man saw it.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "From us-- must have been from somebody with [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "Take it out!",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "Take it out!",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "And started to beat him savagely.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "But he preferred to be beaten but to have this one bite, and to swallow it, which I couldn't understand.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "He's beaten to-- blood was pouring.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "He was-- just this little bite.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "And to us they behaved quite nice.",
      "word_count": 7
    }
  ],
