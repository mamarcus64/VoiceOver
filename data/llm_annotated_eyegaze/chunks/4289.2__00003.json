{
  "stem": "4289.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And I started to play with the baby.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And probably out of being tired and not eating, I fell asleep.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "At night my aunt and my father took off my cross from my chain.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And when I woke up and I wanted to pray, I didn't have that cross.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I started to scream again.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "I felt like God abandoned me.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Who is going to protect me?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Because I always knew that angels walk behind me.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And Jesus Christ is taking, you know, care of me.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And so on.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "So when I did not see that, I was really scared and afraid.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And at that time, I already became very quiet.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "I did not scream.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "So my father took me out to Jewish organization to look for clothes.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "I had no shoes, and very bad clothes, dirty.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "You know how children look after the war.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I was so skinny.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "I didn't look my age.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "At that time I was seven.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I looked like a five-year-old, my father said.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "So he took me to those organizations.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And I remember picking up clothes that I wanted.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I did pick them up.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And in the organizations there were some people talking to my father, what to do with this child.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And they advised him to take me to the orphanage where Captain Drucker has other children.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Which is not far from the city of Sosnowiec.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And he took me on a, on a, a, [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I don't know what you call it.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "A train.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And he took me there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "And when he brought me there, there were young ladies who took me in.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And they were very sweet.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And they gave me oranges.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "They gave me chocolate.",
      "word_count": 4
    }
  ],
