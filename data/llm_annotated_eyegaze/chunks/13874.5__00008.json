{
  "stem": "13874.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "This is a immigration visa to England through the refugee camp, Richborough, in-- and a-- to-- the inscription says I'm only allowed to stay in the camp and cannot travel in England.",
      "word_count": 32
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] This is a shot of the refugee camp in-- which was taken in 1939, from a water tower nearby.",
      "word_count": 23
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "That was in-- Richborough, England-- Kitchener camp.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And it started out as a military camp in World War I, and it was-- and it was converted to a military camp in World War II.",
      "word_count": 27
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of my brother, Leopold Selling and me, before I went overseas from Newark, New Jersey, in 1943.",
      "word_count": 21
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I'm in uniform.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] This is a picture of my two cousins, Katie Selling and Itzak Selling, whom I met up with while I was in the army.",
      "word_count": 28
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They came from Stutthof.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "They were in an extermination camp in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In 1945.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "In-- that was in Fuerth, where they had a-- an apartment, where they could live for a while.",
      "word_count": 18
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "This is the grave of my parents, Isidor Selling and Ida Selling, and the cemetery in Anspach.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And that was a restored cemetery.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "The only thing surviving were granite stones, which could not be used for building material.",
      "word_count": 15
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "Also, sandstones were destroyed.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "That was taken shortly thereafter, about 1950.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "This was taken in Fort Benjamin Harrison, in 1970, where I was executive officer during the summer training.",
      "word_count": 18
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "At that time, my rank was lieutenant colonel.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "This is a picture of my daughter and her family.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "On the left is her youngest son, Alan, and her husband, Dr.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Arnold Wise, then--",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Leon, he-- it was at the time, when he received-- was inducted into the honor-- National Honor Society.",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And on the right is our daughter, Barbara.",
      "word_count": 8
    }
  ],
