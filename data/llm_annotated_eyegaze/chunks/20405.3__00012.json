  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "We were going to get the hair from the women just little by little.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Because we were scared, and cut little by little.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And all this hair was-- [PAUSES FOR 3 SECONDS] was so dirty. from the women.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "They vomit, you know, from the gas and so on.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "So after that, we started to do faster, faster.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "We [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "Start [INAUDIBLE] do it faster.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "He was looking at me.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "I was looking on him, at Dario.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "At one moment, he went, Dario, toward the top over there.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "Because they were one woman to another.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "And we couldn't get their heads do easy.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "So he went to on top.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "There was a woman over there standing like this.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "And Dario, I guess, he stepped on the stomach of this woman.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "And-- and one moment, that woman, I think, she got out some gas of her stomach and made a ooh, something like that.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 3 SECONDS] And I saw Dario jumping from the top of the thing going out of the door.",
      "word_count": 20
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "He got so scared.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "And then after that in quarantine we were.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 22,
      "text": "They were taking us to work here and there.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 23,
      "text": "And then they-- they put us-- to put them in the crematoriums.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "We-- we didn't call him.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have to call them.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I knew about it when I was working the crematorium, I know the kapos names.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "But a kapo who shower you how to cut the hair, the one who got you started?",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "The Polish.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "You--",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Were almost Polands-- he was alive over there for a year, two years, three years, working over there Are on those things.",
      "word_count": 22
    }
