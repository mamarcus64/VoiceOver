{
  "stem": "19969.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 76.3,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So the next morning, I-- I left [PAUSES FOR 3 SECONDS] taking several of my men.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And it took us-- the roads were in terrible shape and clogged up, and it took us two or three days to make it to Le Havre, which was 500, 600 miles away.",
      "word_count": 33
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And I reported in there one morning, we spent the night in Paris and we went Le Havre the next morning, got there before noon.",
      "word_count": 25
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And I checked in with the Transportation Office at Le Havre.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "The sergeant had a little office at the end of the dock there.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And said, I'm Colonel Sparks and I think I have orders here to be sent back to the States.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And he looked me over and he said, well, colonel, I'll have to call my lieutenant.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "So he got on the phone there and in two or three minutes there came a lieutenant, first lieutenant, MP, military police officer.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "He said, colonel, I'm sorry, but I've got orders to take you back to 7th Army Headquarters.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] Well, I was in no mood to be taken anywhere.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I said, well, look around you, lieutenant, and my men raised their rifles.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I said, I'll go back to 7th Army Headquarters but you're not going to take me.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Will you give me your word, he said.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I said, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I give you my word.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So we left and went back to Paris and got a little drunk that night, I think.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And I think we spent a couple of days in Paris.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And then I took off back to where I came from.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "I found 7th Army Headquarters was near Augsburg, which is in Bavaria.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "It was in a small town near Augsburg.",
      "word_count": 8
    }
  ],
