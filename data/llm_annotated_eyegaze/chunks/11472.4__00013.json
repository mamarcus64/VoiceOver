{
  "stem": "11472.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "And we come across, and we see trucks with young boys and girls.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "And they take us in the trucks.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "Before they take us in the trucks, they put, they spray, like, white powder on us.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "They gave us, like, a disinfection because they were afraid people shouldn't bring TB or something.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "And they take us to Munich.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "In Munich, we embark.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "And they tell us there is such a thing as DP camps.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "We knew already that they had this place.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "And my grandmother says-- Displaced Persons Camps.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "My grandmother says that she has a sister that left a, a week or two before, that my uncle had told her she's in Fohrenwald.",
      "word_count": 25
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "And we go to Fohrenwald.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "My sister and my mother are still in Czechoslovakia.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "We come to Fohrenwald, and my grandmother's sister, [NON-ENGLISH] is there with her family.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "We come in.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 29,
      "text": "We see it's one big room.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 30,
      "text": "And about three, four families are living in the room with-- divided, like material or rags were divided, like sheets divided the beds.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 31,
      "text": "We come in, and they tell us that here they have a school, and they, and they have organizations, and they have, they give-- there's a big kitchen.",
      "word_count": 28
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 32,
      "text": "You have to stay in line.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 33,
      "text": "You get food.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "In the morning-- I get up very early in the morning, and I look for school.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "That was my first thing.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I want an education.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I come to school.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I see there are other girls there, meydl, little girls.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "I said, meydl-- in Jewish I speak to them.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "What are you doing here?",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "They said, we have a school.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "I says, where do you live?",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "They asked me, do you have father?",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "I said, no, my father was killed.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And where is your mother?",
      "word_count": 5
    }
  ],
