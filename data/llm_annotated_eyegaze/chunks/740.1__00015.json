  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "I will explain everything later.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "By about 11 o'clock in the morning, we went shopping.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "He shopped for suits, underwear, new shoes, everything.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "It was a joy.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I had a ball with him, not knowing why.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "In the afternoon, we came back home.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "Each had a small attache case.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And he said-- I can hear him saying to my mother, so are you coming with us?",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "Are you not coming with us?",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And she says, no.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I can't leave my furniture.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "I can't leave my house.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "I can't leave my money.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "And-- are we stopping for a moment?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "OK.",
      "word_count": 1
    }
  ],
