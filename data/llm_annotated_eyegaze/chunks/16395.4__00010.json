{
  "stem": "16395.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "You know that.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "And when they came to Israel, they had such a rough time.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "They didn't have nothing to eat, and where to sleep.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And so they wrote us a letter we shouldn't come.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "But at that time, Shirley was born.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "This was in Deggendorf.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "It was still a displaced person camp, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "There was really a black market or whatever.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "We were taking stuff from this town and bringing to the 'nother, and making a living, really, [? have ?] [? the ?] money and buying stuff.",
      "word_count": 27
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Life was much better in the-- in the-- in the-- we were sent things from-- from America.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Not-- nobody.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "But the organizations.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Red Cross or-- or the [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And it wasn't too bad.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And then we registered to go to America.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And-- if we didn't go to Israel, already my daughter was 17 months old, we got the visa.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And we came, and we went.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "My brother-in-law, the youngest, what I take his potatoes, he went before, because he went with the children.",
      "word_count": 18
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Special children's quota.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "So he went with the kids.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And he settled-- they taught him in [INAUDIBLE] in Rochester how to make-- how to work with his hands or to work-- to be electrician.",
      "word_count": 25
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "He went to school-- like I think he went to a-- a school what [? it ?] made by-- all right.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "He went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, a training school.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And he learned, and he was in Rochester.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "So we registered to go to Rochester.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And that's how we came to Rochester.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "He was in a-- he was in a-- in a-- all right, I just know.",
      "word_count": 15
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "No, not in [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "In a technical school, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] school.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "It's terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, there was a hospital.",
      "word_count": 6
    }
  ],
