{
  "stem": "1391.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "You know, this section is different, like two different park, you know, two different governors.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "This belong to the Germans.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "This supposed to be for the Poles.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Oh, but it was not right.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "It was just a bluff.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "And one night, they come in with a tube, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And they say, [SPEAKING GERMAN[].",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We start to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And so you were forced to leave your home at that point?",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "We have to get out.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Not even an address, no.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Some of my sisters used to be with [INAUDIBLE] around the [? town. ?] And we stay outside.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And right away was a couple wagons [INAUDIBLE] was trucks.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Not trucks at this time.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "We even didn't have trucks.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "No, from the farmers, you know, some.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And they say, up on the wagon, you know, house by house.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "And right away, the Gestapo go in the back and looked that there was somebody.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "And who is, who left was shot.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "And I say to my father, I don't go this way.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "What I wanted to go in the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "I want to go this way.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Maybe 10 miles away, my-- she was married by the name Hamprel.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "He was a tailor there.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "And I say, let's take-- we can [? take moving ?] one cow, that I help with father.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "We go maybe 12 miles.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "And we put it in, because start to get daytime.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "It was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And we said-- and by his name was [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And we put the cow there.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "We say, we knock the window.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "Will you let us in?",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "He say, give me the cow.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "He put it in the barn.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And he say, OK, you come some other time.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "I met my parent, met my father.",
      "word_count": 7
    }
  ],
