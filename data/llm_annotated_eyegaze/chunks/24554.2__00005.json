  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "These-- I don't-- I forgot the name.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "One night comes the Polish police, and take us all away-- the Jewish, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 14,
      "text": "In German, you say [GERMAN].",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 15,
      "text": "In Slovakian.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 16,
      "text": "In English, it's-- no, in England, over Christmas, the people who stay in the street, they take it for a few nights in a hostel.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 17,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 18,
      "text": "They took us on the German border.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 19,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 20,
      "text": "Me, my friends, [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "I was lucky.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "I was hiding in the little [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "And my friends, they take the gestapo.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "So I go away back and stay near to [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "And when I come to [NON-ENGLISH], I don't remember how I found an older Jewish couple, and they took me, give me-- uh, I can sleep there.",
      "word_count": 27
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "So and I wait, wait, wait, again, for my visa.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "No visa.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "No visa, up to nearly September.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "You know? 19-- [CLEARS THROAT] 1939, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 32,
      "text": "How old were you?",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "September 1939? 26 also.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "We [INAUDIBLE] started the war between Poland and-- and Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "So one way where we can go, it was only to the east to Romania.",
      "word_count": 15
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "In the '39, it was only central Europe.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "State was Romania.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "It wasn't under German control.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "Hungarias was under German control.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "So we run, I think, three days-- Run, run, run, run-- to so-called [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "West [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "You know West [NON-ENGLISH] belonged from 1918 to Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "It was-- it was Ukraine, Ukraine-speaking people.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "No, they belonged to [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "So after three days, or how much, I don't remember, I was in [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "It was a small town [? in this. ?] In the morning, I wake up.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "I was in the Soviet Union.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "What happens?",
      "word_count": 2
    }
  ],
