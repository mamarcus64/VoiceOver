{
  "stem": "3380.5",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "And three weeks later, we find out that she is pregnant.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I mean, she's pregnant.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I mean, the doctor said that we cannot have any patients in an old people home with pregnant woman.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "She said, I mean, this is not the place for you.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "And she said, she got to go through an abortion.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "And I remember, she was laying in a hospital bed.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And next to her was laying another, it was three feet apart, an elderly woman.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "She was from Chelm.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "You know, the city of Chelm, they used-- the smart people used to come.",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And that old woman said to my wife, do you know, Mrs.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Toporek, what you are doing?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Do you know the crime?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "All the geniuses said that you cannot become pregnant, and you became pregnant.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "This is a-- a thing from--",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "God wants you to be a mother.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Don't do it.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "There is no crime.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "There is no punishment for doing something, what you want to do.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "So and I remember, the doctor came.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And he had the shot.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And she said no.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "If this is what's happened to me, let it go.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "Let nature take its course.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And she had to leave the hospital.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "She start feeling good.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "But the professor said there is no place.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And the doctor said that a child should be born, and the spleen is so big, there is no place for two.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "Either you're going to have a dead body-- a child, or you're going to lose your life.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "Or something going to happen.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "But she felt good.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "She felt excellent.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "For one or another reason, looks like it-- like the thing shrinked.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "When she start feeling-- during the time when she start feeling better, I got papers to come to the United State.",
      "word_count": 21
    }
  ],
