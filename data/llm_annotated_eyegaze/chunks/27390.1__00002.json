{
  "stem": "27390.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And-- But we were very orthodox, and we went to a very orthodox school.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "It was a very large school.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "It was one of the most expensive schools.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "The Jewish schools were all-- had to be paid for.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "It was not supported by the government.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "And I-- as far as I remember, it-- it-- it cost my father a lot of money to send us to this school.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "Lodz had a lot of Jewish schools.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "It was a population of a quarter of a million Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "You can imagine.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 13,
      "text": "It also had a very cultural-- very highly developed cultural life-- Jewish cultural life, I'm talking about.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 14,
      "text": "It had a few daily Jewish-- Yiddish newspapers.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 15,
      "text": "It had lots of periodicals and weeklies and monthlies, some of them orthodox papers, and some of them non-orthodox, and Zionistic papers.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 16,
      "text": "And there lots of-- a few Jewish theaters and many libraries.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 17,
      "text": "There was a highly developed Jewish cultural life in Lodz.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 18,
      "text": "And-- [PAUSES FOR 10 SECONDS] I went to a school where the, the children started from the age of three in kindergarten.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 19,
      "text": "And we carried on in that school till the children were 18.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "They had many classes.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "It must have had maybe thousand or maybe more pupils, that school.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "It was not far from us, that school.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "We started school about half past 8:00 in the morning.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "And we carried on till half past 2:00.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "Then, we went home for our lunch.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 26,
      "text": "And we went back 4 o'clock.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 27,
      "text": "And we carried on-- we were in school until 8 o'clock.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 28,
      "text": "We had a break in the middle, but we carried on until 8 o'clock.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 29,
      "text": "And then we came home.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "And we still had to do some homework.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "We did not have time for-- to do a lot of sport and things like that.",
      "word_count": 16
    }
  ],
