{
  "stem": "24090.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "She hired good people that took care of me in the household.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "We always had pets.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "We had a dog.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "We had a series of dogs called Boobe-- and they would get killed.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "They'd run in the street, and they'd get killed.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "And it was always very traumatic, but she couldn't control them.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "We lived on a business street.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "We lived in the buildings that my father built when he was a pioneer in the town.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "There were two apartment buildings side by side.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "The business was in one of the buildings on the main floor, and it extended to the back, where he had a storehouse for all his paint and equipment, and where he stored the wallpaper and the rugs that we sold in the-- it was called a paint store.",
      "word_count": 49
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "And he ran contracting out of that as well.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Above the store was a first-floor, big apartment which was quite modern for the time.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "We had a bathroom.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "We had-- it was nicely furnished.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "My father collected antiques, and we had his antiques in there, which traveled to this country later on.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "Now, across the way, we had a roof garden on the first floor, so I was able to play in the roof garden.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "Beyond the roof garden was a gate which led to a crosswalk to another building, and that building was a two-story building that housed his paint storage place underneath.",
      "word_count": 29
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 21,
      "text": "And on top there were two rooms.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 22,
      "text": "One was for storage, and one was a comfortable room for the maid, where she stayed.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 23,
      "text": "She had a bedroom.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "They were built by my father.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "From that second building, there was a long stairs going downstairs.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And then there was a back yard that encompassed both those apartment buildings.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "A courtyard.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Very pretty.",
      "word_count": 2
    }
  ],
