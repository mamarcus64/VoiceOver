  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "It was more sawdust and sand than, than, than anything else.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And they would come around and grab things in the house, whatever they would-- they would decide.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "What kind of resistance?",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "To where?",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Why-- the, the, the town was split.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "We didn't even know what was going the other side of town.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "There was no telephone.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "We didn't have telephone.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "We didn't have no radio.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "We had no communication.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "We had no newspapers.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "We could not leave town.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "We couldn't even go from one street to the next.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 11,
      "text": "And this was-- this was life.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS].",
      "word_count": 1
    }
  ],
