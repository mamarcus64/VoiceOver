{
  "stem": "2097.3",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 30,
      "text": "When I got a little potato peel if I brought the food, I gave to her.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 31,
      "text": "She divided between us.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 32,
      "text": "And as I mentioned, and I thought these Czechoslovakian Jews which was brought from Theresienstadt.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 33,
      "text": "And one day, we had a big-- they were very, very sick.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 34,
      "text": "I heard they have typhus.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 35,
      "text": "But it's-- they were out of their-- starved for years.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 36,
      "text": "They-- they were just skeleton.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 37,
      "text": "And one night, we had a very strict day-and-night lager curfew-- curfew, that no one was allowed to go out.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 38,
      "text": "Every block was locked.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 39,
      "text": "And just the Czechoslovakian disappeared.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 40,
      "text": "I saw Miri, our blockalteste.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 41,
      "text": "For days, she was just crying.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 42,
      "text": "I didn't know at the time, but I know that was the liquidation of the real-- the leftover Jews from Theresienstadt.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 43,
      "text": "Now I know.",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 44,
      "text": "At the time, I didn't.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 45,
      "text": "And the-- every day, they were selecting, as I said before.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 46,
      "text": "I never been out when they were selecting, just a few.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 47,
      "text": "On the end of July-- not July, August, they were-- they were starting to-- I didn't know at the time.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 48,
      "text": "Now I know-- liquidating Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 49,
      "text": "Because probably the front was coming close.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 50,
      "text": "And we were selected to go to work.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 51,
      "text": "So Miri said to everyone who wants, to go out from Auschwitz is better.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 52,
      "text": "We-- oh, I skipped something.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 53,
      "text": "One day, Miri's fiance-- was working in the crematorium.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 54,
      "text": "He was coming, now and then, to see her.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 55,
      "text": "And Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 56,
      "text": "Nyiszli-- Nyiszli, Miklos, from Oradea.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 57,
      "text": "And his wife and his daughter was in my barrack, in barrack 18.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 58,
      "text": "Block 18.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The-- these blockaltestes, they had some knowledge of each other.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But Dr.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Nyiszli, we didn't know where he is working.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Now I know he was Mengele's assistant.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "He came to see his wife.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "He brought some aspirin with him, some food.",
      "word_count": 8
    }
  ],
