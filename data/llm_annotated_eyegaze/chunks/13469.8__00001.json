{
  "stem": "13469.8",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "But then I had an opportunity to become involved in international standards and regulations.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The man before me had left.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And somebody said, why don't you do that job?",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So hesitantly, I accepted in 1970 and I became involved in international standards and regulations for the braking systems of cars and trucks and trailers and buses.",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And I went to lots of meetings, national meetings, international meetings.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I became a world expert on braking regulations.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I've written lots of papers and collected books on-- on the subjects and I've won prizes for my regular presentations in America every year in Detroit for the American motor industry.",
      "word_count": 31
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I would give an explanation of the European regulations.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And I worked in Brussels for the EEC Commission and I worked in Geneva for United Nations on the-- all of this international braking regulations.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And basically, I became a very big fish in a very small pond.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And on the basis of all that work that I did, in the new year's honors list in 1990, I got an MBE, very much to my surprise and to everybody else's surprise.",
      "word_count": 33
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "There's nobody in my field that ever got anything like that before.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Everybody was quite amazed and so was I.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I thought the MBE should have been for my-- my wife, because she does all the kind of things that you get MBEs for.",
      "word_count": 24
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "Never realized I would get an MBE, but I did.",
      "word_count": 10
    }
  ],
