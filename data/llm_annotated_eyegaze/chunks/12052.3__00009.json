  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So then he got the news this aunt is in somewhere in a hospital.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And we picked up the aunt.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "And we got reunited.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "So this-- this is the only aunt who-- who returned from concentration camp.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And-- Can you tell us their names, your aunt and uncle?",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "The uncle is Vlaclav Slama and the-- the aunt is Alizabeta Slama, born Klein.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And after war, I was a war orphan.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And she took me under her wing.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And she took care of me, how long I needed to, till I went into Israel from Czechoslovakia.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "I live-- lived there about a year and half to two years with them.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And I went-- they give me the opportunity and the roof over the head and food.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "So it was not easy, of course.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "Only I could go back to school and also to learn mine-- my trade.",
      "word_count": 14
    }
  ],
