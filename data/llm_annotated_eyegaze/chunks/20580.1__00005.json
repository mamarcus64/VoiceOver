{
  "stem": "20580.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I learned at school.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Which, I have the certificate from school.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And then, when I come 16, 15--",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Basically, I-- I used to play violin.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I had two years of violin.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And I don't know the violin.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I played chess in the club.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "It was a-- a club from chess.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "You have to pay there.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "I paid 2 zlotys a year whenever-- this-- whenever you come in.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "Play chess with your partner.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "You take a-- a tray with the grapes.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "It was at that time, it was-- it pays money.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "You have to pay for it.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "And I make money on the side.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "You asked me a question, how did I make money?",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "After my mother was now in the-- the business, and I carry up the packages, this lady, this lady-- after I took-- saccharin was illegal.",
      "word_count": 25
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Saccharin.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Saccharin.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Was illegal in Poland because you have to buy sugar.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "And I went to the-- this guy.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "They knew me a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, send the saccharin, I make a few dollars.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Once, it happened I find American $5.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I bring everything to the mother.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And so on, then later on, my uncle stepped in in the business.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "They called it [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "And I was standing to collect the dollar from everyone.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And I make a little money on the side.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Then, I went out, a name, [NON-ENGLISH], the biggest people, they need money.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "They need $300.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "And I went with them into partnership.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "And we made money.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "Couple weeks.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And they says, listen to me.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "You are a young kid.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "You don't have to go with us.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "It's no good.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "We have your money.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 19,
      "text": "We-- money-- we-- they divided.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 20,
      "text": "They throw me out from the business.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 21,
      "text": "I went to the market again.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 22,
      "text": "I bought myself a cow.",
      "word_count": 5
    }
  ],
