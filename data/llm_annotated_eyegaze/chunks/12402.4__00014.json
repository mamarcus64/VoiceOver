{
  "stem": "12402.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "He's looking for a partner-- maybe I know somebody from the-- from the [INAUDIBLE] maybe.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "He wants a partner.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "Said, a partner?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "I could be a partner.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "I wanted to go on business, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "So I came to my brothers.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "I said, look, I have a good proposition.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "So my brothers said, let me see that business.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "It came in and said, this is a business?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "It's not enough even for-- for a half a person.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "He wanted, her father wanted-- half of the business was worth $7,000-- he wanted $2,500.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "So my brother didn't want to hurt me.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 29,
      "text": "Said, well, it's not worth it, but what are we going to invest money, for what?",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 30,
      "text": "I said, you invest the money.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 31,
      "text": "I promise I'll pay you back.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 32,
      "text": "That's what he did.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 33,
      "text": "They made a deal, and made a contract, and got-- I'm in business.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 34,
      "text": "So what happens, I'm in business.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 35,
      "text": "I had to come up to a house.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 36,
      "text": "So on and on, and so a few years-- no not so long, maybe a few months later, we got married.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 37,
      "text": "But I paid back my brother.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 38,
      "text": "In one year, I paid him back all the money, and I told my father-in-law, I told him this is not a business for you to build another business.",
      "word_count": 29
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 39,
      "text": "So I started-- I got into the blouse business, and we moved out of the old place and got into a bigger place.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 40,
      "text": "And things were going not bad with enlarging the business.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 41,
      "text": "I paid up my brothers, and everything was fine.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 42,
      "text": "And when I got married-- so we went on our honeymoon.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 43,
      "text": "It was-- it wasn't the right time to go and wasn't the right place to go.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 44,
      "text": "We went to the Niagara Falls.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 45,
      "text": "You know.",
      "word_count": 2
    }
  ],
