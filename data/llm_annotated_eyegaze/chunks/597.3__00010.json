{
  "stem": "597.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "You have to go out from the house.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "Go here in the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "There is a woods-- wood around the village.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "My mother says, ah, nobody will touch me.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "I'm here in my-- in my-- in my village.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 33,
      "text": "We heard that-- that she said that in the woods.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 34,
      "text": "We ran away.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 35,
      "text": "My sister and myself, we ran out from the house right away-- and start running, and find themselves a bush.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 36,
      "text": "And it was not far from the woods-- in-- hiding under the bush.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 37,
      "text": "My mother wants to already see.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 38,
      "text": "She lost us already.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 39,
      "text": "She wants to see.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 40,
      "text": "So the girl says, I know where they went.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 41,
      "text": "Come on.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 42,
      "text": "I'll show you.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 43,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 44,
      "text": "Go run to the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 45,
      "text": "Take the girls, and run to the woods.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 46,
      "text": "We was sitting there, under the bush.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 47,
      "text": "And the minute my mother sit down there, the Germans was go looking for us all over there in the-- in the same place.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 48,
      "text": "And they didn't see us into the-- under the bush.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 49,
      "text": "They didn't see.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So they went back to the city, over there-- whatever it is.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And we was left there till the evening in that bush.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "But it was not a big bush.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "In the evening, you want to eat something.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "You need-- you need food.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "We start to go on farther.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And my-- my mother knew that there was another little village.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "My grandfather used to own the-- he had a farm over there-- my mother's grandfather, my great grandfather.",
      "word_count": 18
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And she knew-- she knew all the-- the-- the places there.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "She growed up there.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "She went in the house there on a corner.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And she was asking for a piece of bread-- food.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "We was still there on the bush.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "The woman saw us.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "She got so scared.",
      "word_count": 4
    }
  ],
