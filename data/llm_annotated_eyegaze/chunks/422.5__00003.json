{
  "stem": "422.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They said on every state train station, on every station there will be Red Cross people giving us hot soup and coffee and bread, nourishment.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We'd be sleeping in the evening in movies and theaters and schools.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "We were thinking and thinking.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I said to her, you know something, we cannot risk-- we are so far, we went so far-- to hide and to find our dead.",
      "word_count": 25
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We're going to mix with the German population.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And we're going to be refugees together with them.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "We're going to be running away from the Russians to deep Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Because otherwise, we'll be blown up here.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And that's what we did.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "They gave us food on the way.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "They gave us-- in one of the places, until they brought us to Waldenburg.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "Today, this belongs to the Poles, in upper Silesia.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "This is Walbrzych.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "Today, the name is Walbrzych in Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "This is Waldenburg.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "It was a German town.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And we slept over there in one of the theaters.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "And straw-- they prepared the Red Cross, prepared straws-- straw on the floor.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "And we slept.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "Laying on the floor-- there were two women, full theater with people.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "Men and children, everybody runs away from the Russians.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "And they're helping them on the way, the Red Cross.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "Laying next to us, there were in the nighttime two women.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "And I overheard them talking.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "That in the morning, soon it's going to get daylight.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "They're going to leave the place.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "And they're going to go to the [GERMAN] looking for work.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "[GERMAN] means employment office.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "To look for work.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "And I said, you know, we're going to follow them.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "And we're going to go to that [GERMAN].",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "And we're going to look-- because I'm not afraid no more.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "I've got a document who I am.",
      "word_count": 7
    }
  ],
