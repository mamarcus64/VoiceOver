  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And-- [PAUSES FOR 3 SECONDS] but it must've been about 4:00 in the morning.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It was still dark outside.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We heard terrible noise.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And as we looked out through the window, the village was full of German tanks, with Germans, with horses, with everything.",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I thought to myself, now that I know my score, what am I going to do?",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "So I said to her, why don't we change clothes?",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "You give me your clothes and I leave you my clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "She says, if you say one more word I'm going out in the street and I'm going to tell the German that you're a Jew.",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "So I said, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "In meantime, a German came into the house, and he asked her for some food for the horse.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And she was-- [PAUSES FOR 3 SECONDS] as she walked out to give it to him, she walked out in the street to take a look what's going on.",
      "word_count": 29
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "The forest was like from here across the street.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I picked myself up, and I ran into the forest.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Let me tell him because he doesn't--",
      "word_count": 7
    }
  ],
