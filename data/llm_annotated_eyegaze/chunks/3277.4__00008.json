{
  "stem": "3277.4",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.3,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 12,
      "text": "And I-- I was broken-- really, completely out.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 13,
      "text": "And then, you know, and I was trying different ways-- different ways to get-- to get a way out of Poland.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 14,
      "text": "I used to go to Warsaw and trying-- maybe I can, you know, to-- different ways, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And one day-- one day-- and I was working then, in Waldenburg, in a-- in a printing factory.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And-- and they wouldn't let in anybody into the office.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "The guy that, uh-- [PAUSES FOR 3 SECONDS] what's his name-- not-- [PAUSES FOR 3 SECONDS] in front of the building, how you call this?",
      "word_count": 25
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Security guard?",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "The doorman!",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "The doorman wouldn't let-- yeah, that-- see?",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Plain word.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I am nervous!",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I am completely nervous.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And the doorman wouldn't-- wouldn't let-- And yet the doorman comes up and says, somebody wants to see you.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "And I came down.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And in the meantime, I was trying very hard to get out of Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "Different ways.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "You know, it would took me too much time to explain.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And this guy tells me, you know, I have to talk to you about something.",
      "word_count": 15
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "Then I said to him, listen, you have to wait.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "I have to work until 3 o'clock.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "We used to work there from 7 to 3 o'clock.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "At 3 o'clock, [INAUDIBLE] be downstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "I come.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And he was there.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "We went to a restaurant.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "And I offered him, you know, some vodka, and-- And-- and I was afraid to talk to him.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "Because I was thinking maybe, you know, the Communist Party's sending somebody to get something out of me to, you know.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "Because they considered me not a-- a good element, as a-- you know, as a-- suspicious.",
      "word_count": 16
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "And I didn't-- he-- he didn't talk anything he wanted from me.",
      "word_count": 12
    }
  ],
