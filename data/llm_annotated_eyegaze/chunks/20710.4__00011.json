  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I mean, it's hard to express, you know, what-- I hope they'll have a easier life and a, and a more peaceful world and a, and a happier ones.",
      "word_count": 29
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So-- I don't know what else.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Thank you.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I hope this is going to help in some, some way.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And thank you for being so nice and helping me out.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "I didn't express a lot of things that they were going on, because it's very, very difficult in such a short time.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And certain things were very, very tragic and painful.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Then I left my-- when I lost my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And to know all these things.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And it was very-- I was like, for a couple years, I was like frozen.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "I didn't know what's going on.",
      "word_count": 6
    }
  ],
