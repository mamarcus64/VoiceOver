{
  "stem": "23942.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 31,
      "text": "And she told her, to this Jewish Polish woman, that one day when I came and she said she's going to take me to the priest and going to baptize me, I went like this with my hands, like this.",
      "word_count": 40
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 32,
      "text": "And I said, please, please not.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 33,
      "text": "She even showed me how I looked, how I made, how my body went to sort of like into a very-- into a position where I felt like I was at her-- I was at her mercy.",
      "word_count": 37
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 34,
      "text": "But I didn't want to insult her and I didn't know how to handle the situation.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 35,
      "text": "So I sort of went like this.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 36,
      "text": "And I said, please, not yet, not yet, I want to wait a little longer.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 37,
      "text": "She showed me how I looked, how I did that.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 38,
      "text": "And had this old lady showed what I did and how I said it.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 39,
      "text": "And she reminded me after forty years and I completely forgot this.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 40,
      "text": "And she also told me that this lady Gdynska put a big cross on me.",
      "word_count": 15
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 41,
      "text": "Here.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 42,
      "text": "And I had this cross, that's what she said.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 43,
      "text": "That I had this cross and she named me.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 44,
      "text": "She told me that I should say my name is Marisha and that this is my name.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 45,
      "text": "That I should say that's my name.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 46,
      "text": "And I didn't have a second name.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 47,
      "text": "I was so unprepared for being hidden or anything that if somebody questioned me I would have been dead.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 48,
      "text": "Because I didn't have even my second name prepared.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 49,
      "text": "I was so unprepared.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 50,
      "text": "I was just-- I was lucky that nobody ever arrested me, nobody ever questioned me officially.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 51,
      "text": "I was just-- I believe that-- the way I see it now that there must have been a maluch on this side and a maluch on this side.",
      "word_count": 28
    }
  ],
