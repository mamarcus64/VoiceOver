{
  "stem": "20800.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I'm-- I born 10th of June, 1922 in Vinnitsa.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I am now 75 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I mean 74.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name is [INAUDIBLE] Beri.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "B-E-I-R-E.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "What city?",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "In Vinnitsa.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Vinnitsa is a large city.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I grow up in Vinnitsa till I was about nine years of age, and then my father was an army officer.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "So And they sent him north to Leningrad, where we lived up to 1938-- '39.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And-- yes?",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My mother is maiden name was Gefter.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "She married my father, Beri David-- David.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "My mother was born and Vinnitsa too.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "My father was born in a little town, Mariupol.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "It's all in Ukraine.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember the date of death--",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "--of birth of them, but do-- I do remember when they died.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I have two sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "The middle's-- I'm the eldest.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My middle sister is [?",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Raissa-- ?] like Rachel.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And my youngest sister is Alexsandra, [?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Shura ?].",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "The-- my middle sister born in 1920-- '24 in December.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And my [PAUSES FOR 3 SECONDS] youngest sister born in 1928 in September.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My last address before the war was [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We lived in [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We lived in blocks of flats for Army officers, which we called [RUSSIAN].",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It's in Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "I wouldn't know how to translate it in-- in German.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "It's 100 flats, approximately, and they was occupied only by Army officers, Red Army officers.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "That was my last place where we lived.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "My father was an army officer.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "His rank was captain. it was just before the second war break.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 4 SECONDS] we lived in Leningrad.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Because of his sickness, we were sent from Leningrad south in [NON-ENGLISH], which is Krasnodar.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And--",
      "word_count": 1
    }
  ],
