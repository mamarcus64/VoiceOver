  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Ordnungsdienst, that was called, which means, if we translate it, it was only [PAUSES FOR 3 SECONDS] service for keeping order.",
      "word_count": 21
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "But later on it was rather a reason to keep the German deportations.",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "It was voluntary.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "From Cracow Ghetto, we were transferred to Plaszow.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "That was behind Cracow area, where it was really a Jewish cemetery.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Part of the cemetery was-- [PAUSES FOR 3 SECONDS] part of the cemetery was used for building barracks.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] I think it was the March, 1943, when really the ghetto was closed, or rather, all inhabitants were sent out to the places of Vernichtungslager, as they say.",
      "word_count": 33
    }
  ],
