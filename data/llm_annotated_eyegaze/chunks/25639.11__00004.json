{
  "stem": "25639.11",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 46,
      "text": "But, but they were so proud.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 47,
      "text": "They wanted to do it, and they did it.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 48,
      "text": "And they're doing fine.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 49,
      "text": "And, of course now, they're all married, and they all have children.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 50,
      "text": "The children have children.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 51,
      "text": "And so the family has grown, grown.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 52,
      "text": "Shandor, just a week ago, had a light stroke.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 53,
      "text": "But I think he'll be all right.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 54,
      "text": "I just talked to him.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 55,
      "text": "He was able to speak a little bit.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 56,
      "text": "And this, this naturally, was of some concern to me.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I have two sons, David and Jonathan.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And I'm very proud of them.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "They're wonderful men.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "David is an MD.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "He practices internal medicine and also surgery in Modesto, California.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "David was born in 1953, and my younger son is Jonathan, who was born in 1955.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Jonathan has five children, and he lives in Berkeley.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He is a speech pathologist, a professional musician, and he also teaches summer school at Hayward State University-- English as a second language, culture, and history.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "At the time when David was in elementary school, there was no other-- no alternative.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "There were no alternative schools in San Francisco.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "But I think he received a good education.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He went to Hebrew school, and graduated also from Hebrew high school in addition to public school.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "He went to a college preparatory high school, for which he qualified because of his good grades.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And by the time Jonathan was elementary school age, my husband Karl and a group of leaders in San Francisco, including some rabbis, had formed a group and founded the Brandeis Day School.",
      "word_count": 33
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Our younger son, Jonathan, was its first grad-- in its first graduation class.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "He received a very good-- he speaks Hebrew, of course, very well, and reads and writes it and in addition to a good secular education.",
      "word_count": 25
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
