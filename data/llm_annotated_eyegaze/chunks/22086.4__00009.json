  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Sometimes I'm sorry about it, that I didn't talk to them, that they should be more knowledgeable.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "The only thing they know is that their parents are survivors, but they don't know what we went through.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "My oldest daughter always used to tell me, how come she hasn't got grandmothers, and aunts, and uncles?",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And I never really gave a good explanation that she should understand.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "But I always used to tell them, when you get older, you will understand.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "That was always my answer.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And when they got older, it's too late.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "I'm glad I did it, now that it's over.",
      "word_count": 9
    }
  ],
