  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And their laws, the anti-Jewish laws, were printed in the papers and announced by the, the little man who was-- oh, how did they call it?",
      "word_count": 26
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "God, help me.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "A town crier.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "Town crier.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And he allowed-- every few hours, he brought new rules.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And we would gather in the town square and listen to how we will have to wear a yellow star.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "And after 7 o'clock, you're not allowed out.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "We're finished with this segment of the tape.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And I'd love to continue this particular part on our next tape.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "So thank you very much.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "We'll talk to you again soon.",
      "word_count": 6
    }
  ],
