  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "The authority over there, the UNRRA and the IRO International Refugee Organization, took our names, took whatever we remembered from before the war, family, whatever way we had in Europe, or family that were in the United States, or whatever, on the continent.",
      "word_count": 43
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Whatever I remembered, I gave all the names.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "It happened that I remembered from before the war that my mother's brother lived in Paris.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "That my grandfather, my mother's father, lived in Brazil; I did not know addresses.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "But I remembered that they lived in Brazil.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "And I gave all that.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "I stayed in Salzburg till a group of [?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "Chayalim ?] came from Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "And they told us that we had a place in this world that there is Palestine for us.",
      "word_count": 18
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "Because we used to be called staatenlos, people without a country.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "Because we were so against Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "We were so bitter of the treatments that they did-- what they did to us, and the collaboration that they did with the Germans that we hated them on the same level as the Germans, even more.",
      "word_count": 37
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "[PAUSES FOR 4 SECONDS] The [?",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "Chayalim ?] organized a group, and we went from Salzburg.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "They took us to Udine.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "This is the border of Italy and Austria.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 21,
      "text": "We went to Udine, and then from Udine, we went between the mountains by mountain cable cars, with the mountains.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 22,
      "text": "And then we arrived to Udine.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 23,
      "text": "From Udine we went to Bologna.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 24,
      "text": "That was also the UNRRA.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 25,
      "text": "That was also the IRO, the International Refugee Organization.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 26,
      "text": "They fed us.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 27,
      "text": "They gave us different clothes, the UNRRA.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 28,
      "text": "They gave us soap to wash.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 29,
      "text": "We were very good treated.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 30,
      "text": "When we arrived to Bologna, the UNRRA and the [?",
      "word_count": 10
    }
  ],
