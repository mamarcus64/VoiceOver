{
  "stem": "25938.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "I remember-- we were-- it was-- what do you call that thing in English when you take the horse and you travel on that thing with the horses, with two horses?",
      "word_count": 31
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "A wagon, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 2,
      "text": "So I think we rode on the wagons.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 3,
      "text": "We were-- if it was the horses, I don't know.",
      "word_count": 10
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 4,
      "text": "Maybe it was trucks.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 5,
      "text": "I can't-- it's chaos in my mind.",
      "word_count": 7
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 6,
      "text": "I just know that we were on the road.",
      "word_count": 9
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 7,
      "text": "And they were bombarding there.",
      "word_count": 5
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 8,
      "text": "There were bombarding it.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 9,
      "text": "We used to hide.",
      "word_count": 4
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 10,
      "text": "We used to lie down on the ground.",
      "word_count": 8
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "Just five in line, like this, like soldiers.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "My brother was all this time.",
      "word_count": 6
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "Next to me all the-- all these years.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "All these--",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 1,
      "text": "It was also a unique thing.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 2,
      "text": "My brother-- that is something.",
      "word_count": 5
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 3,
      "text": "Every camp he was with me.",
      "word_count": 6
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 4,
      "text": "We were sleeping on the same boards and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "We had another-- we had two brothers there, I remember, my stepbrothers.",
      "word_count": 12
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 2,
      "text": "I had four stepbrothers.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 3,
      "text": "One was in America already, the oldest one.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 4,
      "text": "He took us over, sent out the visa.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 5,
      "text": "He was in Philadelphia during the war.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 6,
      "text": "And the other brothers, one of them, [?",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 7,
      "text": "Hirshke, ?] was not in the camp.",
      "word_count": 7
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 8,
      "text": "He was sent to the crematorium, I think, with his wife.",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 9,
      "text": "And there was two brothers, [?",
      "word_count": 6
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 10,
      "text": "Shlemke ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 11,
      "text": "Awremel. ?] They were wonderful people, beautiful people.",
      "word_count": 8
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 6 SECONDS] [INAUDIBLE] The youngest one was [?",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 13,
      "text": "Shlemke. ?] We were walking, my brother and I, and [?",
      "word_count": 11
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 14,
      "text": "Shlemke ?] joined us, three.",
      "word_count": 5
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 15,
      "text": "I remember I used to take the bread, biggest portions.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 16,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 17,
      "text": "Shlemke ?] used to take the-- for all three portions, he used to keep it.",
      "word_count": 15
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 18,
      "text": "Then he used to-- used to give us at work.",
      "word_count": 10
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 19,
      "text": "He kept the bread.",
      "word_count": 4
    }
  ],
