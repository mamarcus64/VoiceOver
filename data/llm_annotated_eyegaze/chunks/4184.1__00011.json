  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We had-- yes, we had fairly good food, yeah-- at that point, yes.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And he asked me if my-- they have a chance.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "The Quakers were taking younger children to the States.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Would I let Margot, my sister, go.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I says, please, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I knew I had family in the States, in New York.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And they said that she would come to New York, but that she was assigned to a foster family to Los Angeles.",
      "word_count": 22
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "At this point, I didn't care.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "All I knew-- I wanted her to go to America.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I stayed on in [?",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Chabon. ?] And then one day, I was asked-- there was a girl there, [?",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Angele, ?] I remember.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I still see her occasionally.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "Her name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Angele ?] Haas-- H-A-A-S.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "And she had a sister and-- a younger sister and brother in another home, in southern France, right by the Spanish border, in the Pyrenees.",
      "word_count": 25
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "Would I like to change and go there?",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 5 SECONDS] And so I said yes.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "Got it.",
      "word_count": 2
    }
  ],
