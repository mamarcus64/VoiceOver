  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Until I got to, to Cracow and came back to the ghetto-- I came home.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "I was swimming in butter, but there was no butter to eat or any butter to sell.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "It was just running.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "And the sausage, you wouldn't want to smell it.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The Aktion.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "The Aktion.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "We were all in the Aktion.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But each time, we had to get a different permission to stay.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "One was a blue [INAUDIBLE], and one was such a [INAUDIBLE] and another [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "But all in all, I went through a few of those.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "But don't forget.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "I was young.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "I was a young-- you can say I was quite attractive.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I wouldn't say I was a, a beauty.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I wasn't Princes Di.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "But something they-- [PAUSES FOR 3 SECONDS] I spoke German when I want--",
      "word_count": 13
    }
  ],
