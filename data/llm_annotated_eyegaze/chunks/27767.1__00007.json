{
  "stem": "27767.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.7,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "My father was dressed regular business suit, a regular suit.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And especially in the-- in the store, he was in a working suit.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "And he had a hat or a cap.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And we wear caps actually, not in the school, but on the street.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And when-- when we were younger, we wore caps.",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "My mother, she was dressed also.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "She-- you know, she helped in the store.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "But she was also-- you know, we were four children.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "She was doing the housekeeping and the cleaning and everything else.",
      "word_count": 11
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "And she was very good cook.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And that-- Friday morning, when I woke up, she was already cooking Danish and all kind of cakes and challah.",
      "word_count": 20
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "She made the challah.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "She was doing it.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "And-- and we had a bakery right near our house.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 9,
      "text": "So we took there the challah.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 10,
      "text": "And they baked it for Shabbes and the [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 11,
      "text": "And during the week, Monday she cooked bread.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 12,
      "text": "She baked bread.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 13,
      "text": "She had a variety of big bread.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 14,
      "text": "And they-- we took it to the bakery.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 15,
      "text": "They did it there.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 16,
      "text": "And-- and then the bread-- we took it back home.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 17,
      "text": "We had bread for a whole week.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "A big bread.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "It was tremendous, such a big bread.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "We had this-- we had it for a whole week.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "It was a white-- white, brownish, you know, because everybody was buying flour.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "We sold flour too in the store.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And they took it home.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "And they made bread with-- with potatoes.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "They put in potatoes at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And no eggs in the bread.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "The challah, they did.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 7,
      "text": "And we had always, Tuesday morning, beginning Tuesday morning, fresh bread.",
      "word_count": 11
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 8,
      "text": "We had also like a pizza type-- they did it.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 9,
      "text": "They called it langos, which-- which was a-- like a pita.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Mhm.",
      "word_count": 1
    }
  ],
