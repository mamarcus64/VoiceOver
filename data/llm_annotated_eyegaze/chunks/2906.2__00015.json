  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "We came in the morning, and we didn't have our clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "So I had a-- a nightgown, a torn dress.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "I went to the-- you have to go to work because if not they send you right the way to Siberia.",
      "word_count": 21
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "And this dress had patches.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "I used to every time put a patch more than the dress but themselves.",
      "word_count": 14
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "Patches I had from the-- from the-- where I was working.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 9,
      "text": "And when I-- I got sick.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 10,
      "text": "So they-- they came, and they took me to the hospital.",
      "word_count": 11
    }
  ],
