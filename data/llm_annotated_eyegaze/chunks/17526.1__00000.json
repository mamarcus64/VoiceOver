{
  "stem": "17526.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 98.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Joe Kahn, Joseph Kahn, K-A-H-N.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Kotek, my previous name was Kotek, K-O-T-E-K.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "At attaining citizenship, I have changed my real name to Kahn, and there were reasons which are not important right now.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I reside at 9954 Wingtip Road in Philadelphia, the northeast part of Philadelphia.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "I've been living here for 25 years in this particular house.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I've been in this country since 1950.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "I arrived to the United States in May, 1950.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is January 8, 1922 and I was born in Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "The name of the town was Bedzin, B-E-D-Z-I-N or Bendin, as we knew it.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "We knew it for Bendin.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "It was a town located in the southern western part of Poland among a cluster of other big towns which were highly industralizied.",
      "word_count": 23
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "There was a lot of coal and ore mines.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, as a child I went to a religious school and the studies were intensive.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Coming from an orthodox upbringing, I went to an orthodox school where studies were conducted all throughout the day, beginning at 8:30 until about 8:00.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "There were some secular teachings and-- and studies being conducted, but the main emphasis was on religious education.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And later on, as my father realized that I-- this is not going to be my future, he sent me to public school, where I finished public school, which is the equivalent of high school here.",
      "word_count": 36
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And this was somewhere around 1936.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Well, the name of the school was [POLISH], which is the Polish-- the translation is public school by the name of [POLISH], S-I-E-N-K-I-E-W-I-C-Z-A.",
      "word_count": 23
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "This was the name after a Polish famous writer.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And the school was a predominantly Jewish school, even thought it was subsidized by the government, by the city, by the Polish government.",
      "word_count": 23
    }
  ],
