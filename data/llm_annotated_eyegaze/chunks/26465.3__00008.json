{
  "stem": "26465.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And I was amongst that group.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And they took us on the truck.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "There was a big truck that came.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And they transported us to Augsburg, to Hans Deuter camp.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "There-- there were already other people there-- other women.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "It was a place underground-- a camp that was underground, which was supervised and watched by guards.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And locked, always, for the night.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "During the day, we were escorted to the factory, where I was sewing the-- what do you call that-- [NON-ENGLISH]-- covers for the trucks-- tarps.",
      "word_count": 25
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And it was a very heavy thing-- heavy job.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "In the beginning, I could hardly carry anything, so they put me on the sewing machine.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And I managed to catch up that work soon-- very soon.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And I worked on that machine-- heavy-duty machine, sewing those tarps all day.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And we had a very, very exhausting kind of life, and the food was very poor, so we probably got around-- somewhere around 900 to 1,100, 1,000 calories-- something like that.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "Mostly soup made of squash.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Or sometimes we got potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And there was this Ukrainian woman that was supposed to distribute the food.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "She was bringing, for example, a big vat of potatoes.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "Some of the potatoes were rotten.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "So she gives them anyway, and she gives them sometimes because she doesn't like this person, so she gives her a rotten potato.",
      "word_count": 23
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "And he had fights.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "We had-- we had all kinds of terrible stories there.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "We had this big dormitory, divided by a long, long table-- series of tables put together.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "And on one side were Ukrainians, who were treated with special, special favors.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "Like, they could go out on town.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "They could go to the washrooms whenever they wanted.",
      "word_count": 9
    }
  ],
