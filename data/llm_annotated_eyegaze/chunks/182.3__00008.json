{
  "stem": "182.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 158.8,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "We went back to New York, and my mother--",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "My father was an intern in the Bellevue Hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "And my mother was a cook in a Jewish high school.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And I was also a cook in a Jewish high school.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "She cooked on the meat kitchen, and I cooked on the dairy kitchen.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And we lived in Williamsburg.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And Williamsburg, to me, was paradise.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I met such wonderful people-- poor people-- compared, you know, that how they lived and how I could observe.",
      "word_count": 19
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But they were so wonderful.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And they were so religious.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "But religious in a sense-- in Europe, if you were very, very Orthodox or Hasidic, you had no fun if you were young.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't do anything.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "You couldn't participate in anything that other children do-- plays, or-- or-- or games, or nothing.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And I came to America.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And I met a family.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "I-- somebody who adopted two-- two children from this home in [NON-ENGLISH] said that if I come to America, he will give me a job if I need a job.",
      "word_count": 30
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "He had a resort, an orthodox, beautiful resort.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And when I came, and I needed work, I called him up.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And he gladly hired me.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And I met there some other young people who worked in the resort in the summer.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "Some were students.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "Some were not.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "But they were all Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And when I came to the city and worked as a cook, this one girl, an American girl, she looked me up.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 19,
      "text": "And she took me under her wings.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 20,
      "text": "And she treated me that I just can't tell you.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 21,
      "text": "And because of her, I became even more religious than I-- or observant.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 22,
      "text": "Because religious I was, but more observant than I was at home.",
      "word_count": 12
    }
  ],
