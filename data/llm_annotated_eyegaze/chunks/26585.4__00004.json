{
  "stem": "26585.4",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "It was a lab, and hired maybe 30 people.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And that's where they made the copper sulfate.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And he walked there every morning.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And at noon, my sister and I took turns bringing him his noon meal and walking back.",
      "word_count": 17
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "That's all we did.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Mother did the-- the-- the, uh, buying, the shopping for groceries.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "We did not leave the room we were in unless we had to.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And we didn't have to, so we stayed there.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh, he was still arrested.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, he was getting ready for work one morning, which was, like, 5:30 in summer, when-- where we lived at that time, across the street, they had brought the Gestapo headquarters from [INAUDIBLE].",
      "word_count": 37
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "That was the Gestapo head-- headquarters.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "To our right was the local police station and to our left was a company of German soldiers.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "We couldn't go to the outhouse without somebody se-- seeing us.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Came this local policeman and said, doc, um, you've got to go with me.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So my fa-- kissed us goodbye and my mother said, Max, you'll be home tonight.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And he said, I know.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I mean, it was like, goodbye.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "See you tomorrow.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "That's how my mother worked this.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "She immediately went to Major [?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "Rank ?] and he said, I'll make some phone calls, while my mother waited in his office.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "We weren't worried.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And he said, um, none of my sources know anything about his arrest.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "It's not the Germans.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "It had to be the Croatians.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "And he made more phone calls and said, yes, Tomic has him and he has been taken to [?",
      "word_count": 19
    }
  ],
