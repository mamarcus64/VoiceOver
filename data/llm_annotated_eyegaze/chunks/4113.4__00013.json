{
  "stem": "4113.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.1,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "And then, thereafter-- this was just before we were shipped off to Schindler's-- and then I was all of a sudden assigned to go to Schindler's, to Sudetenland.",
      "word_count": 28
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 26,
      "text": "In Brunnlitz [?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 27,
      "text": "Brissau ?], which was Sudetenland.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 28,
      "text": "And then we were shipped off to Gross-Rosen, which was a camp in Germany.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 29,
      "text": "There we stayed a couple days.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 30,
      "text": "A horrible camp.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 31,
      "text": "We arrived there, and the afternoon and evening we stood out.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 32,
      "text": "It was cold.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 33,
      "text": "Was the 15th of October.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 34,
      "text": "Was very cold and was drizzling a little bit.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 35,
      "text": "I stood in the middle so the other guys kept me warm.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 36,
      "text": "The other guys were freezing.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 37,
      "text": "And then they took us in to disinfect us.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 38,
      "text": "And they would smear us here, and here, and here.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 39,
      "text": "We moved on, then they cut our hair.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 40,
      "text": "And the guy who cut the hair-- I thought was a Ukrainian.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 41,
      "text": "That's the way he looked to me.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 42,
      "text": "He was sitting in this chair and didn't say a word.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 43,
      "text": "He was a prisoner, a Ukrainian prisoner.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 44,
      "text": "Not one word.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 45,
      "text": "But he took a hit over the head for you to kneel down.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 46,
      "text": "And he cut a swath alongside, a vertical swath so you are recognized.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 47,
      "text": "Shaved it off, you know, and rest of the hair was cut short, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 48,
      "text": "And so then they shoved us in to take showers.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 49,
      "text": "And then they put us in a room.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 50,
      "text": "We were sitting on our rears, and we had to spread our knees.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 51,
      "text": "And the next guy into you, and the next guy into you.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 52,
      "text": "And that guy stood there with a whip to squeeze in, squeeze in.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 53,
      "text": "I thought I cannot survive this.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 54,
      "text": "I mean, my knees were hurting.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 55,
      "text": "My hips were hurting.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 56,
      "text": "I could not-- it was awful.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 57,
      "text": "There was no air.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 58,
      "text": "Finally, someone opened a window.",
      "word_count": 5
    }
  ],
