{
  "stem": "15900.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "I played soccer.",
      "word_count": 3
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "In soccer you have to play as a child.",
      "word_count": 9
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "You cannot play when you're older.",
      "word_count": 6
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 4,
      "text": "After I was recuperating and everything, I start to play.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 5,
      "text": "And when-- when you get to 30 years old, 35, you can't still play.",
      "word_count": 14
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 6,
      "text": "Here they play longer.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 7,
      "text": "But you have to learn from a child.",
      "word_count": 8
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was interest in playing.",
      "word_count": 6
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Ha-Po'el-- first we had a working organization, people who work called-- later on, when I went in Warsaw, I joined the Ha-Po'el.",
      "word_count": 22
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "And I played.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "I played.",
      "word_count": 2
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they-- they were all students, and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "I used to go ice skating, and this, and running.",
      "word_count": 10
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "We were going together to dancing, and like young people.",
      "word_count": 10
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 1,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 2,
      "text": "All the Jewish holidays and everything, we used to celebrate very big.",
      "word_count": 12
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 3,
      "text": "It's not like here.",
      "word_count": 4
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 4,
      "text": "Our Passover was a week.",
      "word_count": 5
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 5,
      "text": "Rosh Hashanah was a week, and Yom Kippur.",
      "word_count": 8
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 6,
      "text": "[NON-ENGLISH] was-- and family was very happy there.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "I used to sing a lot of songs.",
      "word_count": 8
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "But who remembers?",
      "word_count": 3
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "I almost went to Israel by bicycle before the war.",
      "word_count": 10
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my father was-- tried to kill me.",
      "word_count": 8
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 1,
      "text": "They all-- all my friends went by bicycles.",
      "word_count": 8
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 2,
      "text": "And they could not go through, you see, Russia would not let him go through Russia.",
      "word_count": 16
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 3,
      "text": "Russia at the border, you can't go through.",
      "word_count": 8
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 4,
      "text": "And they-- they took a boat.",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 5,
      "text": "And they went-- to-- to-- to the-- later on-- they all went.",
      "word_count": 12
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 6,
      "text": "I met them after the war.",
      "word_count": 6
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "My friends-- my friends organized Zionists a trip by bicycle to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "To go to there, and they remained there.",
      "word_count": 8
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "They were very-- very for Israel-- they were--",
      "word_count": 8
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "And my father would not let me.",
      "word_count": 7
    }
  ],
