{
  "stem": "5228.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Edith Danko.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "E-D-E-I-T-H Danko-- D-A-N-K-O.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name maid is Hershowitz.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I think so.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "H-E-R-S-T-K-O-T-Z. ?] Hershkowitz.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My birth date is 1922, October 10.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm 53-- 73.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Seleszcze. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "S-E-L-E-S-Z-C-Z-E. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "In Czechoslovakia.",
      "word_count": 2
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I was brought up, it was eight children in the house, four boys and four girls.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My parents was now young, both of them.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "It was very religious in house.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I couldn't take a brush on Sabbath-- on Saturday-- to brush my hair.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "My father wouldn't let me do this.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And I just agreed with him.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "It's for Shabbas.",
      "word_count": 3
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And we was all [? in ?] just [? guard ?] [? of ?] two brothers.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "They was in school.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "One brother was in gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 11,
      "text": "The other was just learning, like, I don't know, like a shoemaker.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 12,
      "text": "And my oldest sister was married.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 13,
      "text": "She got already four children.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And then between this was my father in the war.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "This was now before the first war, in 1916 or 1917, in the war.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my father-- I mean, they married both very young.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My mother was 16, my father was 17 when they married.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And then they got three children.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And then my father was in the war, the first war, 19-- I think 1916 or the '17.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "He was young.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "My mother was home with the children.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "And then, once he was there, stay in the night.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "And somebody come and told him, he said, you are [? not ?] young.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "You go home and lay down and sleep.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "And I will stay.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "I will take your-- your place.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "So my father went up a few steps, and then he hear a shot.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And he run back, and the man was dead.",
      "word_count": 9
    }
  ],
