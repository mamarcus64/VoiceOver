{
  "stem": "23730.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "A Polish prisoner sneaked over to us because he was asking for our watches.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Because he knew we are going to lose everything.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And a kapo got hold of him and killed him there on the spot, in front of me.",
      "word_count": 18
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "In front of me, just down there, killed him, there and then.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "Imagine the welcome to Auschwitz?",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Where you arrived in a world of evilness, beyond any description.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "The kapo, very often, were people released from prisons, remember.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Criminals who were-- got free hand from the Germans.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Here, you're in charge.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "Imagine that?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Criminals-- to put criminals in charge of decent, normal, lovely people, wonderful people.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "Imagine that?",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And certainly there were people who were made into kapos, because they proved to be the type.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "You have to be the type, for survival you did anything to survive.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "For another plate of soup, you did anything.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "Eventually they were picked out.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And these were the people who were more-- more-- more beasts than people.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 11,
      "text": "Worse than the Germans, to impress.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Polish and Jewish, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Because he was not allowed to make any contact with the new prisoners, with the new group of prisoners.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "He was not allowed.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "It was like nothing for him, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "It was absolutely the most natural thing that he killed him there, nothing.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And I remember, he got hold of his, whatever it was, his jacket, pulled him away.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "Bang.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "That's it, finished.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No!",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Killed him.",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Hacked him to death, there in front of me.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I mean, we didn't eat a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "These people, they're already there for years, remember.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And they were not the strongest, fittest anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "So they didn't eat a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "But he hacked him to death there in front of me.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "In front of me.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "We were all looking, looking on.",
      "word_count": 6
    }
  ],
