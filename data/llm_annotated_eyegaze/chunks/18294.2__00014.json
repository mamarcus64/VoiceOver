  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "She's the one in Israel, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Once I remember, they used to come.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Somebody come from Estonia, to our lager, to our concentration camp.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And he said, what-- he come up to me and ask me, who are you?",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I said, I'm Drabkin.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "You Drabkin?",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "I saw your-- I saw your husband, the father, the father with the five brothers.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "This was the first time what I hear something about him.",
      "word_count": 11
    }
  ],
