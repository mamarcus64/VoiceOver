{
  "stem": "9908.2",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "There were maybe 10 radios in the whole city-- no cars-- only one taxi.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "There was no hospital in Ozorkow.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "When you took sick, you go to Leczyca, or you go to Lodz.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Lodz had a big hospital.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "[DRINKS] Mostly maternity women went to have their children in Lodz, in hospital, because in-- in our, you know, city a lot, a lot of women died at childbirth-- a lot, a lot.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "They-- there was-- there were a Jewish store.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father had a tallis-- a big tallis.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He had the [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And my brothers didn't live to the day.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "My youngest little brother was taken away when he was eight years old.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "He didn't have a tallis, yet.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And this one-- the one is-- was 12 years old-- the one who's alive-- he didn't live long enough to have the-- we didn't live long enough in Poland that's my brother had a bar mitzvah.",
      "word_count": 36
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "Because when the war broke out, he was 12 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "And thank God I have this brother.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "There wasn't any bar mitzvah.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He was 12 years old when [NON-ENGLISH]-- after that, he was in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Not as fancy as you do in here.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Mostly you went to shul.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "You made the kiddush, you know, a bracha.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And the boy read the-- the-- and that's it.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "You didn't make parties, weddings.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Weddings, yes, this was a big event.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "But there were dances.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Every Shabbos night we went to dances.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "And we enjoy like-- I can see my parents.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "We didn't-- we didn't hear as much.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Who read Hitler's knew what's going-- when he wrote this in-- in jail, in Austria.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "You know this-- the book Who read this book knew what's going to happen to the Yidden.",
      "word_count": 17
    }
  ],
