{
  "stem": "2353.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My father had, together with another brother and two cousins, a factory that dealt with anything that had to do with hair.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "He-- they, they bought hair from Italy and China and brought it in and prepared it, cleaned it, dyed it.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And part of it was sent back to China to make hairnets out of them.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And they made the toupees, and they made false beards.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And they made theater wigs.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Some of them even found their way into the Metropolitan Opera here in New York.",
      "word_count": 15
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "So it was a very good business.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "He had about 120 employees, which was pretty good size for a small town like this, and life was good.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She-- it wasn't-- I don't think at that time women worked.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I know my aunt did volunteer work, but my mother didn't.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And she was just, just a-- you know, taking care of us and that was it.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, it started in 1933, really.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "But I had very good friends of whom I knew that they were members of the Nazi party since 1928, and she was one of my best friends.",
      "word_count": 28
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "She didn't care that I was Jewish, and I didn't care that she was a Nazi.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "She was one of my sports friends, and we got along very well.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "But then, of course, in 1933, everything changed, like overnight.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "You could not go into a public place-- no restaurants, no swimming pools, no movies, nothing.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "You couldn't-- you, you were not allowed in any public place anymore.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "And people that you knew wouldn't talk to you anymore.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "Friends that you had, they would shun you, most of them.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Not because they hated us all of a sudden, but they were all afraid because that was-- that was the way it was.",
      "word_count": 23
    }
  ],
