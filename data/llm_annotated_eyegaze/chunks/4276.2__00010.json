{
  "stem": "4276.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "And this was also-- their daughter worked with me when we had to go out from out from ghetto into the workplace.",
      "word_count": 22
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And they had the hole in the back of the bed.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And this was like a little space there, OK?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And they putted a carpet or, or something over the hole.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And then it was-- the bed was against that.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "And then another lady walked in, whom I know because we also worked together.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "So we sat together.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "Now, one day, my uncle walked in.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 10,
      "text": "And he says, that's enough.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 11,
      "text": "At 6:00, be ready tomorrow morning.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 12,
      "text": "I'm taking you out of the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 13,
      "text": "And [?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 14,
      "text": "Renna ?] will go with you.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 15,
      "text": "That's my cousin.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 16,
      "text": "I think I showed you the picture there.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 17,
      "text": "And that's how we got out.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 18,
      "text": "And we went with our aunt.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 19,
      "text": "It was maybe an hour of walk from Krakow.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 20,
      "text": "She was in a village there, the woman that took us.",
      "word_count": 11
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 21,
      "text": "She was also a maid for my aunt for about 10 or 15 years.",
      "word_count": 14
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I will write it for you.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "This was-- oh, why it was.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Because my uncle heard it will be judenrein.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "You know what is judenrein?",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "All the Jews will be taken out.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "So he was scared.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And by the way, when I ran away-- you know, I am jumping.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "Because I didn't write it, so it comes to my mind this way.",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "There were-- in the same week, there were four or five girls that ran away from Plaszow, one way or the other.",
      "word_count": 22
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "And one mother-- there, there was, of course, they were looking still in ghetto for, for them.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And one of the girls' mother was taken.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 10,
      "text": "And then was another girl taken.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "They found her.",
      "word_count": 3
    }
  ],
