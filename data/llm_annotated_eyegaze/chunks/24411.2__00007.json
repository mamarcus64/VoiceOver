{
  "stem": "24411.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "But they came out the same thing what we do.",
      "word_count": 10
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know anything.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't speak to them.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "We didn't understand when they  were talking, but there was translation.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And we said, OK, we want to go home.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "This was before.",
      "word_count": 3
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Then they took us out at night.",
      "word_count": 7
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "I don't know what.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Well, they came in the middle of the night, that's true.",
      "word_count": 11
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "And they took us out.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "And they put us on the trains.",
      "word_count": 7
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "This was already, who didn't want to take the citizen papers.",
      "word_count": 11
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "First they ask, and we didn't take the papers.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "So they took us to the-- on the-- on the buses, like, you know, on the trucks.",
      "word_count": 17
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "And they took us to the station, to the trains.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And I don't-- I didn't know where my husband went.",
      "word_count": 10
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "And they put us in, hundreds of people, on these cattle trains, and they didn't let us out.",
      "word_count": 18
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 6,
      "text": "This was it.",
      "word_count": 3
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "I didn't see him.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 2,
      "text": "They took us out.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 3,
      "text": "They took him in room  one, and they took me in the other room.",
      "word_count": 14
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 4,
      "text": "And this was-- people when they had children, they went together.",
      "word_count": 11
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 5,
      "text": "Without children, it was separate.",
      "word_count": 5
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 0,
      "text": "They said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 1,
      "text": "We'll send you back.",
      "word_count": 4
    },
    {
      "segment_idx": 95,
      "sentence_idx_in_seg": 2,
      "text": "They did say, we're sending all of you people back to the Germans, to your parents.",
      "word_count": 16
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 0,
      "text": "No, they took us already to the train.",
      "word_count": 8
    },
    {
      "segment_idx": 96,
      "sentence_idx_in_seg": 1,
      "text": "They said, when you're taken out, you should-- we should-- we're going to send us back to Poland.",
      "word_count": 18
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 0,
      "text": "That's the same night they sent us away, you know, to Siberia.",
      "word_count": 12
    },
    {
      "segment_idx": 97,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where we were going.",
      "word_count": 7
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 1,
      "text": "Just whatever you were wearing.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I was wearing, like, it was hot, warm.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "And I had a dress.",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "I had shoes.",
      "word_count": 3
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "No stockings.",
      "word_count": 2
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 4,
      "text": "And that's it.",
      "word_count": 3
    }
  ],
