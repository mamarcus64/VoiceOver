  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "And I had a Yiddish speech prepared, and gave, and tried to sell war bonds.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "So the synagogue also was a place where I learned Yiddish, from this Cantor Matlans, a wonderful man.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "He was the original Mr.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "Five by Five.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "Between him and Rabbi Silverstein, the place was jumping all the time.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "And they were-- they were human.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "If you come to services Shabbos morning, they gave you tickets to movies in the afternoon, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "If you didn't come to services Shabbos morning, you got no tickets for the movies in the afternoon.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "Sundays were Sunday school, and then weekdays Hebrew school.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "And it was just a home, really a home for me.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "It's called the 9th Street Temple.",
      "word_count": 6
    }
  ],
