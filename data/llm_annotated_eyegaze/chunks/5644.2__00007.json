{
  "stem": "5644.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 3,
      "text": "I want to be in an organization which is strictly Jewish, because Adolf didn't-- said that he's a socialist or he's a communist or he's-- Jews are Jews for him.",
      "word_count": 30
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 4,
      "text": "And I told myself that's to turn is to go to the most radical organization which I can think of.",
      "word_count": 20
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 5,
      "text": "The radical organization.",
      "word_count": 3
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 6,
      "text": "I did it with knowing what I-- I think--",
      "word_count": 9
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "I selected to go and try to be.",
      "word_count": 8
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 1,
      "text": "Now, the easy part of it was that I knew even Christians, the ones which helped to organize the Jewish organization.",
      "word_count": 21
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 2,
      "text": "That was the man which was very well known in the organization, in the Jewish organization, which helped him.",
      "word_count": 19
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Bystry.",
      "word_count": 1
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "Bystry, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "That was his code name.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "I did, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "I give you in a second his real name.",
      "word_count": 9
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 3,
      "text": "I'm very-- this is 50 years.",
      "word_count": 6
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 4,
      "text": "You ask me after 50 years.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "That's a very--",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "He was very friendly to us, very friendly.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "His name was Iwanska.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "'I-W-A-N-S-K-I.' Iwanska.",
      "word_count": 2
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "And the code name was-- Captain, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "He was a captain.",
      "word_count": 4
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "He was with many Jews before the war in the army and the officers, cadets.",
      "word_count": 15
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "And he was actually in the Polish army whilst he was helping--",
      "word_count": 12
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Underground.",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "The start of-- by start of with a-- with a different name in the organization, the Polish organization.",
      "word_count": 18
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 2,
      "text": "And then I changed, I went and I joined the AK.",
      "word_count": 11
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "The home army.",
      "word_count": 3
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Now, the one which was the most important person was Appelbaum-- Appel-boym.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "That was the most important person which got a contact with Iwanska.",
      "word_count": 12
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 2,
      "text": "In 1939 in October, he went already to him.",
      "word_count": 9
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "He went to-- he seen the Iwanska, and he start to ask him for to help us to try-- the boys for the ZZW.",
      "word_count": 24
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 2,
      "text": "At '39 already.",
      "word_count": 3
    }
  ],
