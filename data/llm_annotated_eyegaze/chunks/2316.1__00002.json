{
  "stem": "2316.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And then my younger brother and I and my parents survived.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "My mother-- my mother had a very nice life.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "She was-- they considered her the society lady in the shtetl.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She was involved in [NON-ENGLISH] and she was involved in Jewish organizationals.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And she would write someplace.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And she always was very, very well groomed.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "And she was really very, very beautiful.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And she took a great deal of pride in how she presented herself to-- to the people in the shtetl.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And she never worked because my father really provided well for her.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "And it was-- she didn't have to.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "And it wasn't just fashionable, we don't-- I don't remember women working when I was a little girl at all.",
      "word_count": 20
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "I don't remember one person in the shtetl working, as far as women are concerned, unless their husbands had a business and they helped him out.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "Otherwise, I don't know of any women that worked, that I remember.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 12,
      "text": "And [PAUSES FOR 3 SECONDS] she kept a very, very busy life.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 13,
      "text": "And it was very nice.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 14,
      "text": "It was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 15,
      "text": "My father worked in the business.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 16,
      "text": "And I loved my dad.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 17,
      "text": "And I used to go on the way to school we'd go together.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 18,
      "text": "And he'd go to the shop and I'd continue to school and stop at the bakery on the way and buy a [NON-ENGLISH], charge it to my father.",
      "word_count": 28
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 19,
      "text": "[LAUGHS] And it was wonderful.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 20,
      "text": "It was really great.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 21,
      "text": "They had a-- they had a pretty decent life until the war started.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I came from an Orthodox family, Modern Orthodox.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Most of the people in our shtetl were Orthodox.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We didn't have any Reformed or Conservative.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "You were either an Orthodox or you were a goy, they called you.",
      "word_count": 13
    }
  ],
