  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And she knew what's happening to her.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "You don't come back.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "I mean anything, but that is beyond forgiveness.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "That is that the helpless little souls, Innocent like what?",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And nobody could help them, nobody.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "There was [?",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "Mashinka ?] in our-- in our camp in the beginning, a little boy from Vilna with his mom.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And those Vilna girls were absolutely great.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "They stuck together, and they helped each other.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "They were loyal.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "They were courageous.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "They were a real fabulous lot.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And this-- the mother was young, had long hair.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And she-- and they used to hide [?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Mashinka. ?] When they were looking for kids, they used to give him something to drink and hide him, and lift up something under the floors and [?",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Mashinka. ?] And one day they got [?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Mashinka. ?] They got him.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "He was a-- I mean, everybody played with him.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "He was the doll.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "One day they got [?",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "Mashinka, ?] and they got him.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And they tried-- the girls tried very much to save the mother.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "She was screaming.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "So all the-- well, she was exactly opposite my bunk.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "I was sitting on my bunk and see the whole scenario.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "She was screaming.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "[DRINKS]",
      "word_count": 1
    }
  ],
