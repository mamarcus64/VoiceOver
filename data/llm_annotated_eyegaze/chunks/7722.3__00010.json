  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed over there.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And when he-- when I met this doctor, I asked him, and he-- and he brought his friends, a colonel.",
      "word_count": 20
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "And he took us, and-- and with my-- with my friend, and he-- and he took us by-- with a truck.",
      "word_count": 21
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And he brought us to Berlin.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "In Berlin, they were three zones-- English zone, American, and the-- and the Soviet Union.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And over there was the first DP camp.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "They called it Schlactensse.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "S-C-H-L-A-C-H-T-E-N-S-S-E.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And over there was the first DP camp where the Joint also was over there active.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "This was on the American zone.",
      "word_count": 6
    }
  ],
