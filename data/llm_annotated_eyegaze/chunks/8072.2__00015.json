  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "I broke out one time in a-- with a rash all over me.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have anything to-- to-- to clean it or everything.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "There was no medication or nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "I don't know for how many days it lasted.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "But somehow it cleared up, and I-- and I survived.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "One day I had under my arm-- I had a big boil.",
      "word_count": 12
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "And I went to the dispensary, and they looked at it.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "And they said, well, come back tomorrow and we'll-- we'll drain it or something like that.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "So I went back the next day, and I'll tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
