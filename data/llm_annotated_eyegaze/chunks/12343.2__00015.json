  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "They [INAUDIBLE] because they did-- did something.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "One time they took me-- they took us every Sunday from [INAUDIBLE] to [INAUDIBLE].",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "They take a bet over there because they [INAUDIBLE] it was nothing, except they take [? the worker. ?]",
      "word_count": 19
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "I was a tailor, but I need thread.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I need something to work.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I got a little needle.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And also I got a little scissors, nail scissors.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "That's what I use, all.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "What I do with thread?",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "They have cases of it, that they used to be packed, the ammunition.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "The handles looks like thread.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "They cut it off, and this is sabotage.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "You know what I mean sabotage?",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "I know in English it's sabotage.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "I bought this.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "I don't cut it.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 13,
      "text": "I bought it for something else.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 14,
      "text": "Then they knew, and cut it.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 15,
      "text": "Then before-- before, we have to go back to [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 16,
      "text": "They-- they check everybody, and my heart was like this, pumped like this.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 17,
      "text": "I was afraid because I was-- it hiding places, and they cannot find me.",
      "word_count": 14
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 18,
      "text": "And I was lucky.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 19,
      "text": "I passed the test.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 20,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 21,
      "text": "[INAUDIBLE] came right [? of ?] the place, right [? on ?] place.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 22,
      "text": "I did it.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 23,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 24,
      "text": "For life.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 25,
      "text": "I fight for life to be alive.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 26,
      "text": "That's over.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 27,
      "text": "Oh, it's over.",
      "word_count": 3
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 28,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 29,
      "text": "We're gonna stop now, and we'll change the tape.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 30,
      "text": "And we'll start again.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
