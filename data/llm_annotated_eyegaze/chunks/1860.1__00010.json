  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "And we started working for my cousins, this Abram Banker, who was the owner of the enamelware factory.",
      "word_count": 18
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "And we were coming out of-- coming out from Plaszow every day, marching five in a row.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "That was my mother, I, my aunt, cousin, and my grandma.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] And we were [PAUSES FOR 3 SECONDS] coming in the morning-- going out in the morning, coming in the evening.",
      "word_count": 24
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "After a while, I think it was in March [PAUSES FOR 3 SECONDS] '43-- [PAUSES FOR 3 SECONDS] by the way, the factory was taken over by Oskar Schindler, like every Jewish business was taken over by-- by a German [PAUSES FOR 3 SECONDS] so-called [NON-ENGLISH], who was in charge of the factory.",
      "word_count": 53
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "And Oskar Schindler was assigned to take this enamelware factory.",
      "word_count": 10
    }
  ],
