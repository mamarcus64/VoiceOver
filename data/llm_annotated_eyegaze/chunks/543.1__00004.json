{
  "stem": "543.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They make plays, they make-- played cards, they, you know, and they talked and they made coffee.",
      "word_count": 17
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "There was a little coffee shop there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And I really always, always came there.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "I was really very much involved in the deaf-- deaf society.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Though we could hear, but we still-- for me, it didn't make any difference.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I was-- like a little thing.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "I was very talkative when I was young, very talkative.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "Talked a blue streak.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "So my mother went to me in the streetcar, and used to say to me, well, you know, if you talk always on your hands, everybody stares, stares at you what you're doing.",
      "word_count": 33
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "And then my mother used to say to me before to me say, listen-- they called me [?",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Bepi ?].",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "I'm Elizabeth.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "She said, I don't want you to talk to me when we go in the streetcar.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "We go out of the streetcar, you talk to me again.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "In the streetcar, you're quiet.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Well, I only talked with my mother on my hands and big, you know, big signs and things like this.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And everybody was staring.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So my mother said, don't talk.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I-- I-- was no sooner than a minute in the streetcar, I forgot all about it.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know the reason why I couldn't talk to my mother, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And then my mother said, shh, shh, you know, don't talk.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "But I did not listen.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "For me, it was so normal.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "It was a natural way of life.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "A natural way-- and I did that, I did-- still talk to her, and then we came out of the streetcar, everybody would say to my mother, who is deaf, you or the child?",
      "word_count": 34
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And my mother used to say, no.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "It's me.",
      "word_count": 2
    }
  ],
