{
  "stem": "5430.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "So I went into public school, which was-- I believe it was on Leszno Street.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "I'm not sure, but it wasn't too far.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And I stayed in public school until the war, in other words in 1939, September 1, which was the invasion of Poland by the Germans.",
      "word_count": 25
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "My father's name was Sender, S-E-N-D-E-R, Sender Borenstein.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And my mother's name was Chava, C-H-A-V-A Borenstein nee Minkendorf, M-I-N-K-E-N-D-O-R-F.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And we had family of four brothers and one sister.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "Well, there was another sister, but she died as an early-- at an early age, long before I was born.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Sheindel.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Well, my oldest brother, George, is Rachmiel Zurich-- in English, they took on the name George-- followed by Sheindel, and then was brother Sam.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And I had a brother Jacob, who later perished in the Holocaust, and my sister Faigele, Felice now, and then myself.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My parents had a cafe in Warsaw on Leszno Street.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "We were consided above-- about middle, as far as affluence is concerned, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "My father was always referred to as the rich Uncle Sender from the family who used to live either in the suburbs of Warsaw in the small shtetls.",
      "word_count": 28
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And my father was born in Mogelnica, which is just a small town outside of Warsaw.",
      "word_count": 16
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "How do you spell it?",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "You spell it M-O-G-E-L-N-I-C-A, Mogelnica.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And, and so he had relatives there also.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And whenever they came to Warsaw, they would come to us, and we were the, like I say, the, the richer part of the family.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "The restaurant-- Sender's Kawiarnia.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Kawiarnia is the Polish version of cafe.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It's-- we had a regular restaurant, no liquor license, I remember.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "The-- we were-- and Leszno, where we lived, was more of a Polish neighborhood.",
      "word_count": 14
    }
  ],
