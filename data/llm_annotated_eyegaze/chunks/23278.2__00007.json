{
  "stem": "23278.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "Because we couldn't get gas.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "All the gas station were burning.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "All the houses were burning.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Everything was burning.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "So we had that jerrycan, which didn't burst, which didn't burn anything, but broke my head.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "So I had a fractured skull.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And I had to end up in the hospital.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And I woke up several days later.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "My sister telling me the Germans are here.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And they are sewing patches on the seat of their pants on sewing machine on the public square.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And I said, what kind of crazy story is that?",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And I was all bundled with things.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And they put me-- the sisters were horrible.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "They cut my nails.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "I couldn't even-- I had long braids.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "They wanted to cut my hair.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "But they didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "I fought, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "And they put me on a wheelchair with all my bandages, because I spoke German.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "And I was wheeled all around with the German commandants to explain what the hospital was and blah blah.",
      "word_count": 19
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Then I went back to Dijon eventually.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "My father, my mother, and my sister, we went back.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We recovered our apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And then I had to go take my exam with my crutches and my head all-- I looked like an Easter egg.",
      "word_count": 22
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "But I passed the exam very well.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And maybe they had pity on me or something.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they were in German all the way to the end.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The flags, the red flags, the-- you know, the swastika was flying, even so low it just swept our faces.",
      "word_count": 20
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And the Germans were all over.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "But I have to say what you hear many French people say.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "They were perfect.",
      "word_count": 3
    }
  ],
