  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "They gave a ruble or two [? or whatsoever ?] because that was the currency there until we got Deutsch Marks.",
      "word_count": 21
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "And this helped us a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 7,
      "text": "Here and there were some people who got a chicken or something to use to slaughter it.",
      "word_count": 17
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 8,
      "text": "And here and there he did some physical work.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 9,
      "text": "But only what he wanted, because people who were religious, in religious functions like rabbis and slaughterers, were-- did not have to work mandatory work.",
      "word_count": 25
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "Not only this-- I kept the payot all the time.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "It was interesting as a personal anecdote that only after I came back from-- from-- from Transnistria, and we went to Czernowitz, I decided I was ready that time-- about 18 years old, or something like this, I decided that I want to take off my payot.",
      "word_count": 47
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And I did it, and I came home for lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And nobody said a word to me, neither my mother, nor my father.",
      "word_count": 13
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "They accepted it, probably as a sign of progress.",
      "word_count": 9
    }
  ],
