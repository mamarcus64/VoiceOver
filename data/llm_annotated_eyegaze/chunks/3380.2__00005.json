{
  "stem": "3380.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "This was the living room, dining room, kitchen, and all the facilities.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "We were one next to the other.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "We were packed in next to the others.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "There were no bunks, nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "On the floor.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "They organized who should be the Lagerfuhrer, who should be the leader.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "They separated people to work.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "Those people remained at the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "They didn't go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "That was like the Lagerfuhrer, they used to call it-- Blockalteste.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "We had some from our own people that worked in the kitchens and in the yards in the camp.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "That caused friction because some of them-- the Jewish people who had come earlier, they had the best positions.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "So they gave the best positions to their own.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And we remained, actually, the last ones.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We had the worst.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We had to take whatever they gave us.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "We worked on the railroad for the railroad company.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Absolutely nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "No medical facilities at all.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Every so often they used to take-- they come in.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "They used to make selections.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "Whoever was not fit to work, they just took them away.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And we know that they killed them all.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "They used to clean up lots of camps.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "They didn't just went to our camp.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "They took transports and they shipped them away.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "Some of them were shot right on the spot.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And some of them they just shipped them to Chelmno.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "We know that that's where they're going.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Oh we knew it.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "We knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They didn't try to keep it a secret.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And we were aware of it.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "We were aware of the full extent.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Naturally, we did not know that the Final Solution was issued at the Wannsee Conference.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "We did not know.",
      "word_count": 4
    }
  ],
