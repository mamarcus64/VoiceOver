  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "We were there like the animals, without food, without drinking, without nothing.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "How long took this traveling?",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "Maybe two days.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And I cannot remember exactly how I came to the [INAUDIBLE] prison, because I knew that this water, and on this island.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I-- maybe it was night.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "We came by rail, then by ship night, and therefore, I remember only I was in the cell only also one man cell.",
      "word_count": 23
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "Just a little, maybe second floor or third floor.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And my job was there as a [GERMAN].",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I have to-- I had never with pigs to do.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "But I think-- I thought maybe it will be very good job, because I have to feed the pigs.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "There will be something will be for me too.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "But it was not true.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "They gave only, you know the skins of potatoes, because near of our prison there was also mess for the Wachtmeister.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And they ate completely different lunch and dinners like me.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "And only they gave me the skins of potatoes.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "I had to boil it for the pigs.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I used sometimes I boiled it.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "And to boil it-- I never-- I took to my soup to make the soup so thick, thick, that I will sometimes I felt even stones, [POLISH].",
      "word_count": 27
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "I felt when I had this.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "And so when the-- it was a little-- I never forget even the from France, the prison, they picked this grass.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "A kind of grass.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "I don't-- Later it's a yellow flower on this.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "And they ate this.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "They told me, eat also.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 21,
      "text": "This is vitamins.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 22,
      "text": "It's very good to [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 23,
      "text": "After the war, I tried, but it's bitter [? food ?] for me.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 24,
      "text": "I remember the food that I ate in this.",
      "word_count": 9
    }
