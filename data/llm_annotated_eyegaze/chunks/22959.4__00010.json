  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Like for instance, when we came to Austria, to Bad Gastein, our aim was to go to Israel.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We were dreaming about moving to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We counted how many borders were left to cross.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "But when we were in Bad Gastein, we made contact with our relatives in America.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "How did we make the contact?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "The American soldiers helped us.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We gave our letters to them.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "They sent our letters to their relatives.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And their relatives sent the letters to our relatives in America.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "Once our relatives in America found out that we are the only survivors with beautiful families, they started to bombard us with letters to come to America.",
      "word_count": 27
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "We felt, OK, we'll come for a little bit, and then we'll go to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "But we came to America, we raised a beautiful family, built up a business, and we stayed there.",
      "word_count": 18
    }
  ],
