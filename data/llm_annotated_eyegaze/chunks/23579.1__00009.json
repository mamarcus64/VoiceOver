  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "So when they began to build in his name many things.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "They got [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "What is [NON-ENGLISH]?",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "All Pole.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Poland was divided now [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "The biggest cities was [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "The smaller [INAUDIBLE] was not the [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Because Mickiewicz was born in Novogrudok, they gave it to Novogrudok the [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 9,
      "text": "So then the Polish people began to come in to Novogrudok.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 10,
      "text": "They begin big offices.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "How big a population did Novogrudok have?",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "I think about 15,000, 18,000 people, no more.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "But this was enough.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "I think about 8,000.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "You see, our city had many Jews, and they were very rich.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "I had a friend, Zaria, which she's now in Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "They had [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "You know what is [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "From the tree they were making for building the [NON-ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Lumber yard, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Lumber yard.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And they were very rich.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They were about four brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And they had children.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And they were very, very, rich.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "There was another family, [?",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "Broido. ?] They were too very, very rich.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "They were making from the corn, they were making flours.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "And they were giving a lot to the Polish [NON-ENGLISH], I mean to the Polish-- for the-- like you see in our organization, yes?",
      "word_count": 24
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "So for the Polish people.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "So they didn't fight the Jew, the big ones.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 6,
      "text": "But we had many Jewish people what they were very, very poor.",
      "word_count": 12
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 7,
      "text": "So we had for them, the old people, we had places for where they took the old people there.",
      "word_count": 19
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 8,
      "text": "And everybody was giving them bread, and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 9,
      "text": "They called this like old age, old ages.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "And the rich one, they were holding onto them.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "They giving them everything.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "But mostly, we cannot talk about this 5%, or the 3% they were very rich.",
      "word_count": 15
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Rest of them, they were very, very poor.",
      "word_count": 8
    }
