{
  "stem": "268.8",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "And she says, you know, they said, I think maybe it's your brother or your cousin because my brother was named Max.",
      "word_count": 22
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "And I had my cousins.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "And I also had a cousin on my father's side, also-- from my father's family.",
      "word_count": 15
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "And his name was also Max and the same last name.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And she says, I believe Max-- one of the Maxes is alive, but I don't know which one.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And I was asking, which one is it-- the heavy guy?",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "The chubby?",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Max, my brother, was chubby when he was a kid.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "He says, I think so.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "But he says, he wasn't chubby this time.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "So I still didn't know.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So I figured, I'll go to the innkeeper my father was friendly with and my folks.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "So I went into the market square.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "I went to the innkeeper.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "And I thought, I'll ask him because during the war, we would have contact with him.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "He would bring food to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "We would buy some food from him and trade off some gold rings or whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And I figured this would be a good place to get information.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "I'm walking into the inn.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And a typical Polish inn-- two, three guys standing at the bar, smoke filled.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "And some guys are sitting there drinking beer or sodas or whatever.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And they're talking loud and all that.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And the bartender-- his name was-- I still remember his name, until recently; it'll come to me-- stays there and wipes off some glasses and puts some beer in.",
      "word_count": 29
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "He was facing the door.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "And there's two or three guys standing with their backs towards the door, facing the bartender.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "And I hear him say something like, no, no, I didn't see him.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "I don't know.",
      "word_count": 3
    }
  ],
