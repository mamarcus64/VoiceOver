{
  "stem": "2581.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "A relative, my grandmother's brother, was shot, and the son of-- of my grandmother's brother, when the-- when they walked over to the German, he says, don't you keep pushing my grand-- my father.",
      "word_count": 34
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "He says, if you say another word, I'm going to shoot him.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "He says, you're not going to shoot my father.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "You are going to shoot me.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "And he stood in front of his father.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "And he was shot.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "He shot him, and he shot his grand-- his grandfather, his father.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And at that time, my grandmother was shot.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "And 6-- like I said before, 65 people were killed on the way to the church.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "We stayed for three days in the church.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The entire town was in the church except those that were killed.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "The entire town was in that Catholic church.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We had to go in through a very narrow entrance, not through the main entrance where they open the gates, but a side entrance.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "They were standing there-- excuse me.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "They were standing there with those police sticks and the-- and the butts of the guns of the rifles, and were hitting everyone who walked in because you could only go through one or two at a time.",
      "word_count": 38
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "Inside, without having any facilities-- hygienic facilities.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] We spent three days without any food.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Thank god we had no food, so at least it kept people a little bit cleaner.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "I remember in that church, the rabbi performed a wedding.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] We prayed in the syn-- the church.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And I asked my father how can we pray in a Catholic church?",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "The crosses are all over.",
      "word_count": 5
    }
  ],
