  "elapsed_s": 9.4,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "And that was the only reason I was keep going in.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 20,
      "text": "And one day coming home on a streetcar, came to a very big crossroad, and the streetcar stopped.",
      "word_count": 18
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 21,
      "text": "And I saw a big commotion on the road, and I looked out.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 22,
      "text": "The window was open, and I heard screaming and yelling.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 23,
      "text": "And it happened to be a gang of people beating an old man.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 24,
      "text": "And I was keep watching, and I realize, I knows that-- I know that man.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 25,
      "text": "He turned out to be a little, old Holocaust survivor.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 26,
      "text": "And I heard ugly anti-Semitic remark.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 27,
      "text": "And this man was bloody, and they were still beating him.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 28,
      "text": "And I got just so angry.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 29,
      "text": "I went home.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 30,
      "text": "I picked up my four-year-old son, and I said, the hell with this country!",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 31,
      "text": "I am going.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 32,
      "text": "And that what made up my mind to leave the country.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "It was in November, 1956.",
      "word_count": 5
    }
  ],
