{
  "stem": "131.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But it was a long way-- I think, two days to go there.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We had to go in that Jeep.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And then I came to Belzenberg, what it was a-- horses were there.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "It was a-- I can't say it in English.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "What it was-- a stable with horses!",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And it was clean, the whole yard there.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "And I met some people there from my hometown.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And I said to them, where is my sister?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Yes, she's here.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "She's alive.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And I bent down.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I was walking between half-dead people and dead people, because they were just laying.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Most of them got food and got cholera.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "Sick, they were very sick.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I was walking between them and tried to pick up the faces to see which is my sister.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And that's when I find my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "And that chaplain took me back to [?",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "Kaunitz, ?] where I was.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And my sister was 80 pounds, skin and bone.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "And when she touched me I was afraid from her.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "I said to her, please, Hannah, don't touch me.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "Don't touch me.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "I was afraid from her.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "She looked like somebody would come out from the grave.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "Not human at all.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I was so afraid of her.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And when we went back, the chaplain took me back to the farm there.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "All the way that he took us back, my sister was so sick-- throwing up and making BM.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "And the chaplain cleaned her up-- everything, I'm telling you.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "I just looked at her.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "And when we came back to the farmhouse there, one day I went out and I stole a chicken.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "But I couldn't kill the chicken.",
      "word_count": 6
    }
  ],
