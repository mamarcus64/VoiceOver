{
  "stem": "10397.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 23,
      "text": "And 20% of what I  make, I'll pay your rent-- not rent, just 20% from the profit.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "She said, sure.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "There was complete office arranged with all the instruments.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "There was a waiting room.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "There was  a couch.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "There was all things-- everything-- examining tables, syringes, everything that a doctor needs.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "OK, I'll give you-- give me-- I'll give you-- she didn't ask for anything-- no-- no contract or anything.",
      "word_count": 19
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "She gave me a key to the office.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "It had a separate entrance.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "I took the key, locked the office, and I started-- I'm going to start office hours tomorrow.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "I came home.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And I told my mother and father I'm a doctor.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "I have an office.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Mazel tov, mazel tov, mazel tov!",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "All right,  next day, I come in there.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "There is another lock on the office.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So I said, what happened?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So I say, two officers came, broke off the lock, put their own lock.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And they said it's-- we are requisitioning the office to sleep-- to live there because there was a couch, and chairs, and blankets.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "One slept on the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "One slept on the-- on the-- on the examining couch.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "What kind of officers were they?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Russian officers.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "So my career is end-- end of my career to practice medicine.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I was bitter.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So I go out to the Communist-- to the party office, which is the secretary of the party in Russia is the-- the supreme being over-- above the city manager, above everybody.",
      "word_count": 32
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I come in to him, to the secretary-- to the Communist party office.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And I say, I want to talk to the secretary.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "The secretary is like God in the-- in the-- in the district.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "And he's a-- he's a nice guy.",
      "word_count": 7
    }
  ],
