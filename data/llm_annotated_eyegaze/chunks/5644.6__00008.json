{
  "stem": "5644.6",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "So if you found only 10 [INAUDIBLE] from each one, we've got tons of food.",
      "word_count": 15
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "And we found the food.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "So [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "--Not 10 [INAUDIBLE], but kilos.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "No, we haven't been registered.",
      "word_count": 5
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "We went to the-- to Prague-- to Praga.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "And in Praga--",
      "word_count": 3
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] No, no, no, everybody walked.",
      "word_count": 6
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "We didn't--",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "They didn't send us a track, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "Everybody walked.",
      "word_count": 2
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "I took Luba, my wife, and went out.",
      "word_count": 8
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And everybody went out on his own.",
      "word_count": 7
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 4,
      "text": "Because he got an address-- an address where to go and how to go.",
      "word_count": 14
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 5,
      "text": "So they went-- I told them at the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "Arriving in Prague, after two, three months, I was arrested--",
      "word_count": 10
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "--by the Russians as a Christian.",
      "word_count": 6
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "Pardon?",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Because I belonged to a Polish organization.",
      "word_count": 7
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "And that's I'm a Christian.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "When I like to prove that I'm Jewish, he said, if you will try again, I'll take you downstairs and kill you like a dog.",
      "word_count": 25
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know Russian at all.",
      "word_count": 6
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "I will be like Slovakia.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "And I was screaming I am Jewish, because I thought that Stalin will come.",
      "word_count": 14
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "And he will kill the man, which is such a big hero like David Landau.",
      "word_count": 15
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 2,
      "text": "Jan [INAUDIBLE] is going to tell him what to do and how to do and arrest him.",
      "word_count": 17
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "Stalin will kill that officer.",
      "word_count": 5
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "What is he doing with such a big hero like David Landau-- like me?",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "So I been-- there I said what do you want from me?",
      "word_count": 12
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "I'm a Jew and a Jew, and a Jew.",
      "word_count": 9
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 2,
      "text": "And then I thought myself-- what do you want, actually?",
      "word_count": 10
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 3,
      "text": "He said, what I want from you is to give me names and addresses of your leaders.",
      "word_count": 17
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "This was a Russian officer.",
      "word_count": 5
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "A Russian officer--",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "--In a Polish uniform.",
      "word_count": 4
    }
  ],
