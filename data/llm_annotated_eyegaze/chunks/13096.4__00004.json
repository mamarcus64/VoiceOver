  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Her name-- her name was [?",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Sylvia ?] [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "She was a very friend of mine.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And she had come to the-- to the hospital because she had a little bit of rheumatism.",
      "word_count": 17
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Otherwise, she was a very strong girl.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "But that night, they give her the pill, and she died during the night.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So the next morning, my-- my sister promise me to come back, you know, while they were-- the-- the nurses were, you know, busy, to come back into the block 20.",
      "word_count": 31
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "So which she did the next day.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And she came to the block 20, while we were in the count.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "So now these girls the block over start counting and counting.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "There was one extra-- extra prisoner.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Say, where she come from?",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "They're counting again.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Nobody will tell who-- nobody knew.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Because they were doing the counting.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "They were counting five, five, five.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "There is one extra prisoner.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "They know when one prisoner goes to hospital, she'll never be coming back.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Because they-- she has been eliminated for sure.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "She doesn't count anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Her name was already eradicated from-- from the list.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "She will never be alive again.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "As I told you, they give-- will give the-- the pill.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "And then eventually, you know, they-- they-- they-- they-- they-- they were making the numbers, you know, the appell.",
      "word_count": 19
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "They find it was her.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "It were-- and they found it was her.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And they took it from one place of the-- you know, from the ear.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "They pick her from the ear.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And threw her in the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And she knock her head, and she was nearly dead.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Eventually-- that's [? at ?] [? that ?] very moment, the doctors arrive with the appell again.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You know?",
      "word_count": 2
    }
  ],
