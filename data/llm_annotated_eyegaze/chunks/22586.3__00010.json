{
  "stem": "22586.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And my sister worked in a-- a Jewish-- like an officer's club, where the American GIs would come to get together with other Jewish GIs.",
      "word_count": 25
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "If it was like a-- a club, I suppose.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And I guess maybe through that, whether it was through the JCC and being in touch with people, [INAUDIBLE] we found out how to try to get papers that we were German citizens.",
      "word_count": 33
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And I remember going to Augsburg to get the papers.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "I remember going on a train, standing all the way, because people were traveling with a lot, a lot of packages and whatnot, and trains being very crowded.",
      "word_count": 28
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "But we were told how to get in touch with somebody down in Augsburg.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And we got the papers.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And somehow we managed to get to the United States that way.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "In 1948. 1948.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "But before we came to the States, in 19-- it must have been during 19-- end of 1947, just before we came to the States, I was-- we were contacted by some Americans who found out that we were working at the Krupp factories.",
      "word_count": 44
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And they wanted us to testify at the Nuremberg trials.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "So my sister and I were taken to Nuremberg for the Krupp trials, where we testified for about two days.",
      "word_count": 20
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Well, I don't know if they were soldiers.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They were lawyers.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I think it was one of their lawyers from Nuremberg came up and contacted us and asked if we would come and testify.",
      "word_count": 23
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I forget.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It was a Jewish man.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "It was a Jewish man, a lawyer.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "And I forget his name.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No, no, there was no pre-trial investigation of any kind.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Nobody asked us any questions.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "They just wanted us to come and testify at the Nuremberg trials.",
      "word_count": 12
    }
  ],
