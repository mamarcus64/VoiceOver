{
  "stem": "25835.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "We are not Greek Catholic, but my father was like friend with this father who provided.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "We rented-- my father rented third floor.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "It was four, four rooms, big corridor, waiting room big like this one, and kitchen also.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Sure-- running water, gas, electricity, big storage for food-- it was not so popular like now.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "That storage was cool.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "It was ice cubes inside special ice cube, like refrigerator but was differ-- different as, as is now, of course, because it was so many years ago.",
      "word_count": 27
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I think was very bad-- very good, very good.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Because my older siblings, they went to private high schools.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "It was quite expensive in this time.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "For one month, I think it was about 100 or 120 zloty.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "And it was three already in high school.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "I was still in elementary school.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "And I finished four grade in elementary school before the war.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I can't tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I know that's very nice people, but I can't tell you.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "My brother probably he will know much better.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "Because he was working, working with him, with my father.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I, I was in public school [INAUDIBLE] 18-- very nice, modern, beautiful school.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "I was also in group of plastic and dancing, like ballet group.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "Now could be said ballet.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "We-- I was in this school with my sister and my brother four years only, very nice school.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And the name of the school was Jozef Pilsudski, our president name.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And also, I remember dur-- before the war, we're always together, whole family without my mother.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Because she never was skating-- small and fat.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And we went for skating with our aunt very close to my school.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I remember it was so nice, so happy time.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Also on [INAUDIBLE] or on [INAUDIBLE].",
      "word_count": 6
    }
  ],
