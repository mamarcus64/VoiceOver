  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "She wanted to study medicine, and that was the problem in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "Jews were not allowed.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "There were a few here and there-- you know, you could count them on-- on one hand-- who somehow through some means, got admitted.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "But on the whole, every Jew who wanted to study medicine had to go to a foreign country.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 12,
      "text": "Like some went to Italy.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 13,
      "text": "Some went to France.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 14,
      "text": "And my sister and a lot of them went to Czechoslovakia.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 15,
      "text": "It was the closest one.",
      "word_count": 5
    }
  ],
