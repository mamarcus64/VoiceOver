  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 11,
      "text": "They didn't-- they say they have to leave, because they are in transit.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So he made it a special the few miles to pick me up.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Well, I could not.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I went only to Ida and to-- because she expecting baby any day.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "And I said, I have to leave.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And-- and there was nothing else I can do, you know, for safety of all people.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "So now I am leaving.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "I am leaving-- in the hiding, in the car, of the Major in this [NON-ENGLISH].",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Those-- that men, have it-- he did have a connection for partisans.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And that was-- on the way, I was-- we were leaving, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And he gave me the name of the partisans.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So on the way, Major left.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "He did go, put me in a hotel and I disappeared.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And that was the last time I did see the Major.",
      "word_count": 11
    }
  ],
