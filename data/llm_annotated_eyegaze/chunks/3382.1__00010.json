      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] I, I remember like now, you know, one day, a sergeant came up.",
      "word_count": 17
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "Not a sergeant, because he was-- he was a lieutenant.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "He came up to me in the morning Appell.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And, you know, he took his hand [PAUSES FOR 3 SECONDS] and drew my cheek.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And I was lightly shaven.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So he hit me, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "You kike!",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Don't you know that you have to come shaved, whatever it is?",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "All right.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "But what I can tell you?",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "I was a good--",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    }
