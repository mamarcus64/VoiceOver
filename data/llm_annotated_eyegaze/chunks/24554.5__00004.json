  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Again, my colleague from the army asked my-- the man, he managed the house-- what you say about your new tenants?",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE], oh, he's a nice boy.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "No. ?] She's a Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "It was the answer about the anti-Semitism.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "The other anti-Semitism was [? worse. ?]",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I work in the-- in different places up and down, up and down.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And one time, I worked in a translator to a Soviet advisor.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "All on the country was Soviet advisor.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "So I work with him, translate and so on.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And what happens always-- I was up and down, up and down.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Why? ?] I had a brother in Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "He go away in 1933 to Palestine.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "He married.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "And he died five years.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "And my sister was in Britain.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "So there are always-- you can work in [?",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "Soviet ?] position.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "You have relatives in the West.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So I must again to down, some work [? up. ?] So once I go to the top to the ministry [? say, ?] look.",
      "word_count": 25
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "You always find out when you don't need me.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Yes, you find something.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "When you must push me out from a nice job, I have relatives in the West.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "My brother-- I was a young boy-- he leave Czechoslovakian in 1933.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "He don't ask the mother.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "He don't ask the father.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "He goes to Palestine.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Yes?",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "He was not a youngster.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "My sister, she was married.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "She goes with her husband to-- to Britain.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "She don't ask, again, the father, the mother [? what died. ?] Yes?",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "And she don't ask me.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "She goes with her husband.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "So why I am responsible for [? the-- ?] Yes, it is you are-- yes.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "And secondly, I am not in contact with them.",
      "word_count": 9
    }
  ],
