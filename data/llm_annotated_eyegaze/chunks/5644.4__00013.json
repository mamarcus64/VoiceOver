{
  "stem": "5644.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 178,
      "sentence_idx_in_seg": 3,
      "text": "Using perhidrol to cover-- to, to, to wash her hair to get the blonde.",
      "word_count": 14
    },
    {
      "segment_idx": 179,
      "sentence_idx_in_seg": 0,
      "text": "Perhidrol is a chemical which makes--",
      "word_count": 6
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 0,
      "text": "--you from black.",
      "word_count": 3
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 1,
      "text": "Bleaches very light.",
      "word_count": 3
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 2,
      "text": "Bleaching the hair to make it blonde.",
      "word_count": 7
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 3,
      "text": "But was a problem because they're growing still from the bottom up.",
      "word_count": 12
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 4,
      "text": "And we did have a lot of work to keep it up.",
      "word_count": 12
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 5,
      "text": "She is-- she was very thin and very small.",
      "word_count": 9
    },
    {
      "segment_idx": 180,
      "sentence_idx_in_seg": 6,
      "text": "Nobody thought-- she got only one accident where she give her passport to a German because they were controlling something.",
      "word_count": 20
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 1,
      "text": "And she ripped the passport and she start to run.",
      "word_count": 10
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 2,
      "text": "He didn't want to shoot her, most probably, but to catch her.",
      "word_count": 12
    },
    {
      "segment_idx": 181,
      "sentence_idx_in_seg": 3,
      "text": "And he shot her in her leg very lightly-- a cut.",
      "word_count": 11
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 0,
      "text": "Because she feared that he will see that this is a false passport.",
      "word_count": 13
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 1,
      "text": "She didn't want to stay there.",
      "word_count": 6
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 2,
      "text": "She-- which my wife was, I think, very clever.",
      "word_count": 9
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 3,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 4,
      "text": "If the Germans said left, she went right.",
      "word_count": 8
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 5,
      "text": "If the Germans said right, she went left.",
      "word_count": 8
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 6,
      "text": "If the German went forward, she went backward.",
      "word_count": 8
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 7,
      "text": "If the German said backward, she went forward.",
      "word_count": 8
    },
    {
      "segment_idx": 182,
      "sentence_idx_in_seg": 8,
      "text": "Always opposite what the Germans said.",
      "word_count": 6
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 0,
      "text": "In her was the instinct as a Jewess with a passport, with a false passport in the hands of the German.",
      "word_count": 21
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 1,
      "text": "And so many people around there which is checking.",
      "word_count": 9
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 2,
      "text": "She got the chance of ripping it out of his hand-- because he's lightly holding it-- and starting to run.",
      "word_count": 20
    },
    {
      "segment_idx": 183,
      "sentence_idx_in_seg": 3,
      "text": "He won't leave the rest of the people to run away completely.",
      "word_count": 12
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 0,
      "text": "So he let her run.",
      "word_count": 5
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 1,
      "text": "And he shot.",
      "word_count": 3
    },
    {
      "segment_idx": 184,
      "sentence_idx_in_seg": 2,
      "text": "And he just slightly--",
      "word_count": 4
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 0,
      "text": "Her leg, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 185,
      "sentence_idx_in_seg": 1,
      "text": "And she run away.",
      "word_count": 4
    },
    {
      "segment_idx": 186,
      "sentence_idx_in_seg": 0,
      "text": "And she, she melted into the crowd.",
      "word_count": 7
    },
    {
      "segment_idx": 187,
      "sentence_idx_in_seg": 0,
      "text": "She melted in there to the crowd.",
      "word_count": 7
    },
    {
      "segment_idx": 188,
      "sentence_idx_in_seg": 0,
      "text": "She was a, a maid at-- with the place where we paid money to be there.",
      "word_count": 16
    }
  ],
