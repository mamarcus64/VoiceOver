{
  "stem": "11499.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He used to go out in-- in Poland, to the little towns, little villages, and buy calves-- young calves-- for slaughter, for meat, for make veal.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So he used to bring into Warsaw about between 300 and 400 veal--",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Calves to slaughter, every week.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And I remember, he never took money with him.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So my grandmother used to send me, when he bought something-- send me to the main railroad station, to send the money to my grandfather, he should pay for the stuff what he bought.",
      "word_count": 34
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "The other-- most of my family were in the butcher business.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They had retail stores-- a butcher shop.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "There was a-- a street in-- in-- in the place where we lived, [POLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Most of the stores used to belong to our family.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My great-grandfather had a beautiful, big apartment house with 72 apartments-- apartments.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And it was burned down during the war, after the Nazis bombed Warsaw.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "It was burned down.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I was very close with my great-grandfather.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Because I was the first great-grandchild.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "So he used to love me.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I used to go around with him, every first of the month.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I used to-- he collected rent.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And I used to help him, because he was an old man.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "He died when he was 96 years old.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "He originally is not-- was not from Warsaw, which I found out the last few years.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Now, he was from [POLISH], in Poland, originally.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "So he settled, from-- came to Warsaw many, many years ago.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, pretty much-- pretty much.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "My family was very much involved in Jewish cultures.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "My grand-- great-grandfather used to support a little shul, a little synagogue, in the neighborhood.",
      "word_count": 15
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He used to pay for everything.",
      "word_count": 6
    }
  ],
