{
  "stem": "20580.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "And he says, come later, and we go for lunch.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "Well, you got plenty to do, do you?",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 19,
      "text": "He said, I have plenty to do in the whole world.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 20,
      "text": "You cannot be anymore over here, because [NON-ENGLISH] is danger.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "I feel danger.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "He said, I belong to the party, the Communist Party.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "And I am protected.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "I have this, I have that.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "You was going outside.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "And I start to work for the factory in there, Rovno.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "Then this night I went away to another town, and over there-- six Jewish people working only in that factory.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "And they called-- and they took out all the Jewish, six Jewish, and they killed them.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "I see no life.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "And they're looking at all of us.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "I'm Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "But the Russian-- the Russian army already.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "This is no life.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I went to them, I says, listen.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I don't want to work.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "It's time to fight with the Nazis.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "So I says, maybe yes.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "But you speak Polish, you speak Russian, you speak Ukrainish.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "They send me away to Lublin-- no, to the forest.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "I come to the same place, which I did work, not to same town, just different.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "In the night we worked, in the daytime we went to the forest to hide ourselves.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "It was about 12, 13 people.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Till we pull up so to Chelm, Chelm.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "And in Chelm, we went to the forest.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And with Chelm, they went away-- I told you-- what's his name-- in the forest, everything in the forest.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "And they have-- and they have food from-- from the Polacks, and meals from there.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And suddenly they went away.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "After Chelm, we went away outside, three miles, I told you before.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And bring food from the-- from the village.",
      "word_count": 8
    }
  ],
