{
  "stem": "2539.3",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Never saw her, I never saw, never heard, never, never, never, and all my girlfriends that went to the high school, like, you know-- never, never saw them, never heard of them-- the Jewish ones.",
      "word_count": 35
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Nobody ever came back-- nobody.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "The only handful that survived, like these two girls from Lutsk, that came to-- that took me off the train-- they were hiding separately, not together.",
      "word_count": 26
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And they were-- they met after the war-- after the war.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And they met two fellows who were partisans-- together-- Jewish fellows, from some village under Lutsk.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "They finished up marrying them.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And the wedding was at my place in Vienna-- after I got my apartment already in Vienna-- a ex-Nazi apartment I got.",
      "word_count": 22
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And the ex-Nazi woman was knocking on my door every second day-- could she come and live with me, and she'll cook for me.",
      "word_count": 24
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "And I just, of course, wouldn't play along with her, for God's sakes.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "But-- because the apartment wasn't hers.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "It was a Jewish apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "And eventually, the proper owner came from the United States of America-- Nelly-- Elly Nebor-- came with a bunch of flowers, and said to me, look.",
      "word_count": 26
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "I-- I'm living in a hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 13,
      "text": "And this-- I lived in before the war, here in this apartment with my parents.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 14,
      "text": "But I've just come from New York.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "My sister is still in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "But we've come to live in Vienna now.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "Can I come and share the apartment with you?",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And that was a two bedroom apartment with a huge, big sitting room in the middle.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I said well, it's big enough for both of us.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "But you know what happened?",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "After, her sister came with her husband and a child.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I had to leave the apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "They were communists, these two women.",
      "word_count": 6
    }
  ],
