{
  "stem": "166.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "I thought I'm going to-- it's going to be the end.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So we walked in further where you stay on a-- they put you on a chair, and they shaved you all over.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "And then you had to go into a big container where there was full of Lysol.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And they tell you to go down with your head down all the way.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "If you didn't, you-- two guys-- big guys there with a baseball bat, they gave you right on the head.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So if you had a wound something, it burned terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Otherwise, you go in and out.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "You don't feel-- we go into the showers.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "We stay in the-- to take a shower, we stay maybe 15 minutes.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "It was ice cold.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "We stay naked until they come-- about 50 people-- and then everybody got-- not everybody.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "For two guys, one piece of soap, which was a square like a square of butter.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "This was for two guys.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And they open up the cold water, and they close the cold water.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "They say, [GERMAN].",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Soap yourself.",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "Those piece of soap for the two guys.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And we soap ourselves.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And as soon as it turn on again, cold water and very hot water that you couldn't stay.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "They burned us.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "That was only for one minute.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Out through the door.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "Not through the door-- to the window.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "We had to run out naked through the window where there was three foot of snow.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 11,
      "text": "We had to run through naked through the courtyard and stay in the-- on the steps maybe a half hour till we got up on the second floor-- all naked in the winter till we got the new uniforms with the stripes and the new wooden shoes.",
      "word_count": 47
    }
  ],
