  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "My mother and father, my sister, and myself.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "In another barrack was my aunt and her son, my cousin John, and my late uncle, Samuel Fransman, his name was.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "In answer to your question, my immediate family, my parents and I, and my sister, were in the same barrack.",
      "word_count": 20
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Not that I recall at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Not that I recall at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "Later in the camp, yes, but not at that particular time when we arrived there.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Because that barrack was basically only for the diamond people.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And the other people, who were in Belsen for other reasons, were in other barracks, although in the same part of the camp, in other barracks.",
      "word_count": 26
    }
  ],
