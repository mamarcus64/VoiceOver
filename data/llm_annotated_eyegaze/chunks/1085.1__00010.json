  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "Then in smaller town, you know, ads appeared on the walls that Jews should live together in certain areas, but only smaller.",
      "word_count": 22
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "Warsaw was not yet ghetto even.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "Warsaw ghetto was organized much later, I think. '40, or even-- the end of '40, only.",
      "word_count": 16
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "So at that time, at that time, yes, the Jews were discriminated.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "But there was no sign of what will happen-- was to happen.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "That so-called Holocaust was decided only-- I don't know you are aware.",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "February 1942-- a conference of the highest Nazi officials and the Gestapo in [INAUDIBLE], suburb of Berlin.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And their decision and [INAUDIBLE].",
      "word_count": 5
    }
  ],
