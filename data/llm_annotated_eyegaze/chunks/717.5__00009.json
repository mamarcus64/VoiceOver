{
  "stem": "717.5",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "She said, you didn't take it yet?",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "I said, I know know.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Should I?",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Are you crazy?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "You are out of your mind?",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "Somebody wants to give you a job and you're doubting?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "See, I had no problem with the language.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "I spoke English we when came, of course with the English accent, which you see I got rid of.",
      "word_count": 19
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And sure enough I took the job as a shipping clerk.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 19,
      "text": "And I worked there five years.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And then I went out on my own.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It was very interesting, very interesting.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I learned Los Angeles.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "I learned the United States.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "For me, it was an education that I couldn't believe.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "I remember writing the letters to Melbourne about Los Angeles, about the United States.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "I said it's very similar.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "It's practically the same with one difference.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Melbourne, Australia is the kindergarten.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "This is the college for grown ups, the rough college of grown ups.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "That's-- they're sort of like 25 years ahead, not in technology but in attitude and lifestyle.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "It's a completely different thing.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And of course, I had to learn how to drive on the right side of the street, which was very funny.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "At times it wasn't so funny.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I remember driving out on Olympic one day on the left side with Sylvia in the car and Dinah.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "And Dinah starts coming, Daddy, you're in the wrong side!",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Didn't realize.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "But I learned very quick.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "I became accustomed to it.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "It was very tough.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I cried.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "I remember getting off the bus, and I cried my eyes out.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Why did I do it?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Why did I come to this jungle?",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "But I-- I'm glad that I realized that it is a beginning.",
      "word_count": 12
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "No matter where you make your beginning, it is tough.",
      "word_count": 10
    }
  ],
