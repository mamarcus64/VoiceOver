  "sentences_input": [
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "The time made you became evil-- even like Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "No, no-- positively not-- positively not.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "My brother was for a little later one.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "They-- they changed the-- the-- you know, if you work with it, you have got to-- you had to be evil.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "You've got to-- if not-- they killed themselves.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "They was afraid.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, thank God.",
      "word_count": 3
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I haven't.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "I--",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Until every time-- let's say there was 30,000 Jews.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "There was 30.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "They-- made a smaller ghetto for 18-- let's say I give you approximately, 18,000 Jews.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And later-- later until it comes to a point was from the 30,000 was left 2,000.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they were sent to death camps.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They went Treblinka--",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "The-- most of the people didn't believe this is possible they're going to do with them what they're doing.",
      "word_count": 19
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "They--",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "At first, I-- we didn't believe it's going to be so bad-- they going to kill you.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They're going to-- little by little, you start to believe this-- everything.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "Because in these camps, it was brave kids that ran away that-- that told the people, take a look, whatever-- to organize a [NON-ENGLISH]-- to try to organize themself or to make a revolution, or-- it was impossible to do.",
      "word_count": 40
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And like the-- they took away the-- the-- they new the leadership.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "They took-- before they took the-- the-- the intelligentsia, let's say the profession, they took away the doctors.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "They done this-- this way--",
      "word_count": 5
    }
  ],
