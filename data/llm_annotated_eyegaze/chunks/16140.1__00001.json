    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "There were-- people were taken to the ghettos and they kill them all.",
      "word_count": 13
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Very few, very few.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was hoping to come to Canada.",
