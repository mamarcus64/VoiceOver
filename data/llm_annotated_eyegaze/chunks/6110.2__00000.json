{
  "stem": "6110.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to go back to ghetto and sneak in, and in that little town what I was in, Skala, started to be dangerous.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They were taking Jews out.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Then, I started to go to the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I went to the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "That time, they already took out my sister with the little niece, and they killed them some place.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I don't know even where.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have an address even where to go in.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "I didn't have nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "I didn't know where my brother-in-law is living with his daughter, the older daughter, because the younger daughter went with my sister and died there.",
      "word_count": 25
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "That was the older sister, Helen.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And people told me where my brother-in-law lives.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So I went to look for him, but they were living a few people in that room.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "They didn't want to let me in there.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And my brother-in-law was working, so he didn't know that I came back to the ghetto, you know, to look for shelter.",
      "word_count": 22
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was always dressed like a Polish girl because that's what I had already.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But I was looking for my brother-in-law.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He was not-- I didn't see him.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "The other people living in that apartment didn't want to let me in-- was no space.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Where am I going to sleep?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "So I went down and I was walking, walking, looking where to go in to sleep.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Then, my brother-in-law came back from work and he started to look for me because he heard that I am back in the ghetto.",
      "word_count": 24
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "And he found me in a Jewish spa, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "It was such a little bathhouse where you go in to take a bath, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "That was in the ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "They made it.",
      "word_count": 3
    }
  ],
