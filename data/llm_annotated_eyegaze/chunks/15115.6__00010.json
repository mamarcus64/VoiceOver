{
  "stem": "15115.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I'll give you, $50 apiece.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "You sell them for $99.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Put a little ad in the paper, classified ads.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "You'll see.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And I used to get teachers [INAUDIBLE] my house on Marquette Street.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "But I was doing very well.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Next, I started going into New York, buying surplus, back.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And I went into the surplus business.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "And I had a lot of connections with the American boys.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "When I used to work for the store, everybody thought that I owned the store.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And I was one of the most well-liked buyer in the United States, in the surplus field.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Then when I went into business for myself, I-- somebody gave me a cold storage room free of rent, and a little desk at an office down there.",
      "word_count": 28
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "So-- and I went to New York, to Chicago, which was a very close friend of mine, that I used to buy stuff from him when I used to work for the store.",
      "word_count": 33
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And he saw me disappointed.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Says, oh, I want to quit my job.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "He says, what are you worried about?",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "Says, come work for me.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "How much were you making there?",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "Here's an office, because he knew how good I was.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I says, listen.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "How can I come?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "I have the kids, a family in Toronto, and all that.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "So anyway, said, what do you want to do?",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I says, I want to be an importer.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "He was an importer at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "Says, you got money?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 15,
      "text": "Says, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 16,
      "text": "How much you got?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 17,
      "text": "Says, I got $50,000.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 18,
      "text": "In those days, it's a lot of money.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 19,
      "text": "OK, let's go for dinner.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 20,
      "text": "We went out for dinner, and he was buying stuff from Japan in those days.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "At those times, there was no [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "This was in 1960, was everything phone.",
      "word_count": 7
    }
  ],
