  "model": "openai/gpt-oss-120b",
  "elapsed_s": 18.5,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "But he told me at night, specially work in the office at night, God forbid at night to work in a office.",
      "word_count": 22
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "It's terrible.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "You are sleepy.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "You are hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "And he came in.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And he said-- I ask him, what did you do during-- before the war?",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "He said, I was a boy who didn't have a job.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Well, finally, when Hitler came to power, he gave me a job.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And I was building-- not.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "You were building?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "You are architect?",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "He said, no.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "I was [PAUSES FOR 3 SECONDS] helping the, the one who build the houses, the workers.",
      "word_count": 16
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "What do you call them?",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "You mean a carpenter?",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Brick layers to bring the bricks up there.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And I said, how did you communicate with them?",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And he start screaming.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "They called him by name, schnell, schnell, schnell, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And I said to him, you know, what are you going to do now?",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It was so-- the end of-- on the end.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "It was the end.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "He said, everything is crazy, you see?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "You're crazy.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Everything is crazy.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "I said, now you tell me it's crazy.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "Why didn't you tell me about three years ago?",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Ah, three years ago, it was terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't tell you, couldn't tell you, see, different kind of thing.",
      "word_count": 12
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "The third kind of-- it was meanwhile, I was very sick.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I have dysentery, terrible dysentery.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "In work A.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the second factory.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "So [PAUSES FOR 3 SECONDS] I was so strong that when I had to go to the factory, I didn't go to the bathroom at all.",
      "word_count": 26
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "I have something there.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And I was bleeding.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "I was a, a, a skeleton completely.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So the [?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Rosenbergers, ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "Rosenbergers, ?] [?",
      "word_count": 3
    }
