{
  "stem": "10358.1",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 41.6,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And then they chased everybody out again of the houses.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And then my mother was taken first.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And I was able-- I was separated from my mother and I ran.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And I opened the door from the basement.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Do you want to say something?",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "They chased-- they chased them-- I didn't know where they chased-- where-- where to, because I remained in the house.",
      "word_count": 20
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They got my mother first.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And I was able to run into the cellar.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And I closed the door on the inside of the cellar, so they were able-- they knew that somebody's there, because I should've left the door open, which I didn't.",
      "word_count": 30
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "I left it-- I locked from the inside in the cellar.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "And I was sitting in the cellar.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And-- and then I heard footsteps in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "Again, [GERMAN].",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "And then somebody tried to open the door from the cellar.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "And he was banging with the rifle.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "At this point, I felt it's no use.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "My mother was gone and everybody else is gone.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "I might as well go to.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "I I felt there's no point to-- to remain alive.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "As I came out from the cellar, in front of me was this Ukrainian policeman with a big rifle.",
      "word_count": 19
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 15,
      "text": "And he said, out.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 16,
      "text": "And I went on my knees and I cried.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 17,
      "text": "And I said please, let me live.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 18,
      "text": "I want to live.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 19,
      "text": "I'm only 16 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And he said, go back into the cellar but leave the door open.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "He remained in the house.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Then several Nazis-- I heard the footsteps-- several Nazis came in into the house.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And they asked him in German, is everybody [GERMAN]?",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And he said yes, everybody's [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And they left.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "And he left.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I was all day in the cellar.",
      "word_count": 7
    }
  ],
