{
  "stem": "8854.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "She had one room-- room, if the girls got sick, to examine them and to--",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "She-- The Nazis know.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She was picked as the doctor, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "And-- and then she says, you know what?",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "You go when-- going to be in the morning say appel.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "Say appel means the counting.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "You go under the bed.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "I'm going to cover you with a lot of blankets.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "We take blankets from the other girls, and we cover you.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And they're not going to see.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "They're going to see blankets only.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "I said, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "That's fine with me, if you think it's OK.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "I went to sleep.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "I mean, to sleep-- we went in at night, in the-- in the-- in the--",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "--bunks.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "In the bunks.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "Mine father, [NON-ENGLISH], died at home.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "He didn't go to concentration camp.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He died a natural death.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] And in the middle of the night, I fall asleep.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "And I dreamed-- dreamt my-- my father comes and tells me, [NON-ENGLISH].",
      "word_count": 12
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "Dear child, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "You're going to be OK in the morning.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "You're going to be healed.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "He said to me, you're going to be fine.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "I got up in the morning.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "My blister, big thing, exploded.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "It came out, the pus.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "I didn't have no fever.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 15,
      "text": "And I went in to the doctor.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 16,
      "text": "It was close to the barrack.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 17,
      "text": "And I showed her.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 18,
      "text": "She says, oh, thank God.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 19,
      "text": "Thank God.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 20,
      "text": "So go out to say appel, to the counting.",
      "word_count": 9
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 21,
      "text": "I did.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 22,
      "text": "I went out.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 23,
      "text": "And I was OK.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 24,
      "text": "She-- she put something to-- against infections, and things like that.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 25,
      "text": "She was very good, that Perl, Gisella, she was some woman.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 26,
      "text": "Very good.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 27,
      "text": "She was the doctor in Hadassah, in Jerusalem, after the war.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Not in Auschwitz.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Not at all.",
      "word_count": 3
    }
  ],
