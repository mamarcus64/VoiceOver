{
  "stem": "2539.1",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "He was afraid that they'll take the revenge on him because they were poor before the war.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "There was an element of Polish people and Jews who turned Communist, who were poor before the war.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "And all of a sudden, they decided, this is our time now.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "We are going to be the big bosses.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "We are going to set the rules.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "And I think my father was afraid that this element could harm him.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "He told me.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "I just remember vaguely that-- I remember that on the balcony, my father was saying, look, this is the end of our lives as we knew it.",
      "word_count": 27
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Now we're going to have a different life and it won't be as secure as it was before.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He was, in other words, afraid of the Soviet regime, very afraid, and the-- all the complications that could come with it.",
      "word_count": 22
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, I had-- I had an argument with him.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "You see, the point is that we had to leave Lutsk soon after.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "We had to leave that apartment, that unit.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And my mother moved to Olyka.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "My father moved to-- also to Olyka Station, which was about 10 kilometers, 15 kilometers away from where my mother was.",
      "word_count": 21
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "So he-- and he became director of a tar factory.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Under the Russians.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Under the Russians.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "It's already '40, '41.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "That's already '40, 1940.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "From memory, about 70 kilometers, 60 kilometers, from memory.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And my sister went to a village and she was teaching in a Ukrainian school.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "She-- I don't think-- she may have just finished the 10 years.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "In other words, she would have been 16.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "She would have been 17.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "She would have finished the school at about, what? 10 years from-- Anyway, she would have been about 17, 17 at the time.",
      "word_count": 23
    }
  ],
