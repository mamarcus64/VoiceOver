  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 57,
      "text": "[PAUSES FOR 4 SECONDS] The Jewish Council-- the so-called Jewish Council-- was founded in the year 1941, who had to represent all Jews in Holland, and was, let's say, an in-between between the German occupying authorities and the Jew-- Jewish population in Holland.",
      "word_count": 43
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 58,
      "text": "Two prominent members of the Jewish community in Amsterdam-- one, the owner of the largest diamond factory, and a former university professor-- became the heads of this [INAUDIBLE], the Jewish Council who handled all Jewish affairs.",
      "word_count": 36
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 59,
      "text": "This was done by the Germans to avoid the public press or the radio to announce all these anti-Jewish measures that were now followed one after the other constantly, so that it should be done quietly-- almost secretly, not to enrage the Dutch non-Jewish population.",
      "word_count": 45
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 60,
      "text": "And so we were-- we were informed that we had to give up our bicycles.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 61,
      "text": "We were informed that we had to give up our radios.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 62,
      "text": "We had to give up our business, our possessions.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 63,
      "text": "We were allowed only a certain amount of money to withdraw from-- from a bank which was now under German control.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 64,
      "text": "And so we-- we sputtered along during that year 1941.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 65,
      "text": "In June 1941, Germany attacked Russia.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 66,
      "text": "And now Max and I, Max also was a former schoolmate of my brothers in the same school when I met him in Amsterdam.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 67,
      "text": "We decided that it might be better not to live at home anymore.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 68,
      "text": "I changed officially my address from where I lived to a totally different address-- a gentile lady whom I knew who was willing to say that I lived there.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 69,
      "text": "[PAUSES FOR 3 SECONDS] The idea was that if anyone came asking for me, that my parents could say that they don't know where I am.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 70,
      "text": "I moved out.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 71,
      "text": "And my address was such and such now.",
      "word_count": 8
    }
  ],
