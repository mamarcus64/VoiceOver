{
  "stem": "15900.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "I went in, and I got unemployment.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "And I went there to California.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I met her through introduction.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "In-- in 19-- in 1952, I met her.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "In '52, we almost-- in 1952, yeah, '52, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I met her at the end of '52.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "See, I used to go for the Jewish holiday to New York.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "My friends who know me from Europe, they came to America for the Jewish holiday tradition, we have the New Years, and this.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And my wife lived in the same building with-- with-- with these people.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "She had no father.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "She was the only child.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "Her father die young.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And they had a daughter.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "They were girlfriends.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "And my mother-in-law used to go in, Mrs.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "Geller, ?] maybe you got a nice boy for this and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And she bothered me all the time to call my wife, for three years I had her telephone.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I said, Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "Geller, ?] she's an American, graduated college, and I'm a [NON-ENGLISH] from Europe.",
      "word_count": 13
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "I didn't speak English perfect either, nothing.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "Why was she going to go for me?",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And my landlady, I used to go dancing, I was good looking, and I have a lot of girlfriends.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And every girl ask me, who don't you get married?",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Why is a guy like you not married?",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "I said, why a girl like you not married?",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "And I used to go with a lot of girls.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "They used to call constantly.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And I was not ready to get married.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "I didn't make a living.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "I work for this boss.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And they were thinking, a photographer makes a lot of money.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "But I was full of life.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And-- and-- what-- one girl I met, and I took her home.",
      "word_count": 12
    }
  ],
