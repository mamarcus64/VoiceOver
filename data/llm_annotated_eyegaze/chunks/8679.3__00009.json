    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Now we came-- we are assembled and taken on a train to Dresden, Germany.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I know that it was December, because arriving in Dresden, Germany, there were Christmas decorations on the street.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "They marched us.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Dresden didn't have an [? ammunition ?] factory, but they had requisitioned a house.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I know the street [INAUDIBLE] 68.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I remember the address where they established an ammunition factory.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "That's where they took us.",
      "word_count": 5
    }
