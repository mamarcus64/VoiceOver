  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "That, that was the wintertime, and we begin, begin the, the temperature begin warmer.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "Knowing ?] we decided to what we can do, but it's not possible when the police begin to ask for us, to look for us and more worse it was.",
      "word_count": 30
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "It begin a time, what's begin it was the Ukraine people, they come in the forest.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "They was fighting for, for the independent Ukraine.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "There was, the politics there, politic it was to kill all other nationalities.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Beside only in Ukraine, must be stay all Ukraine people.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "They was killed-- they tried to kill Jewish people.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "They tried to kill Russian people.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "They tried to kill the Polish people.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And then for us, it begin the worst time.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "We got afraid for the police.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "We got afraid for the Germans, what we hiding.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And now, begin to hiding from the, from the people what they know us and we know them.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And they know what we, we around them, we stay in the forest around Komarova.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And better of them, but it comes, the people Ukraine what I was together with them.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "When I was working in the, in the government business and I went to go to make, to take the money to the bank, no-- and he was always with me.",
      "word_count": 31
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "But this guy, he would-- the guy, he was their head of the, of the bandits.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "I will not another word, I cannot.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "And he was looking for me what he want to kill me.",
      "word_count": 12
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "How many-- we eat with him together, when we take, take the money at nighttime.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I went with him at nighttime to the bank to come very early, to come back-- because no car seats, only, only with horses.",
      "word_count": 24
    }
  ],
