  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "I said because we have an apartment like this, and we are not trusted by the communists because we are-- you know, the Hungarian leader, Rakosi Matyas, said we like the former fascist Hungarians better than the Jews who are winking toward the West.",
      "word_count": 44
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "He was a Jewish man.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "He was the head of the Communist party, and later he became the leader of Hungary.",
      "word_count": 16
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "He became, I would say, the president of Hungary.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "He was a person who was in charge.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "But he got his-- in 1952, so I understand, he was taken to Moscow, and he became a no person.",
      "word_count": 20
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "From Austria, we went to Salzburg where we were in a kind of a camp.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And then eventually, we had some-- my father sent us some money to Switzerland, and I got part of the-- the Swiss were taking, the men who was dealing with the Swiss authorities, has taken one third of the money what my father sent out, and the rest we have received.",
      "word_count": 51
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And what was the question?",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Well, we came to Canada in June, June 13, I guess, in Halifax.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And from Halifax, we got by train to Toronto.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "In those days, there was no such a thing that you arrive into Canada and you are going to be looked after by the government.",
      "word_count": 25
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "Our relatives had to send the money, pay in the money for the train ride from Halifax to Toronto, and that's the way we have arrived.",
      "word_count": 26
    }
  ],
