{
  "stem": "22652.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I had an idea.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "There had been a lady with whom I had spent the summer, a few weeks in the summer, in France.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "They wanted to take children from the city and send them to the countryside during summer vacation.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So as a little child, I had spent some nice summers with her.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And I remembered her.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "And I asked my mom if she knew her address, and maybe contact her, and put me there.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "And that maybe she would be able to-- on her own, it would be easier to maneuver.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "So she did that.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And so she-- I just have to backtrack a little bit.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And my mother was such a sweet, quiet, devoted, lovely, remarkable woman.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And as a child, she used to drag me from one social welfare to, to another.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And some were Jewish and some were non-Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And I used to whine a lot.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "We had to walk.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We were poor.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "We couldn't afford the bus or the subway.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "But because she did that, I owe my life to her.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And so when I was put in this foster home, and later on in other homes or places, these social welfare agencies-- Jewish as well as non-Jewish, they work together as teams-- they paid for my board and keep, and they looked after me.",
      "word_count": 44
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And they saved my life.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "And I'm thankful [SOBBING] to my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "[CRYING] She, she had a lot of foresight.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "So I stayed with this woman.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Madame Meurtabes, and she was in a little town maybe 80 miles from Paris.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "She was a widow.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "Her son was a prisoner of war.",
      "word_count": 7
    }
  ],
