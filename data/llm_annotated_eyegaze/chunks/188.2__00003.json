  "model": "openai/gpt-oss-120b",
  "elapsed_s": 279.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] The courage of these people to-- because there were guns with bayonets drawn.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "To not say, yes, I have Jews right down here, is to me, beyond comprehension.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 5 SECONDS] It's-- and you always lived in a state of readiness.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "We were allowed to play some, but we had a tablecloth on the floor, and it always had to be within the parameter of the tablecloth, that in case there was any problem, we could grab the tablecloth, and everything-- everything was gone.",
      "word_count": 43
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "We had drilled, as far as the sleeping [PAUSES FOR 4 SECONDS] situation, was that the bed that had been used, had been slept in, that somebody else-- when we went in hiding, somebody else would jump in, so there was an explanation why the bed was warm.",
      "word_count": 48
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 3 SECONDS] I haven't thought of this for-- for 50 years, I think.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "This is coming back right now.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Horror stories of what had happened to resistance workers, what was happening to Jews that had been caught, hearing stories that my aunt and uncle had been found or-- by the Germans and had been deported.",
      "word_count": 36
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "The torture that those that were caught doing resistance work were put through, the physical torture, the imprisonments that some went through.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Then they came out again.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "It was always very close because it-- it was such a-- such a hub.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] And feeling [PAUSES FOR 3 SECONDS] that I had to be in control of myself at all times.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] You're no-- I was no longer a child for a long time already, and I don't think I ever became one again.",
      "word_count": 26
    }
  ],
