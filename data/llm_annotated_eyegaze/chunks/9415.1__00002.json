{
  "stem": "9415.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "All I know is we met.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "She was 15 years old, and I was 17.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "And we got married a couple years later.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Eula, ?] and in English you say Julia.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Wildman, Wildman.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "W-I-L-D-M-A-N.",
      "word_count": 1
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Her birthday, December 8, 1914.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I met her she was still in school.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And she has no occupation really.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "1935.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "June 6-- July 6-- or June-- when was it?",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "July 6, right.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "It was a quiet wedding in the rabbi's offices.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "And no big deal.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was a printer.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And we had a printing shop.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I-- on [?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Pawia ?] 31 in Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Had a couple people working for me.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "And this way, you make a living.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "No-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "My daughter was born in August 6, I think, or was it September?",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "August or September.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Wait a second.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "Let me think.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "October 6.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] October.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I-- when the war started, in September 1, they said on the radio that the Germans will kill all the Jews-- I mean, and then, on September 6, I left Warsaw with my brother-in-law.",
      "word_count": 34
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "My brother-in-law-- her brother-in-law, my-- I know how you say it.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And we left both for-- in direction of Russia.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And we spent the 10 weeks with the Russians, on the Russian side of Poland, which Poland was annexed by-- the-- this part of Poland was annexed by the Russians.",
      "word_count": 30
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "And we spent the 10 weeks.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Then I heard that my wife give-- gave birth to the baby.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "And we both came back to Warsaw after 10 weeks being with the Russian side.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "With the Russian [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And matter of fact, we lived in a hotel, which was owned by my [PAUSES FOR 3 SECONDS] family.",
      "word_count": 19
    }
  ],
