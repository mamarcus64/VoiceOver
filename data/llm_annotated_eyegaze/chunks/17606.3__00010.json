  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "The shops were-- the two main shops were [INAUDIBLE] and [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "You probably heard the names before.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "You were working in [INAUDIBLE] and [INAUDIBLE], take off your shoes, make yourself--",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE] called all the foreman from-- from his shops on [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "At the time, I was living already on the [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I was transferred to the high command of the Jewish military organization to take care of the [INAUDIBLE] shops, which was normally [INAUDIBLE] and [INAUDIBLE].",
      "word_count": 25
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And I took charge of that area.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And [INAUDIBLE] called all his shop leaders for a meetings.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And he locked the doors.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "[INAUDIBLE] said, tomorrow you will-- we are moving to shop peacefully to [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "You will have better quarters and everything.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "But he didn't let anybody out.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "So Alexander Rosenfelt, who was the editor before the war of a Jewish afternoon paper in Yiddish, [NON-ENGLISH], he was an outstanding member of [INAUDIBLE], was assigned as a [INAUDIBLE] man special to [INAUDIBLE].",
      "word_count": 34
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And he was allowed to be at the meeting and watch the door.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "But for one purpose, he went out to get [INAUDIBLE] a glass of water.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "At the time, he threw down a slip of paper to his brother, this [?",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "Jakov ?] Rosenfelt.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And he informed us that--",
      "word_count": 5
    }
  ],
