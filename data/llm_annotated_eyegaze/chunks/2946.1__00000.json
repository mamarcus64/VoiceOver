{
  "stem": "2946.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Can you speak a little louder, please?",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I'm Albert Feldman, born in the Czechoslovakia, in Breznica.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Really, I was born in Hungary on January 5, 1914.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "In Breznica--",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "In Breznica--",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "--before the war.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, when I was born, it was Hungary.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "And then four years later, in 1918, it became Czechoslovakia.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Well, I stayed in Breznica in Slovakia until I graduated from high school, which was in Bratislava.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And after graduation from high school, I went to Prague to university.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "And in 1938, I received a degree-- an engineering degree and started to teach commercial high school.",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I beg pardon.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My parents--",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "--my mom, my dad, and my grandmother, my father's mother, and my father's sister Kathy who was separated or divorced from her husband.",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "So I had three-- four-- three ladies around me and one man.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "That was my father.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Their name?",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Herman.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name was Selma.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Maiden name was Eisler.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And my aunt was Kathy.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And my-- I don't remember my grandmother's name, first name.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And I don't remember my grandfather.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "He was dead by the time I was born.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "My mom had two children before me.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They died in-- very shortly after their birth.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "So I was the third one.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And they were very anxious to keep me alive.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My religious background-- it was two Jewish family in a Slovakian village of-- of Breznica, and about 1,500 inhabitants, mainly farmers.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the other Jewish family was my father's sister, Aunt Hanna.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And they had a farm.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And we had a store.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So my religious background-- whatever I learned from-- about Judaism was my father, who was religious, and my mom.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And we kept a-- all the holidays, Jewish holidays, especially the Seder, Pesach.",
      "word_count": 13
    }
  ],
