{
  "stem": "8352.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I'll be better off, I'll be-- which I could have eaten up anything in that time.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "But I-- I thought, I'll save it.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "When I got up in the morning I looked for it.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "It was gone.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Somebody stole it.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "When you get the bread in the morning, the people were so wild that you had to eat it so fast, otherwise somebody would just come and grab it out of your hand.",
      "word_count": 33
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "And-- and they would, and they would eating it up.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "You didn't even-- you couldn't even keep it for eatin' it slowly.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "You had to eat it very fast.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "I'm coming to it now.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I was feelin'-- feelin' weak.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I was feeling plenty weak.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I was hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "When we came back from the camp, from the-- yeah-- from the factory, they used to take in 20, 30 people into the kitchen to peel potatoes, carrots, to prepare for next day.",
      "word_count": 33
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "We would run into the kitchen after the appell, after they counted us.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Try to be the first one so they will take you in.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "If you were lucky, they took in 30 people.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "The rest had to go back out.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Once in a while, I succeeded.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "So I went in there and I was peeling, and I was-- could eat some of those, of those potatoes.",
      "word_count": 20
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 10,
      "text": "And the potato peels, they were thrown out in the back of the kitchen there.",
      "word_count": 15
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "We used to get up at night time, sneak out from the building around to that big pile of peels from the potatoes, grab in that little canteen, run back to the barrack and eat it.",
      "word_count": 36
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "Unwashed, uncooked, just as it is.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "My father starts feeling pretty weak.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "And-- [CRYING] [DRINKS] [CRYING] He was terribly-- [CRYING] He doesn't have no more power.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "He's gotten sick.",
      "word_count": 3
    }
  ],
