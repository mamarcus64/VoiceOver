{
  "stem": "95.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "For once in her life, she listened to my mother, took that key, and went upstairs and hid.",
      "word_count": 18
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "And she asked me to do that too-- where to go with my sister, and I didn't want to go.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "I mean, my sister was not security.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "I loved her.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "I still love her.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "But she was not security.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "My mother was security.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "My father was security.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "They were strong.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "My mother was compassionate.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "My mother was a rock.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "What am I going to do with my sister in a toilet?",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I refused to go.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "My mother was saying-- she gave me some money and-- to go upstairs to tell my sister what to do.",
      "word_count": 20
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "She gave her some money and some clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "She said do whatever.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "But I went twice upstairs evading the policeman, because they were all over the apartment building, screaming, banging on doors. 10 minutes!",
      "word_count": 22
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "Zeliszewski, Widerman, Harmuss, downstairs in 10 minutes!",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I went upstairs evading the policeman, and I gave my sister the money and the clothes, and tell her what to do.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And I went right back.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I took a belonging, I took some-- a blanket, because we didn't have any suitcases.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I put my belongings in it.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I used to go to art school.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "I put my drawings in it-- my-- my design and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I took-- I took--I used to love comic books and and-- movie magazines.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "That's what I put in my-- that was my belongings.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I schlepped-- and we went downstairs.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "One thing-- we had an annex in this apartment house.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "Somehow they did not arrest anybody in the annex.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "There were two apartments on each floor-- the seventh floor-- two apartments.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "They never arrested the other.",
      "word_count": 5
    }
  ],
