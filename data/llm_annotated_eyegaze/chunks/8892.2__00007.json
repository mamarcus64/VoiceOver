{
  "stem": "8892.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "And with the wagon they put my sister in the wagon, a bunch of hay on top of her and took them to another little town to a very good friend of ours who is maybe 10 kilometers, not even that much, thinking that they're not going to be that town, and my sister is going to be safe.",
      "word_count": 59
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "That's how naive.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So when the law came, then you had to wear the yellow stars, and everything.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "I went out the first day, all the way down to my girlfriend's house-- the Gentiles-- and back and no star.",
      "word_count": 21
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I said, I'm not going to put it on.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "I was a little chutzpah, and I was like my father's daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "I did not want to obey right away what they wanted me to do.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "And I walked down all the way, which she lived-- see, this was just one main street, the whole Liszko, where mostly the Jews lived and merchants and some Gentiles.",
      "word_count": 30
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They were already well-to-do Gentiles, not the real peasant.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And I went all the way on that main street and back.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And it was about five o'clock.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "I knew we had to be home five, so I'm rushing back by five.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And I don't know what made me do it or why even.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "Don't ask me, because I knew I wasn't probably welcome in there, but just chutzpah, I wanted to walk down.",
      "word_count": 20
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And my father sees me again.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "He says, Eva [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "You know, that's how they call me, Eva [INAUDIBLE] when it's like a nickname as a child.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Eva [INAUDIBLE].",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "Why are you doing this thing?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Why did you go out?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Where is you yellow star?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And I says, apu-- this is short for Daddy-- apu, [HUNGARIAN].",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I'm not going to put it on.",
      "word_count": 7
    }
  ],
