  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And before the train left Hungarian territory, the Regent sent gendarmes after that train.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "They brought the train back to [?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "Kistarcsa. ?] And within three days, the people were released.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Everybody knew it.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "And that was like a national holiday for the Jews of Budapest.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Look, all of my classmates, because virtually, all of my classmates.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "We were going to a Jewish school.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And a lot of the kids were from the country.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And naturally, in times of stress, they want to be with their families.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "[COUGHS] Pardon me.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "[DRINKS] And so the first thing they did was the day that the Germans got there, they went to the nearest railway station and wanted to go home.",
      "word_count": 28
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And the Gestapo were right there waiting for any Jew who tried to catch a train.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "They must have studied psychology.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "They were taken to this concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "And within days, they were in Auschwitz.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 10,
      "text": "And virtually, all of my classmates were deported like this.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "One friend, one friend who was killed by the Arrow Cross.",
      "word_count": 11
    }
  ],
