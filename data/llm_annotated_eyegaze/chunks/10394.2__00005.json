{
  "stem": "10394.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And just the women.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Everybody-- all the women, there's 300 women.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "All the woman goes-- we didn't know where we go.",
      "word_count": 10
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Not too far.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "But we saw Auschwitz, and we says, finished.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "No more alive-- we are finished.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, sure we knew.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "So we came to Auschwitz-- was one side, and was two sides.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "One was-- we didn't know-- we go to the-- [PAUSES FOR 5 SECONDS] know how you call-- take a bath.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Showers.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, we didn't know where we go.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "But they know where they put you.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "So we went in Auschwitz in the one.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "This [NON-ENGLISH] was-- they don't give you gas.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] The other one, everybody was dead in the shower.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "After the shower, you have to go--",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they took you everything what you got.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I was soaked.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "I got nice clothes, nice boots like this.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "They take everything and they give you one dress.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Not underwear, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "One dress and shoes-- not shoes.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "You know, the [NON-ENGLISH] shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "From [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "From wood.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "From wood.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And I was lucky I got small size.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "But somebody got a big size they couldn't work.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "No stocking, nothing.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And we went to a barrack.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "We got a special barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Like you have to-- [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "You have to, you know, when you see you-- you-- down and up, like a bed.",
      "word_count": 16
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "Up and down, up and down, you know, was the barrack.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "This barrack, you couldn't go out, and nobody let you in.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "No, you can't go in toilet-- no toilet, nothing.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "No water.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "What I did?",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I don't know how I survived the three weeks.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "There was one woman-- I know her from ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "A young girl.",
      "word_count": 3
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "Maybe she got 18, 19 years old.",
      "word_count": 7
    }
  ],
