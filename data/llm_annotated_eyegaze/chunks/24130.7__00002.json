{
  "stem": "24130.7",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 14,
      "text": "And-- and what's going to be and what's-- what's going to be the end and where we going to wind up, and how-- how it's going to be then, you know.",
      "word_count": 31
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 15,
      "text": "In Bergen-Belsen, we knew that-- in Bergen-Belsen we knew this is the end.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 16,
      "text": "A matter of fact, I had a cousin that we always think that she was very smart.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 17,
      "text": "Because we came-- when we came to Bergen-Belsen, we wound up in a washroom, about 50 girls.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 18,
      "text": "And there was water in the washroom.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 19,
      "text": "We couldn't even sit down.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 20,
      "text": "And we were there a whole night.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "And my sister, Lilly, says to my cousin-- she was with us through the whole war-- Lilly, what do you think?",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "You're a smart girl.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We always consider her a very smart girl in the family.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "You're a smart girl.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "What do you think it's going to be here?",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "She says, Lilly, from here we're not going no place anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Either we going to live or we going to die.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "She says, how soon we'll be liberated?",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "She says, that I can't tell you.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "But she-- she like predicted, and everybody predicted something else.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "But Bergen-Belsen was really the-- like, the end of-- of all the things.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "We didn't work there.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "We got very little food.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Then typhus broke out because the lice.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "I used to be so-- I-- I don't know why I suffered so.",
      "word_count": 13
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I didn't feel how other people suffered.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "It was in the winter time.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "We got there in February-- the beginning of February.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "It was bitter cold.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "I used to get undressed, completely naked because the-- the lice were in the clothes.",
      "word_count": 15
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "I says, I just want to freeze to death.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "I don't want to be eaten by the lice.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 12,
      "text": "I used to cry, be hysterical.",
      "word_count": 6
    }
  ],
