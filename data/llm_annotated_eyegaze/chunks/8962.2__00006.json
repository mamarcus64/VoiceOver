{
  "stem": "8962.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 15.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "You've never been in this country, and it's so far away.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "It's over an ocean.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "There weren't any airplanes in those days that you could hop.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "So we would go shopping sometimes and buy supplies, and he would pack them and put them away when we--",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "He was also trying to get his affidavit.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And one day, he said, I have to go to Switzerland.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I said, you're not coming back.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "He says, I'm coming back.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "I said, you'd be foolish if you come back.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Then he went to Switzerland, and I found that out later.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "He took money to Switzerland and deposited it in Switzerland.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "He came back.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And I said as much as I love you, and as much as I'd like to be with you, I think you're crazy.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Why did you come back?",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "He says, I can't leave my parents.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "I got to take care of my parents, and we want to go to America together.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "I had to come back.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I said, you could have waited for me in Switzerland.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I could have made it somehow out of the country.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Of course, you never knew because one day I was-- Friday nights, I always bought flowers for my mother.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "With as little money as I had, I took some money and bought flowers for Shabbos.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "And I walked into the flower shop, and one of the brown shirts followed me and wanted to pick me up.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He didn't know, of course, I was Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "You didn't wear stars then yet.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And I didn't know how to get away from him, and the woman in the flower shop told me-- [COUGHING] excuse me.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Go out the back door.",
      "word_count": 5
    }
  ],
