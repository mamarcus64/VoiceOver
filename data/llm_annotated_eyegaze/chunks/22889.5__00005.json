{
  "stem": "22889.5",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "Was a very short time down there.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "I worked in, in the steel factory.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "We used to work in the big ovens.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Used to load up the wagons, the steel wagon, with the steel, all kind of junk, and I push them to the metal shop.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I used to make the steels to melt in big ovens.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "Was hard work, especially when, when transport came with a row of steel from Norway.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Used to bring the stone.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "It looks like a stone, but it's very heavy.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Use-- don't use no shovel.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "Use like a fork.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And at the end of the fork is like a ball so those inject into the floor on the train and the car.",
      "word_count": 23
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "Was very, very hard work.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "My hands was like a, like a concrete, so hard.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "I could have drove a nail with my hand.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Took me years, I say years, good couple years to scrape off the, the skin from my hands after Liberation.",
      "word_count": 20
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So I worked in there till [PAUSES FOR 3 SECONDS] 1943 when the Russian invading.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "They were coming, I believe, in Ostrowiec, something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "In my mind was '43, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "End of '43, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "Oh, '44.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "Was in '44 maybe, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "In '44.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Finally, the Russian, they were invading.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "They were coming over.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "So they liquidated camp.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "And they transport us in the boxcars to Auschwitz.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "We came to Birkenau.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "We arrive always at night.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "Usually a transport they used to arrive now.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "[INAUDIBLE] they'd keep you overnight in the train.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "We stay all night in the train.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "They kept us all night, and our transport especially.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "They keep us all night in the train.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "Early in the morning we heard the dogs barking.",
      "word_count": 9
    }
  ],
