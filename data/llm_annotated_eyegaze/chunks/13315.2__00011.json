  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.0,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "In that moment, they took you out in-- to-- to the crematory and cremated you and send the bill to the family.",
      "word_count": 22
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "We never saw that.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Because you tried to see as little as possible.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "They were, but we didn't know about them.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And maybe they were not then, yet.",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "It was an early time.",
      "word_count": 5
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "That we didn't see.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Because if that would have been outside of the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "It wouldn't have been in the camp, itself.",
      "word_count": 8
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 3,
      "text": "You see, our camp was only a part of the overall camp.",
      "word_count": 12
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 4,
      "text": "And we didn't see anything outside of the wired fences.",
      "word_count": 10
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "We didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Except the rumors.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "We knew that there were crematories.",
      "word_count": 6
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "SS, he could stop you, but you had to stand at least five feet away.",
      "word_count": 15
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "Otherwise he could shoot you.",
      "word_count": 5
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "That you aggressed him.",
      "word_count": 4
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 94,
      "sentence_idx_in_seg": 1,
      "text": "They could call you all kinds of names, but you couldn't answer.",
      "word_count": 12
    }
  ],
