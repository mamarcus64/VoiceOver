{
  "stem": "14156.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And as she come running outside, the flames-- she was all in flames.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "Neighbors come running try to put her down.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "First, she, she resisted, as I was told.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And but finally, later, they got her down to the floor and rolled her, trying to, to extinguish the flames.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "The neighborhood-- there was a little grocery store.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "And milk cans was sitting there.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "One of the neighbors-- her name, her name was Anna-- she opened up.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "And she took the milk and, and put it right over her in order to extinguish the flame.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And I didn't know anything about it till I, I was walking home from school.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Kids come on to me and say, hey Munford, Munford.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "Your mother burned.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "I said, what?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "My mother burned?",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "Yeah, your mother burned.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "Go home, go.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "As I walked in the house, people were standing around.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I looked.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "There was a cellar.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "You know, you could-- when you walked in, down was a cellar.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "There was a, there was a little pile of ashes and parts of, of clothes.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "I said, oh, my god.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "She's dead.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "That's her.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And I was scared.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And then all of a sudden, somebody calls, calls out, Munford, come on.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Your mother wants to see you.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "She's upstairs in her bedroom.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "So I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And here she was, laying, covered up till here.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "The hairs, everything was burned down.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And she hold my hand.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And she said, it's OK Munford.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "You, you, just you go down.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "You, you listen to, you know, what the people will tell you what, what they-- what you have to do.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "And that same day, they transported her to the hospital, the same hospital I was as-- in the kindergarten as a child.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "And there were nuns.",
      "word_count": 4
    }
  ],
