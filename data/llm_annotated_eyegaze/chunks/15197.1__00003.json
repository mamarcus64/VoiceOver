{
  "stem": "15197.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Mother was the mother every time and everywhere understanding, the practical person who was thinking about the house, thinking how to bring in food into the house, how to manage things.",
      "word_count": 31
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "She was the foundation of the house.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "There was not a religious house, but I would say a very traditional house.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "When the high holidays came or other holidays, we, like everybody else of our neighbors, like the whole surrounding where we live, was quite Jewish, Yiddish [NON-ENGLISH].",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Traditional.",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And this was also my house.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Not the very religious one, but a very traditional one.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "A Yiddish home.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "A Yiddish house.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Friday night was the Friday Shabbat meal.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, although later on when I was already a member in the children organizations and Friday night we used to get together, I was not permitted to miss the Friday night meal.",
      "word_count": 35
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "I have to be at home.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "This is the tradition which was kept.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "So it was a Shabbat.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "But at the same time, it was not very religious.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "My little brother was sent to chaider to know all kind of religious prayers and so on.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "But this was like the stop, how far religious it was.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "But it was a traditional, Jewish home.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The house where we live was also occupied mostly by Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "It was the Jewish section.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It was a so-called [NON-ENGLISH] Jewish ghetto, the Jewish district.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Of course, when we used to get out of the Jewish section, very often we had the antisemitic approach if somebody looked Jewish or if somebody behaved a little bit different.",
      "word_count": 31
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "But I, personally, didn't experience too much because, as everybody said, that I look not typical Jewish.",
      "word_count": 17
    }
  ],
