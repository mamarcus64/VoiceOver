  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "It was together, but fell from the 13,000.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "They took us from over there, from Plaszow.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Like I said before, the Russian come close to Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "They transported us to-- to-- to Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "Is, um-- [PAUSES FOR 3 SECONDS] this is the reason what Schindler comes in.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "He done good, that way, I think.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "He watched it fell from the 1,300 to 1,100.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "He watched them like a hawk.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "He couldn't bring us direct to-- to-- to this town where he developed the factory.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "He took us to another concentration camp-- that camp, terrible.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Called, um-- oh, God.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Um, [PAUSES FOR 4 SECONDS]",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Breninski ?] was-- Gross-Rosen.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "Gross-Rosen.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "Gross-Rosen.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Like Majdanek.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "What they done, the first day we came, they-- they [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "They take everything away from you.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And you go in, uh, put you naked.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "This was around-- must be around January.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "It was so cold, and you're naked.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "In-- it was not ourselves.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "It was a group from other camps.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "The transport they took together, is so many locomotion they got [INAUDIBLE].",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "It's-- it's-- I'm never going to forget this.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "Is, you know like a circus, the part [INAUDIBLE] the whole in the circus, an empty circus?",
      "word_count": 17
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "They ran the people.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "And-- and after you shower, they ran us under the circus.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "The transport, maybe 2,000, maybe 3,000, maybe 4,000.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 14,
      "text": "Is the people were there.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 15,
      "text": "It's cold inside.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 16,
      "text": "[INAUDIBLE] inside.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 17,
      "text": "Everybody's cold and pushed themself the inside.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 18,
      "text": "The part of the inside was almost-- after they finished is dead, because they killed themself.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 19,
      "text": "You know, the-- if you feel cold, you try to get [INAUDIBLE] to the other body.",
      "word_count": 16
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 20,
      "text": "The outside was frozen.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 21,
      "text": "Let's say in this time let's say it was maybe two-- I-- I'm not exaggerating.",
      "word_count": 15
    },
    {
