{
  "stem": "3100.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.0,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "But I found a girl, who became later my wife in a cellar of potatoes because the, the Russians didn't--",
      "word_count": 20
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Your life is connected with potatoes.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Potatoes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "The Russians didn't feed us.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "The Germans didn't feed us.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "We didn't have what to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "So we found out that there's a big warehouse with storage of potatoes.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "So somebody broke up the--",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "--and we went in just like wild.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "We ate the raw potatoes.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "We were-- And I helped a girl there to get her some potatoes, and that was my wife.",
      "word_count": 18
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "Then I met two girls that were liberated.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And as I started to talk to them, they were from the same town, from Belzyce.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "They recognized me because they were first cousins to my brother-in-law, as I said, Shmiel Gradel.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "And I started to say, tell me what happened to my sister, Goldala.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And they started to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And they said, you could be proud of your sister, Goldala.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Goldala had one year or one and a half year old baby boy.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And they wanted to grab-- the SS, they grabbed the baby from her while they made the [GERMAN] in Belzyce.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And she said, you can't get my baby.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Over my dead body, body will you give-- will you get my baby.",
      "word_count": 13
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "I want to go, and I'm young.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And I am-- and she says she's 30 years old.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And you-- she started to call him names.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "But you are absolutely worse than animals.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "What would you gain by it when you sh-- you want to destroy a little baby in this age.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "And they said, what?",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "So they said they didn't like that.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "So they shot the baby in her arms.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "Then she spat on them.",
      "word_count": 5
    }
  ],
