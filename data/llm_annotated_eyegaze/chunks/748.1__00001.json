  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Sometimes, yes, but not much.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I was always with friends from the same class.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean, what I would do?",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Then, I went with my-- with my father to Paris.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Every doctor, he-- he went once a year to Paris from-- I don't know if you will understand this-- this-- from this poviat.",
      "word_count": 23
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "This is like-- like this part of--",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "The area.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "And we went four weeks every month, because my mother didn't want to go with my father.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "She will not go with a airplane Shabbos.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "To Paris.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Sure.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Because they got a interview, all the medical people from around the--",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "With my father, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And then, I went to university.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No, Vienna.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "In medical school, two years.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And then what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "Then the war came out.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And my father came and picked me up.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So [INAUDIBLE]-- don't take nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "Come home.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "They knew what was going on.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "So you-- you did two years, and then you came back to Lublin?",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And-- and what did you do there?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "After the war?",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Then--",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And then they arrested me.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't long.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] It was quick.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "They make-- I don't know to-- in English, this pronounce.",
      "word_count": 10
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS] They take all Jewish people, and included me, to a jail in Lublin.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "We-- I don't know how many months I was there, and then to Auschwitz.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "In 1940.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "What do you mean?",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "No, not a match.",
      "word_count": 4
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS] No.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "He worked with my father.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "He was a-- a medical student with my husband-- with my father, I mean.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Stanley Litwinski.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Oh-- [SIGHS] not-- I-- I don't remember this.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "Before-- sure.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "When I went to-- to Vienna, I got a baby already.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "My-- my mother was the babysitter.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Two.",
      "word_count": 1
    }
