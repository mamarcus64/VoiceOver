    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "You know it wasn't easy coming as a newcomer, without a language-- well, fortunately, I hired a tutor in Austria, to learn how to speak a little English with my husband, how to write and read.",
      "word_count": 36
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "But most of us had to come to a different culture, different country, different language, with nothing.",
      "word_count": 17
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Not asking for anything from anybody, doing everything on our own.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Going to school, working.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "I happened to be very fortunate that I met someone who talked me in, to go into a wonderful profession--",
      "word_count": 20
    }
  ],
