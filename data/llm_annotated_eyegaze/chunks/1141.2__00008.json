  "elapsed_s": 2.7,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And she realized that when they cooked that-- the soup, was-- which was made out of [GERMAN]-- IT was a [GERMAN].",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Oh, you don't speak German.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "It's a powder, a powder.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And they put the bromide in the soup.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I mean, she just read what they are.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "It was no instructions, but it said bromide.",
      "word_count": 8
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "In the soup.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Either then they did, or whatever other methods they used, I have no idea.",
      "word_count": 14
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But all I know is, looking back, that how they can dehumanize a human being-- a person-- and not being able to say something, and do-- do what they want you to do.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Not because you committed a crime, or you are guilty of any crime, but just so because you happen to be born by a Jewish family.",
      "word_count": 26
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "This was your crime.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And as you see, we are clean, we are fairly intelligent people.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "My mother--",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
