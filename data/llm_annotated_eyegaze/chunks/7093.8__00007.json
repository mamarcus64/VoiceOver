{
  "stem": "7093.8",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 167,
      "text": "And I said, well, I would pay back.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 168,
      "text": "But I go to Israel with a child.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Much later-- after, long after, I, I-- perhaps in prison in Marseilles.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Perhaps in prison in Marseilles.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "Not few years, no-- that was, well, that was-- that would have been '46, no '45, '45 until October.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Something like that.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I think so, but it might have been even later.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And then, then I, I went to Israel with a child.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I-- the child, I had to put into a [INAUDIBLE] baby home.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And I was in-- because I could only get lodging in a hostel, where I had to share the room with four-- three other women.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And I was not allowed to take my child with me.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "So he was in a baby home.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And I was in a hostel.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And I was very lucky I got into an [INAUDIBLE], very first [INAUDIBLE], which was as at an experimental stage.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "But they needed nursery school teachers.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "So they let me in on, on it.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "But they couldn't use me without the language.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "And then I had-- I was bitten by a louse.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "And I had typhus.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "I had the spot fever, which is through a louse.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "And I nearly died.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "And Ilan had-- my son, Ilan, had meningitis.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "And I eventually-- well, I eventually got it.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "I, I, I couldn't work with children anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "Because there was polio epidemics in Jerusalem.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "And we weren't allowed to visit.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "We were allowed to-- and he was on the third floor.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "And they brought him out on to the, onto the, veranda, onto the balcony.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 21,
      "text": "But I was on the, on the ground floor.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 22,
      "text": "And I could only wave, wave to him.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 23,
      "text": "And that went on.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 24,
      "text": "And I found it unbearable.",
      "word_count": 5
    }
  ],
