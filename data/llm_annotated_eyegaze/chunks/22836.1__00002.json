    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Ukraine, and we lived there together, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Well, a lot have groceries.",
