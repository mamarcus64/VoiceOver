    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They was working.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "There was tailors, shoe makers with horses, makes for the, for the horses.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Everybody got a trade Everybody got a trade.",
