  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I don't go in [INAUDIBLE] because you have to pay a lot of money for that.",
      "word_count": 16
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "I have a private teacher and yeshivas.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Oh, was overnight drive with a pair of horses, over night.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Oh yeah, I stayed there.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "There was-- there was taking-- like everybody give a day food, and we sleep in the yeshiva there, in the same building.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "In like seven days, I have seven bosses where they feed me.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "And every boy do same thing.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "They help out the yeshiva.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Like in Lutsk, you stay in there, but not everybody takes a-- takes a key to feed him.",
      "word_count": 18
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "One day a week.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "In Lutsk, you Sunday by that place, Monday in another place.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And this way was gone, and this way was staying at the yeshiva.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Every day.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "In someone's house.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Well, mostly boys.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Mostly boys, no girls.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "A child, it was a cheder, a Jewish cheder.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "In Kolki, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I got even and my friend who's in, in Brooklyn.",
      "word_count": 10
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I went with him same cheder.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE], yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No, there was Jews and Gentles.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It was avery nice, nice city.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "It was a good thousand families.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
