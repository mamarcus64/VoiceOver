{
  "stem": "2851.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 11,
      "text": "He walked maybe 1/2 a mile.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 12,
      "text": "Two-- two men stopped him.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 13,
      "text": "It was the Russian people-- the Russian soldiers.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "He didn't see them.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They-- they came in.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they took it.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Then he-- he said from-- to us, don't worry.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "They won't kill us.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "Be free.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "And they took us to a place where the soldiers are.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "They gave us something to eat.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And we told them to take us somewhere where maybe they know where Jewish people are alive.",
      "word_count": 17
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "They took us to a little place.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 4,
      "text": "And there [NON-ENGLISH]-- [NON-ENGLISH]-- the name of the place-- I remember now-- [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 5,
      "text": "It was a little town.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 6,
      "text": "And we went to this town.",
      "word_count": 6
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 7,
      "text": "And there we met-- we met Jewish people in a house.",
      "word_count": 11
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 8,
      "text": "It-- it's a-- it's born a family.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 9,
      "text": "They came back, and they find the house-- their house.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 10,
      "text": "So everyone who was free came to this house.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 11,
      "text": "So it was maybe 30 Jewish people that came together.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 12,
      "text": "We stayed there, maybe a-- a week.",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 13,
      "text": "They gave us to eat-- one-- who has something to eat, he gave us.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 14,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "No, we didn't know each other, but one said I'm from this place.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "I'm from that place.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And we've been happy.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "We've been very close all together.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "We cried together.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "We've been happy together.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And we stayed just one week.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "We couldn't stay more, because there were no place.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 9,
      "text": "We-- we slept in a-- in a chair-- where we find.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 10,
      "text": "And then we went to see-- to see where-- to see a place where to live, where to stay.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 11,
      "text": "So we walked another week.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 12,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "We walked.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We-- we find-- we find two sisters and a brother.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "They're from-- from-- [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "So we got very close, and we walked.",
      "word_count": 8
    }
  ],
