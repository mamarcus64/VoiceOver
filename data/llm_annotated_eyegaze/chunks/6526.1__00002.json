{
  "stem": "6526.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And secondly, business on Fridays was almost nil because the work was mostly the customers that we have that were traveling from far east, from Brest, from [INAUDIBLE], from Baranovichi, from Lodz and Rovno and Vilna, had to pass by our town because it was the main route from Warsaw to Moscow, to say it.",
      "word_count": 55
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And they all stopped, used both gasoline and came to the restaurant.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And the same thing was with buses.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "There were buses that are going to Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "But just like have long distance buses here, and this.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "It was a restaurant--",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Kosher.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "In our town, there was no such thing as non-kosher.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Whoever wanted to eat non-kosher had to hide and go to a-- to a store that sold non-kosher meat, which was kielbasa, and some other meat, that no one should see you.",
      "word_count": 32
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "So the-- the town was a 10-- population of 10,000 people with about 65% to 70% Jewish.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The specialty of town were- were a they use to manufacture of tallits, prayer shawls.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And there was a factory, a few-- [PAUSES FOR 5 SECONDS] produced leather.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Tanneries.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "A few people that had tanners, different things.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And were also a big factory that produces sheep clothes.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Sheep skin coats.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Not only sheep skin.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "They used to buy the sheepskins from overseas.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Not overseas, from Europe, other places, to have enough to produce.",
      "word_count": 11
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "So they used to go-- I know because some-- some of them are friends of mine.",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "They used to go to Yugoslavia.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "They used to go to Greece.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "To places that they had a lot of sheep.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "They bought the sheep, the skin, there and produced sheepskin coats that the villagers, the farmers used to buy.",
      "word_count": 19
    }
  ],
