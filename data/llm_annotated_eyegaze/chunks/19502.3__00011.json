  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "But we didn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "We didn't stay in our house, no.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "We stayed-- most of the people we gathered them on [NON-ENGLISH] Street, and we stayed over there.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And there was [NON-ENGLISH] at her place.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "She used to make-- they made the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "And we gathered all into her place.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "Look how many people that were there, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "She used to do cooking and baking.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "And she says it's such a pleasure.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "At least I've got, you know, but it-- it-- it was a-- like a family, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "We gathered like a family.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "And-- but then later, I lived with my brother and my [? ex ?] sister-in-law, who lived further down, you know, in another part of the town.",
      "word_count": 27
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, my brother was married.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And yeah, was married.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And as a matter of fact, my-- my sister-in-law was four months pregnant when he was killed.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "My brother was killed after the war.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "He was-- there's many stories were going around.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "There was a train going from [NON-ENGLISH]-- from [NON-ENGLISH] to [NON-ENGLISH].",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "A train was going, and there were only two Jewish boys, [?",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Goloup ?] and my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And they were coming home, because it was [NON-ENGLISH].",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "In Russia it's a big holiday.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And he was coming home, and I was coming from Kiev, from school I was coming home.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And he never arrived, and never arrived.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "And then there were rumors around that they-- he was killed.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "They bombed the train and so on.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Some people-- rumors were going around that the [NON-ENGLISH]-- you see, what-- [NON-ENGLISH].",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "What happened, they were promised independent Ukraine.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "The-- the-- the German-- the Germans promised them independent Ukraine.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "So they had-- they had guerrillas.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They had been [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "They had [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And they--",
      "word_count": 2
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Freedom fighters, you know.",
      "word_count": 4
    }
