  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] Because the Polish people, the bastards, they let the German know Jewish boy is going in the city, in the small town there.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And they want me-- this reflector, they're looking for me.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Or I running downstairs because was-- I run downstairs.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "They shouldn't-- they didn't see me, or their reflector was lighting but then 15 minutes, they didn't saw me.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And I was going home.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Still going home.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "I came home and saw my father.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And there was about 200 people more, Jewish people, living in the ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 6 SECONDS] And I told they, they took the woman to kill, and the kids.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "They didn't believe me.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "They didn't believe me.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I can't help it.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "I had no right to stay with them.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "Because they had papers to stay in the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "And when the Germans will come in the daytime, they will see me.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "They will kill my father, and they will kill me.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "I had to go away in the woods.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "It was about 10 miles from the city.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "[PAUSES FOR 3 SECONDS] There were woods.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "It was [?",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Valevkevelte, ?] then name.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "It was very thick, the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I was there.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It was October.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] I had to make a place where to sleep.",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Oh.",
      "word_count": 1
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 5 SECONDS] But then 12 boys showed more.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "And they came to the woods which I was there.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They jumped from the train.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And they were in Miedzyrecz, and they came to the woods after they was also walking two weeks.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "They came to the city where my father was, and they lived with me together.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
