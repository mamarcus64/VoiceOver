{
  "stem": "428.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "Schindler, what was-- they used to play-- what a lot of young people from Krakau, they used to belong to the Jewish Soccer Team, the Maccabi in Krakau.",
      "word_count": 28
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "So they used to play soccer there in the camp on Sunday, when-- whenever we didn't go to work.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "It was the Jewish-- by Schindler, the Jewish chief of the police was [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "He had a girlfriend by the name of Bronca.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I remember this everything.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "Was a policeman there from Krakau by the name of Mischa Gellar.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And I was with a few-- they was-- they was with Schindler all the way through the camp, Solomon Urba, he's on the picture there.",
      "word_count": 25
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They show him on the film too.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "I saw him on television once.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "I spoke to him.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "Just happened, he's very well off now, after the war.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "He was working as a carpenter.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "He was working as a carpenter.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And when the war was finished, I think so, he built himself a house.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And when the war was with Korea, a soldier came home, and he got the allowance from the government money or something, and he bought that house by him.",
      "word_count": 29
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And he built another house.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "He became a builder.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "He make some money.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 12,
      "text": "He's in Orange, New Jersey he lives.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 13,
      "text": "I'm in contact with him.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 14,
      "text": "And another-- and another very close friend of mine, he just died in Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "He-- when I was in Israel-- Adam Mandel, his name, he married.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "He lived in Israel until about two months ago.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "He was a very close, very close friend of mine.",
      "word_count": 10
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "And I got over here.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "I call up that guy.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "What-- we went to from one camp to the other.",
      "word_count": 10
    }
  ],
