{
  "stem": "3097.3",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 19,
      "text": "So '42 from August, OK? 20th to about spring of '43.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 20,
      "text": "Spring '43, they liquidated the arbeitslager.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 21,
      "text": "[PAUSES FOR 3 SECONDS] OK, the small area where this-- those 1,500 Jews used to live.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Well, they surrounded the place one morning.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Everybody had to go out from the buildings.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "You used to sit down on the ground with all hands like this on our-- on our heads, sitting like this.",
      "word_count": 21
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And they said, who works in this-- hold on, before anything, they counted off some people, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Who works at this factory?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Who works at this factory?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "So forth and so on.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I lifted myself up, because I worked here.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Mosberg got up, because worked there, you see?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Wasser, the same.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "But Minsberg had an uncle.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And the uncle had something in his house-- something-- some money, or some place there.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So he delayed coming out.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "By the time he came, already-- we were already selected to go to the factories.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "So Minsberg, one of those four, went to Pionki, to another camp.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "So from the 1,500 to Henrykow and [?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Ludvikow ?] went 400 and 400-- 800.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "The rest went to Hasag, to Blizyn, and Pionki.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "Also in the area, other different camps.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "A camp, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Part of the--",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So a factory, and people were attached to the factory, OK?",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Pionki was also a factory what they used produce the dynamite, OK?",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And [PAUSES FOR 3 SECONDS] [? pulver. ?]",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "P-I-O-N-K-I.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And Blizyn was also a camp.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Excuse me.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "But they used to have some workplaces to make uniforms, shoes, and so forth for the German army.",
      "word_count": 18
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Blizyn, B-L-I-Z-- a soft Z-- Y-N.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "That was a rigorous camp, Blizyn, OK?",
      "word_count": 7
    }
  ],
