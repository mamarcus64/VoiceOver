{
  "stem": "24651.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "When I was-- when I got into the eighth grade, my eighth-grade teacher referred to me as the little foreign girl.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "She always sort of identified me that way.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "[LAUGHS] And so we moved to Newark.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And my-- my stepmother, Sadie-- her-- her maiden name was Allman-- Sadie Allman-- she adopted me.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And they worked very hard, very hard, in the store, you know, because they had to catch up.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "She was in her early 40s.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "And I guess my father was, too.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "So they had to make up for lost time.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "She had never been married before.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I grew up in New Jersey, right.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Well, my parents' ambition was to send me to college-- send me away.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "You know, I couldn't live at home-- I mean, not that I couldn't, but they thought I-- I should have that experience.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "So I did.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I went to Syracuse, and-- you know, with nice clothes, and did very well; did well in high school, got-- got good grades-- just-- just adapted very well-- wrote for a newspaper.",
      "word_count": 32
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You know, I did a lot of the other things.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But anyway, so then I went to college, and I-- I met my husband.",
      "word_count": 14
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "I was still in high school.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "I was a senior in high school.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "He was a senior in college.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And-- but I transferred from Syracuse to Boston University.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And then I was here for a year, and we got engaged.",
      "word_count": 12
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "And so I came back to New Jersey, and I finished at Rutgers.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "So that was my college career.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I was a history-sociology major.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And-- but while I was still in school, I had my son, David, my oldest son.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "He was born in 1956.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I was married in 1955.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But I hadn't quite finished college.",
      "word_count": 6
    }
  ],
