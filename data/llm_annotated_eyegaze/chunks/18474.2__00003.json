{
  "stem": "18474.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 495.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "I was working there before.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "I crawled into the barn.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "And I'm peeking out between the-- between the boards, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And I see the help, the farmhands there.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And then I see the-- Mrs.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Prokop.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] and I called her, [INAUDIBLE] [?",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "Prokova, ?] [INAUDIBLE] [?",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "Prokova. ?] All of a sudden, she comes in.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "She crossed her heart and says, what are you doing here?",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "The Jews were already liquidated in Mlynow.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I'm telling you, the Jews were already killed out.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And the Ukrainians were hunting and the Germans hunting for Jews, of any left-overs.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They were catching them and killing them.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Anyway, she says, crawl into the straw.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "Don't tell nobody that you are here.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "Sure enough, I crawled in.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "An hour later, she brought me some bread and other stuff.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And they kept me for three days.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "And they brought me food a couple of times a day.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Then he came in on the third day, Mr.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "Prokop.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 12,
      "text": "And he knew the situation.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 13,
      "text": "He says, my father sent me a note from the ghetto with that Prokop's son, which lived in-- in Mlynow.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 14,
      "text": "And he handed over that little note to Prokop.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "And he gave me the note where he was going to be in hiding.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Anyway, I-- on the third day he came in.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "He says, tomorrow morning, he says, 4 o'clock, he says, we're going to go.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "He says, I'm going to Targowica, to a different town there.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "And he's driving by Morawica and he's going to-- he gives me the-- the-- the reins.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "I should drive the horses in a big coat on me.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "And he's sitting next to me in a wagon.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "As we're driving, he says to me, in case we're stopped, you don't say a word.",
      "word_count": 16
    }
  ],
