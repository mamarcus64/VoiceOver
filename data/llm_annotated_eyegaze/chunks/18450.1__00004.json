{
  "stem": "18450.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 460.1,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And you-- you know, you were like isolated a little from the rest of population.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Almost, almost, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Not exactly, because I was out of school, and it started the summer.",
      "word_count": 13
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And the air wasn't clear all that.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "In Poland, there were seven grades.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But the curriculum was much tougher than here.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Seven grades, it was like high school here.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And it was the summer the war started.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] Well, almost nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "We used to go in the woods and pick up some mushrooms over there.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Well, and you know.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And you belonged to a Jewish organization, whatever it was there.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And friends, and that's all.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "Saturday, you used to walk around the city.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "It's like was the usual, you know, time in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yeah we went to-- I was-- they call-- used to call Bital.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I guess it's B-I-T-A-L.",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And it was a better-- I didn't know.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "It was probably my friends and whatever there.",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And then was a [?",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Czomer ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Raziel ?] was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "My brothers belonged to the [?",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "Czomer ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 8,
      "text": "Raziel, ?] because most of the boys belonged there.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "A Czomer, C-Z-O-M-E-R, [INAUDIBLE], R-A-A-Z-I-E-L.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "That's I would spell it.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes, 100%.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "As far as I remember, no.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "It was just the most social.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "It was a social organization that-- it was a place to gather, that young people gathered.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And they had meetings and lectures and all the things.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "We had theater, not as here, but we had.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "We had a movie.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "And most of the-- we had lectures from certain people who came in, most on the-- from the Zionist organizations.",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They used to have lectures.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And they tried to persuade a lot of people going into Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And a lot of them went.",
      "word_count": 6
    }
  ],
