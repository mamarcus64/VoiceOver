  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And that was the second, no, that must have been about the 5th or 6th of September 1948.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And I landed in USA, 15th of September, a week later.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Excitement, how many times can a person be killed.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHING] I felt like I'm a cat.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "How many times can I kill you, but this one was tremendous.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And also when I was on the airport, I had a terrible experience.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The immigration, the check, one guy came and said, this is your-- I had one suitcase.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "He said, what's in it?",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Open, clothes, junk.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "He said, oh no, this one's going to take me more than three hours, your plane leaves in three hours.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "To do it, you have to leave with the next plane.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I knew there was no next plane.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "There was no next plane.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "I go, what shall I do?",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Well, at that minute, somebody comes to him and he tells him-- [CRYING] tells him, you know, you're wanted in the office.",
      "word_count": 22
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Why don't we change tapes, OK?",
      "word_count": 6
    }
  ],
