{
  "stem": "17299.4",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And then they put Latvian SS to chase us even more that we should do the work faster and instruct the Latvian SS, if you see a Jew picking anything up like he's not supposed to pick up, shoot him.",
      "word_count": 40
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Middle of July, '42 the Germans start taking out the Jews back to the ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Because they were putting gentile Latvians in.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "First they had put in women.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Now they were putting males in and putting a big fence around the camp, also.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And I was marched back to the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And I was 24 hours in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And then I had to stand up for roll call.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "And I was selected to work in a motor pool for the Gestapo-- or [GERMAN], what they called.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "That was the killer kommando who did the mass killings.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "I was on [GERMAN].",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "The Germans called it [GERMAN], in Riga.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "For 10 months.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "When we marched in, we got greeted by two SS NCOs, [GERMAN], Walter [?",
      "word_count": 14
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Weiderman ?] and Heinrich-- no, yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Wait a minute, Walter [?",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Weiderman-- ?] no, I can't remember the name of the other.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "He-- Lad-- Heinrich [?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Ladovitch. ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Ladovitch ?] greeted us with a rubber truncheon.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "Weiderman ?] was nearly seven feet tall.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "He only had to kick or to slap somebody.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And then we were assigned to work.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And I'd always had to go fast.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "And if you made a mistake, you had a kick in the rear or you had a slap.",
      "word_count": 18
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "And you would not get any food.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 14,
      "text": "And you had to work 10 hours a day.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 15,
      "text": "I was assigned to an [GERMAN].",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 16,
      "text": "That's an NCO, staff sergeant-- [PAUSES FOR 3 SECONDS] Dausig.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 17,
      "text": "He was from Osnabruck.",
      "word_count": 4
    }
  ],
