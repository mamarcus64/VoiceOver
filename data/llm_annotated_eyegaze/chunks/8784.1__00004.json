{
  "stem": "8784.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "On many occasions as I walked to school from Borek Falecki to Krakow, somehow the non-Jewish children knew that we were Jewish and they would throw rocks at us, at the Jewish children.",
      "word_count": 33
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So anti-Semitism, we lived with anti-Semitism.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "It was one of those situations that we couldn't get away from.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And it was especially true with Hitler's coming to power in Germany.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Were you aware of Hitler at that young an age?",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "We were aware of Hitler.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "The newspapers carried the stories.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "The radio, you would hear the broadcasts about Hitler.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "You would hear the broadcasts telling on how supportive many of the Poles, many of the Polish organizations were of Hitler.",
      "word_count": 21
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So you would hear of Hitler.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "You would hear about bad things happening here and there, but not, not so much as we felt the anti-Semitism coming from the Poles.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Your family was quite large.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "Could you describe your family and your home a little more.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Our family of six children, as we were in 1933, were two sisters and four brothers.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I had one older brother than myself, three years older.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "My sister, the older sister, was a year and a half older than I was.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And my younger sister would have been younger than I was by two years.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And the two youngest brothers were, were four and five years younger than I was.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So when the World War II broke out, my, my brothers and sisters were ranging in age from eight or seven to 14, 15.",
      "word_count": 24
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "My brothers, older brother's name was Samuel.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "My older sister was a Rifka Regina.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "Younger one was [?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 10,
      "text": "Anne ?].",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 11,
      "text": "The two younger brothers, one of them was Simon and the other one was Haskel.",
      "word_count": 15
    }
  ],
