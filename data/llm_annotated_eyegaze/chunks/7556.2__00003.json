{
  "stem": "7556.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And some people had to put the-- a number on the pots or whatever it was, and other were carrying it like this on the wooden board to the oven.",
      "word_count": 30
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And it was too heavy for me each time I had to carry it.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS] The pots fell on the floor.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And the Polish supervisor got very angry at me.",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "He said-- he called me all different names.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "I don't want to repeat it.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "And he gave me a can with water.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "He said, you're going to work the whole night and spill the water on the floor.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "It shouldn't be so hot, but you won't carry the pots and pans anymore.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So this was my first job in Emalia.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "And then when they opened the other side where they made the ammunition-- so I was transferred on the other side, and I was working at the-- [PAUSES FOR 3 SECONDS] a little instrument.",
      "word_count": 34
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I don't know how to call it today.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember the name of it.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "One of the parts that eventually was made into a gun.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "So you were making that every day?",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "One week during the day, one week at night.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "The same job.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I think we had one day off, if I am remembering exactly.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "I think, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And there was a kitchen provided by Schindler, and we could have our hot meal during the intermission, lunch hour, whatever.",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We didn't call it lunch hour.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I knew him, and he knew all his Jews, as he called.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "But he never referred to us as Jews.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "He used to say my children, And I remember one night shift, I was working at the press, and I had a bandage on one of my hands.",
      "word_count": 28
    }
  ],
