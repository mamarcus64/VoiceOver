{
  "stem": "2170.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 26.5,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And he's running straight to our house.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "As they walked up the steps, and they came into the house.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And they said-- the German said to my brother-in-law, Zynsztein-- his name was Zynsztein-- you don't worry, and also the [INAUDIBLE] of the police.",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "You your family are going to survive because you are tailors.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "And we're not going to kill you, but you come down right away with us.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So my brother-in-law and my sister, they took each other by the hand, and I was walking after them.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And as, as we came down from the house, that woman with the two children, they took her out, the Jewish woman.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And she started screaming and crying for the Germans, for the Gestapo, that her children are not Jewish.",
      "word_count": 18
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They took her the same way.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "As we walked down the couple steps from the house, a Ukrainian-- I saw already fire.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "The Ukrainian policeman-- later on I knew his name was Kobaliuk-- he pull his gun.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And a man was running, to run away.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He shot him dead right near my legs.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I saw the fire of the gun of the bullet, coming through my eyes.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "As we are going already, I saw this is-- this is the end.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And we're walking towards the center of the city of that town, which was only, maybe, about 10 blocks away.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "The snow was white.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And I see bodies laying all over near the houses.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "The blood on the white snow, all over.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And as we come to the center, I see thousands of our people-- Jewish people-- in the center, standing.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "There's one group on one side, and another group on another side.",
      "word_count": 12
    }
  ],
