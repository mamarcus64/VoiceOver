{
  "stem": "8352.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.6,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "They beat you or they sent you outside somewhere and you got beaten up.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "That was going on for months, and months, and months.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "That was our hard labor camp.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "That's a good question.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "If there were people missing, they kept us outside there until they accounted where that person is.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "They would not let us in.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "If they found out that he died, or he ran away, or he was hiding out, or where he was, they would not let us in.",
      "word_count": 26
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Once they had the results of him, we don't know what, then they let us in.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "There were some people, when they lost their mind, and they did some bad things like they tried to fight or they tried to run away.",
      "word_count": 26
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "They didn't care if they will get killed or no.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "They got caught by the SS.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "We had a thing where they hangin' them in the middle of the, of the appell place.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "They used to catch those guys.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "Now, people start to lose their mind and they go crazy.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "They didn't know what was going on with them.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "They used to catch them.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "They called all the people out of the buildings.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "Appell again.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "Take that guy, pull him up there, hang him in front of us, that we could, we could all see what will happen to us if we don't follow the orders.",
      "word_count": 31
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "[SIGHS] The food was very bad.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "A lot of people were big smokers.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "They used to smuggle in cigarettes from outside.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "You know, like my father, should rest in peace, he was a big smoker.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "A lot of people were like that.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "They used to-- somehow they used to bring in a cigarette.",
      "word_count": 11
    }
  ],
