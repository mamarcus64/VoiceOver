  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Bert Strauss.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Germany in 19-- April the 29th, 1925.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And my given name at that time was Berthold Ludwig Strauss.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "I was born in Gemunden an der Wohra, which is in the district of Kassel.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "My Jewish name was Baruch ben Yitchzak, named after my grandfather-- father rather, who had lived in Gemunden since 1863, I believe it was.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "My mother is from Gemunden.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "My father was born in the southern part of Germany in a small little town called Billigheim in [INAUDIBLE], Mosbach.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And he married into this house.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "The house I was born in and lived in had been occupied by my parents, grandparents, great-grandparents, and their parents before that.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "I believe to the best of my knowledge, the family lived in that house since the early 1800s, or possibly even the late 1780s.",
      "word_count": 24
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "In any event, I had a very nice childhood.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "We lived in this small little town.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "My parents were in the general goods business.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "We had a little store, as well as a farm.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And we work the farm, as well as did business out of the store.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "And I helped and I was exposed to both of these enterprises as a child.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "And obviously, it gave me a lot of insight into what business was all about, as well as what agriculture was about.",
      "word_count": 22
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 17,
      "text": "My childhood from the age of three-- I can remember that far back-- till the age of about six or seven was, I would say, a kind of childhood any child might have wanted to have-- serene, loving, caring parents and grandparents.",
      "word_count": 42
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 18,
      "text": "I had two aunts living in the house where I lived.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 19,
      "text": "And in 1926, I had a-- a little sister was born into our family.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 20,
      "text": "Her name was Greta.",
      "word_count": 4
    }
  ],
