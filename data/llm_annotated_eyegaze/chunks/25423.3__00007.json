{
  "stem": "25423.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "It was very dangerous, because I could be suddenly caught and people, say, take my documents away, tear them, and shoot me.",
      "word_count": 22
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "So, it was taking my life into my hands each and every time I went on the railroad.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yes, but it was not closed yet.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Slowly, it was the same process.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "Namely, removal of Jews from the luxurious areas.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Then, squeezing them into smaller, and smaller area.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "But the ghetto was not yet defined or closed.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Before my escape.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother moved first to one place, and then to the final ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "She moved twice.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I was in Rawa Ruska.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Regularly, stayed there a few days, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "She lived-- the first move was to what used to be a Jewish quarter.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "It was a [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Actually, if you are interested, this was a square.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "They used to sell fish in huge wooden tubs.",
      "word_count": 9
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "It was not too far from the orthodox synagogue.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "She has done it on her own, and she moved only few possessions because the furniture, everything else, was left behind.",
      "word_count": 21
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "It was impossible to take with the limitation.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "The second move was into the final ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "I escaped shortly before it was closed.",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "For two weeks.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "No, no, I wasn't there.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "The second place was one apartment shared by three families.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "So, first she lived in an apartment by herself with the children.",
      "word_count": 12
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "Then she shared an apartment with three more families.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "And then finally, everybody had three square meters assigned.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "In their first apartment, it was the widow of my uncle, who was shot with my father, also a prominent rabbi, his daughter, who was a child, and some other people whom I don't any longer remember.",
      "word_count": 37
    }
  ],
