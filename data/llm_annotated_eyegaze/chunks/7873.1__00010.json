    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "They-- by generation, generations, they were Germans.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "And we lived nicely with them, better with them than with the Poles.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "Till Hitler came in.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "Then they changed not just an armband, they changed the whole uniform.",
      "word_count": 12
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 12,
      "text": "Put on a-- right away, they put on the yellow uniform.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 13,
      "text": "They became-- they joined the party, the National Socialist Party.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 14,
      "text": "And they became Nazis.",
      "word_count": 4
    }
