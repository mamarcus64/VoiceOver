{
  "stem": "15732.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I think that there were 100,000 or 120,000 Jews in, in, in Chernivitsi But I don't recollect it exact.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "That might have been less than that.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "But I don't recollect the exact number.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "The non-Jewish people that were in Chernivitsi were mostly Romanians that came with the administration after 1918, with the Romanian administration of the, of the city.",
      "word_count": 26
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "But were a few professionals.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "There were peasants that were around the town.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "But in that town, I think there must have been maximum 10% Romanians, maximum that I recollect of.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It was a Jewish life.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "It was a Jewish city with a very active Jewish life who had a lot of Zionist parties.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "There was the Bund.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "There was everything on the Jewish, on the Jewish interest there was.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "I was a bit too young to be so much part of it, as much as I know that my father was member of a Zionist organization.",
      "word_count": 27
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "My grandfather belonged to one of the numerous [INAUDIBLE] temples, would you say here or shuls, synagogues, that we had in, in Chernivitsi.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "We had a Jewish theater.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "We had a Hebrew school.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "It was a nice city.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "It is hard for me to, to answer that.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Most people were traditionally religious.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "The-- all the variations that I've learned in the last few decades to, to [INAUDIBLE], I do not know how they were in Chernivitsi, It's something that I cannot answer.",
      "word_count": 30
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "My grandfather was a traditional Orthodox Jew.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "My father not-- my father was in national thinking [PAUSES FOR 3 SECONDS] Jew.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "But he was not religious.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Gustav Herscher.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "He was a tailor.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He was born in Poland in a little town called Skala, which was on the Russian-Polish border.",
      "word_count": 17
    }
  ],
