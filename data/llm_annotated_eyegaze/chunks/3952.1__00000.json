{
  "stem": "3952.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Can I see that name again?",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "From this side it sounded-- it looked so different here from this side.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS] That's why I wondered.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My name is Izchak, I-Z-C-H-A-K, Goldblatt, my last name, G-O-L-D-B-L-A-T-T.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I was known by the name of Icu.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "That would be I-C-U, Icu.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "That's how my friends called me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "That's how they called me in the house.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Birth date is May 5, 1927.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "68.",
      "word_count": 1
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Born in Sighet, Romania.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "S-I-G-H-E-T.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Romania is R-U-M-A-N-I-A.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "That's where I grew up till I was 17.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Childhood-- well, I didn't really have a childhood.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "I always liked to say that I was born old, and I'm getting younger every day.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And I'm trying to prove that by playing tennis and ping pong as much as can-- as I can.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "But there was a childhood.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I was a child.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I remember when I was a kid.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "We lived in a village near Sighet at the beginning, and-- where my father was the notary of three villages.",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "It was Upper [?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "Rona, ?] Lower [?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "Rona ?] and [?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "Ronasak. ?] Those-- those were the names of the three villages.",
      "word_count": 11
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Well, as it-- why did I say where I wasn't a child?",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I didn't have a childhood because there was no time to play.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "You got up at 6 o'clock in the morning.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "I went with my two brothers, two of my brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I went to cheder till-- from 6:00 to 8:00. 8 o'clock we went to school, to public school.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "That was 'till 12.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "And then we head back to cheder and we had a sandwich-- kind of a sandwich, bread and butter for lunch-- and we continued there till 2 o'clock. 2 o'clock we went back to school.",
      "word_count": 35
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It was till 4 o'clock.",
      "word_count": 5
    }
  ],
