{
  "stem": "1733.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 170.9,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 27,
      "text": "It's an area office, area official office.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 28,
      "text": "And all the-- I was in charge of all the mail that was coming in to that-- through the area from any official government offices.",
      "word_count": 25
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 29,
      "text": "Everything was coming through my hands.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 30,
      "text": "And I was in a position to see when the Russian government was asking the Czech government to find the Schneiders, which was my wife and my-- and her two sisters and brother-- and bring them back to Russia, because they registered-- when they came out of the camp, they registered as Jewish nationality, and the Russian government wanted them back because they considered them as Russian citizens.",
      "word_count": 68
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 31,
      "text": "When I got notice from the chief of police from Prague that the Russian government was looking for them, I took it, and I put it in my drawer.",
      "word_count": 29
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 32,
      "text": "I didn't turn it over to anybody.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 33,
      "text": "Then a few weeks later, they were-- I got another notice telling me that these people were not rounded up.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 34,
      "text": "They know they live in Zatec, and a copy of the letter is going to the police.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 35,
      "text": "And I got only one copy of the letter.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 36,
      "text": "So that day, they had to leave Zatec.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 37,
      "text": "They had to leave the town, because I knew that the police is going to pick them up.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 38,
      "text": "They went to Karlovy Vary, and from there, we went to Prague.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 39,
      "text": "We already had papers to come to the United States.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 40,
      "text": "My wife, her two sisters, and brother-in-law had papers from their uncle, Uncle Henry.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 41,
      "text": "And I and my two sisters have papers from my father, that he sent us the papers.",
      "word_count": 17
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 42,
      "text": "They bought flight tickets from Paris to New York for us, so those tickets were paid for already.",
      "word_count": 18
    }
  ],
