{
  "stem": "3994.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "In Gyor, Judy was born in Gyor.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "'46.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "September 23.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "We were very, very happy for quite a while.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "Everybody was happy.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "Everybody started again to come together and--",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "We had a shop.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "A textile shop.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "And we were very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Judy was born and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And when the children, my two sisters had a boy, [INAUDIBLE].",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "My Greta had [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "Herta had Peter.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And we went-- we were very close.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 7,
      "text": "Cousins, they went to school together.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 8,
      "text": "They were about six years old when Judy came home from school and the others, too.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 9,
      "text": "And they said, you bloody Jew in the school.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And then when that was happened, we couldn't do anything.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "But we said, if the first opportunity to get out from here, we go.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Well, the first opportunity was when the Hungarian revolution was.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "I went both to my sisters and said, through the night, at 12 o'clock somebody will pick you up, to my other sister, too.",
      "word_count": 24
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "We paid a bus from town hall.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "We left the key.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "Everybody left the key in the flat.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "The kids got a little bag in each bag on the back.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "If anything happened to us that we couldn't go through, we said that we had arranged that who will take the kids.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "But luckily, we were very lucky.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "We escaped very well.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And we arrived the next morning in Vienna.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "And I never look back.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "I never have been in Hungary.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "I have only have been once in Austria, because I needed some documents from there.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "And I have never been back.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Everything.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "We arrived in Australia every couple with $2.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I wanted to go far away from Europe, as far as I could.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "I worked on the Australian [? council. ?]",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "When they got to Austria.",
      "word_count": 5
    }
  ],
