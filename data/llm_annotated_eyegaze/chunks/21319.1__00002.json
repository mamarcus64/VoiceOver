{
  "stem": "21319.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.3,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "That was one who the father was, I think-- he was the premiere-- I don't know how to call it-- to say.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "He was in the economic division in the-- in the government.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And his daughter and his son were my friends.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I was very religious.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "I never could eat in their house because of kosher.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "But we were very close friends.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "And I remember her brother's-- his name was [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "And her name was [?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Wanda. ?] And I'm-- he was-- oh, he was the Minister of Finances in the department, in the government.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "But the part of it, where in Vilna, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "And I forgot-- yes, she-- I forgot I have-- since I had the stroke, I forget everything.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "So what can I do.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "But we had a very loving family.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I had mine older sister, Miriam, as I said, the one who went first, who was taken in and killed.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Miriam, her husband was Itzak, and her son, [?",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Mayer, ?] and three daughters.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Two was to [INAUDIBLE] and [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "The little one, when she was breastfeeding, and she was in-- in like, in the late 30's then.",
      "word_count": 18
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I don't remember the name.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And then I had a sister, Julia, who went to Havana, Cuba, with her husband when I was eight years old.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And she's-- she lived in Cuba until Castro came to power.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "Then they came to United States.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "They had-- their daughter lives in Boston, who is a teacher of music.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And son-in-law is a scientist.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "And they have two daughters living in California.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I was in Hebrew gymnasium.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Gymnasium [INAUDIBLE], on the [INAUDIBLE] street.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And I wanted to be a dancer.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And I wanted to be writer, and all these dreams I had.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "I took dance lessons for three, four years.",
      "word_count": 8
    }
  ],
