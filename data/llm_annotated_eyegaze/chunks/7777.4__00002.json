{
  "stem": "7777.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.8,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 64,
      "text": "As I just was hoping to get out, when I get out, if I live, to be able to go to this pump, to get a drink the water.",
      "word_count": 29
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 65,
      "text": "After two weeks being in this, we hear Jewish [INAUDIBLE] going around.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 66,
      "text": "They talk Jewish-- will nothing more happen to this town.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 67,
      "text": "In Jewish-- [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 68,
      "text": "[NON-ENGLISH]-- no more killing.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 69,
      "text": "We come out [INAUDIBLE] over there a guy by the [?",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 70,
      "text": "Shia ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 71,
      "text": "Lablanda. ?] The [NON-ENGLISH] have some people.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 72,
      "text": "When they took the clothes, the people went naked to the graves.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 73,
      "text": "Everybody was naked.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 74,
      "text": "The people-- he had some Jewish people for they work for their clothes-- was a school over there.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 75,
      "text": "They call this the red school.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 76,
      "text": "And they took over there the clothes.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 77,
      "text": "I just was before there-- I was going to work.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 78,
      "text": "I was wishing, everyday, I wish I get killed, and not to know when, not to come back to the ghetto.",
      "word_count": 21
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 79,
      "text": "Because I know what is waiting for me in the ghetto.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 80,
      "text": "After the 14 days, people start to come together.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 81,
      "text": "People was hiding in the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 82,
      "text": "People was hiding in different places.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 83,
      "text": "But Gentile came together.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 84,
      "text": "There was-- they got together about 2,000, 3,000 people.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 85,
      "text": "It was taking about two months, til-- til November.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 86,
      "text": "And the [NON-ENGLISH] said they make a new [NON-ENGLISH], a new Jewish committee, a Judenrat.",
      "word_count": 15
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 87,
      "text": "And the people going back to work.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 88,
      "text": "And nothing happened to this.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 89,
      "text": "Only here was about 15,000, 16,000 people.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 90,
      "text": "Before now, it's just 2,000, 3,000.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 91,
      "text": "You have to make a small ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 92,
      "text": "We make a small ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 93,
      "text": "We was over there about six months, until May.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 94,
      "text": "I was going to work.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 95,
      "text": "In this time, I went with my brother to work in a factory, they make belts.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 96,
      "text": "We were making the belts.",
      "word_count": 5
    }
  ],
