{
  "stem": "10.5",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.4,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And then here, she was there.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "This is-- When did you and your wife come to the states?",
      "word_count": 12
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "We came-- we remained till June, '46.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "She came about in February, '46 from Paris.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "And I still worked with the American war crimes, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "And then we got an apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "The Germans had to give me right away an apartment because I couldn't live in the hotel with the officers and with my friend, you know?",
      "word_count": 26
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "We got an apartment.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And we lived separate.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And I went every day to work.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And here, we have to go to Germany-- to America.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We have no money.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "Sieg.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "We will go without money.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "What will we do?",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "I got a salary from the Americans.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And my money, I sent every month to Cleveland to my cousin through the APO through the military [INAUDIBLE] mail-- post.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "And I kept here a few thousand dollars.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So I said, we have no money.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I will do something.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I would go into the black market.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And all of my friends, they became millionaires.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "They did black market in Germany, smuggling cigarettes, liquor, and all those things, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "They became millionaires.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "So I never wanted to do it-- never.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "I said, I don't need it.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "Because I thought I come to the United States, I will go in my profession, and I will work as a pharmacist.",
      "word_count": 22
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "I don't do this kind of work.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 5,
      "text": "She said, we have to do it, she said.",
      "word_count": 9
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So I went every morning to work.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "And I [? sold ?] to all the officers-- do you need some money?",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They gave me dollars.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "I took it-- the lunchtime route, went to the DP camp, displaced person camp, near Frankfurt.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "The name was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And in the afternoon, she brought money.",
      "word_count": 7
    }
  ],
