  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "All Rome-- all over Rome, I went to see all the places.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "One day, I-- they asked me in the office about America-- to fill out forms.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't remember the name of my aunt.",
      "word_count": 8
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "So they said, if you don't know the name, you cannot find-- you have to know the name.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Where is she located?",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "What is her name?",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "So I-- they asked me, do you want to go to-- you're from Czechoslovakia?",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "There's a transport train leaving from here, from this camp, back to Czechoslovakia.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 9,
      "text": "I said, OK, I'll go.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 10,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 11,
      "text": "Because I  want to see if somebody from my family survived.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 12,
      "text": "Maybe a brother survived, maybe my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 13,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 14,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 15,
      "text": "So I joined this train.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 16,
      "text": "And it took me to Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 17,
      "text": "So you went back to Czechoslovakia?",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Czechoslovakia.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "That is it.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "That's It.",
      "word_count": 2
    }
  ],
