{
  "stem": "7455.6",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 20,
      "text": "They are short of manpower, so they are catching young girls to go work in their factories.",
      "word_count": 17
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "So I said that my stepmother would like to get rid of me, and I don't want to go to Germany because Germany's being bombed day and night.",
      "word_count": 28
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "So that I-- that's why I'm working.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "He said, oh, you're so smart.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "They liked me.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "They were playing the harmonica and talking and so on.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "And for a few days, I felt-- for a few weeks, I felt safe.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "It was a sort of remote village.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I'm trying not to get into-- much into conversation.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I don't even want them to know that I'm working because I don't look like a peasant working.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "They may think I'm related.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "I'm just coming here for the summer.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "And suddenly, something terrible happened.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "Her husband, Vincent, had a heart attack.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "They rushed him to Tarnopol to the hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "After a few days, he died.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "Now Sophia, she went to stay with him.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "So I was left in my house-- in the house taking care of the baby.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "She was very appreciative that she has somebody to leave her baby with.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "I was very good with the baby.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "After he died, and they brought him back to that village where the funeral took place.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And her mother came, her family came, and there was all that procedure where people come, and so on.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "She was heartbroken, completely lost.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "And she appreciated my being-- taking care of baby.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 18,
      "text": "But then they decided-- and the mother said, you are alone here with the baby.",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 19,
      "text": "Come live with us.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 20,
      "text": "That she should move to go with the family now that she's a widow.",
      "word_count": 14
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 21,
      "text": "And it was decided that Sophia will go to live with her mother.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 22,
      "text": "Her life has changed.",
      "word_count": 4
    }
  ],
