  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Who is-- who-- who's here, the barrack, responsible, the-- the-- the barrack foreman?",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "So I'm [? one. ?] What is this here?",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "There's some-- something irregular, some-- some dirt, some-- come out, and he shot him.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "He told him, knee, kneel down.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "And the man was, of course-- I have-- he said, I have a wife, and I have children.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "Please.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "Kneel down, and he shot him.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "What was his name?",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I forgot.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "I forgot his name.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Yes.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "It was a-- it was a tremendous traumatic experience, traumatic experience.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "I still can see this man in my-- in my nightmares, in a pool-- lying in a pool of blood, like in my nightmares.",
      "word_count": 24
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And I have very often nightmares at night pertaining to my history and pertaining to-- to the Holocaust and to the years-- my-- my years of 1939 and-- and '40-- to '45.",
      "word_count": 32
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "[SIGHS]",
      "word_count": 1
    }
  ],
