{
  "stem": "353.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "My friends started businesses there.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "So I helped them.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I was working a little bit.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "You had an application in, too, for a visa to come to the United States?",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "I was waiting until I get the visa.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "An affidavit.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I had here family who was very, very old man.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "He was 92 years old.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "I never met him.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "He died before I came here but I got a letter from him to Austria, to Vienna, that he's alive.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And when I came to United States I had a hard time.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "I couldn't find a job.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "My first job was [INAUDIBLE] Matzos.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "I was stirring the dough.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "I was working there maybe for two months.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "They didn't let me work 40 hours, only 30 hours.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "They-- they had more people to employ, other people like me.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "So they had to spread the hours.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "Then I quit the job and I went to learn machine shop.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "My brother, who lives here, he is machinist from--",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "He came eight months before me.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "He was a single guy.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "He got the visa before I got, and he came here.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "He started to work and I came here and started to go to school a little bit to learn English and then to learn some tool making.",
      "word_count": 27
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And slowly, slowly I went to work and from work-- [INAUDIBLE] And I built myself a business, and I was in business for many years, for around 30 years.",
      "word_count": 29
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And I will tell you the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "God bless America.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "America was good to me.",
      "word_count": 5
    }
  ],
