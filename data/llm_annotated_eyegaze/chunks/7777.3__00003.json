{
  "stem": "7777.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "And we put it, in this basement, was two benches.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "There also over there was working two tailors.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "They bring him in, too.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "There was already 12 people.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "When we come in this room, we say, maybe you will give us a little bit water after a day work.",
      "word_count": 21
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "He said, you don't need more water.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "And he locked us up.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "Later, we hear the doors opening up.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "The Ukrainian police come in and take away-- somebody got a sweater, a good jacket, they took it away.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And we sitting over there.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "A couple hours later, again open up-- comes in another Ukrainian-- two Ukrainians.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "So they look.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "There was already nothing to take, because the other was taken.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "We were sitting over there.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "We know we will be killed very soon.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "We were sitting and crying and howling, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And we say, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "I say it, [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "And we was prepared to get killed.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "We just was begging, God, if we have to get killed, why we have to keep us here?",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "Kill us right away.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "We know we dead, no question about it.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And we sitting in this basement.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We have a little window over there.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "It was open.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "We hear they said in Polish, [POLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Boys, get ready.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Take the shovels.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "We know they go dig the holes for us.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "We was praying a whole night.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "Nobody was sleeping, just what faster to get out, killed.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "At 6 o'clock in the morning, we hear it's got life, people running around.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "We saw some German.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "We saw lakes.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "We don't saw the people.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "No, we-- we understand already they getting prepared for us to get killed.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "We're sitting over there till about 11 o'clock, 10 o'clock maybe.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "The doors opening up.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "There come a cart in the hallway.",
      "word_count": 7
    }
  ],
