{
  "stem": "8703.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 15,
      "text": "We have a sister in Israel.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 16,
      "text": "We-- I finally I found-- at that time, I found her whereabouts, you know, in Israel.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, in Palestine.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "And I, I wrote a letter.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "And she received the letter.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "And I said, we have to go-- leave Poland because there was no life.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "There was no future in Poland at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS] So we decided--",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "We decided to leave Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "From Lodz.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So a friend of my-- a friend of mine who lived over there, a neighbor, he said, if you leave Poland and if you go to Austria or to Germany, you've got to have marks.",
      "word_count": 35
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Marks, with the German--",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "--German marks.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "German currency.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "So I said, I don't have any marks.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "He said, don't worry.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "I'll get you some marks.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So once, he came in.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And he said, OK, Kaminsky, I've got somebody who has marks for you.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "I says, who is this?",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "This man has marks for you.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "He said, how many do you have?",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "I said, what, I don't know. 10,000 marks or something.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "I said, how much is it?",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "So he told me a certain amount of Polish money.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And I took, and I paid him.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And as soon as he got the Polish money, he put it into his pocket.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "And he took out one side a revolver, and one side a, a, a this, showing me that he is from the UB.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "You call it the UB, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "It's from the-- from the-- from the police.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And you are under arrest.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Me and my brother.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "They were accusing us that we were dealing with marks and money.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I said, I don't have any anymore, the, the new-- the new money.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "You can check.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And they were looking all over.",
      "word_count": 6
    }
  ],
