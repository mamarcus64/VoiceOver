  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "You're-- so [PAUSES FOR 3 SECONDS] in strain all the time that you miss out a lot.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Then later, you think, one word I would have told him, I could have had it.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "OK, so--",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "In Dachau?",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, I was safe.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "I was so safe [PAUSES FOR 3 SECONDS] that sometime a colonel who was involved, you know, with that trial [PAUSES FOR 3 SECONDS] said to me, Moses, can I wake you up one time around 1 o'clock or 12 o'clock at night?",
      "word_count": 43
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "I want to show you something that you are going to be very happy.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And it'll be your memory.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] And he said that he had a permission, if I say yes, to take me.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "I says, if it's going to be my memory for good, you can take me.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "So one day, he knocked on the door.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And he says, Moses, I'll take you right where all the 40 prisoners are sleeping [PAUSES FOR 3 SECONDS] in their circumstances.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And through a window, you know, I can hear everything what they say, something like that, you know.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I can see them.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But I don't think they can see me, something like that it was.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And I could hear what they're talking.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "And I heard that the-- all the 40 criminals were fighting with each other, not in physically fight, but mouth, cursing each other.",
      "word_count": 23
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "But you were the main chief!",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "You told me to do that!",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "So I did it!",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And that was saying, you were higher than me!",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "I didn't want to do it.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 9,
      "text": "You forced me to do!",
      "word_count": 5
    }
  ],
