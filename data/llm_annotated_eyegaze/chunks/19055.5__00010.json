  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It's a cliche it's the greatest form of government in the world, but it is true.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I, I had the disprivilege of experiencing fascism.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I experienced Nazism in Hungary, the German system in Germany, the communism afterwards.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "I lived through quite a few regimes and different systems.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And this is the only one that you can live.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "This is the only one, this is acceptable to, to normal human life.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "It's a wonderful country.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I have three children.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Don, my oldest, is in, in U-Penn in Philadelphia.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He works there.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And Dean, he's a physician in San Francisco, connected with the university-- works at San Francisco General.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "And his wife is Ariella, who is a lawyer in San Francisco.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And Ben, who lives in Philadelphia, and he teaches English at Berlitz.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "And he's not married yet, Don married in Israel to Karen.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And all my children and their wives are wonderful.",
      "word_count": 9
    }
  ],
