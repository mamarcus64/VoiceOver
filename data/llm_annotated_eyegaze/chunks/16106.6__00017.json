    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "Ziva. ?] We had two.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "That was raining.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "There was nothing to do on the fields, had enough gasoline.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
