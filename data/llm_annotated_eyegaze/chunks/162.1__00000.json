{
  "stem": "162.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[INTERPOSING VOICES]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Should I take these away?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "They're not going to get heat?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I know, but they're not going to get heat, are they?",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Are they going to get heat?",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Oh, OK.",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Survivors of the Shoah interview October 19, 1994.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Survivor Brigitte Medvin.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "Interviewer Dana Schwartz in the city of Los Angeles.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "The interview will be conducted in English.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My name is Brigitte Medvin, and I was born in Berlin, Germany in 1933.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "So now you know how old I am.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS] My father was Polish, and my mother was German.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "My father had come from Poland, from a little village, with his three brothers.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I think it was called [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And my grandparents, whom I never knew, I only have a picture of my grandmother.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My fath-- my grandfather, from what I understand, was a shamas in the local shul.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And my-- the three brothers immigrated to Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And my two uncles started a Coke manufacturing company.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And my father, who was the rebel in the family, came to Berlin to study music and become a musician, and which he did.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And my mother was born in Berlin of parents from Berlin.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They were assimilated Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "You know, the Jews were-- in Berlin, they were not very religious.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And my grandfather was a tailor.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Oh, my grandmother's name was Anna, on my mother's side.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And my grandfather on my mother's side was Max.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "But I don't remember the name of my grandparents on my father's side.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "I really can't remember that.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Fuhrman.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "At first it was F-U-H-R-M-A-N when I was born, and then later on, as a professional name, towards, I think the end of the war and after the war, my father changed it to F-U-R-M-A-N.",
      "word_count": 35
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Heuermann.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "H-E-U-E-R-M-A-N-N.",
      "word_count": 1
    }
  ],
