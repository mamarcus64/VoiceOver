{
  "stem": "21319.4",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I remember only once there came a plain wagon, you know, pulled by a horse, with some bread for the Christian-- there were Christian prisoners too, you know?",
      "word_count": 28
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And there were-- there were Russian-- White-- White Belarus-- White-- White Russians woman there, with the-- you know?",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And they attack that little wagon with the bread and they grabbed all the bread.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "But we never had not a sign of bread or any food.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "We were from a-- when we came, in February?",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "We were 2 and 1/2 months before the liberation, we were in-- in Bergen-Belsen.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "So April 15-- March, February-- so we came February by the time we got to Bergen-Belsen.",
      "word_count": 16
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "And we have-- the conditions was terrible.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "No more water.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "We were laying on the-- on the-- on the ground, and the same-- the same-- take away the-- the-- there was not-- it was not wooden building.",
      "word_count": 27
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 10,
      "text": "There was-- you know, the same condition.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And people were dying like flies in the barrack where I was.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "You know, we were laying on the floor.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "When we came in the barrack were 15,000 people in that barrack.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "Woman.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And you know after the liberation, there weren't even 40.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "Everybody-- I was crawling too, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "I can't stand up.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Because there was no food.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "And diseases.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "I survived for one reason, because I had typhus and dysentery in Estonia, you see.",
      "word_count": 15
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "So my body was immune.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "I couldn't get it again.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "So when everybody was dying around me, I was alive.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And when the British liberated us-- this will never forget.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Big soldiers.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Big men-- no, wait a moment.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "They were standing up like statues, and they were like frozen.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "They couldn't believe it, their eyes, because there were mountains of dead.",
      "word_count": 12
    }
  ],
