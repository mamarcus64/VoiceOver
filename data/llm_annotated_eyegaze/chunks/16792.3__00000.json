  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "It was some bombs going on.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "And it was a lot of planes, which was bombarding small bombs-- not big bombs, small bombs.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "And all the time.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And the time when we was running, when the plane-- the German plane, because in Poland, was no plane.",
      "word_count": 19
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "In Poland, they forgot to-- to send out planes, maybe.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "And, uh, the-- the planes was killing a lot of people, which was running for this, when we was running.",
      "word_count": 20
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And I-- we had a plane coming.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "We run to the fields, on the wilderness.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "We run over in the side, in the side, in Poland.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 10,
      "text": "It's not like here, you have a five freeway.",
      "word_count": 9
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 11,
      "text": "It is a small, which a-- which a horse and wagon can go.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 12,
      "text": "There's no-- there's no asphalt.",
      "word_count": 5
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 13,
      "text": "There's stones.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 14,
      "text": "And-- and in the side is wilderness.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 15,
      "text": "Then you run in, in the wilderness.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Very crowded.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Very crowded, 24 hours a day.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "They were shooting, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "They were shooting from the planes.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "It was a lot of problems.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Um, it was about a couple days from Lwow.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I don't know exactly the name of city, because we didn't go to cities at all.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "We only go in the sides to make near how to come to Lwow.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "No, I was crying.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "All of-- all of us.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "Because I didn't see them any longer.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hm.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I-- I knew that they go-- was going back to Oswiecim.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Because it's the only way they can do.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "I have got some-- some to start with in 1939.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I've got some letters coming.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "They knew where I am, and they knew that I will go to Russia.",
      "word_count": 14
    }
  ],
