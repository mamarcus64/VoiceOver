{
  "stem": "747.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed in Italy almost three years, because nobody wanted to take us.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "We were married, and they took this dangerous little boats, that left from the-- from Genoa, or down in Napoli.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And they were very dangerous, and they-- risky, so they took only single people.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "So we were sitting and waiting.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I was working, as a-- as a dressmaker.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I worked for the [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Where were you at this point?",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "In Grugliasco-- the outskirts of Turino.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "It was a DP camp.",
      "word_count": 5
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "By the UNRRA-- United National Relief Fund.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Something, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "So we were fed, and I was working, and I had made a little bit of supplement, and maybe hoping to get somewhere.",
      "word_count": 23
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "In the meantime, in the second year, I had my baby.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Robert Eli was born in March, 1948.",
      "word_count": 7
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "And the war of independence came in a month later.",
      "word_count": 10
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "But right away, the war started in Israel.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So we were scared to take a small baby into the war.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "The bombs are falling, and God knows what will-- what else will happen.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "So we decided to wait a little bit longer.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And while we were waiting, fur trade commission came from Toronto, and looking for furriers.",
      "word_count": 15
    }
  ],
