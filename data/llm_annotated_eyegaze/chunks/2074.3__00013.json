{
  "stem": "2074.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.6,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "And they went and got eggs and they had-- got milk.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And we're sitting and we're eating and the ceiling falls down, the windows fall down.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "They look out the window.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "The German is in front of the house, and we are on the back of the house.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And we started running.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "Those six soldiers took the orders of the lieutenant.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I didn't weigh much, but they dragged me like a dead animal.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I was sitting there, I was writing my life history.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And I lost everything there when they were dragging and running with me.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I had bundles, you know, saved, but I was trying to write something down every day.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 9,
      "text": "We ran like that 15 kilometers.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 10,
      "text": "Hand grenades and-- and-- and whatever were falling after us, after the Russian soldiers.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 11,
      "text": "And they knew their strategic point was next to a river where they're swamps only.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 12,
      "text": "And the hand grenades were falling in the swamp, only the mud went up in the air.",
      "word_count": 17
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 13,
      "text": "One of the soldiers got some-- wounded.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 14,
      "text": "One of them had his coat full of holes.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 15,
      "text": "And we ran like that 15 kilometers where the Russian front line was established.",
      "word_count": 14
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 16,
      "text": "So then I lay all night with all the soldiers on the ground.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 17,
      "text": "And nobody even looked because I looked like-- you can picture me, how I looked like.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 18,
      "text": "In the morning, they had to report they found somebody.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 19,
      "text": "To bring me to the Russian headquarters to report.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 20,
      "text": "Well, at that time I'm already living.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 21,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 22,
      "text": "And the Russian-- nobody was going to kill me.",
      "word_count": 9
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "So they bring me into the main office of the big leaders of the war for questioning.",
      "word_count": 17
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "So they spread out a map and they trying to find out where I'm coming from.",
      "word_count": 16
    }
  ],
