  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I split by hands and make sharper knife till today.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "I sharp a knife, nobody else.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "I work with the butcher line.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "I can sharp the knife like any-- when I take the knife just out to tray, knives get sharp.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "And you could shave it with it.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "Then I got that same thing, to sharp the knife.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And, a lot of stories about.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 16,
      "text": "And I make the leather by the Nazis.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "1939.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Then I told you, I hided my leather because not registered.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I hide it under the floor.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "I knock off the floor.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Oh, let me see how it come.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "That have come to the point--",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "I registered.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And I hided a lot of leather.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Somebody-- everybody make business.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "You had some stuff.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "The money was not worth it.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "But you have leather.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "And I got potatoes, or things like this.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "We changed for each other according-- the-- before the war.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "That's were the change.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "Now, let me give you two examples.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "How did it change, it was Rosh Hashanah, Yom Kippur.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "I remember one guy, he has books, is fully religious.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "And the other guy is-- only has horses-- skin from horses and cows.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "They come together.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "They have to change.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "They have to-- differences from each other.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "Then they call the [NON-ENGLISH SPEECH] They'll come-- I was there.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "He was [INAUDIBLE] he was-- how could you make-- you know-- you know the difference between this.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "I'll just give you example.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 19,
      "text": "Then, comes [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 20,
      "text": "You have to buy every-- buy every time-- every-- you have to buy something.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 21,
      "text": "They call up the farmer, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 22,
      "text": "He has the-- [NON-ENGLISH SPEECH] He says, because, he says, I only have fertilizer.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 23,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 24,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 25,
      "text": "That's all I could give.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 26,
      "text": "He says, [NON-ENGLISH SPEECH] That sounds funny.",
      "word_count": 7
