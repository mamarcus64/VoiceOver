{
  "stem": "6076.6",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.7,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And while I was immune to ty-- my immunity, I could visit typh-- you know, sick people, whoever had typhus.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "You just get it once in your life.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "So I got acquainted with Chanka.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "She was a very lovely girl.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And we became like two sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "And Chanka's mother got struck with typhus.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I wanted to bring her some little food what my brother Moishe brought me-- a little soup, you know?",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "My mother cooked.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And she put it in, in, in a, in a little dish.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "You know, I don't know how-- you know, in a little box, whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And, and, and I wanted to bring that over to her.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "I wanted to bring black coffee to her.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "When I came in, I couldn't recognize her.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't describe how.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "It's hard to describe how the ward looked in that typhus ward.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "Women were laying on one side, men on the other side, naked, with all insects, with all flies flying around their hair and just a piece of paper covered the body.",
      "word_count": 31
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And all of them [INAUDIBLE] to the last breath.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "When Chanka stood outside, but I went in.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "But I never told her how her mother looked.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "I don't want to bring her pain.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "But the woman who was watching me, I told her that I had typhus in, in ghetto.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "She gave me the permission to go in.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And next day, we went hurry up from work.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "And I says, Chanka, let's go.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "I want to visit your mother.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "Because she was so desperate I should go in and give something for her mother and visit her.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "Meantime, they took out all these people from that pa-- from that ward and send them-- we had a forest, not a crematorium.",
      "word_count": 23
    }
  ],
