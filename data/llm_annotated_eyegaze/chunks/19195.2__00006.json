{
  "stem": "19195.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 570.8,
  "sentences_input": [
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "We got out to a-- for a [GERMAN].",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "And there were two sisters.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES]",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "And one came over, and she pulled me away.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "She says, look, this is my sister.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "Why don't you go in-- in the other line?",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "Because I want us to be together.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "Well, they weren't put together for long.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "Did you see any children in Birkenau?",
      "word_count": 7
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Towards the end, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I was there till December 16.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And they also took us out of lines.",
      "word_count": 8
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And they took us-- did you see, Birkenau on the other side was also a camp.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "They took us into that camp.",
      "word_count": 6
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "And then in the morning, they put us on a train.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "We were working in Stuttgart in ammunition factory.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And there were civilians too who worked there, civilian Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And as we're walking up the stairs, she would always look like this and that and this way.",
      "word_count": 18
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And she took out from her bag a piece of bread.",
      "word_count": 11
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And she says, now eat it.",
      "word_count": 6
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "Don't let-- don't-- don't let anybody take this away.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "She would do this to me every day.",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Because we weren't allowed to mingle.",
      "word_count": 6
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "Why get them in trouble or ourselves?",
      "word_count": 7
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Well, they were very sheltered.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "And the ones who were working outside of the camp were tried to bring in, you know, something for-- for the baby to-- to eat.",
      "word_count": 25
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "Because it was-- it was just born there.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Would what?",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "We were.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "One would tell the other, you know, that such and such holiday is coming, which were the High Holy Days, like we're going to have now.",
      "word_count": 26
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES] But, yes, they even allowed us to participate.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "A lot of us didn't want to eat on that day.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "Because we never ate on Yom Kippur.",
      "word_count": 7
    }
  ],
