{
  "stem": "11472.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "We're on house arrest.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "And the Red Cross brings us food.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 28,
      "text": "My Uncle Schloime somehow ran away from the transport.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 29,
      "text": "He went to-- and he runs back to-- my uncle was already in Linz in Austria in a DP camp.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 30,
      "text": "He runs back, and he tells my Uncle Nisel what happened.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 31,
      "text": "And Nisel comes back with money because Schloime didn't have that much money with him, tried to buy us out from the Czech police.",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 32,
      "text": "He comes, and he makes all the arrangements.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 33,
      "text": "My sister, Simala, well, she gets the chicken pox or she gets the measles.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 34,
      "text": "I don't know which.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 35,
      "text": "She's sick.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 36,
      "text": "My mother can't travel.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 37,
      "text": "Child has temperature, and she had a rash all over her body.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 38,
      "text": "And she can't-- my mother's crying again.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 39,
      "text": "Again, there is a catastrophe.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 40,
      "text": "A woman, [NON-ENGLISH]-- her maiden name was Dodek.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 41,
      "text": "Her brother was killed the first one, when we came out from the grotto.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 42,
      "text": "[NON-ENGLISH] Dodek was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 43,
      "text": "She died.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 44,
      "text": "She was under transport with us together.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 45,
      "text": "She got a heart attack from all this.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 46,
      "text": "When they stopped us, she got a heart attack, and she died in Moravska Ostrava.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 47,
      "text": "And her children are crying.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 48,
      "text": "They're orphans because the father was killed by the Germans.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 49,
      "text": "[PAUSES FOR 3 SECONDS] My Uncle Nisel comes in through a window.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 50,
      "text": "The police let him come in.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 51,
      "text": "And he says we have to go, he says.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 52,
      "text": "So Yetta, my grandmother, and I and Nisel leave Moravska Ostrava.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 53,
      "text": "There were some boys and girls that-- Czech boys, Jewish, from the Briha, I think, or they-- anyway, they came.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 54,
      "text": "They bought us the tickets because we didn't speak Czechoslovakian.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 55,
      "text": "We spoke Ukrainian, but it's a little bit close to Czechoslovakian.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 56,
      "text": "We got on the train, and we come to Prague.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 57,
      "text": "In Prague, they had the funkaserne.",
      "word_count": 6
    }
  ],
