{
  "stem": "311.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "You know, the Jewish things, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "This is after the war?",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "After the war.",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Are we going too fast?",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "OK, let's go.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "We're going-- we don't want to go after the war yet.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "OK, we didn't go there.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Well, I know, he was a Belz Hasidut That's all he belonged, you know, my father.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Whoever, you know--",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I want to tell you my uncle was the rosh yeshiva in Auschwitz.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Oswiecim, but this is Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "You know, but there was a city, and there was a part what was the camp-- the concentration camp.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "There's another part.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "The name is the same.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, oh, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "He schlepped me with me, too, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "By the ear.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I hated it.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I-- I-- I know-- I know the-- the Belzer Rebbe, you know, used to-- used-- I remember he-- he had trouble with his eyes.",
      "word_count": 24
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "He was across the street. on [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "Where we used to live just across the street by [INAUDIBLE] by-- while he was attending to the doctor, you know, and all those thousands of people standing in front of the house tried to get-- to get in, you know, just to see him.",
      "word_count": 45
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "But I was-- my father-- he was roaming with all of them.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "I-- I know-- I know Rabbi [INAUDIBLE], you know.",
      "word_count": 9
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I know-- I know the one in Brooklyn.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I know his father.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "He had the quarters in Trzebinia, where I used to go to my grandmother on vacation every summer.",
      "word_count": 18
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Where I was born.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "So my grandmother was still there, so we used to go there to my grandmother.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "He was.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "He could have been-- he had the credentials to be a rabbi, let's say that.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "He's-- he was a-- a big learner.",
      "word_count": 7
    }
  ],
