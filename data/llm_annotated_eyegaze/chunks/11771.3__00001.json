{
  "stem": "11771.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "[SOBBING] I feel I'm choking.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I can't take him anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "[CRYING] And I feel his blood all over me.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "I feel like I'm warm, but heavy.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "[SOBBING] Then I start to figure, no, I'm not dead.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And I'm not alive.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 18,
      "text": "[PAUSES FOR 4 SECONDS] [CRYING] Oy.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 19,
      "text": "[CRYING] I'm sorry.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 20,
      "text": "I'm--",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I-- when my feelings-- I feel good with him.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "But I feel good.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "Even, he is heavy, I feel his closeness to me.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] But I couldn't take it anymore, his weight.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 3 SECONDS] I tried to slide out.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "When I slide out, in way, other corpse, other dead people.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "They wouldn't let me.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] It was hard to slide out from him.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "But I managed somehow.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 5 SECONDS] [CRYING] [?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Heaven. ?] [CRYING] Oy.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "[CRYING] Oy, my God, my [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "[CRYING] I-- I slide out.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] I managed somehow.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 3 SECONDS] But I feel mine whole body's full with blood, and it's drying.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "[PAUSES FOR 4 SECONDS] But I feel I'm not dead.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 16,
      "text": "I am not alive.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 17,
      "text": "But I came-- I got more strength every minute.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 18,
      "text": "Conscious thought come back to me.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 5 SECONDS] So let's be quiet and in hiding, and not to-- [PAUSES FOR 4 SECONDS] not to give anybody a sign that somebody's alive here.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 20,
      "text": "Because I hear every time screaming or yelling or crying, they used to come.",
      "word_count": 14
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 21,
      "text": "When we hear single shots, they used to finish them.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 22,
      "text": "Conscious came back to me, fully conscious.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 23,
      "text": "But I feel blood, a little.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 24,
      "text": "I touch, I feel, it's not my father's blood.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 25,
      "text": "Because my father's blood was already dry.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 26,
      "text": "Fresh.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "So I feel.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And then I put my finger in.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I saw it went over that.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I'm not dying.",
      "word_count": 3
    }
  ],
