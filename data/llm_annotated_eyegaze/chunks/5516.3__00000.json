{
  "stem": "5516.3",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The story's like this.",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "See, when I had the little brush shop my-- and we had the Lithuanian from the city hall and the lady over from the city hall.",
      "word_count": 26
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "A man, he was like the manager, you know, from this, appointed by the city to look over.",
      "word_count": 18
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And we need hair, you know, to make the brushes.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Hair of-- horse hair.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So we had to go from Shavl to Kovno to get the hair for the shop.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So they took my brother.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "Well, my brother-- a Jew cannot go on a train, in a car, and he cannot even do nothing.",
      "word_count": 19
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So they allow them to go with this manager, the Lithuanian manager, to Kovno, over to Kovno.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Come over to Kovno, he had to bring my brother in the Kovno ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "In Kovno was a ghetto.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "Sometime for Kovno ghetto, they used to come in in Shavl, by the-- later, you know, in Shavl, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "The German used to make all kind of stuff.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "They need something.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "They used to go from city to city.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "They need sometime Jew, they used to take him.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 12,
      "text": "But they couldn't sleep in a hotel.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "They had to sleep in ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "So my brother was in there, when he find out my sister is there, the oldest sister, with three children.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Her husband, they killed.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And she was with three small children.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And she had to go to work and no food, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "It's bad condition, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I don't know how he managed.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "They allowed them to take my sister from Kovno ghetto to Shavl ghetto.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "We didn't know nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And he come over to the Shavl ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "It's a gate, you know, with police, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "He come over a truck stop.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I saw my brother was out.",
      "word_count": 6
    }
  ],
