{
  "stem": "1975.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 220.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "The equipment, and I see that you-- you did a little bit better.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "You did it in less than an hour.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So we're going to have a little bit more time to express ourselves and to tell you certain things, which are-- oh, they're very painful, but you have to bring it out.",
      "word_count": 32
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "It's-- you know, in Hebrew, they have a saying.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "[SPEAKING HEBREW] That means that time is very short, and the workload is just huge.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I was born in a small city in Lithuania.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The northern part of-- northern part of Lithuania by the name of Rakiszki.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My date of birth was 2/27/1924.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "At that time, my family name was Resnikowitz.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I had two sisters.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "One, the older one, which was four years younger than me, Yonina.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And my-- the second one, which was eight years older-- younger than me, and her name was Miriam.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Haym, and my mother's name was Lisa.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My mother was born in this town, which was actually a county town, Rakiszki.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My father was born in a different part of Lithuania in a small town by the name of [NON-ENGLISH], which was close to the capital, Kaunas, Kovno.",
      "word_count": 27
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I had my grandfather that was living at that time.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "He was around 60 or 62.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "My grandmother died a few years before that.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My parents and my grandfather, they were observant, yes.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "I started going in the public school.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And before starting public school, I went to cheder, local in Rakiszki.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Then I went to a [NON-ENGLISH] school, which was a Hebrew school.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "And then I went for a short time to [NON-ENGLISH] public school.",
      "word_count": 12
    }
  ],
