  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "[PAUSES FOR 4 SECONDS] So the Swiss started to help.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "So the Swiss and the Swedish Red Cross came.",
      "word_count": 9
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 16,
      "text": "And the people died on the road.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 17,
      "text": "And Raoul screamed.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 18,
      "text": "He says, anybody with my paper, turn around!",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 19,
      "text": "And some people had his paper.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 20,
      "text": "Some people didn't.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 21,
      "text": "But they turned around anyhow.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 22,
      "text": "And he says, go!",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 23,
      "text": "Go!",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 24,
      "text": "Get into the trucks!",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 25,
      "text": "And he brought a thousand people back to our houses.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 26,
      "text": "And by that time, some of the young people learned from him.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 27,
      "text": "And they did the tricks, just like, if Raoul can do it, we can do it.",
      "word_count": 16
    }
  ],
