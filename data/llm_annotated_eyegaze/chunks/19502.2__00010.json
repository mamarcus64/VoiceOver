{
  "stem": "19502.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And as we were coming, hiding in the backyard of somebody's, a man came.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "I-- one of the-- the policemen, Ukrainian, came and grabbed us.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And they grabbed us and they brought us into a place where it's-- by that time, you know, we were walking the streets like in a rope.",
      "word_count": 27
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "Grabbed us and put us in-- in the line.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "People were walking.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And we were walking there.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And there was a lady.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "This I'll never forget.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Her name was [?",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Bisou. ?] She-- she went out of the lines, so he went and shot her.",
      "word_count": 15
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And she was laying with her hands in the-- you know, and her keys were straight in her hands, yeah, as if this-- she locked the door.",
      "word_count": 27
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "But you know, the children were around.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "They-- they watched us, the Ukrainian and the Polish people.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "They all watched us and the going.",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "And you know what?",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Deep in my heart, I envied them so much.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I envied them so much.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "You have no idea.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "I says, why can't I be in her place?",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "Why can't I be [?",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "Sasha, ?] you know, the-- the next door neighbor.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "I wanted so badly be her.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "Isn't it-- that how much I envied her at that-- at that moment.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "Did she said anything to you?",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No, nobody said nothing to us.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "No one said nothing, a word, to us.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "But I was so envious.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "Then they-- we came to a place on the street.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "It's [NON-ENGLISH], the street.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And there's [?",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Feldman's ?] house, a big house.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "At that time, when we came, mountains of clothes.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "My mother wore a coat.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 9,
      "text": "She had to take off the coat.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 10,
      "text": "She had to take off her rings, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 11,
      "text": "So she took off, and she gave it.",
      "word_count": 8
    }
  ],
