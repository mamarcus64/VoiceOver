{
  "stem": "27443.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And I know that a young boy was hanged, because when we were marching through the gate, he was stopped.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And he had some vegetables that he found in the field.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "And he took it out from his shirt, and he was hanged because of that.",
      "word_count": 15
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "At one point, there was a selection.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "This was right after typhoid.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And we were afraid-- in fact, that very-- after they massacred, the day when I went to the sugar factory, while I had typhoid, they had a selection while I was away, and they were digging up all the basements, looking for people that they were in hiding.",
      "word_count": 48
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "They shot a lot of people in bed.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "The ones that they had typhoid.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And when we came back from the-- from work, we found-- we found a lot of empty homes, that people were not there anymore.",
      "word_count": 24
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "That they were shot.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "In fact, the bed that I slept in was overturned, because underneath the bed was a basement.",
      "word_count": 17
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "Not a basement, but it was in the ground, like a-- in Poland, they used to be-- call it as a basement.",
      "word_count": 22
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "Poles used to store food in there.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "It was in the ground.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And it was all dug up, looking for me, because they knew there was another victim of typhoid.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So we were afraid.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "The people that survived that selection was afraid that will-- that they would come again for us.",
      "word_count": 17
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "So one day, we found out there was going to be another selection.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "And that day, I escaped from the room.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And I was hiding.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "It's unbelievable when I talk about it.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "There was no place where to hide.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And we had outhouses.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "There was no bathroom.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We had no bathrooms.",
      "word_count": 4
    }
  ],
