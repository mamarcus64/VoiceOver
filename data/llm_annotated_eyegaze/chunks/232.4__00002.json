{
  "stem": "232.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "We were put in the main D camp for-- or where they did all the labor.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "We were working there through the winter, where it was very, very, very hot.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "And in April, they were looking for transport to the Jawiszowice ghetto to clean up.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They put together two transports.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "I was one of the transport to go.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "One transport was sent to Jawiszowice.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "The-- the other one was not sent.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "It was sent to Buna.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "Buna was a factory, a chemical [INAUDIBLE] farm factory where they used to make-- where they made rubber and tires, all chemical things for the war effort.",
      "word_count": 27
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "In Buna, I worked for-- until January of 1945, when we heard already the Russian cannons in the background and the Germans prepared the camp to-- to evacuate.",
      "word_count": 28
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "We were evacuated.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 13,
      "text": "We walked three days to Gleitwitz.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 14,
      "text": "In Gleiwitz, we already street fighting by the Russians, when they still had time to put us on wagons.",
      "word_count": 19
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 15,
      "text": "And we were transported to Nordhausen.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 16,
      "text": "Nordhausen was a factory for V-2 rockets, where they shipped-- where they sent over to London.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 17,
      "text": "We were-- this factory was underground.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 18,
      "text": "It was in a mountain carved out from the rocks.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 19,
      "text": "We were working-- I was working there until the end of March 1945, when we heard already cannons again in the background.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 20,
      "text": "It was fighting around the city of Nordhausen.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 21,
      "text": "We were next to Nordhausen.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "And we-- the Germans had, again, time to evacuate us, put us on flat wagons, on trains.",
      "word_count": 17
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "And we were, again, few days on the road.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "And we ended up in Bergen-Belsen.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "Bergen-Belsen, we did not work.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "We did not eat.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "We didn't do nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "We did just starve.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "We were eating leaves.",
      "word_count": 4
    }
  ],
