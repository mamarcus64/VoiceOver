  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And I arranged for her, at the Jewish Community, that they would bring her meals so she won't have to cook that much and it will be easier for you-- for her.",
      "word_count": 32
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And I had to promise her that I'm going to see her again, so I do hope that I will go in spring again to see her.",
      "word_count": 27
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "She is a great lady.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes, very much so.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I was always very concerned where they were and-- and when my son-- my son was a competitive swimmer.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "He-- he traveled a great deal.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "And when he-- let's say he went out of town somewhere, he knew that he had to phone me.",
      "word_count": 19
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "He said, you know, ma, nobody has to phone their parents except me.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I said, yes, I know.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "But I want to know how you are.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "I was very protective of-- of them.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "I also was very strict.",
      "word_count": 5
    }
  ],
