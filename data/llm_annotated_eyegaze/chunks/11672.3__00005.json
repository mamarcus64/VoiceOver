  "elapsed_s": 7.6,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "It was a Muslim country.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "All this belonged to Russia, to the Communists.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And there, people-- there's very warm around here.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "People lived in the street and slept in the cities, all Jews who escaped and all Russians come there.",
      "word_count": 19
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "Sleeping in the streets and dying in the streets, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "And the people, I'm sorry, smelled [INAUDIBLE] because they-- where to wash?",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "Were nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 13,
      "text": "You have a sign in the street, everyone go to the farm.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 14,
      "text": "I went and I-- I-- I want go because on the farm I get a little bread.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 15,
      "text": "I can wash myself, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 16,
      "text": "Took three boys, my new friends, which I escaped with them.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 17,
      "text": "And I one day come, it was called in Uzbek [INAUDIBLE] language, [INAUDIBLE].",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 18,
      "text": "This is a little-- a little woods, make like this, and a little-- how do call this?",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 19,
      "text": "The little-- with the long ears.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 20,
      "text": "Donkey?",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 21,
      "text": "An animal?",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "An animal.",
      "word_count": 2
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "The one-- the little one.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Maybe a donkey.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Maybe a donkey.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I never hard this word till now.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "And it comes on its back a Muslim man.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "And he taked the four boys, the-- I and--",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Three boys more, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Solomon-- yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And they are in the little wagon.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And and the little-- this was so high.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "The tires were so high, like, one floor.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "So high.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I walked all the time.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Sand and the sky.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "Sand and the sky.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "It taked all day to come in the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "This is a-- a-- a farm.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "The name is and the Stalin's [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "In the meantime--",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "What, now listen, in the-- when you went there to the farm, you see little houses.",
      "word_count": 16
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Not built houses, mostly made from [PAUSES FOR 8 SECONDS] straw with something like this.",
      "word_count": 15
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "You don't have a door.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "You go in, like, an opening.",
      "word_count": 6
    }
  ],
