  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "The only thing this thing accomplished, that they never repeated this request.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "Somehow, despite our laws, we felt fortified in our-- you know, we felt more resolute, and we felt better about ourselves.",
      "word_count": 21
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "In 1943, when the SS came, the, the--",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "--The administration of the camp fell directly under the SS, because they brought with them Ukrainian and Lithuanian guards.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And they were inside the camp, and they guarded the camp.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "They were in charge of security.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "This particularly-- do we have time?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I'll tell the story about [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "But we don't have the time?",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "We better continue this on the next tape.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "OK",
      "word_count": 1
    }
  ],
