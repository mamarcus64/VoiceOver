{
  "stem": "1677.4",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.2,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "I was in a girls' hostel where I didn't belong.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "I was the only Jewish person anybody ever saw.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "The bosses gave me a job as a business advisory officer, because I said I had a shop.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "They were sorry for me.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I had more luck with people in life who were sorry for me than these nice people who respected me, which was very sorrowful to me.",
      "word_count": 26
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Because I would have rather been, been respected than feeling sorry for.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And, in Port Moresby, I trained in bookkeeping.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And to cut the long story short, they send me up to the highlands in Goroka and then had a bet amongst themselves.",
      "word_count": 23
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "How long will Fischer last-- a month, two months?",
      "word_count": 9
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "They didn't think-- they all knew that I was sick.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Only I didn't know that I was sick.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I was under no medication, under no doctor.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "And I had a manic depressive condition, which I didn't know I had.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "And they let me loose on humanity.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "And I volunteered to go into a leprosy hospital to put the leprosy station on a [PAUSES FOR 3 SECONDS] business-like level.",
      "word_count": 22
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And the we ordered spinning wheels from the National Council of Jewish Women in New Zealand, where they are very cheap.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And I got it as a donation, 10 spinning wheels, the [INAUDIBLE] of the first loom in the Lutheran Technical College.",
      "word_count": 21
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "Leon [?",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Fink, ?] he-- who died not so long ago-- sent me carpet residue for ponchos and for doormats.",
      "word_count": 18
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And I cannot sew a button on.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "I cannot do-- I cannot cook an egg.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "But I'm a brilliant organizer.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "That's what I learned there.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And with this leprosy, if they had no fingers, they could weave with their legs.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "If they had fingers, they could spin.",
      "word_count": 7
    }
  ],
