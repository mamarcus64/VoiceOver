  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "The Poor Sisters of Notre Dame, a teaching order in Trencin, in a Slovak-- nice, bigger town than mine.",
      "word_count": 19
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Money.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "But my grandfather, who then was dead already, had a very good friend who was the Monsignor Carlei-- a Hungarian, I think he was a great anti-Semite.",
      "word_count": 27
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "But he brought the offering from the plate every Monday to my grandfather to change into notes.",
      "word_count": 17
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "In the biggest Nazi times, when the Gestapo was in the streets, Carlei sent two minstral boys, and they had to bring the offering.",
      "word_count": 24
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And he didn't trust anybody at all with this honor.",
      "word_count": 10
    }
  ],
