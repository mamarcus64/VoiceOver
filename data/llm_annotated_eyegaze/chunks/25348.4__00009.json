  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "And I spoke to these people in German and they came in droves to give their blood.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And then we moved to Melbourne.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Look, difficult is a sort of-- it's quite a loose term.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "It's like I heard a term the other day about poverty, poverty in India and poverty that your fridge isn't big enough.",
      "word_count": 22
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "We had no social help.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We're not on a welfare.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "But we are both working.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "We are grateful of the freedom.",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "It's the best country in the world.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And it was like a life kind of nectar for people, for survivors, who come here and complain-- we ought to send them back.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Came to Australia in 1950.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And about 18 months later, we moved from Brisbane to Melbourne.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We've been here since, and I have managed to get an Australian education in the meantime.",
      "word_count": 16
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Made my life the best I could, but none of my family survived.",
      "word_count": 13
    }
  ],
