{
  "stem": "131.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.1,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And [PAUSES FOR 4 SECONDS] one day, I took-- I saw my cousin's mother there.",
      "word_count": 19
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "And I brought her in in the kitchen.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I said to her, sit down here.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "And they were looking for her the whole day.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "And I knew that [PAUSES FOR 3 SECONDS] they will shoot her and me too, when they find out, because the main thing was that they should have the figures what they had.",
      "word_count": 33
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "They didn't want to lose, God forbid, one person, so-- but they didn't kill us then.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And I saved my aunt that time.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "I told her to sit down and peel potatoes the same way like I do for that few hours that we had.",
      "word_count": 22
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "You couldn't even touch the-- the potato peel to eat it.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] But I peeled them, because they watched you constantly.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 16 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I remember when I was peeling the potatoes, I put the potatoes in my dress.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] And I went out and I took it for my cousins.",
      "word_count": 15
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "And you know, the lights were on you constantly, because it was-- [PAUSES FOR 3 SECONDS] and I wasn't afraid.",
      "word_count": 20
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "I had two potatoes.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And that was like I would have a whole bakery with me.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And I wasn't afraid that they will kill me.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "No fear at all that time what could happen.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "Life is over.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "We were praying that life should be over.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 8 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I'm thinking.",
      "word_count": 2
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember already.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "When was it?",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I know it was in Auschwitz.",
      "word_count": 6
    }
  ],
