  "elapsed_s": 109.7,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "This what was basically with the Jewish population of, of the Sofia, this what is remarkable that I, I never heard [PAUSES FOR 3 SECONDS] the Bulgarian language spoken of them that is not absolutely correct, precise, and in, in very high level language.",
      "word_count": 44
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "I never heard Jewish people there speaking incorrectly the, the language, never heard Jewish people speak with the slangs that you very often will find in different areas or in different classes of the country.",
      "word_count": 35
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "And, and they were treated almost as a favorite youths of this certain circles of Bulgarian political circles.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "They used to call them [NON-ENGLISH] meaning kind of children or youths that is faithful to the Bulgarian people and the, the governments.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Well, I experience [PAUSES FOR 3 SECONDS] personally some of the activity of some of these little children.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I was very little-- first of all, with this little accident that happened when I was approaching my fourth year, three and a half, fourth years, when they used to throw all my eyes sand.",
      "word_count": 35
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "Later on, I, I was [PAUSES FOR 3 SECONDS] number of times maltreated and, and even beaten of these children.",
      "word_count": 20
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "But fortunately enough, this didn't happen too often.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "And we, we left this area.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Well, was once when I was leaving the, the school there in the synagogue.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And with the curiosity of a young child, I decided to see what is happening in the neighboring streets there.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And when I arrived to-- or I should say immediately before that, that the Jewish children were able also to be distinguished by their dresses also, very poor dressed.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And they were supposed to dress in certain way.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And they were also-- the Jewish people was obliged to carry yellow six corner star.",
      "word_count": 15
    }
  ],
