  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 10,
      "text": "And my father was beaten up that time, only she didn't let them touch me under no cost.",
      "word_count": 18
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 11,
      "text": "For them, I was still a Polish officer.",
      "word_count": 8
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 3 SECONDS] And they took our apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 13,
      "text": "[PAUSES FOR 3 SECONDS] So my wife's sister, the one which is in Australia, lived in our building on Smolna, and her sister, which I showed you, it was my most beloved sister-in-law, who lived on Smolna 14.",
      "word_count": 38
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 14,
      "text": "And she told me, you know, my neighbor-- my sister's neighbor has-- wants to split her apartment with someone, so you better go and grab it.",
      "word_count": 26
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 15,
      "text": "So we got that apartment, two rooms in her-- in her apartment.",
      "word_count": 12
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 16,
      "text": "And that's how I actually started to flirt with my wife, because she was next door-- her-- with her sister.",
      "word_count": 20
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 17,
      "text": "She moved in to her sister.",
      "word_count": 6
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 18,
      "text": "That's how he met.",
      "word_count": 4
    },
    {
      "segment_idx": 98,
      "sentence_idx_in_seg": 19,
      "text": "[PAUSES FOR 4 SECONDS] And--",
      "word_count": 5
    },
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 0,
      "text": "My parents--",
      "word_count": 2
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "--myself, and my sister.",
      "word_count": 4
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "My widowed sister.",
      "word_count": 3
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 1,
      "text": "And my brother.",
      "word_count": 3
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, but a very short--",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "--very short time.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "They found-- for a very short time.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "All to have eight people in two rooms was very common.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "It was very common to have eight people in one room.",
      "word_count": 11
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "We could use the kitchen facilities.",
      "word_count": 6
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "The-- the owners of the apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "That was a woman with her son.",
      "word_count": 7
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 1,
      "text": "It was a widow woman.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "And my sister-- sister-in-law introduced us, and that's quite common housing stuff.",
      "word_count": 12
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 3,
      "text": "Was my neighbor introduced me to--to her sister.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 4,
      "text": "That's-- because we were-- we were very close, and give me a-- give us a good reference, and--",
      "word_count": 18
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "I wouldn't call it even they were conditions.",
      "word_count": 8
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] It's typhoid, starvation.",
      "word_count": 7
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "I knew right away it's-- because people came in with nothing.",
      "word_count": 11
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 1,
      "text": "Food was scarce.",
      "word_count": 3
    }
