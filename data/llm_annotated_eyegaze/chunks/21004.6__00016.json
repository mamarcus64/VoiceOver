{
  "stem": "21004.6",
  "chunk_idx": 16,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.1,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Forgot also her first name.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "So we say, all right.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "Anytime-- anytime you're ready, I'll go with you.",
      "word_count": 8
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "I say, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "I'm-- I'm going to be ready in a day or two, because I have to prepare my wife and child.",
      "word_count": 20
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "We have no clothes, and there's a lot of--",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "She say, what?",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "You have a wife and child?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "Forget it.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "You have a wife and child.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "I'm not going with you.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "She was afraid of the child and-- she told she'll go with me, you know, two people will be fine.",
      "word_count": 20
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "We can live like kings, you know, with money.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "With a lot of money.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 9,
      "text": "So anyway, she say, no, I can't go.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 10,
      "text": "She said, you want to leave your wife and child, you want to leave, then it's a different story.",
      "word_count": 19
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "I said, no, I'm sorry.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "So I left.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "Then I saw again Beilare.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 14,
      "text": "Beilare, it doesn't work.",
      "word_count": 4
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 15,
      "text": "I have to-- somebody else.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "He say there's here a lady from [POLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "She has got a nephew.",
      "word_count": 5
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "The nephew is a young boy 14, 15 years old.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Her nephew.",
      "word_count": 2
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Because her husband-- she is the cousin.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "She is my father's cousin.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So later I find out who she is.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "So she is my father's cousin.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And the boy is her husband's, her nephew.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "Her husband got killed also the first day, what I told you, when we came to the concentrate-- to hard labor camp, Jaktorow.",
      "word_count": 23
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Because he couldn't run.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "So-- so I told her about her husband.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "He got killed in-- in the same concentration camp.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "So anyway--",
      "word_count": 2
    }
  ],
