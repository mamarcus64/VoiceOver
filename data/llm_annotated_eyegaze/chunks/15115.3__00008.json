{
  "stem": "15115.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "In between them, you know, like they used to bring food into camp.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "They used to bring a lot of things.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And I used to carry them in camp for my kapo, you see.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "And then about-- my brother got sick.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Avraham.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He went to the hospital, and he came out of the hospital.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "He was really skinny.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They put him into a quarantine block, block 31.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "There was strictly-- which I wasn't aware of it.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "And he was there.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "But I tried to help him.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "I already had connections with my kapo.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And he used to bring him some milk from the gypsies, the gypsy locker.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "We used to have the gypsy camp next to ours.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And the gypsies were good.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "They had everything.",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Till in the end they burned them all.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "But while they were there, they were with their families.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "They were with everything.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 15,
      "text": "And I used to do transactions through the-- through the wire fence.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 16,
      "text": "And I used to have some bread, some milk.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 17,
      "text": "And I was trying to give it to my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 18,
      "text": "Because I was block 21, and he was block 31.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 19,
      "text": "So it was quite a walk to go over.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 20,
      "text": "And I used to go there and give him, you know, make sure that he gets some energy, you know.",
      "word_count": 20
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 21,
      "text": "Because he wasn't working.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 22,
      "text": "He was strictly waiting there.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And sure enough, it didn't take long.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Another selection came in.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So I was out on the line again, so I was OK, back to work.",
      "word_count": 15
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And they took the whole block where my-- where my brother was.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "You know, 90% of them they took.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "And I to go-- I go to the block.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "I says to my brother, they took your number?",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "He says, yes.",
      "word_count": 3
    }
  ],
