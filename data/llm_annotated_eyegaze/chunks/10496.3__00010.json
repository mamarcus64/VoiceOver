  "sentences_input": [
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 3,
      "text": "History and German.",
      "word_count": 3
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 4,
      "text": "See, I-- I had a-- a minor in-- in German.",
      "word_count": 10
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 5,
      "text": "That's, of course, basically, from-- from my experience.",
      "word_count": 8
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 6,
      "text": "But it-- it worked out very nicely.",
      "word_count": 7
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Well, she was a secretary of-- in a South Philadelphia school.",
      "word_count": 11
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "Secretary.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "But when she-- when she moved to Asbury Park, she wasn't doing anything except taking care that-- of my daughter, who was-- you know, was just one-- let me see.",
      "word_count": 30
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] Was just about a year old, my daughter.",
      "word_count": 12
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "What's that?",
      "word_count": 2
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "The first born, right.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Linda.",
      "word_count": 1
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "Linda Susan.",
      "word_count": 2
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "October, 1955.",
      "word_count": 2
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "What's that?",
      "word_count": 2
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Linda?",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 2,
      "text": "I have Steven.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "Who is 35.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "And-- now, 35.",
      "word_count": 3
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 2,
      "text": "And Scott, who's 26, who's getting married in February.",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Grandchildren?",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "I have three of them.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "One is Erin, and-- and Laura, and Diana.",
      "word_count": 8
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 4,
      "text": "Laura and Diana are-- belong to my son, Steven.",
      "word_count": 9
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 5,
      "text": "And-- and Erin is my-- my daughter's daughter.",
      "word_count": 8
    }
  ],
