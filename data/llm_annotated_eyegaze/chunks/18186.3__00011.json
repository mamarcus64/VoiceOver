  "elapsed_s": 185.4,
  "sentences_input": [
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 9,
      "text": "So-- but anyway, that's all-- that was the first thing that came in my mind.",
      "word_count": 15
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 10,
      "text": "And then we were moved back to-- we went-- I went-- wherever the family went, I went.",
      "word_count": 17
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 11,
      "text": "I was with them.",
      "word_count": 4
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 12,
      "text": "And then finally, they left.",
      "word_count": 5
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 13,
      "text": "I said to them, you know, I'd like to go to the cities, Polish bigger cities.",
      "word_count": 16
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 14,
      "text": "And look, maybe I can find, maybe if there are any Jewish people.",
      "word_count": 13
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "They was like, from-- since Germany-- Scheidemuhl became Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 1,
      "text": "After the Russian occupation, they gave it to the Polacks.",
      "word_count": 10
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 2,
      "text": "It became Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 3,
      "text": "Because the area where I came from, when I-- I was born, was the Russian.",
      "word_count": 15
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 4,
      "text": "Was no more Polish Ukraine.",
      "word_count": 5
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 5,
      "text": "It was Russian Ukraine or whatever.",
      "word_count": 6
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 6,
      "text": "So they gave them the Scheidemuhl that they named it Pila.",
      "word_count": 11
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 7,
      "text": "Schneidemuhl is like, is--",
      "word_count": 4
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "It's not-- no you cut something.",
      "word_count": 6
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "And Pila is also, you-- it's like when you when you have-- you will have this-- what do you call-- you cut, cut.",
      "word_count": 23
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 1,
      "text": "You cut, you cut wood or sawing you,",
      "word_count": 8
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "Right.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "Right, right, right.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I didn't-- That was a long story.",
      "word_count": 8
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I hope it's going to-- am finishing already.",
      "word_count": 9
    }
  ],
