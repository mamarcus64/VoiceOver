{
  "stem": "3605.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "I'm Judy Lachman.",
      "word_count": 3
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "I was born in Poland, in Tomaszow Mazowiecki, in 1924.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name is Judy Lachman, L-A-C-H-M-A-N.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Judyta Strykowska, J-U-D-Y-T-A, S-T-R-Y-K-O-W-S-K-A.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "December 1, 1924.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I am now 70 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Tomaszow Mazowiecki-- T-O-M-A-S-Z-O-W dash, capital T-- excuse me, capital M-A-Z.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "This was in Poland-- in central Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I was part of a family of four-- my father, Joseph Strykowski, my mother, Gitel Strykowska, and I had a brother, three years older than I.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And we lived in a middle town-- Polish middle town in Poland.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "Our-- we were better than average situated, because my father was a wholesaler of glass, china, earthenware, and window glass.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And in Poland, there was-- there were cartels.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "So he was the sole distributor of those factories for 10 towns.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And even though there was a lot of anti-Semitism in Poland, and some people boycotted the Jewish business, nolens volens, whether they wanted or not, they had to come and buy by us.",
      "word_count": 33
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And our business was, naturally, closed on Saturday.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "And if somebody came after sundown, they had to wait til after Shabbat to come and take care of their business.",
      "word_count": 21
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "We are-- we were a modern orthodox family with a great appreciation of everything that was Jewish and cultural.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "My parents were very much pro-Israel, but they did not believe in going to Israel.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "They were hoping, when-- when Moshiach will come, we will all go.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "To-- to Palestine, at that time.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Life was good-- carefree.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I was fortunate to attend a private school-- had my friends.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And when I was 12 years old I realized that Poland-- even though it was a country of my forefathers for generation-- did not quite accept us as equal citizens.",
      "word_count": 30
    }
  ],
