{
  "stem": "22959.5",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "But my husband, he was involved with Heald College, here in San Francisco, where he would receive from them some lectures, and he would do some homework at home.",
      "word_count": 29
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "But it was very hard on him, because he had to go to school, and he had to work.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "So finally he temporarily gave up.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "And so did I, so did I.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "He started-- he-- he worked for his uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "It was very hard.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "He was not exactly satisfied.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "That was not his dream.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "He-- he wanted to become a professional.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "He wanted to go back to school.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "So-- but then he felt that he would like to get into his own business.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "And we finally got in-- into-- into our own business.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "We had a restaurant, a fast food store at the Embarcadero Center.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And they called it [?",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "Norman's ?] Institution.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "Because everyone would come into the store and say he's hungry, my husband would assure him that when he leaved the store, he will not be hungry.",
      "word_count": 27
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "So it was very successful business.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "And everything worked out OK.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "We came here-- I would like now to tell you a little bit about my children, and when we came to America.",
      "word_count": 22
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "OK, in New Rochelle we stayed two months.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, we were just visiting with our relatives.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "Visiting with our relatives, looking at pictures.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "They would love to listen to our stories, love to listen to the way we survived the war, loved to listen about the families who did not survive, who perished during the Second World War.",
      "word_count": 35
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They would take-- we would go visit one relative, another relative.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And just spent time with them and talking about the past.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "No, they-- we-- I-- I felt-- I felt good.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Those were actually my husband's relatives.",
      "word_count": 6
    }
  ],
