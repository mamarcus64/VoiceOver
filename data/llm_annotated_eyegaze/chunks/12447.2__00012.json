  "elapsed_s": 2.3,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "But I remember prior to that, my father was called few times to work.",
      "word_count": 14
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "But he always came back.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "He always managed even to bring some food.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Somehow, when he was called to work, he would manage always to do something kind of good for the Germans, like fix them-- locks or doors.",
      "word_count": 26
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 19,
      "text": "But instead of coming-- like some other people were beaten up from this trip-- he would come with some reward, with some food.",
      "word_count": 23
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "So somehow, he, he managed to, to survive in a pretty good way.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And this continued through the summer of 1940, or so.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "We-- my mother was very good in selling things.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "She was kind of also very helpful.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She would buy bread and sell it on the-- on the market.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "We had a little stand.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
