  "elapsed_s": 4.5,
  "sentences_input": [
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 4,
      "text": "And we start to-- to build up a home just for a very short time, and then everything went wrong.",
      "word_count": 20
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "When the war started, when I have to go, yes.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "The first, when I-- when I-- they collect the old soldiers, the German, the German collect the soldiers, what they need.",
      "word_count": 21
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "But I was in Prague from [INAUDIBLE] the-- the-- the river in Prague.",
      "word_count": 13
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "And I have to go to Warsaw.",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 4,
      "text": "I have to go through the bridge, the [INAUDIBLE] Bridge.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 5,
      "text": "And they're standing on the bridge, and every soldier they collect, and they put in a-- in some-- in some [INAUDIBLE], I don't how to call this.",
      "word_count": 27
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 6,
      "text": "In some place when it's first a fence around.",
      "word_count": 9
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 7,
      "text": "And they put them in, and they keep them there.",
      "word_count": 10
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 8,
      "text": "And when I was in the-- in the-- in the place where they put me, and there was a lot of soldiers.",
      "word_count": 22
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 9,
      "text": "And we started to talk what they are going to do to us.",
      "word_count": 13
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 10,
      "text": "And see, mostly say they take us to Germany to-- to-- to dig potatoes or something.",
      "word_count": 16
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 11,
      "text": "And-- and this was a time when I-- when I decide to run away.",
      "word_count": 14
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 12,
      "text": "So I jumped the fence, and-- and run away, and take off the-- the-- [NON-ENGLISH]--",
      "word_count": 15
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "The uniform, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "And-- and went home, and went home.",
      "word_count": 7
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "And the home was-- the whole house was bombarded.",
      "word_count": 9
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 3,
      "text": "It was [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 4,
      "text": "There was nobody there.",
      "word_count": 4
    }
  ],
