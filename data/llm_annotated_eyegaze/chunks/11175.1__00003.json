{
  "stem": "11175.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "They had worked already in places.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "All-- my brother worked also in the same trade what I did, and he helped me, and you know-- and I-- became a [NON-ENGLISH].",
      "word_count": 24
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "[LAUGHS] This-- the life was a hard life.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "I was already an independent person.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "I worked for myself. and I made a living for myself, a few zlotys.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "And so-- you know, and then they-- you have to belong to a trade union.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "Being that I belonged to the trade union, and life was going on-- not too, too good, but I lived.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "I lived and I grew up.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "I went to, you know, night courses in Warsaw, you know-- to learn a little bit, the writing and the reading and everything.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "I went to-- I cannot live like that.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "Every-- every night, for a long time, I went to school and I was working during the day.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "And I-- so I kept myself.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "You know, I became independent-- not to my mother, not to nobody.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "You know, nobody didn't needed the help.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "I was 15, 16 years old.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "I was a grown-up man.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "It's like-- Because I-- I felt, you know, the-- then I have to do it.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "If I would not do it for myself, nobody will help me.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "My mother couldn't help me, my sisters couldn't help the brothers cannot help me.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "I have to help myself.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I try to do it, whatever I could.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And I did it.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "When you came to Warsaw, you said you were 12 or 13 years old.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Where did you become bar mitzvah'd?",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I didn't have a bar mitzvah.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Let me tell you the truth-- I didn't have a bar mitzvah like-- like we have here, bar mitzvahs, with my grandchildren.",
      "word_count": 22
    }
  ],
