  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I was always interested in in-- [? push ?] [? walking, ?] and-- and bike riding, and horse riding, and-- and being in the fields, in the woods, and this was my life.",
      "word_count": 33
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, very much, oh yes.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "You can see--",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I love very much, horses and dogs.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "I always had a dog, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was-- was-- yes, it was not very common, yes.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "It's not far.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I lived there.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I attend the agriculture school.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "This was-- this was in Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "And it was-- it was more antisemitic than other schools.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Because the students were antisemetic.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Just they don't want to sit together.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "They don't want to sit together on the bench or something like this.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "But-- but many didn't know I'm Jewish.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No, just boys.",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I suppose so, yes.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it's a very big-- big program studying.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "We studying about-- about all-- everything what is from the land from the-- from everything.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "Starting from-- from-- I couldn't tell you in-- in English.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Farming, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "But farming in-- in all directions, and not-- not specialized in one direction, but everything.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "With crops, with cattle, with-- with-- with-- I-- I couldn't tell you.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "With all branches would come from-- from the land.",
      "word_count": 9
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Because farming in this time means a mixed farm with everything.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "A farm has cows, and has horses, and has woods, and has corn, and has vegetable, everything.",
      "word_count": 17
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Four years.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I graduated in-- what was it?",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] I suppose it was '32 or something.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I find a job.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "It-- it's easy for me to find a job, because with many Jewish land owners, and they're always looking for-- for a Jewish agronomist.",
      "word_count": 24
    }
  ],
