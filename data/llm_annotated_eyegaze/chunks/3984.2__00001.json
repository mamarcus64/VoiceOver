{
  "stem": "3984.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 13,
      "text": "I need to be upstairs all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 14,
      "text": "So I was very sad.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 15,
      "text": "I tried to cry.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 16,
      "text": "I told my mother, I don't want to leave my family.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 17,
      "text": "I want to be with you, whatever is going to be.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 18,
      "text": "I want to be with you.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 19,
      "text": "I don't want to be separate.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 20,
      "text": "I was, I don't know, about 10-- I was nine-- I don't remember.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 21,
      "text": "So one day I was over there, a holiday.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 22,
      "text": "Nobody saw, nobody know.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 23,
      "text": "And in the night, I came home again.",
      "word_count": 8
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 24,
      "text": "This was about three, four days.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 25,
      "text": "And later, they come to me and speak with my mother, and they told me that I cannot come to home more.",
      "word_count": 22
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 26,
      "text": "I need to decide, and they need to decide that I need to stay over there.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 27,
      "text": "So they make me a little hole-- a room-- over there, a little bed.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 28,
      "text": "And I have all kind of little-- Clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Closes.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I start to be over there.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "The woman come up to me every time-- sometimes in the morning, sometimes in the middle of the day.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "They bring me food all the time, and to drink, and everything.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "But I was feeling very lonely.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "I was very sad.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I was crying a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And I was feeling every time, very lonely and afraid.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And I was there-- why I need to be I, a special, that I need to be alone?",
      "word_count": 18
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And to separate from my family?",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "The family is living near me, and I cannot see them because it was a roof that it was-- without light.",
      "word_count": 21
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "It was alight only with little this light.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "She bring me all kind of food.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "She bring me all kind of [PAUSES FOR 3 SECONDS] little books.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I can read in this time.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I don't know, I can read.",
      "word_count": 6
    }
  ],
