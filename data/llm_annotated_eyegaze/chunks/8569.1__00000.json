{
  "stem": "8569.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Anna Heilman.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Anna, A-N-N-A.",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Heilman, H-E-I-L-M-A-N.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My name at birth was Hanka, H-A-N-K-A, Wajcblum, W-A-J-C-B-L-U-M.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I was born on December 1, 1928.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw, Poland.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "W-A-R-S-A-W, Warsaw; Poland, capital P-O-L-A-N-D.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In Warsaw.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Jakob.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Wajcblum.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Rebecca Wajcblum.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "I am the youngest of three daughters.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "My eldest sister name was Sabina.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And my middle sister name was Esther.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes, my nanny, Isabela Szapowska, was living with us.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "I-S-A-B-E-L-A S-Z-A-P-O-W-S-K-A.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I remember the cold winters.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "It was very cold in Warsaw, and my mother believed in fresh air.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "So I had to go out with my nanny every day for a fresh air ride on a sled.",
      "word_count": 19
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "And remember that I was crying all the way going out, through there, and coming back.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "So this is what I remember from Warsaw.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My father had a wonderful sense of humor.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "My father traveled a lot.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "He was a representative of the Polish Arts and Crafts.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And because of that, he traveled a lot.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And when he used to come back, he used to tell us all kinds of stories from his travels in a very humorous way.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And, of course, the only time we were all together was at the meal time, at suppertime.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And it was usually during the suppertime that my father was entertaining us with his stories.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And invariably, my sister Ester, whom we called Estuscha, used to laugh so much that she used to spill whatever she was drinking on the tablecloth.",
      "word_count": 26
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And my mother was furious.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "So-- [LAUGHS] those one of the things I remember.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a very unusual woman.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She was very beautiful, she was very elegant, and she was kind of a snobbish side as well.",
      "word_count": 18
    }
  ],
