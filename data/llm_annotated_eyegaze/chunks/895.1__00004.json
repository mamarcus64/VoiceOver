{
  "stem": "895.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 21,
      "text": "My neighbors were 12 and a half-- Jewish people-- were 12 and a half years married.",
      "word_count": 16
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 22,
      "text": "In Europe, they called that the Copper Wedding.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 23,
      "text": "They make a big party.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 24,
      "text": "And we would rehearse for everything.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 25,
      "text": "And that same night, the Germans came bombing with the bombs.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 26,
      "text": "And then we didn't have the party.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 27,
      "text": "It was cancelled.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 28,
      "text": "And then it started.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Before we go into the war experiences, Jack, let's go back to, what was your home-- you and Ella and Sientje and Joseph together-- how did you-- how did you do your Jewish observances?",
      "word_count": 34
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "What type of home did you have?",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Describe it.",
      "word_count": 2
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We had an apartment in Retiefstraat.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "That was the name where my apartment was, in the east of Amsterdam.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "We had a nice home, two lovely children, and a beautiful wife-- so beautiful.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "But they didn't like Jews that was blonde and blue-eyed, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And everywhere I went with them, everybody said, what beautiful children, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "And then everything went fine till '45-- 1940.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "What were the relationships between the Jews and the non-Jews in Holland before--",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Very, very good.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "There was no antisem--",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No-- no hate-- no antisemitism.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Nothing at all.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Very-- of course, we have Christian friends.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "I went in the Social Democratic sports club, where we were swimming and everything.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "We went with canoes, when I was living in-- we went to the countryside and through the canals in Amsterdam.",
      "word_count": 20
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Well, that was-- when I was married, then.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "And after that, when the war broke out, that's when the sorrows began.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "I was-- I was-- had goals to sing with the bands, because I was well known, and I sang a lot of jazz and everything at that time.",
      "word_count": 28
    }
  ],
