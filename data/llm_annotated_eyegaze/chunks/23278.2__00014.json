{
  "stem": "23278.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.3,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "And the next day, where's Beatrice?",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "Nobody knows.",
      "word_count": 2
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "No, Beatrice is ill.",
      "word_count": 4
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 6,
      "text": "OK, so all right, forgotten.",
      "word_count": 5
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Maybe five days later, I go by the house of Beatrice.",
      "word_count": 11
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "And I see-- we have windows that open like that and shutters in metal.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "And I saw beautiful lace curtains flying in the wind in the rain.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 3,
      "text": "And I was-- I knew the mother of Beatrice.",
      "word_count": 9
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 4,
      "text": "I didn't know her much, but she was absolutely, you know, wonderful housewife.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 5,
      "text": "Everything was in order.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 6,
      "text": "And when the German took over a nice apartment, they didn't mess it up.",
      "word_count": 14
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 7,
      "text": "It was for their officers.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "I find it was strange.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "So I went to the concierge.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "And I said, what happened to Beatrice?",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Well, she said, my poor mademoiselle, you don't know?",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "They were all arrested.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "Somebody told on them.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "And the Nazi came.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "And they were leaving.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "And they had all their packs ready.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "And they were taken.",
      "word_count": 4
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "We're going to have to change the tape--",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
