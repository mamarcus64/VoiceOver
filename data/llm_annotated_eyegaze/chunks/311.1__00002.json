{
  "stem": "311.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.5,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Yes, they decided since they cannot do anything with me, you know, they're going to send me to a Hebrew school, where I had to learn a little Hebrew, and mechanical high school, right.",
      "word_count": 34
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It was an expensive school.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They had to pay monthly, you know, whatever it was.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "And we had, let's see, four hours Hebrew a week, and we had about 20 hours working in the shop work.",
      "word_count": 21
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "Then we had another, 20 hours, you know, school.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "There were lathes.",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "You had to go through everything.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "You-- you were, like, two weeks, you know, you work with the welders.",
      "word_count": 13
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You-- about four weeks each year, each semester, you had to work with lathes the and the milling machines, and then all kind of hand work, you know, filing and stuff like this.",
      "word_count": 33
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And then we had one month of blacksmith work.",
      "word_count": 9
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "It was-- we didn't exactly horseshoe horses, but it was a part.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "It was nice.",
      "word_count": 3
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Mechanical.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And we had a lot metallurgy to learn and everything.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "It was very helpful to get started.",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "I had to work between schools, between semesters.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "You had to show that you did something.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "They would work for some kind of-- some kind of mechanical shop or something, you know, to get a little more practice outside.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Apprentice, you know, outside.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "So you're not strange when you go and look for a job.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I worked for a-- it was a-- it was a good place.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Mr.",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "Gemski, ?] and we did-- I remember we did-- we did the front gate for the university-- Jagiellonian University of Krakow.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Jagiellonian, that's the oldest university in Krakow.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "We did the gate.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And-- and this was an art.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Since he put the metal flowers on it.",
      "word_count": 8
    }
  ],
