  "elapsed_s": 235.8,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 24,
      "text": "And we're at the Red Cross kitchen.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 25,
      "text": "And I-- and I was writing a note on-- on the wall to see whether, you know, somebody might find my name to let them know that we are-- that I'm alive, and we are alive.",
      "word_count": 36
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And as I was standing in line, there was a-- a boy looking at me.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And he came over to me, he says, are you Andy's sister?",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I says, yes, I am.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "I'm looking for Andy.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "He says to me, well, don't look any further, because Andy is alive.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "Can we pause right here, then?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "This is the end of tape number four.",
      "word_count": 8
    }
  ],
