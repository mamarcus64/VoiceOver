{
  "stem": "9665.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Paul Kornmehl.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "K-O-R-N-M-E-H-L.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "3-7-1920.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Scheveningen, which is the coast of the Hague.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "In",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "In Holland.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I'm now 75.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Not as far as I know.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "My-- the name I've been booked in, in Holland, by my father, was not Paul, but was Pinkas, P-I-N-K-A-S.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "As far as I know, my parents came to Holland in 1916 with two daughters.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "The one was Bertha, the other one Ana.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "They were both born in Tarnow in Poland.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "My mother came from Kolomea, also Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I was-- my brother was born in Holland, by the name Isaac, in 1917, and I was born in 1920 in a street called-- in a street called [NON-ENGLISH], which was opposite a very religious synagogue.",
      "word_count": 36
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "My parents were very, very religious.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "If my father didn't travel-- I'm not talking of the 1920s, but even later on-- he went to shul in the morning and in the evening.",
      "word_count": 26
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "We were strictly kosher, and Holland, like everywhere else in the 1920s, was very, very difficult to make a living.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So my father, mother, and family left for a place in Germany called Chemnitz, where he started a hosiery factory with his partner, [?",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "Hagler. ?] And the hosiery company was called Hako, H-A-K-O.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "What year was that?",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "That was in 1922.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And we stayed, and I went to school when I was four or five years of age in a German school.",
      "word_count": 21
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We left Germany in 1928, and we went to Belgium.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And we stayed in Antwerp-- well, we lived in Antwerp.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "I believe and I understand, and I saw it with my own eyes that my father had a very, very difficult time.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "What he exactly did, I think, he was buying and selling hosiery.",
      "word_count": 12
    }
  ],
