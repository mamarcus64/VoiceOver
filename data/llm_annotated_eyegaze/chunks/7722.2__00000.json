  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "I was working like for the Polish.",
      "word_count": 7
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "They call this [POLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "The [POLISH], the Secretary of Forest.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "They send out the-- the-- the-- the trees or they chop everything.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "They send out, and I rented land by the railroad from the Polish government.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And I used to-- they used to send out from the-- from the forest, and I used to-- [PAUSES FOR 5 SECONDS] and I used to put in the people where they brought those trees.",
      "word_count": 35
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "They used to-- I used to keep them over there.",
      "word_count": 10
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 7,
      "text": "And later on, I used to send them wherever they sold them, to Germany, to England, to north-- and I had-- and I had people, Ukrainian, probably I had about [PAUSES FOR 3 SECONDS] 24 or about 30 people, and the same three girls, they were over there.",
      "word_count": 48
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 8,
      "text": "And they made those for the barrels for-- for the whiskey, for-- for England.",
      "word_count": 14
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 9,
      "text": "So they make smaller little-- little [NON-ENGLISH], where they called this for beer bar, for beer in Poland.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So I had girls, Ukrainian girls, when the people came, the people who bought it, the companies sent people to-- to-- to test them, because they used to check them if they are the proper and right.",
      "word_count": 37
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "So I had girls working for me.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And I used to get from them-- [PAUSES FOR 4 SECONDS] I used to get-- I get from them, not monthly, according to what I did, I used to get paid from that.",
      "word_count": 33
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "This was my job.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And next to the same, I had the one what-- what it was the big tank, what it was kerosene.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And my-- and my brother-in-law, he took care-- he took care of this.",
      "word_count": 13
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "When the war broke out, we were in Mizocz.",
      "word_count": 9
    }
  ],
