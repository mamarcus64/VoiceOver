{
  "stem": "21259.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "You know, he took a gun, Zygielbojm, and-- and killed himself.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "No, they didn't believe him.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "This was-- When you-- your father passed away before you were bar mitzvah'd.",
      "word_count": 13
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "Were you-- were you bar mitzvah'd?",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "No, but yeah, bar mitzvah after, when my father passed away.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I got bar mitzvah'd, yes.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, my father passed away.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "I was-- I tell you, 11 or 12 years.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And never got bar mitzvah'd.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And it was after.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "I remember my uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "I got an Uncle Rosen, and took me in shul, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "Put the [? tefillin ?] and say [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And I got bar mitzvah'd.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "There was-- yeah, there was the organizations, here the Zionist organizations they make with the groups, you know, they used to play all-- all this.",
      "word_count": 25
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "They used to play [NON-ENGLISH], Joseph.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Joseph, with the brother, a lot of brothers, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "Joseph, the brothers, this they used to play.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "They used to play [NON-ENGLISH], all Jew, and [NON-ENGLISH] a lot, and [NON-ENGLISH] a lot-- a lot-- a lot concerts they make.",
      "word_count": 22
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "They rent, and all-- all Jewish they went there to make, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "All the organizations they used to make, pick a band, and they used to play.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "You know, it was very cultural.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Boy, so-- so small.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "No, so cultural, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "It was everything.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Everything was there.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "[NON-ENGLISH], you know and the [NON-ENGLISH] in the organization, and Labors.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "Labors-- is such a-- Labors there.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "You know how many Labors there was?",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "Four in such a small city.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And I said, [NON-ENGLISH] was [NON-ENGLISH], [NON-ENGLISH], I says [NON-ENGLISH], like that.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I was-- I was very-- not-- not Hasidic like this.",
      "word_count": 11
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "No, I was Orthodox, very Orthodox.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "No-- no flashy kind of-- no, never in my life, never.",
      "word_count": 11
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Daven in shtiebel.",
      "word_count": 3
    }
  ],
