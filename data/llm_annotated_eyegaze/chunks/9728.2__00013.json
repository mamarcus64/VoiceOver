  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And now you're gonna get potatoes, and now you'll get-- everything was signed by him, by [GERMAN].",
      "word_count": 17
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "He was a German.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "I believe he was from Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "As I said, I don't know.",
      "word_count": 6
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "All I know that after the war, they brought him back to Lodz, and he was hanged in Lodz.",
      "word_count": 19
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "He was hanged.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Must be.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "He was probably hanged by the Poles, probably.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "Then, as I mentioned, my brother worked in the, in a tailor shop.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "My sister-in-law-- my sister-in-law kept house.",
      "word_count": 6
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "But she could not-- she was not well at that time.",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "She was already a little bit sickly and she did not work.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And I had to work on the-- as a handyman.",
      "word_count": 10
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "I did not have a job that I was given, but I went to the employment office and every day they sent me out-- do this as a handyman, or cleaning the street or fixing the street, or do this or that, but nothing-- OK.",
      "word_count": 45
    }
  ],
