  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He was-- when I hear him open the door with the keys, and I was terrified.",
      "word_count": 16
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "He walks in.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Oh, god.",
      "word_count": 2
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "In May-- I never forget-- May, the 11th May, I give birth to this child.",
      "word_count": 15
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "He brought me in a woman-- find out about a woman who is-- what do you call this woman who helped-- not a--",
      "word_count": 23
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Midwife.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "That's exactly.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "A very nice woman, happened to be.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I don't know where he took her from.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "He brought-- he find a-- he asked somebody.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "She came in, and she said-- and she was not aware that I am not-- that I'm Jewish.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "She thought I am his girlfriend-- to be having an affair, and we want it so secretly.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And she said to  him, sir, mister, they're so antihygienic, everything.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Don't you have a few bedsheet-- something-- a blanket?",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "How can I receive the child without any-- I started to get-- how do you call?",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "To have the baby.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "The labor-- you went into labor.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Labor.",
      "word_count": 1
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "Oh, god.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "And he stands behind this woman and making suggestions to me that-- not to cry, not to scream.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "You are a mother, and you know the pain.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "I don't know if [?",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "Joanie's ?] a mother.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "Not yet.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 7,
      "text": "I don't have to tell you the labor, but-- And I have to bite my-- my-- my lips.",
      "word_count": 18
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 8,
      "text": "I bite.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 9,
      "text": "I was having bitten here and-- and hold onto it, because it was-- now, these days, they're giving something against the pain.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 10,
      "text": "They give something-- that you-- you push, but you don't have the-- whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 11,
      "text": "And I gave birth to this little child.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 12,
      "text": "And she needs hot water, and she was criticizing-- why don't you-- I don't-- because she didn't realize the situation.",
      "word_count": 20
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 13,
      "text": "And I get-- gave birth to this beautiful little child.",
      "word_count": 10
    }
  ],
