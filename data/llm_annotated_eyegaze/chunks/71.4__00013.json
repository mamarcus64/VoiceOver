  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "I would not say that 100%, but it's a large population of Holocaust survivors that see to it that even in this country if it's needed, a lot of organizations are supported, Meals on Wheels or what have you, the Westside Jewish Community Center.",
      "word_count": 44
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Memorial-- [INAUDIBLE] Memorial is supported by the community.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "I'm sure that Wiesenthal Center gets some, and a lot of other causes are given.",
      "word_count": 15
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "I'm very proud to say that while I was president, I was very honored, and I have-- I have something to show that was given to the-- to the B'nai Brith [INAUDIBLE] chapter.",
      "word_count": 33
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "We donate $10,000 to the-- for-- for Exodus.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And it was the first time that a single organization of the B'nai Brith did it, because usually it goes into the-- into the council or the region that they-- that they donate the money to it.",
      "word_count": 37
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "But I had in my mind to do it.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "I organized the cruise.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "And this money, I-- I asked for permission to take this money and-- and donate to the-- to the Exodus, which was-- they gave me the permission to do it, and I was very, very proud to be able to do it.",
      "word_count": 42
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "And I hope they will continue doing it again.",
      "word_count": 9
    }
  ],
