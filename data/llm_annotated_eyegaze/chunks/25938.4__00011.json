  "elapsed_s": 4.7,
  "sentences_input": [
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 20,
      "text": "But it was [INAUDIBLE]-- It was in different barracks, somehow, than [? it used ?] [? to ?] [? be. ?] He was sent to Auschwitz at a different time.",
      "word_count": 30
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "So I remember he was sick, and he died.",
      "word_count": 9
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 1,
      "text": "My brother used to visit him every day, and he died.",
      "word_count": 11
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "He was in the [? crematoriums. ?]",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "And one brother, [?",
      "word_count": 4
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "Awremel, ?] he died-- that was-- the whole barrack [INAUDIBLE] was sent to the crematorium for nothing.",
      "word_count": 17
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "There was something, a unique thing.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "They took the whole block.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "The people they sent-- he was with them.",
      "word_count": 8
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "In Auschwitz, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "On the death march, we know that we went from place to place.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "We were, I think, in one place called [?",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Allach, ?] I think, if I'm not mistaken.",
      "word_count": 8
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "Stayed for a few days.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "About two weeks or something.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "It was the [? famous ?] death march.",
      "word_count": 8
    },
    {
      "segment_idx": 107,
      "sentence_idx_in_seg": 0,
      "text": "I don't know exactly how--",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 1,
      "text": "Many people died.",
      "word_count": 3
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 2,
      "text": "I just remember that I used to-- my brother and I used to cling to each other to get warm.",
      "word_count": 20
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 3,
      "text": "I think it was cold because in evening, at night, we used to lie on the floor.",
      "word_count": 17
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 4,
      "text": "[? with ?] the bombing.",
      "word_count": 5
    },
    {
      "segment_idx": 108,
      "sentence_idx_in_seg": 5,
      "text": "[INAUDIBLE] bomb the places.",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 0,
      "text": "I don't know really how we got food.",
      "word_count": 8
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 1,
      "text": "Did they give us?",
      "word_count": 4
    },
    {
      "segment_idx": 109,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 2,
      "text": "I don't how we got the food.",
      "word_count": 7
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 3,
      "text": "Interesting.",
      "word_count": 1
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 4,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 110,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH]?",
      "word_count": 1
    },
    {
      "segment_idx": 111,
      "sentence_idx_in_seg": 0,
      "text": "Still to go one more, huh?",
      "word_count": 6
    }
  ],
