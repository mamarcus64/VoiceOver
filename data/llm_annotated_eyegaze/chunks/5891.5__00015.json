  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they merge build.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "A lot of other little things going there.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "So that's pretty good.",
      "word_count": 4
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "It worked out pretty good as far as that was concerned.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "They didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "They didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "And we were good-- still good friends with every one of them.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "And of course, a lot of them passed away, the old folks.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 14,
      "text": "And we used to reminisce about our parents, how good they were, and what they did, and this and that, and this and that.",
      "word_count": 24
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 15,
      "text": "But I tell you, I hope from all this-- and I'm so glad this interview is there.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 16,
      "text": "Because things are really looking down, looking too good with the skinheads and all that stuff, that this somehow, somewhere will help discourage someone to get all this stuff going again, that never, never, never, never should happen, never again this should happen to any one, any Jewish religion, people, Polish people-- I don't care who-- the human race, not a-- not a one.",
      "word_count": 64
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 17,
      "text": "And no organization, no government of anywhere in this world should allow that.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 18,
      "text": "They should totally-- they shouldn't even allow the skinheads even in fun, even in-- but we didn't know.",
      "word_count": 18
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 19,
      "text": "We old folks know better.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 20,
      "text": "There should never been allowed for anywhere to get even that much a hair next to the situation, that it was even an idea that it could actually happen again.",
      "word_count": 30
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 21,
      "text": "And it is not just this country.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 22,
      "text": "It's the whole world.",
      "word_count": 4
    }
  ],
