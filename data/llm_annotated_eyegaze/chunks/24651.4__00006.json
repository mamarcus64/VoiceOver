{
  "stem": "24651.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So-- but I-- I finished-- carried him to school--",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "--many times, held him.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "You know, I took my finals with him in my arm.",
      "word_count": 11
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And-- and then-- then I was home-- [LAUGHS] for-- you know, I didn't work after I graduated.",
      "word_count": 17
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "I graduated in 1958.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "I had three kids.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And in 1978, I went back to school for my graduate degree, at Boston University.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "In social work.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I am.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "I'm a clinical social worker, and I work with the geriatric population.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "No, not really.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "They knew that I was born in Poland, but I never talked about my experiences with them, because nobody really asked.",
      "word_count": 21
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "The Holocaust wasn't really discussed very much in those days.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I always talked about it with my family, with my kids.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "My father always talked with me, you know, he told me what happened to him.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And I-- I was always very open with my children about it.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "So they-- you know, there wasn't this dark cloud that hung over our house.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I think it was the-- the movie on television.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Things started to be talked about on-- publicly, you know, on television, radio.",
      "word_count": 13
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Lena Kuchler wrote a book, which was published in 1961.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "My father noticed a little, little article in the that she was on a speaking tour in New York.",
      "word_count": 19
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And we went to see her.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "And she also had tried to get-- get it made into a TV movie.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "And finally, it was made.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I think it was 1988, '89, something like that-- maybe '86-- it was on-- on television.",
      "word_count": 16
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, it was wonderful.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "It was wonderful.",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "She-- when she got into Israel, she-- she had studied-- I think she had studied in Poland-- psychology.",
      "word_count": 18
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "When she got into-- to Israel, she-- she was a psychologist.",
      "word_count": 11
    }
  ],
