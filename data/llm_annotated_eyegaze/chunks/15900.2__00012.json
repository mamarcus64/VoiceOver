{
  "stem": "15900.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 17.0,
  "sentences_input": [
    {
      "segment_idx": 99,
      "sentence_idx_in_seg": 3,
      "text": "A couple-- couple months later on there was a rumor--",
      "word_count": 10
    },
    {
      "segment_idx": 100,
      "sentence_idx_in_seg": 0,
      "text": "Right to the-- right to the-- to the concentration.",
      "word_count": 9
    },
    {
      "segment_idx": 101,
      "sentence_idx_in_seg": 0,
      "text": "On a train like cattles.",
      "word_count": 5
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 0,
      "text": "North, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes, with guards, with everything.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "And we got there, we worked maybe six, seven months.",
      "word_count": 10
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And I hear they're transferring us to another place, to the North Pole.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "I don't know where the North Pole.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 4,
      "text": "They took me to Krasnoyarsk.",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 5,
      "text": "I show you here on the map.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 6,
      "text": "Krasnoyarsk is a city, the port city.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 7,
      "text": "From there, we-- we put us on a boat.",
      "word_count": 9
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 8,
      "text": "I don't know what I-- a regular boat, but like cattle.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 9,
      "text": "And we were there for two, three weeks till we got to Igarka.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 10,
      "text": "There is nine months the dark.",
      "word_count": 6
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 11,
      "text": "When we left, three months the sun, 24 hours the sun.",
      "word_count": 11
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 12,
      "text": "Unbelievable the temperature, maybe miles, kilometers, ice.",
      "word_count": 7
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 13,
      "text": "You cannot survive.",
      "word_count": 3
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they set-- they gave me water, even ice water.",
      "word_count": 10
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 1,
      "text": "Who knows?",
      "word_count": 2
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 2,
      "text": "It was water.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "And-- and-- and-- in-- in the prison when we were going on the train, they stopped the train.",
      "word_count": 18
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "And we-- we went out.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "And we eat snow, snow water.",
      "word_count": 6
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "Who gave us this water.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "And we-- we-- we sucked the snow with-- with grease, with everything.",
      "word_count": 12
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 6,
      "text": "But there, when we got to Igarka, I was working in the-- in the mountains with ice-- unbelievable.",
      "word_count": 18
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 7,
      "text": "They took us out, and they were bagging lunch.",
      "word_count": 9
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 8,
      "text": "I never forget.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 9,
      "text": "And I was running with a ladder.",
      "word_count": 7
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 10,
      "text": "The ladder was not nailed.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 11,
      "text": "They were loose.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 12,
      "text": "And I fell down, and a-- a nail went down my hand, with-- with a head.",
      "word_count": 16
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "No, here.",
      "word_count": 2
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "A nail went down.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "And I said to him, and I'm laying there bleeding.",
      "word_count": 10
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "And the guards came in, and took me into the barracks.",
      "word_count": 11
    }
  ],
