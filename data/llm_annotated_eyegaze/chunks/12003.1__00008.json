  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "The children went with my parents.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "My brother and I went to Plaszow.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But he went to Wieliczka.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "Wieliczka, it's another little area, where I guess that they had salt mines.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "I really don't know what my brother was doing there, but we were separated.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "No, the other four children, because the fifth one was born after the war--",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "--besides my brother and me.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "The other four went with my parents to Biezanow.",
      "word_count": 9
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
