  "elapsed_s": 6.5,
  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "The older girl came running in. 'Down.' She didn't say nothing else, just, 'Down.' And we went down.",
      "word_count": 18
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "And then we put the trap door over us.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "The Germans came in, and started looking for us.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And they told the Czech, if you give us-- if there is anybody hiding, you tell us, and we'll spare you.",
      "word_count": 21
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Which is a lie.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "They never do anyhow.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "They would never spare him, but.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Sorry?",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "OK.",
      "word_count": 1
    }
  ],
