{
  "stem": "17044.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "00.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Nice present.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, my name is Abraham Getman.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "I was born by the Polish authority, government.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And at that time, they called us 'Hetman.' And when the Russian occupied our part of Poland, and they-- they-- they changed the name to Getman, because, in Russian, the letter 'H' don't exist.",
      "word_count": 34
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "In town of Luboml, in the Wolyn in Gubernia, that's-- and that's the northwest of Ukraine.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And until 1939, was Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "From '39 till '41, was occupied by the Russians.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And in '41 till '44, by the Germans.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And I was born on July 21st, 1926.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My family?",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It's-- I had a-- a father and a mother, five brothers, and one sister.",
      "word_count": 14
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And in our house, our grandmother was living with us.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And about two streets away, the parents from [BACKGROUND NOISE] my mother, my grandfather-- my grandmother and grandfather and a uncle were living on the same street.",
      "word_count": 27
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And this was-- the-- the name for the street, we called the Rynek.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And my number was 15.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Shmuel Hersh.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "My mother's named Miriam, my older brother, Yaakov, and Faigie, my sister, then my brother, Moshe, Chaim, and Leibel.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "There was a difference in two years apart from each of us.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I was before the small-- the smallest, before Leibel, between Chaim and Leibel.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My grandparents' name, from my-- my father's mother, Sorah-- Sorah, and my mother's father is Yitzchok.",
      "word_count": 16
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And the-- the grandmother, Margula--",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "--and a-- a brother, Moshe.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "And their last name was Zuckerman.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "It was.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And the same-- my mother had a sister, and who was-- their name was Faigy and her husband, Israel.",
      "word_count": 19
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And also had six children, three boys and three girls.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And my-- this is from my mother's side.",
      "word_count": 8
    }
  ],
