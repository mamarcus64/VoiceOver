{
  "stem": "8854.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.3,
  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "They-- they-- they always talked bad words about the Jewish people, how rich the Jews are because they are-- they don't do, the right way, the money.",
      "word_count": 27
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "That's what they said.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And they were antisemitic.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "Until 1944.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Then--",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they-- we left them there.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "They took us-- they shipped us to the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And they-- we left the Germans, the Nazis, still, in our home.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "The date, I know it's 1944.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "It's-- It was in-- before Pesach.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "It was around April, April the 18, something like that.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Yeah, I remember, it was my birthday.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "And I said, no!",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "And on my birthday they're going to come and make a-- a mess.",
      "word_count": 13
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "And we couldn't celebrate my birthday.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "That, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "April 18.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "All of the sudden, we saw a lot of tanks and cars, big trucks full with people.",
      "word_count": 17
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know that the Nazis-- we didn't know about that.",
      "word_count": 11
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Because we didn't believe what the Ukrainian said to us.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And they run out from that trucks and they-- from the tanks, with those boots, and with those uniforms.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And-- and we got very scared.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "All of a sudden, they went-- they came into our house, knocking with their boots and-- and screaming.",
      "word_count": 18
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "And in their hand, they had that stick, iron stick in their hand.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "They didn't came only to us.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "The came to every Jewish family's house.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "But I saw what I saw.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 11,
      "text": "And they said, out!",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 12,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "Out from here!",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 16,
      "text": "Out!",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 17,
      "text": "You have to go!",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "I said, warum, then?",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "In German language, warum, then?",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "Why?",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "He says, you are a Jew!",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "So I said, so what is it, if we are born Jewish?",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "You have to go in the ghettos!",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "And this house has to belong to us!",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "We need it.",
      "word_count": 3
    }
  ],
