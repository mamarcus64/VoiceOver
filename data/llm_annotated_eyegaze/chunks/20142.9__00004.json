  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And for out of sheer excitement-- this was in, during the siege of Jerusalem when him and his wife, [?",
      "word_count": 20
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "Leah-- ?] excuse me-- were teaching at the University of Jerusalem.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And out of sheer excitement, he could not write, but they reverse the letter, mine to my brother and my brother to me.",
      "word_count": 23
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "And added a note, do not come at the present time.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "Do not come at the present time.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "And when I met him quite a few years later, as a matter of fact, they it came to the United States to National Institute of Health in Bethesda, [INAUDIBLE] bases of the scientific, in scientific field.",
      "word_count": 37
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 8,
      "text": "She was a-- a doctor of biology, biochemistry.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 9,
      "text": "And she was experimenting on a skin affected by radiation and becoming quite famous in this field.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 10,
      "text": "During the time when there were some going on in Vietnam and there were fears of people being affected by radiation.",
      "word_count": 21
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "They [? came, ?] of course, every two weeks I was in Bethesda, Maryland.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "I learn quite a bit about Washington, DC, and I was very happy about it.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "There were many places that we spent together and we traveled together.",
      "word_count": 12
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 3 SECONDS] While I came to United States, after--",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "When I came to United States in 1949, I came on the date of the Warsaw ghetto uprising of April 19, 1949.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I was liberated on May the 5th, 1945, the date of my mother's birth.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] I was received quite warmly by my family.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And I felt like a-- a soldiers coming from war.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And they made my days quite memorable, that I was always grateful to them.",
      "word_count": 14
    }
  ],
