{
  "stem": "17625.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "Didn't-- And they did that inside where you were?",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "Inside the--",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "In the mortuary.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "--mortuary.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "In the mortuary.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "We were by the ovens.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "This-- this crematorium four was in a smaller form than the crematorium two and three.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "Four and five was in that smaller form than two and three.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Two and three were 15 ovens.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "And here were only eight.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "So and-- and the mortuary was next to it.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "In the middle was-- was a dentist and a hair cutter.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "It was a little room.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And a hair cutter.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And then came every-- every here and there they came-- came out to collect the teeth.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "And after the mortuary were the bunkers, the gas chambers.",
      "word_count": 10
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "So it wasn't so big.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "We could-- we could-- we could see through.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "I told you, Kitt, and the other one I got written down.",
      "word_count": 12
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And the other, written down.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "Dentist, Jewish dentists?",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Jewish dentists?",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "They took in to-- two Jewish dentists, French.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "They were-- they-- from a transport, they asked for dentists.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And they thought they're going to have dentists.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "You know what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Because there-- there was also a-- a-- a-- what do you call it?",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "A-- a-- a-- a recovery room, whatever, they had, for-- for sick people.",
      "word_count": 13
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "And meanwhile, they took him into-- to-- to-- to-- to the crematorium to be the dentist, not to pull teeth.",
      "word_count": 20
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "Pull teeth was a-- was a prisoner, like-- like us, a regular one, a prisoner.",
      "word_count": 15
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Oh yeah, yeah, his name was Epstein.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "But he-- he did things-- we did-- we did the-- the-- the-- the ovens.",
      "word_count": 14
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "He did the pulled-- the-- the teeth pulling.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "And one that did the hair cutting.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "As a matter of fact, the hair cutting wasn't my kommando.",
      "word_count": 11
    }
  ],
