{
  "stem": "1965.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 20,
      "text": "And it was there that I was given by Madame Rothschild, and several other children, a piece of land to grow vegetables.",
      "word_count": 22
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 21,
      "text": "And I grew poppy seed and the most jumbo-sized radishes, the-- the red variety.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 22,
      "text": "And when my mother came-- see what I'm bringing in now, I'm just giving you quickly my own personal experiences, which are, you cannot really detail everything on video.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 23,
      "text": "I just want to bring my mother and father experiences in, because they are not alive to bring out their experiences.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 24,
      "text": "So I want to bring as much as my mother and father into this.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 25,
      "text": "But when my mother came to pick me up in 1945 sometimes--",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "We all were reunited, because the-- the Jewish Underground, the Jewish Joint, all of these organization, and some Catholic Belgian women, they all made sure that all the children that were placed were always coming-- were going to come back as families.",
      "word_count": 42
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was written about, the names and so forth.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So we-- they always knew where everybody was.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And when my mother came to pick me up, to take me home to Antwerp, I did not want to go with her.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I was frightened of her.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "And the reason I was frightened, Sontha, is because in front of me stood a woman 68 pounds of weight. 68 pounds.",
      "word_count": 22
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And that frightened me to see nothing but a skeleton in front.",
      "word_count": 12
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "But she coached me, and we came home.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I was always making beds, working in the kitchen, working on the land.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I always made sure that my day was productive.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "I didn't like to laze around.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "I had to be productive.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "As a matter of fact, it was in Auderghem that I saw my first movie in my life.",
      "word_count": 18
    }
  ],
