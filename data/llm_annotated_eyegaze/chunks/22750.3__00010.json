{
  "stem": "22750.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "That's the answer.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "And that's why.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "I was with a different mind, at that time, and in my situation.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "He was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "Took him out from the ghetto with all his family.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "The name is Sherman.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "I have his brothers over here and pictures, some of him.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "They came from Israel because-- because from his family, survived two brothers' kids.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And they're in Israel, young kids.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Somehow they survived.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "And I show you a book that I have from the ghetto from Israel.",
      "word_count": 14
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "They made a book of pictures they took.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "Their pictures are there, too.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "And they were from the leaders to make the book in Israel now.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "What it--",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I didn't understand you.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Boboski was a Pollack.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "He was a worker for Germans.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "He was a Polish guy.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "I know him.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "But a good human.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Don't think only was good Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Was other people, also.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "His name?",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "Boboski, B-O-B-O-S-K-I.",
      "word_count": 2
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The first name was, if I'm not mistaken, Edward-- if I'm correct because this is the way which rings in my-- my head.",
      "word_count": 23
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "I was buried-- I was burying some people.",
      "word_count": 8
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I had to go.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "In ghetto?",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Lots of times.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "Even at night.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "Most of night, they'd make-- what do you call this-- a probe to act when the time will come.",
      "word_count": 19
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "It was a couple times.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "In that time, I couldn't give you [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "Only any amount you want-- not by the hundreds, but [? single. ?] Yes.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Some of them.",
      "word_count": 3
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "By luck, they find a family.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "And it was up to them.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And I couldn't now judge how many people because--",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I believe for no reason.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Because they were Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And they were on this-- and this life, their life was any value, like a dog.",
      "word_count": 16
    }
  ],
