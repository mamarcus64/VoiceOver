  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "One thing I had that they sent me-- I don't know how he knew to send it-- a package of needles.",
      "word_count": 21
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "I lived on these needles almost a year.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Nobody could get a needle.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Sewing needle.",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 9 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I stayed there for a little while.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "He was starting-- and I decided I'm not going to wait there.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "And I decided to follow the Russian army with my family, too.",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "And it came out another edict that all Polish Jews who were born in Poland can now return to Poland.",
      "word_count": 20
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "So we came to Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And then we smuggled our way to Russia and Germany.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And then I smuggled myself to the American zone.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "This I want to tell you, if you have room.",
      "word_count": 10
    }
  ],
