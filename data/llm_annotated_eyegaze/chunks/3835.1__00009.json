{
  "stem": "3835.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 17,
      "text": "And then she worked in NYU.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 18,
      "text": "The last 15, 20 years of her life she finished in NYU, had her laboratory with her mice, with her doctors' work.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "That's the trouble.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That-- that's the $64,000 question.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "We were in Poland, but we never, never felt that we are citizens.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "We were citizens.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "We went-- when-- they had the [POLISH] there for a president, for a senate, we went.",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "We had the right to vote.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "But we were never felt that we are citizen, that I can love this country-- the opposite from the United States.",
      "word_count": 21
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "Here, I feel that I am a citizen.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "I love this country.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And I would give my life for it.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "But not in Poland, not at all.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Naturally.",
      "word_count": 1
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "No, we didn't have a sense of be-- we-- when it was quiet life, no pogroms, we were happy.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "When-- when they didn't put in a guy in front of my father's store, don't buy from a Jew.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "This a Jew's store.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "When it was quiet, we were happy.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "But from times to times, you always had these excesses, which happened.",
      "word_count": 12
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "But we didn't feel trapped.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "No, we didn't feel trapped.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "But we didn't think of moving or emigrating.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "We didn't think about it.",
      "word_count": 5
    }
  ],
