{
  "stem": "15943.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And as a child, maybe I didn't realize how much she struggled because she put up a big front and people thought that she was doing well.",
      "word_count": 27
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "We were dressed decent.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "We went to private schools.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "But my older sister always said she knew how hard she struggled, but she kept her children home.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "It was a specialty manufacturing little girl's coats.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And usually little girls-- only very rich little girls could afford it, coats made to order.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "So she was making those coats and selling it to the stores, manufacturing them and selling it to the stores.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And those were a-- it was specialty trade.",
      "word_count": 8
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "She had people working for her.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She did the designing, the cutting.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And she had people that did the sewing and the finishing and the pressing and the delivery to the stores.",
      "word_count": 20
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "They were too young.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "Their first-- my brother sometimes would help with delivering the, the-- bringing whatever to other manufacturers, materials delivering.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "My oldest sister went to work.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "She was 12 years old when my father died, and she looked older, so she got working papers.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "She took the birth certificate of a older cousin-- same name.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Esther was her name, so then she was called Esther and then Malka or Mala.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "And she went to work in a factory at age 12, actually.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "Supposed to be that she was 16.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "And she worked all her life to help my mother until she was-- she left Poland when the war started in 1939.",
      "word_count": 22
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "My other sister, when she finished school she went to a trade school.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "I don't remember exactly what she was learning in that trade school.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "It was an art school, where they were teaching all different-- they still do.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "Or it still is active teaching people.",
      "word_count": 7
    }
  ],
