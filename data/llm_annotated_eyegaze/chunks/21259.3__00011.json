  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "I brought her up very, very-- not Orthodox, you understand?",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "There is a-- now, you say conservative, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "Very, very-- and now, she's, she's so Orthodox.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "I, I, I mean it.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "She's a good kid.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "Is there anything you'd like to add, any question that you feel that I've not asked you?",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "You know, I feel, you see-- this from Poland.",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "When I remembered from Poland when, when they told me the Polacks, they save a lot of Jewish Jews.",
      "word_count": 19
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "I know-- I know in mine, this, since I was a small, you know, till seventh year is the blood always was problem.",
      "word_count": 23
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "Well, it's not my city.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "But my city, they know there is a-- there is a [INAUDIBLE], you know?",
      "word_count": 14
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "They can beat them [INAUDIBLE] up.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "You know, in other cities, even [INAUDIBLE] was a bigger city, Ozarow always by.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But the Jewish, they got stores, you understand?",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "Then the Polack, they won't come in.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "They never pay.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "This is, is [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "Swindlers, they told the Jewish.",
      "word_count": 5
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "And always was fights, always was problem, always.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "Every week was markets, you know, markets, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "This, this on there, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "But I, I can never forget.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 10,
      "text": "And this is the reason my daughter, she knows this, you know, what the-- what the Christian do.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 11,
      "text": "They go Sunday in the church.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 12,
      "text": "After, after they pray, they go drinking in the bars, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 13,
      "text": "Who has the bars?",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 14,
      "text": "The Jewish.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 15,
      "text": "They have the bars.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 16,
      "text": "They drinking.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 17,
      "text": "And after, yeah, after drunk, and this-- [INAUDIBLE] you steal.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 18,
      "text": "You swindle.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 19,
      "text": "You this.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 20,
      "text": "And this is this.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 21,
      "text": "This was Poland all my years since I went to school, since this, always.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 22,
      "text": "This is the reason [INAUDIBLE] was working here.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 23,
      "text": "My, my uncle, he was a tinsmither, a blacker, you know?",
      "word_count": 11
    }
  ],
