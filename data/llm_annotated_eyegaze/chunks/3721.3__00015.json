  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And all of a sudden, he's beating me up-- what did I do with the gold?",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And we did have some.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And we did hide some.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "But I didn't take it because I didn't want him to have it.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And he-- when he beat me up, I said, now, this I need?",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "So I took off.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And I went by train to Bucharest.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And in Bucharest, I met up with this Zieman, who-- then, I knew who he was.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "In-- when, when I was in, in the city, in, in-- I believe it was [NON-ENGLISH].",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I never really met him.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "And I just knew there was somebody.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Supposedly, he was dropped off by parachute at the same time.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "I learned that after.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Because they didn't want to give me that information.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And they didn't even want me to meet with this individual who brought-- excuse me.",
      "word_count": 15
    }
  ],
