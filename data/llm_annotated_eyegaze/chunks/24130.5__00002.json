{
  "stem": "24130.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 31,
      "text": "[PAUSES FOR 3 SECONDS] And we were crying.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 32,
      "text": "And-- And then, we were riding the train and everybody was praying.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 33,
      "text": "And then, all of a sudden, the train stopped.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 34,
      "text": "It stopped.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 35,
      "text": "They said, it's Auschwitz.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 36,
      "text": "We never heard of Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 37,
      "text": "We never heard of a camp.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 38,
      "text": "And everybody says, this, this.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 39,
      "text": "Well, my father looked out from the window.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 40,
      "text": "And he says, you know, they look-- these people look like they're working here.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 41,
      "text": "They all wear the same clothes-- striped clothes.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 42,
      "text": "Men.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 43,
      "text": "He didn't see any women.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 44,
      "text": "But he says, I see men.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 45,
      "text": "And it looks like they're working here.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 46,
      "text": "So he says, maybe we have a chance.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "So we work.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "So he says, work is not going to kill us.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "This one, ?] they're not going to kill us.",
      "word_count": 9
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "He says that you have to work hard.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "You work hard.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "He says, make sure that you work hard just to survive.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And while he was talking to us, they opened up the trains.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "They opened the trains.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And there were standing Germans with German shepherds-- dogs.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And they-- all of a sudden they said, we have to separate man and woman.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "They took like-- there was such a confusion getting off the train and such a screams that we-- we didn't know where to go.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And somebody says, you know, these people go home.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And these people, because they're young, they go to work.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I had the baby, the [NON-ENGLISH], in my hand.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "And I figure, oh, I could go home with her, because I saw the women with the children go to-- to the left.",
      "word_count": 23
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 9,
      "text": "And the working people go to the right, the young people.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 10,
      "text": "I held this little girl.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 11,
      "text": "And I was going to the left.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 12,
      "text": "And then, a man came over.",
      "word_count": 6
    }
  ],
