{
  "stem": "14708.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is Zuzana Adam.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Z-U-Z-A-N-A A-D-A-M.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "My maiden name was Klein, K-L-E-I-N.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born on June 2, 1925.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "I am 70.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I was born in which Miskolc, M-I-S-K-O-L-C, in Hungary.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "This is a large city.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "It is the second largest city in Hungary, after Budapest.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "When I live there before the war, it had 70,000 inhabitants.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "But today, it has maybe 200,000.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "This is an industrial and commercial city.",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "My father's name was Vilmos Klein, V-I-L-M-O-S Klein.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Vilmos means William.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "He was born also in Miskolc in-- on October 15, 1900.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And my mother's name was Erzsebed.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "That's E-R-Z-S-E-B-E-D Klein.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "She was born on March 5, 1901, also in Miskolc.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Her maiden name was Weinberger.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "That's W-E-I-N-B-E-R-G-E-R.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "No, I was an only child.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I was an only child.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "Actually, I had a very beautiful and very happy childhood.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "My parents, when they were first married, they were very poor, but they both were very, very ambitious, and very skillful people.",
      "word_count": 22
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "My father went to business, and my mother, although her dream was always to be a pediatrician, but of course this couldn't come true.",
      "word_count": 24
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "So she became also a very, very good businesswoman together with my father.",
      "word_count": 13
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "So they managed very well.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "So by the time-- what I remember as a child, we were comfortably off.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "We were not rich by any means, but very comfortably off, so-- What did your father do?",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father had several things.",
      "word_count": 5
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He-- he had a grocery store, and he had also a wholesale store for bakery equipment.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And he had also an advertisement agency, but this was mostly my mother's job.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "She did the advertisement agency.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Oh, in-- in movies, in theaters, in streetcars, all the different firms, different businesses who advertised with us.",
      "word_count": 18
    }
  ],
