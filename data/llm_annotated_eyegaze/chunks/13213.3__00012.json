{
  "stem": "13213.3",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 54,
      "text": "And I lived in Gliwice and went to school there, for preparation for university, and I wanted to study engineering.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 55,
      "text": "At that same time, HaNoar HaTzioni still was active, and I was going to meetings in the Zionist organization.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 56,
      "text": "I learned quite a bit about Zionism, and was eager to go to fight for Israel, because it was already-- in 1948, beginning of '48, the war broke out in Israel for independence.",
      "word_count": 33
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 57,
      "text": "And I was eager to go.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 58,
      "text": "But for some reason, they wouldn't give me a passport to go, and I continued school.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 59,
      "text": "My friend decided to leave Poland because they were going to, I don't know, recruit him to the army or something.",
      "word_count": 21
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 60,
      "text": "His parents and-- his father was a doctor, so he was able to get his papers and went to Israel.",
      "word_count": 20
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 61,
      "text": "And I got my papers later on.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 62,
      "text": "And I went to Paris because a friend of mine that went to school with me-- George Guc, G-U-C, and his parents-- had some family in Paris and in New York.",
      "word_count": 31
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 63,
      "text": "And they were taken over to Paris, so they wanted me to stop in Paris and maybe go with them to United States.",
      "word_count": 23
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 64,
      "text": "I arrived to Paris, and-- and I stayed with another group, which were a Zionist group.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 65,
      "text": "Some of them were going to Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 66,
      "text": "Some, I don't know where else.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 67,
      "text": "And we stayed in a hotel.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 68,
      "text": "And this friend of mine, with his parents, were trying to convince me to go with them.",
      "word_count": 17
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 69,
      "text": "And his uncle had made them papers to go to New York.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 70,
      "text": "At the time, the war was very-- going very bad in Jerusalem.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 71,
      "text": "I remember reading and listening to the radio for Israel.",
      "word_count": 10
    }
  ],
