{
  "stem": "4160.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.8,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 29,
      "text": "But they killed-- Germans killed.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 30,
      "text": "And I lined up in Brest-Litovsk.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "Then they took me to work.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "The Russians, they took we to work.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "They took us about three or four weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "We went to the Russian city.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "They called it Surazh.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "I was working there in a factory from paper, a paper factory.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "And we were working there very hard.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "I used to-- I used to work in a-- I used to work in a factory, and we used to [INAUDIBLE] turf, like turf.",
      "word_count": 24
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "It was very hard for us. 23 years, a boy, what we know about so hard work?",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And then I decided I will run back to the borders of like Kovel.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "We ran back.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We run back.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "We was there-- we was living in Kovel.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "In Kovel was-- This is on the Polish side?",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "This is-- that was on the German-- on the Russian side.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But that wasn't, that wasn't 99.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "That was supposed to be 90, 100 kilometer from the border.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "From the Bug.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "The Bug is the River Bug.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "The Bug is the border between Russians and Germany.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "They divided-- Stalin and Hitler divided that.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "And I couldn't be in Kovel because that wasn't 100 kilometers.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So we have to run.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "We left Kovel to Krzemieniec, Krzemieniec [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "Over there was a town.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "The whole town was in the hills.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Beautiful town.",
      "word_count": 2
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "I was there through 1941.",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "And when the Hitler's came in, Germany came in, occupied Krzemieniec.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "It took them about three, four days, or five days.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 12,
      "text": "I can't remember how many days.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 13,
      "text": "And they make right away a ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 14,
      "text": "But lucky, I was an upholsterer and I was a saddlemaker.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 15,
      "text": "They need me to work for them to repair the-- the harnesses-- the harnesses.",
      "word_count": 14
    }
  ],
