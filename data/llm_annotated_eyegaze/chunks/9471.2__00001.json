{
  "stem": "9471.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 8,
      "text": "I says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And after three days I went home.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I says-- I came home, and big bunch of roses were waiting already.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And my mother said, now what's going on?",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "I says, mother, I am engaged.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "She says, what?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I says, yes, I met a guy, and I am engaged.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And he came, uh-- after couple days he came with his brother to our home to ask my hand of marriage.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And my parents liked him very much.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "He was a nice man.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "And he had a very good business.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "He was very wealthy.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "And they were crazy about him, more than I was.",
      "word_count": 10
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "But I-- I liked him.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "But I didn't really know him, because he want back to Koprivnica.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "He just came every weekend to see me.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "And that was going on, uh, two months.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "Because I met him in December.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "In February 20, we got married.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Uh, his name was Dory, D-O-R-Y.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "Dory Weiss, W-E-I-S-S-- Weiss.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "I remember when they put veil on me.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I started to all of a sudden cry.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "I says, oh my God, what am I doing?",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "I don't love him.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "I like him, but I don't love him.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "But I couldn't disappoint anybody.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And we got married.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "I had a beautiful wedding.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And we went to honeymoon to, uh, Dubrovnik.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "It's a, uh-- on Adriatic Sea.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "And I'm embarrassed, but I was three days married, and I didn't let him touch me, you know?",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "I was scared, and I was naive, young.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And then he says, you know what?",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "If you don't want to be married, go back to home.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "Because after all, I married you.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "I want you to be my wife.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "So I did.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "And after that was normal.",
      "word_count": 5
    }
  ],
