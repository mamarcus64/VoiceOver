{
  "stem": "13584.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I do remember, though, that my mother start to receive from the American organization of UNRRA-- I remember-- not I remember, but it was UNRRA that everybody was talking-- food, and packaged food.",
      "word_count": 33
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Somewhere in '45, end of '44.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Apparently there was an agreement between-- between America-- United States-- and Russia.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "They were helping.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "My father got also help from-- during the-- during the-- when he was on the front.",
      "word_count": 16
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "But that's a different chapter.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "Also some help, you know-- that's what-- we received the first food in package.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Package was UNRRA food.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "From this place we moved to the same place.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "I mean the same city-- I'm sorry-- but on a different street.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "On a different street.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "On a different street.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "I remember the address of this street-- Ulitsa Stalina, Sorok Odin.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "It means Stalin Street, number 41.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "We moved to a 70-year-old widow.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "She was a illiterate, but she let us in.",
      "word_count": 9
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "She rented us the room.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "She had-- her-- her daughter-in-law was a teacher in the school, not from-- in this.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "And at this time when my-- when we moved to this old lady, my mother decide to take care of our life in her own hands.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "Namely, she start to go into business, sort of.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "She went once to the market.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "That's how she started.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And she bought a kilo or two or three kilos, I mean, four of five pounds of little fish-- little fish that-- you know.",
      "word_count": 24
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "She brought it home.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "She grinded the fish, the little fish, made little patties.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And she went to the market with those patties, and she sold it.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "She made the first profit.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Then when it came wintertime, she bought a big wrought-iron kettle, named [INAUDIBLE], I remember.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And she, especially during wintertime, she started to cook.",
      "word_count": 9
    }
  ],
