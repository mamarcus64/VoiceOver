{
  "stem": "10010.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 20,
      "text": "She has children and married.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 21,
      "text": "She was with us all the time until we came to Israel.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 22,
      "text": "And during the war, her parents were with us as well.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 23,
      "text": "About the religious-- religious part.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 24,
      "text": "Now, my parents, as I said, came from religious homes.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 25,
      "text": "But when they married, they rather were traditional.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 26,
      "text": "That on Rosh Hashanah and Yom Kippur they were going to-- to synagogue, but otherwise, not.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 27,
      "text": "They had to work, both of them, on Saturdays.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 28,
      "text": "And-- but when they-- they were very respectful to their parents.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 29,
      "text": "And whenever the parents came to the house, we had a special kosher set of dishes.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 30,
      "text": "And the parents ate on those dishes.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 31,
      "text": "My-- my mother's father was a scribe-- was a Hasid.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 32,
      "text": "And he was mostly, instead to attend to the business, which he had, they had also a business.",
      "word_count": 18
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 33,
      "text": "We-- we cannot call it business.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 34,
      "text": "They were working at home on-- on making buttons also from this galalith-- which was a platform of plastic-- making buttons.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 35,
      "text": "The sons were helping.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 36,
      "text": "And my grandfather had a big beard.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 37,
      "text": "He was a lovely, very full of humor person.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 38,
      "text": "That's what they were telling me.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 39,
      "text": "He rather would study Gemara, study Chumash, than a Torah, and scribe in the Torah, because he was a Torah scribe.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 40,
      "text": "And this has to be done in calligraphy-- cannot be printed, the Torah.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 41,
      "text": "And my grandmother was this energetic and working hard.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 42,
      "text": "My mother, when she was at home, also she had to help very much.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 43,
      "text": "My mother was extremely energetic, and she was-- she taught herself how-- how to sew by opening a pillow, opening a sheet, and sewing by herself the-- the pieces, of-- buying material and sewing.",
      "word_count": 34
    }
  ],
