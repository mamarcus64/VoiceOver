  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 31,
      "text": "And she sat down and she said to me, I have my son somewhere in the war and the army, and I hope that somebody will pick him up and treat you-- treat him, my son, the way I treat you.",
      "word_count": 41
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 32,
      "text": "She went down on the street.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 33,
      "text": "She picked up an American Red Cross patrol.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 34,
      "text": "They took me down on their hands.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 35,
      "text": "I remember the guy carrying me.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 36,
      "text": "I must have been weighing about 70 pounds, put me on a-- on a Red Cross van, took me to hospital.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 37,
      "text": "And that was the end of my liberation.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 38,
      "text": "There I was in hospitals from 1945 until-- until 19-- [PAUSES FOR  SECONDS] I'll pick up.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "What, is it an hour and a half already?",
      "word_count": 9
    }
  ],
