{
  "stem": "9486.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "She had a hard time to be there.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "The kibbutz gave permission me-- they gave me half a year off.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 10,
      "text": "I should go out in the city of Haifa [SIGHS] to go to work, and to help my mom to stand up on their feet.",
      "word_count": 25
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 11,
      "text": "And the kibbutz would send her food every week.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 12,
      "text": "But she-- she cannot be in the kibbutz.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 13,
      "text": "If she be there, she would die.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 14,
      "text": "Every place which she went, and every-- there's Meir.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 15,
      "text": "There is there.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 16,
      "text": "She couldn't stay.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 17,
      "text": "I was having a six month off from my kibbutz.",
      "word_count": 10
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 18,
      "text": "And I was working               in kindergarten.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I-- I bought all the furnitures for my mom.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "At that time, I was there I met my husband.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "I came to a lady [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "She was a cousin to my mom.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "She-- she didn't never went to school.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "She didn't know to write and to read.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And she had in America some family, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "She asked me I should come to write you a letter to the family.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And they used to send her money.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "And I saw a picture [INAUDIBLE], nice-looking soldier.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "You know, very nice-looking man.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And I said to you, would you tell me who's that guy?",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And she said, you want to met him?",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And I said, I just want to know who this is.",
      "word_count": 11
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And that time, I wrote you the letter.",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "She write my good letter, I'm going to make sure you going to meet him.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "I-- I went away to the kibbutz, working there.",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And a week later, I came to see my mom.",
      "word_count": 10
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "I came to see [? you, too, ?] to write you a letter again.",
      "word_count": 14
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "And he came with-- that's the only people what he have, family like.",
      "word_count": 13
    }
  ],
