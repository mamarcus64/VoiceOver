{
  "stem": "22586.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "And we worked for them and stayed there for quite awhile as receptionists.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "But then we realized that we wanted to go to-- we found out-- somehow we met-- the-- the Konigsberg girls had a brother who was in Auschwitz with my father.",
      "word_count": 30
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "And he found us after the war somehow.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And he told us that our father, my father, did not survive.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "He was in Auschwitz, but he did not survive.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "He died of starvation.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "And so we decided we had no reason to go back home at all.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "We knew that our-- the rest of the family died.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "So we decided to-- we would like to go to America.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "My brother-- we got in touch with my brother in Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "And he really wanted us to come to Israel.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 8,
      "text": "But at that time, Israel was still under British occupation.",
      "word_count": 10
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 9,
      "text": "It was not-- we could not go there legally.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 10,
      "text": "If we went there, it would have been illegally.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 11,
      "text": "And there was a lot of fighting going on.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 12,
      "text": "And we just did not want to go.",
      "word_count": 8
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 13,
      "text": "Although I was a big Zionist before the war-- and still am-- I did not want to go illegally.",
      "word_count": 19
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 14,
      "text": "And I didn't want to go anywhere where there's still fighting going on.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 15,
      "text": "So we decided-- decided we not-- did not want to go to Israel.",
      "word_count": 13
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 16,
      "text": "We'd rather go to United States.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 17,
      "text": "Through my brother, we found out our aunt-- we had one aunt in Pittsburgh.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 18,
      "text": "We found out her address.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 19,
      "text": "And we had written to her.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 20,
      "text": "And then she had arranged having sponsored us and sent shipping-- a ticket for the ship so that we could come to the States.",
      "word_count": 24
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Aunt Helen, Helen [?",
      "word_count": 4
    }
  ],
