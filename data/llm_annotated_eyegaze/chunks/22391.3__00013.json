{
  "stem": "22391.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.5,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 18,
      "text": "And one of my aunts said, she said, you're too good.",
      "word_count": 11
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 19,
      "text": "You know how to sew.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 20,
      "text": "I'm going to take you to another place, and maybe they'll give you a job.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 21,
      "text": "So she took me to a coat factory, where they really gave me a job.",
      "word_count": 15
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 22,
      "text": "And I did a lot of good for them.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 23,
      "text": "And I was very happy.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 24,
      "text": "I worked like, like a horse in the end.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 25,
      "text": "I started to work in the morning from 8:30, and I worked to 5 o'clock in the afternoon.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 26,
      "text": "And then I learned this new trade, how to make the hems on the coats and the facing on the coats.",
      "word_count": 21
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 27,
      "text": "And I become very fast.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 28,
      "text": "I was a very fast worker.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 29,
      "text": "And then I got into trouble with the union, because I knocked down the work for the other people.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "On the coat factory?",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I, I worked on this coat factory over a year.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "Then I went to another factory, because this one was sold.",
      "word_count": 11
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I went to the next factory, and that's where I became pregnant.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And I-- this was in 1952.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "'52.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "In August.",
      "word_count": 2
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Should I talk, or stop?",
      "word_count": 5
    }
  ],
