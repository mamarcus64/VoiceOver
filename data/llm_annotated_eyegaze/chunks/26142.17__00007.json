{
  "stem": "26142.17",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.2,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 38,
      "text": "Because I had injury on my leg, so I got to be on the lowest-- on the lowest one.",
      "word_count": 19
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 39,
      "text": "And the food that was given was given the same in the revier as-- as in the-- in the barracks.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 40,
      "text": "The only thing, it was nice and warm inside, and it was clean.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 41,
      "text": "And you didn't have to go out to work.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "When I came into the revier, there was one guy that registered about two, three weeks earlier.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I was holding back with all my strength not to go.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And when he saw me, he didn't recognize me.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He says, oh my god, Michael, what happened to you?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "He still looked half-- half normal.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And I told him-- I told him what happened.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I said, I was afraid to-- to register because they're sending the people-- he said, they are not sending any more because the Russians are already nearby, and they're emptying that camp.",
      "word_count": 32
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "They're not sending any more.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Anyway, the next day, there-- there was like a butcher shop.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "The-- a doctor-- there happened to be a doctor by the name of Dr.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "Schwartz, that was a major surgeon in Budapest Jewish Hospital.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And he was the-- the surgeon but he had nothing, no-- not even an aspirin.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And he was-- he was operating on me.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He said, it's infected.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "It has to be opened up.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "He said, I can't give you-- I have nothing to give you, any anesthesia or anything.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "It won't hurt you.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "I'll do it fast.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "He even asked me, do you speak Hungarian?",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And-- and two guys were holding me down.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "It was just on a table and laying down on a table.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "And he opened it up and cut it open, cut it through and through, drained it out.",
      "word_count": 17
    }
  ],
