  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "What we going to say in Bialystok, we intend to go, and I said in Russian was saved and everything.",
      "word_count": 20
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "And it was an open registration.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "Where you want to go?",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "And I registered.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "I'm going to--",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "To Crimea, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "But we went up, in the Ural Mountains.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "It's warm.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "It's nothing-- I didn't want to go to Siberia.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Because Crimea is a seaside town.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "A seaside town.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "I was there in Crimea.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "After when I was coming home, out of Russia, I was never in Russia.",
      "word_count": 14
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I didn't speak Russian.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "But anyway, we were there-- in-- in--",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "You figured you'd go to a nice, relaxing warm place.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "And later when we came to-- to the Ural Mountain, I said, I show you on the map, Magnitogorsk, the most gorgeous city.",
      "word_count": 23
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Magnitogorsk.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "I show you on the map, Ural Mountains and Magnitogorsk.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And we were there, my brothers, they took him to a-- they took-- they took my brothers to work, very hard work.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Oh, we went to the Ural Mountains.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "We were all there.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They give us quarters, where to live.",
      "word_count": 7
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And they go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "The Russian government.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Instead of to Crimea.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "The train went to Ural Mountain.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "We don't know about it.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "And we got to Ural Mountain, they give us homes, where to live, family.",
      "word_count": 14
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "And you go to work.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "You go to work.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "But they fooled us.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "We-- they fooled us.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "Instead of going to Crimea, they went to-- to the Ural Mountain.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "To-- to-- to go to Crimea.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And we was-- all of a sudden, we landed up in the Ural Mountain, in Magnitogorsk.",
      "word_count": 16
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "It was a beautiful city, but it was Siberian.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "It was unbelievable to live there.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "It was--",
      "word_count": 2
    }
