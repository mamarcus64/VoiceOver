{
  "stem": "4693.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.4,
  "sentences_input": [
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "The name of the street was Dembinska, Number 7.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "It was a pretty modern house, apartment.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "We all lived in apartments in Europe.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "People didn't live in houses or villas, .",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "Unless they were connected with some industry and this was outside of town.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "The house was modern.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "It was the house-- first house in Poland, first building which had central heating.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Which was still before the First World War.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Oh, all over town were  living Jews.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "So it was not-- it was not the Jewish part of town.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "The Jewish part of town was the part, Madreieska, and around where were all the shops.",
      "word_count": 16
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "But Jews lived everywhere.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "Poland actually had originally two classes-- the land owners and the peasants.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "The [PAUSES FOR 3 SECONDS] third class, the town dwellers, this developed originally, it was developed by German colonists and Jews.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "So it was a problem in the Polish economy.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "So that really [PAUSES FOR 3 SECONDS] the merchants were mostly Jews.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Poles were not interested in it, and they didn't know how to do it.",
      "word_count": 14
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I can say only that I was having Hebrew tuitions.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I had bar mitzvah.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But I had arrangement with my parents that after bar mitzvah I do what I want.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And I did it.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "I never went back to the synagogue, or temple, unless for special occasion, but not for religious reasons.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "My father was going, not during the week, or on Saturdays, but on Jewish holidays.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "He was going there.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "I attended-- sorry-- I sometimes went with my father on the Jewish holidays just to go with him.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "I-- generally Poland had 3 and 1/2 millions Jews approximately.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "The high majority was very religious-- Orthodox religious.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "I would say 3,400,000.",
      "word_count": 4
    }
  ],
