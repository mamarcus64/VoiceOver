  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "And for water, we had to dig a hole until water came up.",
      "word_count": 13
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "And I remember the day the water was yellow, and that's what we drank.",
      "word_count": 14
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "We had one Polack with my mother, was hiding there by him.",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 8,
      "text": "My father-in-law had money, so we gave him money.",
      "word_count": 9
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 9,
      "text": "And he used to bring us bread.",
      "word_count": 7
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 10,
      "text": "And we were there close to four-- I think three or four weeks.",
      "word_count": 13
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "It was my wife's parents.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Abraham Schon and Malka Schon.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "And-- [PAUSES FOR 3 SECONDS] --Tonia was her name.",
      "word_count": 9
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "My future wife.",
      "word_count": 3
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "And my mother, and myself.",
      "word_count": 5
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "And we were there, and then--",
      "word_count": 6
    }
  ],
