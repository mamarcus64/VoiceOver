{
  "stem": "1733.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.8,
  "sentences_input": [
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "And the Czech people that were running the-- the-- the village were able to prevail on the Germans, because they had no place to go anymore, to find out if there are any Czech prisoners on the transport, to let them out-- to-- to let them out to their responsibility.",
      "word_count": 50
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "And one morning, they came and they started yelling on the train, anybody Czech, get off the train, get off the train.",
      "word_count": 22
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "So I got off the train.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "Another 30-- another 30 kids got off the train.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "I think they were all Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "They started questioning us, first the Czech authorities--",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "--first the German authorities, and then the Czech authorities.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And they wanted to know where we are from and what our name was.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "At that time, my name became Vladimir Burjan.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I took that name because Vladimir Burjan was a friend of mine I went to Czech school with.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "He was a Czech official's son.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "He was a very close friend, the same age as myself.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And I became Vladimir Burjan.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And the spelling of Vladimir Burjan is very simple-- V-L-A-D-I-M-I-R, second name Burjan, B-U-R-J-A-N.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "I was taken in by a Czech family.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "They knew that I was Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "They treated me very well.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I was with that family for a couple of days until I got pneumonia, and I was taken away to a hospital.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And then I don't know what happened to me for two months, because I was very sick with high temperature in that hospital.",
      "word_count": 23
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "No, [SIGHS] I don't remember the name of the town.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "I really don't.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I know it was in the [?",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "Sudetenland. ?]",
      "word_count": 2
    }
  ],
