{
  "stem": "3103.2",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.5,
  "sentences_input": [
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "When my dad and mom came in to sign me up to the orphanage, assume-- I mean, there was trauma on them.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "They didn't realize what it is.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "They didn't know if I will see them.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "She offered-- she-- I don't know what-- I cannot judge the age, as a youngster.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "But she wanted to adopt me, because she didn't have children.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "I even don't know if she was married.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And my parents would not sign a paper.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "But she was very nice to me.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "She will always sometimes if she will see me that the other kids won't see, she will give me something also to eat or extra.",
      "word_count": 25
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "We didn't have in the orphanage a lot to eat.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "It's the same thing.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "They give us one piece of bread a day.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 16,
      "text": "If it was lunch time, we came into the dorm.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 17,
      "text": "And basically, there were potato peels in the water.",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 18,
      "text": "There were no potatoes.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 19,
      "text": "The kids at night, the boys, through the windows, ran to the farm to dig a potato and make, usually, little fire so they can cook the potato.",
      "word_count": 28
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 20,
      "text": "So for the kids, we have comfort that we kept warm.",
      "word_count": 11
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 21,
      "text": "They gave us warm clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 22,
      "text": "Food was not available.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 23,
      "text": "This was Stalin's time.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 24,
      "text": "We used to sing the songs to Stalin.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I wish you would ask me before.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I could-- [RUSSIAN].",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I remember a lot of Russian songs.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But I wouldn't sing.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "My voice is not the greatest.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "Have to tune it up.",
      "word_count": 5
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] Not really.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I myself-- at that age, I and three or four other girls, I don't remember, we were assigned at dawn, which is like 4:00, 4:30 in the morning, to go on the pasture.",
      "word_count": 34
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "And we were responsible, like, for 15 or 17 young calves.",
      "word_count": 11
    }
  ],
