  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And I wrote him that it is better that he changes his name because this Jew, this [GERMAN], which I suspected then-- I did not-- I was not sure, but I suspected only that he-- he denounced us.",
      "word_count": 38
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "That he knew his address, so better you change your place, and-- what he did, which he did.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And from this time on, we were not in touch anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "That was one-- more than one and a half year till the end of the war.",
      "word_count": 16
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "He knew about the-- even my parents knew he's--",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "At this stage, my parents did not live anymore because--",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I heard afterwards that in September, the-- the ghetto in Przemysl was liquidated, and they were taken.",
      "word_count": 17
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Probably to Auschwitz, see--",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "--like everybody else at this time.",
      "word_count": 6
    }
  ],
