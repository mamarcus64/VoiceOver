  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.7,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Granite ruined the car, which came in because the Russian shelled the city, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 13,
      "text": "But otherwise, I had never had to do anything, anything what they call physical, except what I chose to do, you know, on my own for the underground.",
      "word_count": 28
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 14,
      "text": "But anything physical-- nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 15,
      "text": "I was issued my gun, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And I was issued a rifle, which I absolutely-- I mean, I was-- never even-- I was in a office.",
      "word_count": 20
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "I never even-- no, I'm wrong.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "Afterwards, I took it down to the hiding place, put him under the work bench, just in case if my pistol misfire, I have another one, you know, in case if I have the people, you know, if anybody would come in and try to, you know, nosey.",
      "word_count": 48
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "One time, a person came in.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I wasn't there.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "My cousin Susie would tell you, if you ever have the chance to talk to her.",
      "word_count": 16
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And they were able to talk [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They said, how come you're in  not in your home?",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "How come you're sitting here in the basement of your factory?",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "Said, oh, because in case of air raid, this feels safer in a-- in the basement than being home.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And then they were able to get away.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And the guys did not look around, because the hole, which was about that big, about four bricks, they were covered with all kind of a junk and everything.",
      "word_count": 29
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "So people didn't know it.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And when somebody came in, we always-- they always knocked on the wall.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "No words.",
      "word_count": 2
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "Someone is here, a stranger, even if their friends came down.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "They-- because a lot of time, Susie had friends, and my aunt has friends.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "They won't even trust their friends.",
      "word_count": 6
    }
  ],
