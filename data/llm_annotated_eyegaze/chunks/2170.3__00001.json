{
  "stem": "2170.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.3,
  "sentences_input": [
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "She put me-- like, there was a oven in the top between the oven where they bake, you know, I don't know, attic, you call it.",
      "word_count": 26
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I was sitting there until 3 o'clock in the morning.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "She woke up.",
      "word_count": 3
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And she woke me up.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "And she said to me, we have to go.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And where do we go?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We go 8 kilometers to Zhmerinka.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Zhmerinka was a big ghetto of almost 4,000 or maybe 5,000 Jewish people.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It was under the jurisdiction of the Romanian government.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Because during the war, Hitler and Antonescu, which was the leader of Romania, gave up part of the Ukraine to the Romanians for recognition that they're fighting together.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They're Axis.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And this was a part of the Ukraine, which was Odessa up to Zhmerinka, other cities.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "The Romanians did not make big concentration camps.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "There were many Romanian Jews who were thrown out after the Germans and the Romanians took it over from the Russians-- part of Bukovina, Moldavia, and Bessarabia, not inside of Romania.",
      "word_count": 31
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "But the Jews, which I mentioned-- the states were sending in to occupy Ukraine.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "And they call that Transnistria, which was Zhmerinka, only 8 kilometers away from Brailov.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "In Transnistria, in Zhmerinka, there was a ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 8,
      "text": "There was a hospital.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 9,
      "text": "There was a Judenrat.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 10,
      "text": "There was even a theater.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 11,
      "text": "There were Romanian Jews who were thrown out from Chernovitz and coming into that ghetto.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Many died on the way coming over there.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "But everybody in that ghetto was working, working outside of the ghetto, helping the Romanians, doing the work, and also some occupation chairmans.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "There was no German SS or Gestapo authority over the ghetto, only Romanian authority.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "And this woman, Ukrainian, told me she's going to take me to Zhmerinka.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "We walked up from the house.",
      "word_count": 6
    }
  ],
