    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "In Holland, nobody spoke Ladino.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "They spoke the British-- the Dutch language.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 4,
      "text": "Only the rabbi-- the rabbi received a photo of my-- when I'm being the chuppah-- the 'chuppah,' we call that-- is dressed like Napoleon.",
      "word_count": 24
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "The rabbi from-- he's walking in front of me, bringing me into the shul.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And we called the shul the [NON-ENGLISH], all Sephardic names.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "When it's-- when it's Sukkot, the Sukkot we call 'Cabana,' still the Spanish name that, that-- but the history for my family, what I have going back, 1492, [PAUSES FOR 4 SECONDS] Rabbi Daniel Pinto was a rabbi in New York in 1700.",
      "word_count": 43
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS] They came from--",
      "word_count": 7
