{
  "stem": "20575.4",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 13,
      "text": "And that's why I find it so wonderful from Steven Spielberg that he, he manages and arranges all these interviews.",
      "word_count": 20
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 14,
      "text": "Even though we didn't want to do it, we find now that it was our duty--",
      "word_count": 16
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "--duty to, to the people who got killed.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "Because there are many who don't believe it.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They say, all of these pictures and all these stories are lies.",
      "word_count": 12
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And not 6 million were killed, only 1 million.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "It doesn't make any difference.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "But there were 6 million Jews killed.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 6,
      "text": "There were other people killed, too.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 7,
      "text": "But they decimated the Jewish-- half-- I think there were-- there were 12 before the war, 12 million Jews in the world.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 8,
      "text": "I think now may-- might be 14.",
      "word_count": 7
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 9,
      "text": "And that that's-- so they decimated us.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "No!",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHTER]",
      "word_count": 1
    }
  ],
