{
  "stem": "2002.5",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.1,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "And he said, you're going to get me your money.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "Or I'm going to put you in jail.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "You've got a false document.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "I said to him, I don't have a lot of money.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "Whatever I got, I give it to you.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "I had, maybe, $20, $30.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "And I said, I'll give it to you.",
      "word_count": 8
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "No, he wants more.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "And I could see I got problems.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "So I said to him, I got money sewed into my cuffs in my pants.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "If you get off the train, I'll, I'll take it out and give it to you.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "We got off the train in Hanover, I think-- oh, no, Kassel.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "That's right, Kassel.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 25,
      "text": "We got off in Kassel.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 26,
      "text": "And behind the train station is a building, four walls bombed out on the [INAUDIBLE] there.",
      "word_count": 16
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 27,
      "text": "I go inside.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 28,
      "text": "But I haven't got any money.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 29,
      "text": "While he's bending down to go to my cuffs, I pick up a brick.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 30,
      "text": "Young I was.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 31,
      "text": "And I was very strong.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 32,
      "text": "And I hit him with the brick.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 33,
      "text": "And I hit him with the brick.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 34,
      "text": "He started to bleed.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 35,
      "text": "And he fell down.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 36,
      "text": "It's long, he gave me a chance to get out of there.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 37,
      "text": "As I got out.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 38,
      "text": "I ran a couple corners right and left, right and left, that nobody would know what's going on.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "As I'm walking there, I asked somebody, where do you sleep over if you have no money?",
      "word_count": 17
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "He said to me, there's a monastery.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "You go two blocks.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "Go to the right.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "And there's a monastery.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And you can eat, sleep there.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "And you know, they'll give you-- and I went there.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And I went there.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "And I slept over.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And they were talking to me.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "And they said to me, there's a camp in the town.",
      "word_count": 11
    }
  ],
