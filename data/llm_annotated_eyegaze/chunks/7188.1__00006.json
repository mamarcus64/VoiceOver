{
  "stem": "7188.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 5 SECONDS] When I peeled the potatoes, there was a knock on the door.",
      "word_count": 16
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "The door wasn't locked.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "They came in [PAUSES FOR 3 SECONDS] and looked around.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "They did find-- I had a very rich uncle-- they find wool.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "They had a factory for sweaters.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "So he wanted to protect them, so he gave it all to the family, wool, to save.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "If you're going to be liberated, we'll have something after the war, because the German liquidate everything.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "So I got beaten up terrible because the wool was hiding under the mattress in the bed.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "So everybody thought they shot me, but they shot the man in the attic.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Was a man grinding bread.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "He got shot and they came to the house and saw me alive.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "They were happy.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "I said, what happened?",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "I said, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "There was black and blue marks on my back.",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "I couldn't even straighten my back out.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "And that was-- How old were you?",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "How old you were then?",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "What, 10, 12, something.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "Comes to dates, I don't remember anything.",
      "word_count": 7
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Well, sure it was hard.",
      "word_count": 5
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "He was the provider.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, in German.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "But Polish people [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "Because they said they're going to rape girls.",
      "word_count": 8
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "They did rape the girls.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "They molested them or something, and my mother was afraid of them.",
      "word_count": 12
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "They didn't want me sent out to work no more.",
      "word_count": 10
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "Because what was going on.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "Other girl they killed.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "And this girl got killed.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "And this one was molested.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 8,
      "text": "So--",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Well, my mother explained it to us.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "She says, you're going to stay a couple days till it quiets down.",
      "word_count": 13
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "You'll come back home.",
      "word_count": 4
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "My youngest sister stayed with my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "By myself with the Polish people.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "My mother knew them.",
      "word_count": 4
    }
  ],
