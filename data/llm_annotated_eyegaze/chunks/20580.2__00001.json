  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 22,
      "text": "I took this leather with me and go to the main office, which is Horochow.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 23,
      "text": "I told you.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 24,
      "text": "Over there is a manager, Zimmerman.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 25,
      "text": "The main officer is Winkler, a German from the-- from the [NON-ENGLISH], from the German government.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 26,
      "text": "Winkler.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 27,
      "text": "You have to put it on.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 28,
      "text": "That Winkler was the main manager.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 29,
      "text": "And the Jewish guy, Zimmerman, which has a parent-- relatives a lot over here.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 30,
      "text": "If you're going to be in the paper, you're going to read it.",
      "word_count": 13
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 31,
      "text": "They probably-- they're going to talk about.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 32,
      "text": "Then, I belong to them.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 33,
      "text": "And I became the authority to make the leather and to bring them finished.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 34,
      "text": "Raw material, which I cannot do it, like, foxes.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 35,
      "text": "I couldn't do it.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 36,
      "text": "Then the polizei master, Gretzner, gave me couple foxes.",
      "word_count": 9
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 37,
      "text": "And I took the foxes and bring to the city.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 38,
      "text": "And they have-- and I gave-- I didn't give him the receipt.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 39,
      "text": "But he says, next time, you bring me the receipt.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 40,
      "text": "The next time he came, he wants-- was 1942, when I feel that a Jewish has to be killed-- to give me my receipt.",
      "word_count": 24
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 41,
      "text": "I say, [NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 42,
      "text": "Says, [SPEAKING NON-ENGLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 43,
      "text": "You speak Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 44,
      "text": "You speak Russian.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 45,
      "text": "You speak a little bit German, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 46,
      "text": "He's in Germany.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 47,
      "text": "I heard from this guy, he's in Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 48,
      "text": "He's still living.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 49,
      "text": "Now, today, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 50,
      "text": "It's a long time ago.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Which one?",
      "word_count": 2
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "He says to me-- he says to me, cover up yourself.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "You are speaking English well-- [NON-ENGLISH], you speak Russian well, and this.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "And you could hide yourself.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "I, if it comes a time to my when I have to hided, I have nowhere to go.",
      "word_count": 18
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "You could go anyplace you want to.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "And you know the area.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "He says to me-- that's what he said to me that time.",
      "word_count": 12
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    }
