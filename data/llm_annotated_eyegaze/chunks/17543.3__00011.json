  "model": "openai/gpt-oss-120b",
  "elapsed_s": 194.2,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "So I came to England, and I divorced from that first marriage and married to my second husband in 1963.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "I got two children, and one is not married.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "[SOBBING] The other on is in Israel. who-- who went-- I wanted to go to Israel.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "Wouldn't have me because I haven't got the money to keep myself, because I-- because I'd taken on the British National, really.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "And they only have space for those who is in danger.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "So after my [INAUDIBLE] the Israeli government wouldn't have me unless I keep myself.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "So everybody who is-- who is a Jewish person can go to live in Israel, but they have to keep themselves.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "So if you hear-- What do you mean by that?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "Do you mean they have to-- to earn a living to themselves, or--",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Either have a chance to earn their living, or they have any income.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "But they can't support-- they can't support anybody who is not coming from a country where they are in danger, because the country is very beginning, and they can't afford to support people.",
      "word_count": 33
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So it's really hurtful, but because under 32 can go to work in a kibbutz, that's different.",
      "word_count": 17
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "So my daughter as a volunteer, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "She was only going six weeks for her between study.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And she says, well, I'll take a year out, because I find other people who take a year out.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "And she met her husband, and she stay.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "She's there.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "But it's really hurtful for me not to be able to go to live in Israel is really-- is very hurtful.",
      "word_count": 21
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I-- I find that really this is a very bad for me, because I should really live there.",
      "word_count": 18
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "What can I do?",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "This is [INAUDIBLE].",
      "word_count": 3
    }
  ],
