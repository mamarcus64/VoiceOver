{
  "stem": "10825.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.8,
  "sentences_input": [
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "Her birth place was Danzig.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] And she had three brothers.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "And her father, thank God, died in 1933, when Hitler came to power, and her mother.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "They were well-to-do people.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "And she married a doctor from Berlin, an-- Dr.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "Frank.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "And her brother was told a day before-- you see, they are different.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "They are Nazis.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "And Nazis also, and SS.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "He was sitting with him on the same bench in the-- in the school.",
      "word_count": 14
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 17,
      "text": "And he came to the bureau of Elsa's brother.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 18,
      "text": "And he said, Fritz, I saw your name, that tonight-- no, tomorrow night, they will come at 11 o'clock at night.",
      "word_count": 21
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 19,
      "text": "And they'll took-- take away your home and everything.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 20,
      "text": "Take your family today and go away!",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "You see the difference?",
      "word_count": 4
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "He was a Nazi who gave him a tip.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "And my girlfriend turned away when the war broke out.",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "You see?",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And the same day, Elsa, with her husband, they were two brothers, and the mother.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Because one son was in Israel when he was 14 years old.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "He couldn't attend, already, school in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "So he was sent to Israel, by HaBonim.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "So he lived in Israel.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And they left for Warsaw with the last train.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "They couldn't take-- probably they took jewelry, or cash, what they had.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And they left the-- the-- the-- the help there with-- you can imagine how they-- they lived.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And they left for Warsaw.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "And as he said, next day they came.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "And they demolished the house.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "And-- and from Warsaw, later, the mother called the help.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "And she said, my goodness, good that you haven't been there.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "They came and they demolished the house.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And they took away everything.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 14,
      "text": "And that was that.",
      "word_count": 4
    }
  ],
