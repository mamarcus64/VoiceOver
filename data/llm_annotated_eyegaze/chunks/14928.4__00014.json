  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And we traveled all night to go to Luboml.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "We traveled with gypsies.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "There were a lot of gypsies.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And it was very scary, because they made a lot of noise.",
      "word_count": 12
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "But they were nice.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "They were nice, nice people.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "We lived through the night and went in Luboml to a-- to a priest.",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "And she got all the orders where to go, because the priest knew already where that is.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 7,
      "text": "So we went through with a train to the Polish partisans.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 8,
      "text": "And I came to the Polish partisans maybe two days.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "I walked there.",
      "word_count": 3
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "We went through the dining room, whatever we went.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "I took a look.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "I saw a man, a young man that also worked on the farm.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "But he knew that I was Ukrainian.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "So I was very scared again.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "So-- and-- and the night later, or the night before, we had a message that the Ukrainian partisans came in, and they killed all the Polish people in the town-- in the village where her parents lived.",
      "word_count": 37
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "So she said she wants to leave us and go to see what's happened to her parents.",
      "word_count": 17
    }
  ],
