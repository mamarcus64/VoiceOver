  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 15,
      "text": "I didn't go to bed.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 16,
      "text": "Who could-- could even?",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 17,
      "text": "I just put my baby to bed, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 18,
      "text": "So he said to me, give me the baby.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "He gave it to me.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 20,
      "text": "He said, go this way.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 21,
      "text": "And I walked up on the second floor where they were living.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 22,
      "text": "And he saved my-- the first beginning of my life saving was him.",
      "word_count": 13
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 23,
      "text": "And there-- And then where did you go from?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So early in the morning, I didn't have no [NON-ENGLISH] during a-- a control.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I had nothing to-- to prove.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "And he told me that.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "He told me that, what will you do during control?",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I said, I'll think of something.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Whatever will be, will be.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "So early in the morning, before 8 o'clock, a army man came to call for him.",
      "word_count": 16
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "This is what he always used to be called to go to war.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Because he-- he worked for the [NON-ENGLISH] to make a [NON-ENGLISH] in his apartments.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 9,
      "text": "And this is why his back jacket was-- [LAUGHS] --help me!",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 10,
      "text": "[LAUGHS] I'm laughing now.",
      "word_count": 4
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 11,
      "text": "You don't know what I went through.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 12,
      "text": "You-- you know.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 13,
      "text": "And here he came in-- came up.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 14,
      "text": "And I said to him in German, [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 15,
      "text": "My mind goes-- goes-- you know, with-- be working.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 16,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 17,
      "text": "I-- I know German and how to.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 18,
      "text": "We did took up in school, the German, too-- then changed to French as a-- as a extra, you know, additional language-- foreign language.",
      "word_count": 24
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I said, I don't have what to show.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "And they went.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I will-- he will-- he hadn't [NON-ENGLISH] the proof whether when-- when the, you know, control [NON-ENGLISH].",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So he ask me, what shall I do?",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "I said, you can-- you can do a lot for me and with a little bit of work.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "What is it?",
      "word_count": 3
    }
  ],
