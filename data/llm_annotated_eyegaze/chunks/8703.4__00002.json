{
  "stem": "8703.4",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And she prepared also a soup or something for me, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "Over there it was not as bad as barrack C.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Woman was also in, in, in barrack C.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "There were women in barrack C.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "But they were separate barracks--",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "--and the men were separate-- barracks.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, women were working in the same place where I was.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "They were supplying the powder.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "It had to be weighed the exact amount, you know, and they were working on these things, you know.",
      "word_count": 19
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And the only one problem was the selections that we suffered immensely, terribly.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "They came-- the Germans came every week or every two weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "They came usually after the people left to work.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "Whoever stayed home for any reason-- claimed that he was sick or he was injured at work-- and they took them out.",
      "word_count": 22
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "And they took them to a certain place they called strzelnica.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "This was the firing place and testing place. and over there, they were shot.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Firing place is a Polish word, strzelnica, yeah.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The firing place and testing place.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "This was over there.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "They tested, ammunitions and if they, you know.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "And this was-- that people, you know, were scared, and everybody.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "It happened.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "Sometimes you were injured, or-- And people were sick with the typhoid.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "They couldn't stay home, and they couldn't walk even.",
      "word_count": 9
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 8,
      "text": "So people were so nice and so supporting.",
      "word_count": 8
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 9,
      "text": "They carried the men.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 10,
      "text": "Two men carried them because they had high fever, and they were so exhausted.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 11,
      "text": "For 13 days-- after the 13th day, they-- if he went through the crisis, then he survived.",
      "word_count": 17
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 12,
      "text": "Some-- a lot of them died from the-- from the-- from-- from typhoid.",
      "word_count": 13
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 13,
      "text": "And people were very supportive.",
      "word_count": 5
    }
  ],
