{
  "stem": "9471.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "I-- I was there I don't know how many months.",
      "word_count": 10
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 7,
      "text": "I went to every opera, and just had a wonderful time, made lots of friends there.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 8,
      "text": "I-- I liked to travel.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 9,
      "text": "Oh, I remember when I was I think 13 years old, I got pneumonia.",
      "word_count": 14
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 10,
      "text": "And they send me to Slavonia.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 11,
      "text": "Slavonia is like here, Aspen, you know, to recuperate.",
      "word_count": 9
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 12,
      "text": "And I was there three months.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 13,
      "text": "And that, I remember all my life.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 14,
      "text": "That was-- they call it [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 15,
      "text": "That's like a-- like a camp, you know, for young girls.",
      "word_count": 11
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 16,
      "text": "And oh, we had wonderful time.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 17,
      "text": "And I remember our-- we called her Aunt, the one who was director of this camp.",
      "word_count": 16
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 18,
      "text": "One day, she had to go to a baroness, because it was a castle there.",
      "word_count": 15
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 19,
      "text": "And she needed the gloves.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 20,
      "text": "So we make a-- a nice poem.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH] goes to baroness, and she-- it rhymes in-- in-- you know.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I cannot.",
      "word_count": 2
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "But it was so funny.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And I-- I remember the nurse, she always came.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "We had to had [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "You know what is [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "The children, you know, you have to go to washroom to have a-- how do you call it?",
      "word_count": 18
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH].",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Like a cough medicine.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "It's a cough medicine.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 4,
      "text": "And I remember a song.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 5,
      "text": "We said, sister, knock, knock, knock.",
      "word_count": 6
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 6,
      "text": "Sister comes in room, asks you for-- to take the medicine.",
      "word_count": 11
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 7,
      "text": "That I remember, too.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "I have a picture from this.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "We were I don't know how many people there.",
      "word_count": 9
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "And we had lots of parties, children parties, you know, of-- [PAUSES FOR 3 SECONDS] That I remember.",
      "word_count": 18
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "How long?",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Three months.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Three months.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "That was in summer.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "That's a mountain.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "You know.",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "And when I came back, I-- I was OK.",
      "word_count": 9
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "What year?",
      "word_count": 2
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh.",
      "word_count": 1
    }
  ],
