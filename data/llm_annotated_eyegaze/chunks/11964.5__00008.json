{
  "stem": "11964.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And they gave the list to the International Red Cross.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And after-- I don't know how long we were at Wells.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "Whatever time we spent there was too long, because we were very uncomfortable there.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "We were taken to Linz in Austria.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "Linz is also a displaced persons camp.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 13,
      "text": "We were taken to Linz, and we were told that it is overcrowded, that we won't be able to stay in Linz, that we have to wait there a few days until they figured out another displaced persons camp to take us to.",
      "word_count": 43
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 14,
      "text": "These displaced persons camps were then being established under the auspices of United Nations.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 15,
      "text": "They created what they called UNRRA, U-N-R-R-A, United Nation Refugee Rehabilitation Administration.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 16,
      "text": "And one of the newly-established camps was in Austria in Bad Gastein.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 17,
      "text": "And once they established that community for a displaced persons camp, they took us there.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 18,
      "text": "It was a brand new camp.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 19,
      "text": "When we arrived there, there were some people already there.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 20,
      "text": "But it was a beautiful location.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 21,
      "text": "It was in the Austrian Alps.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 22,
      "text": "And they acquired some of the hotels for the camp.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 23,
      "text": "And they put us up.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 24,
      "text": "All three of us were put into a nice hotel room with a bathroom.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 25,
      "text": "We had a bathroom with running water and a toilet.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 26,
      "text": "And the bedding was there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 27,
      "text": "And we just felt that we were in the lap of the highest luxury.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 28,
      "text": "When we got to Bad Gastein, the International Red Cross came, and they tried to help us, indeed.",
      "word_count": 18
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 29,
      "text": "And I gave them the name of my uncle, my mother's brother, who left Poland so early for England.",
      "word_count": 19
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 30,
      "text": "My mother's maiden name was Heiman, H-E-I-M-A-N.",
      "word_count": 7
    }
  ],
