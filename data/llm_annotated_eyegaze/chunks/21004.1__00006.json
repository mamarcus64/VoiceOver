{
  "stem": "21004.1",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.5,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "Even when we built the house in [INAUDIBLE], a lot of Gentile people gave stuff, whatever they could help, materials, straw, and all kind of things, whatever you need to build a house.",
      "word_count": 33
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "They were very, very nice to us.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "But then my mother are very good.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "She also knows all about-- she helped Ukrainian people with kids.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "They had always a lot of kids and some of them were sick, you know.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 8,
      "text": "So she helped them.",
      "word_count": 4
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 9,
      "text": "And she-- she was putting down those-- in Europe, they put down-- you have a cold or whatever, so you put on such a glass with spirits.",
      "word_count": 27
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 10,
      "text": "You put it on on the body.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 11,
      "text": "And this cleared the-- the sickness.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "And also, they had some kind of worms where they put it on when you have pneumonia.",
      "word_count": 17
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "She also-- we had this, what she was going-- anybody they call, they came, they call my mother.",
      "word_count": 18
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "And she came and she know how to do that, to put on the body.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "They soak out the blood and that helped for the pneumonia.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "That's what the old-- the old doctors.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "So she was an old doctor like that.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "And they all respected her.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "Even the priest in the city, he always respect my mother very good.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "He always used to buy cigarettes, specially only by us, because she was a widow, so he stopped.",
      "word_count": 18
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "He bought two cartons, three cartons of cigarettes.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 5,
      "text": "He said, you can't buy no place else, only from my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 6,
      "text": "Very nice.",
      "word_count": 2
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "He was very nice.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "But later on, it started getting the anti-Semitism.",
      "word_count": 8
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "How did your mother make a living?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Oh, made a living.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "We had our own food.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "We went to the-- we went to the-- to the field.",
      "word_count": 11
    }
  ],
