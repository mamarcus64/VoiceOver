{
  "stem": "17761.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.0,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "Sunday afternoon around 4:00, a little tank on the mountain, gave three, four shots, [INAUDIBLE].",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "Three, four shots, and went down.",
      "word_count": 6
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "And now there are about three tanks.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "These chased the Russ-- the German army.",
      "word_count": 7
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "And then started to-- to come from the mountains soldiers by foot, by horse, by cars, by you name it, in a total mess.",
      "word_count": 24
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 25,
      "text": "But masses of soldiers.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 26,
      "text": "Their kitchens and their-- their-- they came two, three weeks later.",
      "word_count": 11
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 27,
      "text": "They used to go to the-- to a-- to a ground, take a big onion out and-- and clean it from the-- from the mud, and eat it.",
      "word_count": 28
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 28,
      "text": "They didn't have anything.",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 29,
      "text": "We didn't understand how could they chase such a well-organized army, but that's a fact.",
      "word_count": 15
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "I remember razzias in two periods.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "Basically in two periods.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "One is at the beginning where they just used to catch in people in the street and to chase them farther.",
      "word_count": 21
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "One of my uncles, my mother-- my father's sister-- her name is Raisel.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 4,
      "text": "She's now over 90 years, still living in Jerusalem.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 5,
      "text": "Her husband's name was Israel Heller, H-E-L-L-E-R.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 6,
      "text": "He was from Suceava, and he has been deported from Mogilev-Podol'skii.",
      "word_count": 11
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 7,
      "text": "He Was caught on the street and deported to what was called the camp of death, in a place-- in a place called Picioara, P-I-C-I-O-A-R-A.",
      "word_count": 25
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 8,
      "text": "From there, almost nobody came out alive.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 9,
      "text": "Somehow, he succeeded to run away from there, and he arrived, after two weeks of wandering from there, back to the ghetto of Mogilev, and after a day, he passed away from starvation.",
      "word_count": 33
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 10,
      "text": "That his memory be blessed.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 11,
      "text": "That is one period.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 12,
      "text": "Then there were-- they used to catch people in the street and see if he has documents.",
      "word_count": 17
    }
  ],
