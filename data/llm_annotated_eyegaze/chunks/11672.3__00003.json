  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "These two brothers went back to Poland, [PAUSES FOR 3 SECONDS] went back to Poland to Germany because the-- the two brothers, they couldn't take this life.",
      "word_count": 27
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "The Russians were very hard to live.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "But for his parents, a little richer, he can make, you know, it's a better life--",
      "word_count": 16
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Here, you have to work.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "For me, it is not so hard because I'm from a poor house, poor parents.",
      "word_count": 15
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "And this older brother, [?",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "Dorfman ?] sent me a letter in German.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "[INAUDIBLE] gone to factory, and-- in a metal-- a metal factory, and learn to make legs and go away.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "You know what this means?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Escape in Russia and go back to Germany.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "The Russian Gestapo is smart.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "Oh, he didn't fool them.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "He said, your friend is a spy.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Are you a spy?",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "I told him, how am I a spy?",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I'm a young boy, and I'm a Jewish boy.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "No, you're a Polish pig.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Sign you're a spy.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I'm not a spy.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I don't know what you talk to me.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "Arrested me and put me on a cellar.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 9 SECONDS] [SOBS]",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Every-- [PAUSES FOR 4 SECONDS] every night, 2 o'clock in the morning, They would-- sign.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] I don't sign.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I know if I sign, this it-- this it is, go and hang me.",
      "word_count": 14
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "And this man, I remember this man's name.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Shestabitov. ?] Because somebody called-- not of one is [INAUDIBLE], this is prison already.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They're going to take me out, that they have four or five here they've-- they uncovered there from the Gestapo.",
      "word_count": 20
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "And one called, [?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "Shestabitov, ?] like this with the finger.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "And one time, they put my [INAUDIBLE] to the nose.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "[SOBBING]",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "[SOBBING] Electric, they put electric.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "In three days, I lost hair, in three days.",
      "word_count": 9
    }
