    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Well, I think it was around a year.",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "A year, and then we--",
