  "sentences_input": [
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Why, I told you, I have on my passport--",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "That you were a prisoner.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "No-- yes, a special--",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I'm not supposed to live so, so far away from a big city.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "Then I pay a few underneath the table, and-- 30 kilometers away from the city where Liuba lived.",
      "word_count": 18
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And they give me a stamp.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "I have the right.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "Over there, you're supposed to have a stamp in police.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "When you came in a new city to live, you have to go in police.",
      "word_count": 15
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "You have to prove that you have a-- excuse me-- a, a place where to live in so many square meters.",
      "word_count": 21
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And then they give you a permit.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "You can live over there.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "They give me a permit over there, 30 kilometers away--",
      "word_count": 10
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "--which I have problem, too.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They said you have to stay 105 kilometers away.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "[SIGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "When I married my wife, I was a foreman.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "And, you know, foundations-- they used to make the foundations.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "And I learned a little bit the blueprint, slightly.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And I took this job, a foreman.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "When they're making the foundations, they're cutting all the foundations, I was this kind of job.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "It was very, very low paid, not high wages.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "We was living in Troki, a little city, Troki, T-R-O-K.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "This is-- was-- used to be-- yeah, Lithuania.",
