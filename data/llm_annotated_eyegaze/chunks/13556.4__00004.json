    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "And we left.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Son was born--",
      "word_count": 3
    },
    {
