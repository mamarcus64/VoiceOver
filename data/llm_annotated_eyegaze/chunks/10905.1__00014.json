  "sentences_input": [
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 9,
      "text": "And when the fascists turned on them, it was such a shock that-- and in such an assimilated place.",
      "word_count": 19
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 10,
      "text": "I mean, the Admiral Horthy through marriage had Jewish relatives.",
      "word_count": 10
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 11,
      "text": "It was-- it was-- it was-- it was amazing.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 12,
      "text": "But things got bad.",
      "word_count": 4
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 13,
      "text": "Now, the reason I'm sitting here today, and that I am not someplace in Eastern Europe, [INAUDIBLE] Eastern Europe, is because I happened to have been living in Budapest, and my father happened to have been a Zionist.",
      "word_count": 38
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 14,
      "text": "And thanks to a man called Kastner-- Rezso-- R-E-Z-S-O, with a two-- umlaut-- Kastner, K-A-S-T-N-E-R-- he was able to save a significant number of Hungarian Jews.",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 15,
      "text": "And probably that's why-- I was so young, and I-- I survived the war, even though it was a concentration camp.",
      "word_count": 21
    }
  ],
