{
  "stem": "23131.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.1,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "She was a lady of-- she could afford-- my father made a very nice living.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And, you know, she took care on her kids.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "She was from the old-- from the old timers.",
      "word_count": 9
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "Loving ballet, loving opera, loving shows, speaking beautiful Russian-- you know, from the old, old intellectuals.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I just had only one brother.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We were two kids.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Mayer.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "He was six years older than me.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "I remember him that, when he had to come for vacations home, I used to kiss a week ahead, the chair where-- the chairs were assigned.",
      "word_count": 26
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "Here was Daddy sitting, here was mommy sitting, my chair, and his chair.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "So his chair, I used always to kiss a week before because I knew that soon, soon he will come and he will be sitting on it.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "We had a very close relationship, period.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Our family was a very, very close and devoted family.",
      "word_count": 10
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "He finished Tarbut in our little shtetl [INAUDIBLE], where we lived-- where Daddy moved when I was, I think, nine months old or a year.",
      "word_count": 25
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "And then, when he finished Tarbut, they sent him to Bialystok to the high school, to the Hebrew high school.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Which at that time, it was a very expensive proposition.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "It was on the same level like here, for instance, college.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "And not everybody could afford that.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "It was a private thing.",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "He lived on my-- the whole family was in Bialystok-- my father's sisters.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "So he lived by one of my father's sisters.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "Her name was Rifka.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And from there, he used to go-- he finished the whole-- he finished-- there was eight classes and two lyceums.",
      "word_count": 20
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "Lyceum is, you know, like advanced two years of college.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "I attend the same Tarbut school-- six classes.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "Six or eight, I don't remember exactly.",
      "word_count": 7
    }
  ],
