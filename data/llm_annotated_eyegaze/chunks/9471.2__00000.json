{
  "stem": "9471.2",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "In my 20s, I remember I went for a New Year to the other city, Koprivnica.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "K-O-P-R-I-V-N-I-C-A-- Koprivnica.",
      "word_count": 2
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 3,
      "text": "And I remember, uh, it was a big, uh, New Year party.",
      "word_count": 12
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 4,
      "text": "And I saw, uh-- [PAUSES FOR 3 SECONDS] next table I saw three young men sitting there.",
      "word_count": 17
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 5,
      "text": "And one was just watching me all the time, and I felt a little bit uncomfortable.",
      "word_count": 16
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 6,
      "text": "But he just stared at me.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "And then when the dancing starts, he sent his friend to dance with me.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And he says-- he asked me who I am, or from where I am from.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And he says, you know, my friend, he fell in love with you.",
      "word_count": 13
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "I says, how could he fell in love with me?",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "He doesn't know me.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "He saw me now at first-- he said, he's just crazy about you, he would like to meet you, and can I introduce you to him?",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I says, I don't know.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "Because I was in love with other guy-- [LAUGHS]-- in Slatina a little bit.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "Nothing serious, but I liked him very much.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "I says, no, I don't think I want to meet him.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And next day, I got roses at my aunt's house from him.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "And, uh, his friend called.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "He says, how about going to movie?",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "I would like to take to movie.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "Would you like to go?",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "I says, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "And I went to movie, and this other guy was there, so he introduced me.",
      "word_count": 15
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "And he asking me to get married right away-- just like that.",
      "word_count": 12
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "And I don't know what possessed me.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "I says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "I says, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "And I didn't even know him too much.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "But I really wanted to go from home.",
      "word_count": 8
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 7,
      "text": "I know this guy, I-- never would come anything serious between us for many reasons.",
      "word_count": 15
    }
  ],
