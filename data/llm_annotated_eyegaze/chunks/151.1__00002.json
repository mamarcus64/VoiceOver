{
  "stem": "151.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 5,
      "text": "And my mother hired an attorney and the attorney told my mother they the two of them will do everything possible to find out what happened to these boys.",
      "word_count": 29
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 6,
      "text": "They found out that they were taken to another city called Munkacs, or Mukacevo.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 7,
      "text": "And they were taken in one of these-- to one of these castles that they Hungarians used as a torture place.",
      "word_count": 21
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 8,
      "text": "And they beat up and tortured these boys, accusing them of dispersing communist propaganda.",
      "word_count": 14
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 9,
      "text": "Now my brother had never any political affiliation with anything.",
      "word_count": 10
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 10,
      "text": "So we knew that it's just a, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 11,
      "text": "[INAUDIBLE]",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "He was.",
      "word_count": 2
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "Finally my parents paid and released all the boys.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And then they came back and they graduated gymnasium.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Well, later.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "Later we had to wear yellow stars and we had a curfew.",
      "word_count": 12
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "My father's business was taken away from him.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I would like to tell you a little incident about my father's business because at one point there was a non-Jewish family, a shoemaker, who had about nine children, came to my father and asked him to take his 13 year old boy as an apprentice in his business.",
      "word_count": 49
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "And my father took pity on him and of course took him in.",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "Not only took him in as an apprentice, but he brought him in our house and he grew up with us as a brother.",
      "word_count": 24
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "And at the end when we were taken to the brick factory, to the ghetto, my father wrote a letter to him to send us some supplies and the answer was that he's not going to risk his life for us.",
      "word_count": 41
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Now this is a young man who took over my father's business.",
      "word_count": 12
    }
  ],
