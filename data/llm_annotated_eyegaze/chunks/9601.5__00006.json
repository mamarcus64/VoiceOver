  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We went into the back-- the back of the, of the pigsty, a [? pig of ?] the barn.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And we went home.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "We could have gone through the front.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "But then we would have known-- people would have noticed, whoever was awake, that we were-- came from Mr.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "Scastny's ?] This way, no one knew that we were-- had anything to do with Mr.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "Scastny. ?]",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "Came home-- guess what?",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "The house is full of Russian soldiers.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "They're sleeping on the floor, on the table, under the table.",
      "word_count": 11
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "There was one guy sleeping on three chairs.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "My parent's chairs were still standing there, because people lived in there.",
      "word_count": 12
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "But the officer wanted to move.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And he was sleeping on the chair, and on three chairs.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "He was kind of dark complected, you know, some was from the [?",
      "word_count": 13
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "Caucasus. ?] He was not a, a Russian by itself.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "He was one of the ethnic.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And he's got this Tommy gun, you know, on his chest.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And he's hugging it, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And he says you know-- whatever he-- forget what he-- I don't remember what he called him.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And I was watching another soldier with a Tommy gun.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Wow, big guy, right?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And he says to him, you know, I want you to move.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Because you're in the way.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "We can't go by.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE] And he keeps talking to him, talking.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "He says, I know how to get him up.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 10,
      "text": "He hollers at him, whatever his name, sir, we are surrounded.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 11,
      "text": "Guess what?",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 12,
      "text": "Got up just like that.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 13,
      "text": "Then he moved to another place, of you know, seat.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 14,
      "text": "And we bought with us-- brought with us from Mr.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 15,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 16,
      "text": "Scastny's ?] home, the clothes were scattered.",
      "word_count": 7
    }
  ],
