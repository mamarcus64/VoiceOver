  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] Israel-- [PAUSES FOR 3 SECONDS] Israel is of great importance to Jewish people.",
      "word_count": 17
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "We have a home now.",
      "word_count": 5
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "If we find ourselves threatened, like [PAUSES FOR 3 SECONDS] in Bosnia-Herzegovina recently, or in Ethiopia, where Jews were threatened, they-- Israelis found a way of taking them out of the danger and bringing them to Israel.",
      "word_count": 37
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 4 SECONDS] My message would be that Jews could not rely of justice from the world.",
      "word_count": 18
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 3 SECONDS] Poland now is riddled with antisemitism, even though there are only over 10,000 Jews living there, as far as I know.",
      "word_count": 25
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "I do not trust the Germans to feel remorse for what they did to us.",
      "word_count": 15
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "Jews have to rely on Jews.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "[PAUSES FOR 4 SECONDS] I pray to God [PAUSES FOR 6 SECONDS] that Israel will be strong enough [PAUSES FOR 5 SECONDS] to be able to safe-- to save her existence for the people that live there now, and for the people around the world.",
      "word_count": 45
    }
  ],
