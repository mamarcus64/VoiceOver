{
  "stem": "12810.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.6,
  "sentences_input": [
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "I started to make some clothes to the children, to her children.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "And then I started to make her a-- a frock.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "And I said to her, you know what?",
      "word_count": 8
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "I started to be sewing, and I will keep a housekeeper for you.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "And I will make a-- a living.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 3,
      "text": "Because-- And you-- you still lived with her, though?",
      "word_count": 9
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "And I working with the-- to the Russian woman, you know, the baryshnyas.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 3,
      "text": "They have no taste and no-- don't know what to wear and how to wear it.",
      "word_count": 16
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 4,
      "text": "And they bring me some nightgowns to make an evening frock out it.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 5,
      "text": "And I do it for them.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 6,
      "text": "And they bring me sugar, and ducks, and chickens, and things.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 7,
      "text": "And I was a rich girls, you know, because I have food.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 8,
      "text": "And it was everything-- everything for the food at that time to surviving.",
      "word_count": 13
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 9,
      "text": "And I even get some jams.",
      "word_count": 6
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I make a parcel, and I go to the priest.",
      "word_count": 12
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 11,
      "text": "I give it to them and bring it to them.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And my cousin said, what you doing?",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "I said, they was good to me.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "I have to.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I-- the first thing, I take some food for them, what they-- what I earned with the Russians.",
      "word_count": 18
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "How long did you continue doing that for?",
      "word_count": 8
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "I do it that about till May.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And then I meet my mother girlfriend who was a-- a-- our lawyer's sister.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And she live behind our house.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "And she has a empty flat.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "She said to me, you know, come here.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Live with me in this-- not-- not together.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "I have a separate flat, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "She said, make it nice, and you are my girlfriend daughter.",
      "word_count": 11
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "You are not alone, and I am not alone.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "She lost her family.",
      "word_count": 4
    }
  ],
