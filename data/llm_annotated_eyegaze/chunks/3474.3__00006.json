{
  "stem": "3474.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.0,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 19,
      "text": "Everyone, mowed them down there, cut them down with machine guns, died, killed them all.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "If I didn't-- if I didn't walk to the other side, I would have been dead, too.",
      "word_count": 17
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "But I don't, I just-- I don't-- I don't understand it up today how I walked away from there, not knowing.",
      "word_count": 21
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I don't know if I was-- you know, your mind gets so numb to everything.",
      "word_count": 15
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "You know, you, you walk around like in daze.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "So I walked from there to the other side.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I didn't know what be different between these prisoners or the other prisoners.",
      "word_count": 13
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And I walked over to the other side.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "And it didn't take 5 minutes, 10 minutes.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "They mowed them down.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "And they left them there.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Then we started death march.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "We were marching through the, through the Sudeten.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "That was on the way to Theresienstadt.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "We were marching.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And every-- we start out from that camp about 4,000 from, from, from Rehmsdorf, about 4,000.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "We were marching.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And everybody three feet behind, they killed them right in the gutter, right in there.",
      "word_count": 15
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I'll never forget.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "Did you ever see a snake when it's like, it's like curling up there?",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And a guy, the SS gave him a bullet in his head.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he was just going like this.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "He was trying to, to hang on to something.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "It was like, no you'd see it.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] His eyes was like puffed out.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "He was trying to grasp into something in the air.",
      "word_count": 10
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "So a guy came out from, from a room from one of the houses.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "And he had a pistol.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And he killed him there.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 11,
      "text": "He gave him another bullet.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 12,
      "text": "So I don't know if he did him a favor or just killed him.",
      "word_count": 14
    }
  ],
