{
  "stem": "18670.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 390.0,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "Five guys sitting there at the table, long table, they're questioning and questioning.",
      "word_count": 13
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "Finally, it passed.",
      "word_count": 3
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "He can come here.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 14,
      "text": "Now we have another thing that's happening.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 15,
      "text": "We have quota systems, right?",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 16,
      "text": "Not the American quotas.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 17,
      "text": "American embassy has a quota.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 18,
      "text": "And the quota-- my quota was because I was born in Vienna, I have a German quota, wide open.",
      "word_count": 19
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "There's a Polish quota.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "They were born with Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Polish Jews.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "They're not Austrian Jews.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "They're Polish Jews.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "That quota is only-- I forgot already what it was, a very small quota.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "And there-- for everyone that wanted to come here, there were 10 that couldn't make it.",
      "word_count": 16
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "But finally, Pearl Harbor is here, everything else.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "One ship is coming to the United States a month, a little Spanish ship from Marseille, lands in Bermuda and then comes here.",
      "word_count": 23
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "The tickets are $1,100.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "I had $800 saved.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "So I went to the [INAUDIBLE], no way.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "They wouldn't advance any money.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "I'm short $300.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "They're the ones that get you the tickets.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "You have to buy it through the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "What are you going to do?",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "Went to the bank.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "I had my uncle, my mother's brother, co-sign.",
      "word_count": 8
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "I got the $300, brought it to the [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "Now we had $1,100 dollars and I think it's time.",
      "word_count": 10
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "Now we're 1942 already.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "Had a ticket to go to be on the ship.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "When the ship gets to Bermuda, they have an advance passenger list, you're not on the ship.",
      "word_count": 17
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "I came up to the State Department in Washington, DC.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "Within a few days, I got an answer.",
      "word_count": 8
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "The embassy in Marseilles-- the consul, not the embassy.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "You have been deported to days before or three days before the ship left, you were deported to German proper.",
      "word_count": 20
    }
  ],
