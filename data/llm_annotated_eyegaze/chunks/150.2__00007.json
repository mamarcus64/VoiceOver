{
  "stem": "150.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.2,
  "sentences_input": [
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "The daily ration was-- they would take a loaf of bread, which was one kilo, 2.2 pounds.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "And they would divide us-- divide it.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "When we first came to the camp, it was one loaf of bread for four people.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Then it was a loaf of bread for six people.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "Then it was a loaf of bread for eight people towards the end of the war.",
      "word_count": 16
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "So you'd just get a slice of bread is all that was.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And then they'd give us a thing, a portion of margarine, or a slice of some kind of meat, or slice of some kind of cheese.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And most people would just eat it right away because they were too damn hungry to do anything.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "Then we'd march for about an hour or so to work.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "Then we'd work for six hours.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "There'd be a half an hour break.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "They would give us soup from a sort of a pot that they would carry to work.",
      "word_count": 17
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 15,
      "text": "And if you knew whoever it was dishing out the soup, they'd give it from the bottom and you'd get a potato or barley or something.",
      "word_count": 26
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 16,
      "text": "And if you didn't know them, they'd give from the top.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 17,
      "text": "And you'd get water.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 18,
      "text": "And then we'd work for another six hours and march back to camp.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 19,
      "text": "They would count us again.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 20,
      "text": "They'd give us another bowl of soup.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 21,
      "text": "And then the rest of the night, you could do what you wanted.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 22,
      "text": "But you count up the hours, there isn't much sleep left.",
      "word_count": 11
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 23,
      "text": "And with the diet we had, people were dying.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I got beaten up a couple of times.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "You know, nothing really, really serious to the point where I couldn't walk.",
      "word_count": 13
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "There was punishment in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "They would whip us.",
      "word_count": 4
    }
  ],
