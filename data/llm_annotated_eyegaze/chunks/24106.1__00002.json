{
  "stem": "24106.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.9,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "We were a family of three children.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "I was the oldest of three girls.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "My middle sister, Ruchel, and my younger sister, Pesie.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "And my mother took care of the children.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And she went shopping, she cooked, she cleaned, she washed the clothes, she did everything.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "My mother never worked.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a [NON-ENGLISH].",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My middle sister, Ruchel, she was younger six years.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "No, excuse me.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "She was younger two years.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I was two years old when my mother had Ruchel.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And then we have another sister, Pesie.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "She was eight years younger than I am.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I remember only my-- my zaide-- my mother's father.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He lived with us all his life.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "His wife died.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "She was very young.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "She left him with five children.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "My mother-- four boys and my mother was the only girl.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "And my mother took care on the-- on the children.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "She raised them all.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "My-- my grandfather's name was Icchok.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Icchok.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "[NON-ENGLISH SPEECH]",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS] My zaide was my first teacher.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I was about three years old.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "And you already-- I have to say brucha.",
      "word_count": 8
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 4,
      "text": "And I have to say, Shema Yisrael.",
      "word_count": 7
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 5,
      "text": "And then he used to put a piece of paper and put it in pencil.",
      "word_count": 15
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 6,
      "text": "You know, alef, bet, gimel.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 7,
      "text": "And I have to-- I have to go over this with-- with a pen.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "My zaide was my first teacher.",
      "word_count": 6
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "My first language was Yiddish.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "That's all.",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "We speak only Yiddish.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "We speak-- we spoke Polish.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Yeah, you know, with children, to go to school.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "We spoke Polish.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I went to school.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "At about seven years old, you go to school, to public school.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "[POLISH]-- that's School Number Seven, yeah, a public school.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I have a favorite subject.",
      "word_count": 6
    }
  ],
