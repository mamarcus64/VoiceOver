  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "But, well, it wasn't anything more than the Christian Hungarian landowners.",
      "word_count": 11
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "And as a matter of fact, the people actually felt this-- this atmosphere that the servants on-- on the Jewish estates are better treated than the ser-- the same kind of servants-- the horse drivers, and the oxen drivers, and then other-- than on-- on the Christian Hungarians there.",
      "word_count": 49
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "No-- these-- these-- these are the facts.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "They never wanted to-- or wanted to- to admit it, but that's-- that was the de facto situation.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "Well, because of my-- of the activities of my father, who was in the leading-- leading personnel in the 1919 socialist revolution in the village.",
      "word_count": 25
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "They called it the-- the council was called the Directorium.",
      "word_count": 10
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 2,
      "text": "And, uh, and they were-- were very close contact-- contact with the provincial city, [NON-ENGLISH], you see.",
      "word_count": 17
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 3,
      "text": "And there, a famous, real upstanding Jewish fellow, uh, Tibo-- [PAUSES FOR 3 SECONDS] [SIGHS] it just slipped my-- my mind.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 4,
      "text": "Who was the second in command, next to Bela Kun-- Szamuely-- Tibor Szamuely.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 5,
      "text": "I saw him personally, on the first [LAUGHS] May Day, when Hungarian revolution came.",
      "word_count": 14
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 6,
      "text": "Following the-- the red flag, it was-- it was so long that it went out about 10-- 10 meters.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 7,
      "text": "And Tibor Szamuely was at-- at the front, leading the May Day demonstration-- it was first such open May Day [NON-ENGLISH] day in the-- in the history of Hungary, in 1919.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "No, no-- be-- because of-- because of his-- because of his philosophy, his political outlook-- well, he was kept out on the-- on the end, mind you, in 1919, when the revolution was-- had been suppressed in blood.",
      "word_count": 38
    }
  ],
