{
  "stem": "25835.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.8,
  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "And he jumped on me.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "He threw me on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "And he start to bite me.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "I covered face.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 18,
      "text": "But he opened wound on the right side.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 19,
      "text": "It was very painful, very bleeding.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 20,
      "text": "They didn't let me go to make some cover.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 21,
      "text": "I was bleeding, very weak.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 22,
      "text": "You know, this wound was not, not, not clean.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 23,
      "text": "This was very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 24,
      "text": "And after this dog opened my body, he called him up.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 25,
      "text": "It was very bad.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 26,
      "text": "[SOBS] And returning to this time when this SS woman told me to work in warehouse, it was a little, a little better. 16 hours for me, it was, very tragically, a long time.",
      "word_count": 34
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 27,
      "text": "But this highlight-- mother, give her something.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 28,
      "text": "And you know, one day, I was unloading, I remember that-- everything what, what came to this campus, I had-- I had to unload.",
      "word_count": 24
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 29,
      "text": "For example, it was old truck with 30 kilo of salt.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 30,
      "text": "It is about 20 pounds salt I had to carry to this warehouse on my back.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 31,
      "text": "I don't know how, but I did it.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 32,
      "text": "And one day, also, I unload bread.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 33,
      "text": "I was standing on the table, through the window, taking from this man bread and putting on the shelf.",
      "word_count": 19
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 34,
      "text": "In this time was passing group of women, not my language.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 35,
      "text": "Some-- I knew that they are from Hungary, Jewish women.",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "It-- they, they said.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Somebody said me they Jewish from Hungary.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "They were living next barrack.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "And she-- only showing me [INAUDIBLE] that to give her something to eat.",
      "word_count": 13
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "And I didn't know about the consequences.",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 5,
      "text": "I put small piece.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 6,
      "text": "And I throw her, supposing that nobody see.",
      "word_count": 8
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 7,
      "text": "Putting this loaf of bread different way, nobody can see.",
      "word_count": 10
    }
  ],
