  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 17,
      "text": "The Rabbi came to the house and brought about half a dozen boys.",
      "word_count": 13
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 18,
      "text": "And we used to read still Hebrew.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I talked Ukrainish, Polish, and Jewish.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And that's it first.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 48,
