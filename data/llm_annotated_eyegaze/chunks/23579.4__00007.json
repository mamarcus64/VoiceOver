{
  "stem": "23579.4",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.4,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "You have to stand up.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "I said, I cannot go.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "I don't have nothing.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "You're going.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "And I went without nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "And it was very cold.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "And I was feeling till here, this snow.",
      "word_count": 8
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "And I couldn't go.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 19,
      "text": "When I am very afraid of something, I'm losing myself.",
      "word_count": 10
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 20,
      "text": "I lost everything.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 21,
      "text": "And I said, Chaya, you go my kin, and you tell how do I fell.",
      "word_count": 15
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 22,
      "text": "She said, oh no.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 23,
      "text": "I don't want fell from Zusia's hand.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 24,
      "text": "Oh, no.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 25,
      "text": "I'm not going without you.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 26,
      "text": "And they were a one [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 27,
      "text": "This was a machine gun.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 28,
      "text": "And he said, Chaya, if you're not going, I'm going away.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 29,
      "text": "I will not wait for Sonia.",
      "word_count": 6
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 30,
      "text": "He said, you can go.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 31,
      "text": "I'm not leaving Sonia.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 32,
      "text": "And she took me for the hand.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 33,
      "text": "And she took me out from there.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 34,
      "text": "And that's why I'm alive today, because of her.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "And so it took us about two nights, two or three nights.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "He went into a house.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "And he took something for me to wear.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And we came to the Bielskis.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We knew right away, we knew always if something happen, we will know where to find them.",
      "word_count": 17
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "You understand?",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "When they came in, all the houses was already in fire.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "Tuvia came and Zusia and Asael.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "They saw that the whole is in a fire.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "They were looking.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "The German went away already.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "Because everything was killed.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "So they were looking.",
      "word_count": 4
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "They saw something.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "They saw the boys and the girls.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 3,
      "text": "But they couldn't find me.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 4,
      "text": "And they couldn't find Chaya.",
      "word_count": 5
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 5,
      "text": "The other was too very-- they were thinking that they see something.",
      "word_count": 12
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 6,
      "text": "But they were burned to nothing.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And they came to the places where the partisans were staying.",
      "word_count": 11
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "So they knew that maybe somebody went out from second house.",
      "word_count": 11
    }
  ],
