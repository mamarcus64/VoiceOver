{
  "stem": "25114.7",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.9,
  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "You hopped-- if something was going.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "Otherwise, you walk on foot.",
      "word_count": 5
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "Everything was disorganized.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "People were returning from-- especially the soldiers-- the Russian soldiers who were returning home, from Hungary, from everywhere, from Czechoslovakia.",
      "word_count": 20
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "They were robbing, they were--",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "A lot of them were robbing, and a lot of them were-- yeah, there was-- how many years?",
      "word_count": 18
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Four years on the front, and they were a bit wild.",
      "word_count": 11
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "You have to be careful not to be raped, not to be robbed, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "But-- in certain places.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "But this time-- this sort of thing brings out all this-- the-- the victors if they-- the defeated ones and the victors-- what was done to them, they did to others.",
      "word_count": 31
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "You know how it is, in those circumstances.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "I did not go to Palestine.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "Actually, they took us south.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "But they took us-- established us in displaced-peoples' camps.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "So first we went through Czechoslovakia.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "Being close, to-- we went from, like, from Chelm to Lublin.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "From Lublin, we went to-- to Krakow, to Katowice-- south, all closer to the-- went, and then went to the Czech border-- went to Czechoslovakia-- not long.",
      "word_count": 27
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And then we went to-- from Czechoslovakia, went to Hungary-- yeah, went to Hungary.",
      "word_count": 14
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "Yeah, went from Czechoslovakia to Slovakia, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "I mean, and this time to Bratislava, because that was the junction where you can go to Budapest.",
      "word_count": 18
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "We went to Budapest.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "In Budapest, we stayed for three weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "In a big house-- must have been an abandoned Jewish estate or something.",
      "word_count": 13
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "A huge place with huge rooms, with lots of bathrooms and things.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We're sleeping on the floors, mostly, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "A bit of-- got a-- prepared a few straw mattresses.",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "And we stayed for three weeks, which was a very nice stay.",
      "word_count": 12
    }
  ],
