  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.7,
  "sentences_input": [
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS] And people came out.",
      "word_count": 8
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "They had a dozen shirts to put on, a dozen-- oh, the whole dozen on him.",
      "word_count": 16
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Well, I had nothing to worry about.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "I-- as I only had a couple shirts, not even that, one shirt.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have much.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "But people brought with them the blankets and feather beds, everything.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "And we went out, [PAUSES FOR 3 SECONDS] out of town.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "And we stayed in a warehouse overnight.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "And the next day, from over there, we marched by ourselves-- no police, no nothing.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "We-- next day, we marched to the train station.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Not two miles away from the city.",
      "word_count": 7
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And we got there.",
      "word_count": 4
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "And they gave us a passenger train, [PAUSES FOR 3 SECONDS] just to make it look good, that we're not going to any bad places, that we are going-- really getting resettled.",
      "word_count": 32
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "So in the beginning, they told us nicely to go in the-- inside.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "But soon as everybody was in, you could hear the shots because people opened up the, the windows and stuck their heads out.",
      "word_count": 23
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "That was against the law.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Nothing-- locked it, sealed it.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "You're in it.",
      "word_count": 3
    }
  ],
