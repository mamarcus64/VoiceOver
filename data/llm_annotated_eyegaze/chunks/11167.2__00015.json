  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "I can come.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "My-- my mother wants you.",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 3,
      "text": "I want you.",
      "word_count": 3
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 7 SECONDS] [DRINKS] You see, I did grow with her.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 5,
      "text": "She was friends from [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 6,
      "text": "I used to go for every holiday to her.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 7,
      "text": "She used to come to us every single morning.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 8,
      "text": "They did want me.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 9,
      "text": "And I know, because I had afterwards a letter from her mother.",
      "word_count": 12
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 10,
      "text": "She said you will be exactly like my daughter, [?",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 11,
      "text": "Yakluba. ?] But I must tell you the truth.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 12,
      "text": "That it is very bad, very bad, the killings.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 13,
      "text": "[INAUDIBLE] right after the war, they are taking away everything they can get a hold of they are taking away.",
      "word_count": 20
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 14,
      "text": "You will not be able to go into your house.",
      "word_count": 10
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 15,
      "text": "They will kill you-- plain and simple.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "And then I had a letter from my sister.",
      "word_count": 9
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "She said don't move nowhere.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "You go with the people going.",
      "word_count": 6
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 3,
      "text": "We-- they organized, trying to take the-- take a hold of these immigrants.",
      "word_count": 13
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 4,
      "text": "You see? the Haganah did work already.",
      "word_count": 7
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 5,
      "text": "They did work.",
      "word_count": 3
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 6,
      "text": "The Jewish movement from Israel was already sent to Munich and all over, you know?",
      "word_count": 15
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 7,
      "text": "Then we had to emigrate.",
      "word_count": 5
    }
  ],
