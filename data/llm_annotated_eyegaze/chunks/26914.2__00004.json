{
  "stem": "26914.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "He didn't have time for himself.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "The books which he was written-- it wasn't about the orphanage.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "All kind of-- I remember he also had a book.",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "The book was [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "He had a girl.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "He was in love with the girl, but she was much younger.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "And her parents didn't allow him to marry her.",
      "word_count": 9
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He wrote about her.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "He wrote all kinds of books.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 8,
      "text": "Lots of books.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "He read stories.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "And then he had questions and answers.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "All was on the tele-- on the radio.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "It was I think once a day he had the radio.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "The title was titled 'Doctor Speaks.' 'Old Doctor Speaks.'",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "I saw him very often.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to go to the-- to my father.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "There was-- if you went out of Korczak's house, and you didn't have where to go, he was trying to get a place.",
      "word_count": 23
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And there was a house for the youth-- teenagers.",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "It was also for orphans.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "He located me there.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "From there, he called the art school, and I learned to sew underwear.",
      "word_count": 13
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "When I finished this, he asked me, what do you want to do now?",
      "word_count": 14
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I said, I would like to work.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "He called up a house-- a orphan house-- and they took me there to sew underwear.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "After a year, since I was practicing by Korczak too, I got to work as a social worker in the house-- in the orphanage.",
      "word_count": 24
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "And the ma-- and the orphanage where I used to work was 49 children, boys.",
      "word_count": 15
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "And I worked there.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "This was my job thanks to him.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And there I worked until the war broke out.",
      "word_count": 9
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "They were different.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "This was run by the Gmina, the Jewish organization.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "But Korczak doesn't have nothing to do with this.",
      "word_count": 9
    }
  ],
