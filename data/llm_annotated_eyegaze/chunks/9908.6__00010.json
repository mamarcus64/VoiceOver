{
  "stem": "9908.6",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They live in Florida, in Hollywood.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "They have-- my son-in-law is a stock broker, very good looking, tall guy.",
      "word_count": 13
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "And my daughter is a really beautiful.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "He said to me after the wedding.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "He said, Mom, everything I wanted in a wife is Rebecca, if she was just a little bit taller.",
      "word_count": 19
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "She's-- she's not really little.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "But he's tall.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "That's-- the only son.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "She has wonderful in-laws.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "And Mommy stays here.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "What do you do?",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "Spend the-- spend the husband's money.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "What does she have to do?",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "They have only one child.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they're my life.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "The grandchildren.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "Chana was four months old in New York.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "My [INAUDIBLE] Brenda and-- and Chana, when she was four months old to Los Angeles.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "They stayed with us two or three months.",
      "word_count": 8
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "Then they went to South Africa.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "This was a ball.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "When we were bathing her, you should see it.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "We were sitting around watching how Brenda's bathing her.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "It was a thrill.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "It's just too bad that my husband didn't see all his grandchildren.",
      "word_count": 12
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "I came over here.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "I-- yes.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "When I took so sick, my husband said, after Mosche's marriage, he said I want you to go to-- to Johannesburg and see.",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "I'm sure if you go see Mosche, that she's all right, you come back.",
      "word_count": 14
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "You'll be cured.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "So Mosche came home to America, had just bought this house, a month or six weeks had bought this house, not this one, the smaller house.",
      "word_count": 26
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "Mosche came home.",
      "word_count": 3
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "He took me to-- to Los-- over here to Johannesburg for one month.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "My husband said, when Mom's coming back now, she's gonna be walking.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "She's-- I will see her a month.",
      "word_count": 7
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Yedidya was eight months old.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Chana was five or six.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And Beila.",
      "word_count": 2
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "This what hurts me.",
      "word_count": 4
    }
  ],
