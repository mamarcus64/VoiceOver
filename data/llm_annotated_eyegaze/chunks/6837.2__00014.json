{
  "stem": "6837.2",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.6,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "The SS ran away and they left us there.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "And there was nothing to be eaten.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "No water to drink.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "It was-- Were there any guards?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "There was no more guards.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "There was some Hungarian soldiers, who helped, who came, went voluntarily to the German army.",
      "word_count": 15
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "They were around yet.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "And instead of helping us, they showed their true themselves, the real-- that they were, like, they enjoyed seeing us like this.",
      "word_count": 22
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "And they would not help or do anything from us, for us.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "So my sister went where the kitchen used to be.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And there were like garbage-- peels of potato and beets.",
      "word_count": 10
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "She picked it up.",
      "word_count": 4
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "She had a little knife.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "She scraped up a little meat.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "Where did she get the knife from?",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "That's what she was eating.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "She was eating.",
      "word_count": 3
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And then they had some cans, which was food it it-- milk, whatever.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "So we took the can from the garbage.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 4,
      "text": "And we tried to take drips, whatever was left there to give us something because we were desperate.",
      "word_count": 18
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 5,
      "text": "We were so hungry.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 6,
      "text": "And there was no water.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 7,
      "text": "Then my sister got very sick.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 8,
      "text": "She got the typhus.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 9,
      "text": "And I got the typhus, too.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 10,
      "text": "And we're really with fever and no water.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 11,
      "text": "It was-- we thought this is the end.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 12,
      "text": "But then the British army came and liberated us, which was in April.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 13,
      "text": "April 15.",
      "word_count": 2
    }
  ],
