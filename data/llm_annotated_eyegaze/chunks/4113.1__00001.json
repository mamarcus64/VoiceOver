{
  "stem": "4113.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "On my mother's side.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "The grandfather of my-- of my father's side was [?",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "Indom ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Brova, ?] in a small town where my father comes from, near the city of Tarnow, which is not far from Krakow.",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And my grandmother on my father's side had been killed during World War I by a shrapnel which hit her as she was hiding on the cemetery when they were attacking the town, the-- the Russians.",
      "word_count": 36
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father was in the glazing business.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "He was a glazier.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Plus, we had, together with an uncle of mine, a retail as well as a wholesale plate glass business.",
      "word_count": 19
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "And we also had a-- a-- a glass and mirror-making establishment.",
      "word_count": 11
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 4,
      "text": "And we made to also putty and such other things related to glass framing as well.",
      "word_count": 16
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "We-- the retail was in that building.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "But we had a warehouse at the train station, so that trains could unload right then and there.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "So the wholesale business was there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Well, you know, as a youngster, since my family was a Orthodox family, you know, at the age of three I started what's called the cheder, which is a school.",
      "word_count": 30
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And we ran around barefoot for the most part in the summer.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "We went to the cheder early in the morning, all afternoon, just about the entire day.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "We were picked up-- the children were picked up-- by what was called the [?",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "Bellefaire ?] which is a helper to the-- to the teacher.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 5,
      "text": "And we used to go there.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 6,
      "text": "We studied, you know, the Bible and et cetera.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 7,
      "text": "And we played there.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 8,
      "text": "And then, as I came of age to go to [PAUSES FOR 3 SECONDS] school, of course-- most Jewish kids or many did not go to a secular school.",
      "word_count": 29
    }
  ],
