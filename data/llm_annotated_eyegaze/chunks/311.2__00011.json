    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So my father said, let's come [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And we went in, and we got the papers to get into the ghetto.",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yes, we came to the ghetto, and there was a family there.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "And what they didn't-- what they didn't want them in the ghetto.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "I remember Roman Zukerman, they took away his mother and his uncle.",
      "word_count": 12
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "And they had an apartment that was two bedrooms and a kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And then-- so we lived in that-- that apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "The grand-- no.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "My aunt with the-- with the husband-- so we were four.",
      "word_count": 11
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "There were six, And Roman, you know, the Roman Zukerman who--",
      "word_count": 11
    }
  ],
