{
  "stem": "23599.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "Well, I wanted-- you know, I was prepared.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And I wanted to see.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "And there was one of my husband's sisters, she survived.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And-- and then there were some other relatives.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "They were very good to me.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And I stayed with them, so I wasn't alone.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "But nobody wanted to stay under the Russians.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "Most of them, they went out.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "They wanted to go west.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "They-- no, they were-- they were good.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "They were good.",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I have no complaints.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember anything.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I say I don't remember.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "There are so many other things I would have to say, but I-- right now I'm blank.",
      "word_count": 17
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "I found out what happened to my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "They took him away to a-- to a factory to work.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "And I still had hope that he survived.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "But then one day, we were in a [INAUDIBLE] in Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "They-- we had to walk somewhere from one-- from one end to the other somehow.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "And while we were waiting and there, there came another group.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Another group of women came by.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "And one was calling the other, they are-- today they brought Treblinka here.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 8,
      "text": "And when I heard that, I had no-- no hope anymore.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 9,
      "text": "Because that's where my husband was taken, to the- to a factory to work.",
      "word_count": 14
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 10,
      "text": "But then they-- that's what they did.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 11,
      "text": "They used him, and then they took them to the chimneys.",
      "word_count": 11
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 12,
      "text": "So she said to that one room, and it was in our group.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 13,
      "text": "Today, Treblinka came in.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 14,
      "text": "So when she said Treblinka, I lost my hope that my husband will be there.",
      "word_count": 15
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "It's a good question.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "[DRINKS] Ah.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 8 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I came there-- I went back-- I'm just thinking-- as I [INAUDIBLE]-- that I went-- [PAUSES FOR 4 SECONDS] yeah.",
      "word_count": 20
    }
  ],
