{
  "stem": "5516.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is now Boris Abel.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "Before I was in Lithuanian, Berelis Abelskis.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "I'm born in 1915, July 23, [PAUSES FOR 6 SECONDS] Panevezys.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Lithuania.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The name of my father?",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "My-- first-- my father's name?",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "My father's name is [BACKROUND NOISE Schneir Benjamin Abelskis.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "My mother's name is [BACKROUND NOISE] Sonya Abelskis.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "My father was a rope and twine manufacturer.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "He established this in 1902.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 4 SECONDS] On-- after the war, [BACKROUND NOISE] when his children grew up, [PAUSES FOR 4 SECONDS] there was the company larger, you know.",
      "word_count": 26
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "Larger.",
      "word_count": 1
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And after this, when I grew up, when I was [BACKROUND NOISE] maybe 18 years old, we made a corporation.",
      "word_count": 20
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And the family was the owners from the corporation.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And we, we had branches in the capital cities of Lithuania.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And [PAUSES FOR 3 SECONDS] we used to import all kind stuff from all over the world.",
      "word_count": 17
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] [BACKROUND NOISE] It's a big company.",
      "word_count": 10
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "One, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "My father come over because [PAUSES FOR 3 SECONDS] after the war, he had to come in.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And during the war, he was-- no, but when the revolution was, he was in in Russia.",
      "word_count": 17
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "And after this, he come over back to Lithuania.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "I had four brothers and two sisters.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Number [PAUSES FOR 3 SECONDS] six.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "My father was religious, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Family was religious, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "He was religious.",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "He was-- he even built a synagogue by himself.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And he was the president of the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "And he was the cantor of the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "And he was the treasurer of the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "And he was the supporter of the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Was a lot of them, but was a lot of synagogues.",
      "word_count": 11
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "Although my father had to have, like, the Hasidic-- a Hasidic synagogue that-- he established this.",
      "word_count": 16
    }
  ],
