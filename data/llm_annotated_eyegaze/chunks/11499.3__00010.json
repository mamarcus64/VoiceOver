{
  "stem": "11499.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes, third time.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And-- [PAUSES FOR 3 SECONDS] We are very-- And Mathausen Memorial.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "We are very active in the [NON-ENGLISH] organization.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "The Council of Postwar--",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "--Jewish Organization.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Look, we-- we do what-- And I was also-- I'm a founder of the Hebrew University for many years.",
      "word_count": 19
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "Hebrew-- no.",
      "word_count": 2
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "American--",
      "word_count": 1
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "American Friends of the Hebrew University.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it's a little hobby.",
      "word_count": 5
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "It used to be a little hobby, but, now, getting harder and harder.",
      "word_count": 13
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "I am--",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "--very lucky.",
      "word_count": 2
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I have a nice wife, nice children, nice grandchildren.",
      "word_count": 9
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "What else do you want?",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "You see, my story is very unusual, because a lot of people were partisans much, much later, much, much later.",
      "word_count": 20
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I started from the very, very, very beginning, one of the first in Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "Because they know Korchinski.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 2,
      "text": "Because he was known.",
      "word_count": 4
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 3,
      "text": "He was known.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "In the center of this picture is my great grandfather, Simon Kamm.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Above him is my father, Aron Kamm.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "To the left of my father is my mother, Rachel Kamm.",
      "word_count": 11
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 4 SECONDS] Standing in the back, [PAUSES FOR 7 SECONDS] the second man, standing on the left, is my grandfather, David Kamm.",
      "word_count": 24
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "In the second row, sitting next to my great grandfather, is my grandmother, Hannah Kamm.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "Underneath, on the bottom, the children are.",
      "word_count": 7
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "On the left side, is me, Ben Kamm.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "Next to me, on my right, is [NON-ENGLISH], my brother, younger brother.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "The rest of the family is my uncle and aunts.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "The rest, cousins.",
      "word_count": 3
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Approximately, I would say 1931.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "In-- in Warsaw.",
      "word_count": 3
    }
  ],
