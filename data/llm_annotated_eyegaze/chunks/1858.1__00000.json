{
  "stem": "1858.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "And he's got to go--",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "--through this",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "--all over",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "--again.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Aw, see?",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "I-- I have been doing-- speaking about it-- you know, 25 years, so--",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "--I don't get so emotional--",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "--anymore.",
      "word_count": 1
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "I do-- I think, mostly when I speak of my father, you know, having to take me to--",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "--the Nazis-- That's all.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "But that was so terrible.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "The man was sick.",
      "word_count": 4
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "He lives in Palm Aire.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "He's so-- such a sick man, and he had to do it again the next week-- aware--",
      "word_count": 17
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "That-- that is painful.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "That's-- you know, that's negligence-- carelessness.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "OK, it can happen.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But after tape two, when she saw she had problems, she should she should have stopped.",
      "word_count": 16
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "She should have-- [BACKGROUND NOISE] --turn it a certain way.",
      "word_count": 10
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "I lost.",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "So I said, I don't need it.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "My goodness.",
      "word_count": 2
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "How far am I from a telephone?",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "[BACKGROUND NOISE]",
      "word_count": 2
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "With my kids, it's so busy.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Oh, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "They walk around talking to you, and they're doing the dishes, or they're cleaning--",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "What I hate the most-- the telephones in the cars.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 11 SECONDS] It's the 4th of April, 1995.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I am Ruth Resnikoff-- Ruth, R-E-S-N-I-K-O-F-F.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And I'm interviewing survivor, Rose Kaplowitz-- Rose, K-A-P-L-O-W-I-T-Z.",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "We're in Coconut Creek, in Rose's winter apartment, in Florida, USA.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "The interview is in English.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 18 SECONDS] Rose, tell me your name before you were married.",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "Polish name was [NON-ENGLISH] Zaks.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "In English it would be Rose Zaks,",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Z-A-K-S.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "[NON-ENGLISH], but it was just Polish.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "I was born on September 6, 1930.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "In Sosnowiec, Poland, which is the southwestern part of Poland, very close to the German border.",
      "word_count": 16
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 3 SECONDS] I think--",
      "word_count": 6
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "--when I look back today, I think I had a very happy childhood.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "We lived on a street that was mixed.",
      "word_count": 8
    }
  ],
