  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Well, the first thing is that I'm really, really proud of you for doing-- for having the courage to tell your story, to give this testimony, because it's-- I think it's important for my children and for Maurice's children and for their children and for other people to-- to hear what you went through, and the strength that it takes and the strength that you had to survive what you went through and what you-- what Mom went through, and-- and that if it wasn't for you and Mom, Maurice-- me and Maurice wouldn't be here and seven grandchildren and five great-grandchildren wouldn't be here, and probably a number of other people that you helped along the way, so--",
      "word_count": 119
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Also what I have to say, I didn't mention with Maurice, Maurice and his wife.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "He's got a lovely wife, a doll.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "We are always together.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "Never had a fight.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "We lived together for a while and we've been in business together.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "She is very lovely, very nice.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And they have nice children.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "They are very happy.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "We are a very happy family, big, happy family.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "You're welcome.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
