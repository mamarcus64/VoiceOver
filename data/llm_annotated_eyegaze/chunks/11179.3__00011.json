{
  "stem": "11179.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.1,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "And they had to take, the Jewish community, whoever took it over-- you know, the joint committee, or whatever they called it, kitchen fund, they had different names-- they had to keep the gardener and a-- and a-- and an Indian caretaker who lived there with his wife and children.",
      "word_count": 50
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "They had to pay them basically to keep the property in good shape, the outside yards, which they-- which they did.",
      "word_count": 21
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Yes, it was Chaoufoong street.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "C-H-A-O-U-F-O-O-N-G. 680.",
      "word_count": 2
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "I know how to spell it now, after I looked it up.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I stayed in a room with 30 boys.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "There were 15 double beds, 30 boys.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "I know that.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "And when it became-- when-- we had to keep it clean, and we did.",
      "word_count": 14
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "We did like the other.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "I was in the upper berth, and the other one-- a boy a couple years younger than I-- was in the lower berth.",
      "word_count": 23
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "We cleaned it out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "And we got the mattress to be cleaned.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "I forgot how we got the mattress cleaned really.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "I think they may have helped us with that.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "But the bed, itself, bed bugs got in there.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "We burned them out.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Then put them in cups with water in there, so they wouldn't get up in the bed any more.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "It worked.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "But when the several older men came in, and when I found out that some people had lice, then I-- then I-- then I asked my parents, can't you get me out, so I stay with you?",
      "word_count": 37
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And my parents stayed in another building where there were families.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "And they got me out.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I didn't want to stay in there, anymore.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "I figure I don't need that here.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "The kids were clean.",
      "word_count": 4
    }
  ],
