{
  "stem": "1775.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 157.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "But the war was dragging on, and he said that he's afraid, and we have to go.",
      "word_count": 17
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So me and my husband decided we're going to go back to where we were working, where I was working, by the river, by the [NON-ENGLISH], because we knew-- we talked to the people.",
      "word_count": 34
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And they said, if we're going to be of some kind of-- in some kind of trouble or something, maybe we should have a place where to meet.",
      "word_count": 28
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "So we figured, we're going to go back there.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "And maybe we're going to see somebody over there, on the other side of Meserich.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So we walked back there.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "It was about 10, 12 kilometers.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And we walked back there.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And it was a very dark night.",
      "word_count": 7
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And as we were walking, my husband missed the place where they told us to go.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 9,
      "text": "And it was very-- a person could sink into it.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 10,
      "text": "And I was screaming and yelling, let's go and get it over with, because we can't get out.",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 11,
      "text": "We can't do it anymore.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "And at that particular time, I guess God wanted us to still be around.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "My husband found a place that was hard.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And he was able to cross it.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "And he dragged me across.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And we went to that place, where I used to work by the [NON-ENGLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "We met up over there with six other people.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I just know two people, they came-- two boys.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "They came from the same town, like my husband.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "And the other four, I didn't-- I didn't know.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "I just met them at that time.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "They came from a small town around Meserich.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "It was called [NON-ENGLISH].",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And all four of them-- we were there about six weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "There was so much rain, and we didn't have nothing.",
      "word_count": 10
    }
  ],
