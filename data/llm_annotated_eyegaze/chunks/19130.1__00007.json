{
  "stem": "19130.1",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 462.2,
  "sentences_input": [
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "And they organized-- all, everybody, especially the police, what they used to work, they organized to-- to-- to kill these, the-- the paratroopers.",
      "word_count": 23
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 6,
      "text": "Perhaps somebody saw them and they caught them.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 7,
      "text": "But one paratrooper, I remember, he shoot one of the leaders of the Ukrainian.",
      "word_count": 14
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 8,
      "text": "I know.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 9,
      "text": "I remember who the leader was.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Eh-- [UKRAINIAN], they used to call him [UKRAINIAN].",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "I-- so-- they called him-- they-- they shoot that leader.",
      "word_count": 10
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "No, they were very-- so I don't remember how many they kill, how many of the paratroopers they kill.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And they went to look for Jewish people to-- to bury them, to bury the paratroopers.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Oh, they-- they took-- they took mine brother and another to bury.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "And they-- they were afraid they're going to kill them too.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "But they didn't kill that time, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "They make all kind of fun of them.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "But didn't kill them.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "Next day, [PAUSES FOR 5 SECONDS] a group of the Ukrainian, the youth, organized.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "They took-- [PAUSES FOR 4 SECONDS] over a-- a truck.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "And they-- they went to look for whoever they can catch.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "Mhm.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Like a-- are tender, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "They-- and whoever they-- and they-- they caught three-- three Jews.",
      "word_count": 11
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE], from [POLISH].",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "This is the next village.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And it was a label, [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "[NON-ENGLISH] was our next-door neighbor.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "They stop in our house.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "They couldn't-- they couldn't-- nobody was out.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 5 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "You know, one that was together with them, he came, he told us.",
      "word_count": 13
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "You know, it was a time that we were friends.",
      "word_count": 10
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "You know, when the Germans came, everything-- you know, they-- they-- we became their enemies.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "So and they shoot the-- they-- they shoot them.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "Just like that, they told them to run.",
      "word_count": 8
    }
  ],
