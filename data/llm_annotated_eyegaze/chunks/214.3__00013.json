{
  "stem": "214.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.0,
  "sentences_input": [
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 15,
      "text": "And then the ghetto was-- you know, people, they want-- the people who were, again, they were hiding, like my mother did with my little sister, with some neighbors, in-- somewhere in the basement of something or other.",
      "word_count": 38
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 16,
      "text": "But the ghetto was closed for three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 17,
      "text": "There was not a soul to be-- to be seen.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 18,
      "text": "They kept it-- maybe they thought, you know, that everybody is gone already.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 19,
      "text": "I don't know-- or waited to make sure that [NON-ENGLISH] became judenrein.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 20,
      "text": "And we were lying there.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 21,
      "text": "My feet burn-- froze.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 22,
      "text": "My-- that's another thing.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 23,
      "text": "My-- my toes froze, as [NON-ENGLISH].",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 24,
      "text": "And she kept on saying, don't worry.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 25,
      "text": "Don't worry.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 26,
      "text": "We won't be sitting-- lying here all the time.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 27,
      "text": "You know, she was-- and we were going down in about midnight.",
      "word_count": 12
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 28,
      "text": "And there was this milk and bread.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 29,
      "text": "And that's what we lived on.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 30,
      "text": "And maybe it must have been already November.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "This went on for at least three weeks.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "Nobody-- nothing was happening.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "It was absolutely quiet.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "We didn't know what's happening in town.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "We didn't know whether the-- that the ghetto is still.",
      "word_count": 10
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "We knew, also, that nobody-- there are no Jews on the road-- you know, this contingent that we were a part of.",
      "word_count": 22
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And one day we hear the truck.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "And we hear Jewish voices.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "And it-- it was really a cold day.",
      "word_count": 8
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "It was freezing already.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "And we look through the top there on the-- and we see there are Jews working on the road again.",
      "word_count": 20
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "See, I will never--",
      "word_count": 4
    }
  ],
