{
  "stem": "12564.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "And this was a true story. 90% of the guys what I was training, all died over there.",
      "word_count": 18
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "So this must be-- I went out of jail, probably in June, 1948.",
      "word_count": 13
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "So your being in jail might have saved your life?",
      "word_count": 10
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Uh, probably, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "I didn't-- I didn't want her to stay in Poland.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "She remarried.",
      "word_count": 2
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And her husband was buying eggs, chicken at that time. what-- peddler, like, buying and selling.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "And my girlfriend was living next door to them at the time, also with her mother.",
      "word_count": 16
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "No I didn't-- not-- I know her.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "But she wasn't my girlfriend yet, till I come back for my mother.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And I was several months in town.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And that's how we got to know each other.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "I went to Warsaw.",
      "word_count": 4
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "I didn't want to live in a small town.",
      "word_count": 9
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And I went to work in a-- actually, like, a corporate-- corporate factory, to make pocketbooks, women's purses.",
      "word_count": 18
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I started with not knowing.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "And each, by the table, was six people.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 5,
      "text": "And each one was working according to percentage.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "After two months I reached the equal percentage with the guys with their new [? girlfriend. ?] And I was there till July, 1950, in Warsaw, where I went to Israel.",
      "word_count": 31
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I went to visit many times.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And in July, 1950, we left legally from Poland with my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I actually-- [PAUSES FOR 3 SECONDS] --put an application for her and her mother.",
      "word_count": 15
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And she left one week later from me.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Szyfra.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Chamita-- C-H-A-M-I-T-A.",
      "word_count": 2
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "The picture tells everything.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 1,
      "text": "We married in Israel.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 2,
      "text": "We went-- farm-- we took a farm, Kfar Bilu, near Rehovot.",
      "word_count": 11
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "In July.",
      "word_count": 2
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "And our wedding was in December.",
      "word_count": 6
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "We went into a-- they call it like, a place where all the newcomers got together.",
      "word_count": 16
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "It was [HEBREW].",
      "word_count": 3
    }
  ],
