{
  "stem": "10478.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 1,
      "text": "My sister bleached the baby's hair.",
      "word_count": 6
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 2,
      "text": "It was black.",
      "word_count": 3
    },
    {
      "segment_idx": 112,
      "sentence_idx_in_seg": 3,
      "text": "And we told the neighborhood that one them, my aunt was-- had TB, and was in the hospital, and asked us to look after the baby till she was back out of the hospital.",
      "word_count": 34
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 0,
      "text": "That's correct.",
      "word_count": 2
    },
    {
      "segment_idx": 113,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 0,
      "text": "And then my sister walk around with her.",
      "word_count": 8
    },
    {
      "segment_idx": 114,
      "sentence_idx_in_seg": 1,
      "text": "And it was like a normal baby.",
      "word_count": 7
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 0,
      "text": "With dyed hair.",
      "word_count": 3
    },
    {
      "segment_idx": 115,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 0,
      "text": "Well, when the train, and the-- the girl I had with me, and there was even a German soldier.",
      "word_count": 19
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 1,
      "text": "He looked at it for a cute baby.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 2,
      "text": "And somebody on the train said it looked like me, the father.",
      "word_count": 12
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 3,
      "text": "And another said it looked like the girl.",
      "word_count": 8
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 4,
      "text": "It looked like the mother.",
      "word_count": 5
    },
    {
      "segment_idx": 116,
      "sentence_idx_in_seg": 5,
      "text": "So.",
      "word_count": 1
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 0,
      "text": "That's right.",
      "word_count": 2
    },
    {
      "segment_idx": 117,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 0,
      "text": "--and one said they looked like the father, and the other like the mother.",
      "word_count": 14
    },
    {
      "segment_idx": 118,
      "sentence_idx_in_seg": 1,
      "text": "Interesting.",
      "word_count": 1
    },
    {
      "segment_idx": 119,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 120,
      "sentence_idx_in_seg": 1,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 121,
      "sentence_idx_in_seg": 0,
      "text": "I had [INAUDIBLE] was arrested.",
      "word_count": 5
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 0,
      "text": "My parents encouraged me to do that.",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 1,
      "text": "They never-- we were-- we were scared, of course.",
      "word_count": 9
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] just got normal.",
      "word_count": 4
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 3,
      "text": "But they encouraged me to do that.",
      "word_count": 7
    },
    {
      "segment_idx": 122,
      "sentence_idx_in_seg": 4,
      "text": "So.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 1,
      "text": "Not at all.",
      "word_count": 3
    },
    {
      "segment_idx": 123,
      "sentence_idx_in_seg": 2,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 0,
      "text": "Well, of course you were in danger.",
      "word_count": 7
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 1,
      "text": "But they never-- they never had somebody who searched the house.",
      "word_count": 11
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "And they never had a suspicion that they were involved.",
      "word_count": 10
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 3,
      "text": "Only when I was interrogated by the Gestapo when I was arrested, he tried to blackmail me more or less to tell me that my father was also arrested.",
      "word_count": 29
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 4,
      "text": "And I was [INAUDIBLE] for that, because I took my own responsibility for that, my parents.",
      "word_count": 16
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 5,
      "text": "And he said, your father's arrested, he said.",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 6,
      "text": "And he said he's in same prison where I was.",
      "word_count": 10
    }
  ],
