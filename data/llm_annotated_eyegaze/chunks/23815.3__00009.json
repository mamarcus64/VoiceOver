{
  "stem": "23815.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 4 SECONDS] We were sitting and watching.",
      "word_count": 9
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 12,
      "text": "And behind us it was sitting a Australian couple-- a wife and her husband.",
      "word_count": 14
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 13,
      "text": "And when the picture was being shown, this lady couldn't stop crying.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 14,
      "text": "She crying and crying-- cried to see what they were showing in Auschwitz, in-- in the concentration camp.",
      "word_count": 18
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 15,
      "text": "The husband said to her, darling, don't cry.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 16,
      "text": "It's only a movie.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "When the picture finished, a friend of ours turn around, and he said to the gentleman, he said, this was not a movie.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "This is what the true story, because we were in it.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "The man didn't say a word-- not one word.",
      "word_count": 9
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "And what I wanted to say is the world should know this is not our real story.",
      "word_count": 17
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "This is the truth-- only the truth.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "And I hope that one day people will realize that is the truth-- and-- and not to let it happen again.",
      "word_count": 21
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 6,
      "text": "Because we are in a wonderful would.",
      "word_count": 7
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 7,
      "text": "We have the right to exist.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 8,
      "text": "Everybody has the right to exist.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "You mean before or now?",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "I'm enjoying my life.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "I'm happy, because I have a family.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I'm not alone anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "You see, I-- I-- what I want to say is they took away from me my youth, my freedom, my mother, that I wanted so much to have it.",
      "word_count": 29
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "They took away from me my best years of my life.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "A young girl, 16, needs a mother, needs parents, needs the-- the-- the-- freedom.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "I didn't have that.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "They took away from me everything.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "The best years of my life, they took away from me.",
      "word_count": 11
    }
  ],
