{
  "stem": "12022.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.4,
  "sentences_input": [
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And naturally, my brothers, they used to work with some-- all in wood, and all kind of-- all kind of stuff to-- from-- from like, from the forest to the station, to load the-- I think it was loading to send it to Germany, the wood.",
      "word_count": 46
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "And I mostly was helping out our relatives from the United States.",
      "word_count": 12
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "My-- my father's brother, Morris, he used to help us out a lot.",
      "word_count": 13
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And my grandfather, he used to daven in shul, like the holidays, on Passover.",
      "word_count": 14
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "And the money, he used to send to my mother, because my mother was a widow with seven kids.",
      "word_count": 19
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 6,
      "text": "And the money used to send for my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "I was eight years old.",
      "word_count": 5
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "I think 17.",
      "word_count": 3
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Six months.",
      "word_count": 2
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "It was a big help.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "There was-- I was working.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "The pay was very-- very, very little pay.",
      "word_count": 8
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "They don't pay-- mostly nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Every penny what I used to make, I give-- I give to my mother.",
      "word_count": 14
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "For hard work.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "I was doing blacksmith's work.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 1,
      "text": "When I was-- when I was 12, I started on blacksmith's work.",
      "word_count": 12
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "In Nacza.",
      "word_count": 2
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "A neighbor was a blacksmith.",
      "word_count": 5
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "He would just-- he have a slave labor.",
      "word_count": 8
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "That's how you-- the pay was very little.",
      "word_count": 8
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "Chaim David Schmidt.",
      "word_count": 3
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I used to get up early and work late.",
      "word_count": 10
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "And the pay was very little.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "7 o'clock.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "At least 7 o'clock, maybe earlier.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I used to do all kind of work, farming work, and for farmers, and for-- shoe horses, and wagons, and all kind of work.",
      "word_count": 25
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "Mostly-- mostly at the times, farming.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "Takes a quite while.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 1,
      "text": "Takes a few years.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 2,
      "text": "Took a few years.",
      "word_count": 4
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 3,
      "text": "Then I was in the army.",
      "word_count": 6
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 4,
      "text": "I was doing the same work, so a blacksmith.",
      "word_count": 9
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "Still, still I don't get paid.",
      "word_count": 6
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS]",
      "word_count": 1
    }
  ],
