{
  "stem": "17625.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "One cousin, which is one-- the youngest from this family, is still alive.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "The rest of them is not here.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "They are not here.",
      "word_count": 4
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "True-- truly my brother-in-law, sister's husband, once, he had a-- he had a tough time here in Chrzanów.",
      "word_count": 18
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "He was [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "And he couldn't really make it out.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "So he thought-- it was just a thought-- to go to Israel, as a whatever.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And he had a few dollars, whatever.",
      "word_count": 7
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "But it-- it didn't realize.",
      "word_count": 5
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "My grandmother.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "Chana Henda.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "My mother's mother.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "Chana Henda.",
      "word_count": 2
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "She was-- she preferred to be with my mother than the aunt which was across, because she liked-- she liked better my father.",
      "word_count": 23
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "So you know, son-in-law, he was-- he was a good-- a good son-in-law.",
      "word_count": 13
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 5,
      "text": "And this was the story.",
      "word_count": 5
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "Well, [SIGHS] my grandmother had a-- had a-- had a hard life.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "Her husband died when he was 30 years.",
      "word_count": 8
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "He left her with seven kids.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "He died.",
      "word_count": 2
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 4,
      "text": "His name was Bendit, which my brother, his name-- my older brother's name is after this-- this grandfather.",
      "word_count": 18
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 5,
      "text": "So what was the question?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, she-- she-- she talked about family at home, how-- how-- how she provided.",
      "word_count": 14
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "And she-- she traveled from one-- from one-- from one son to the other son, to the other daughter.",
      "word_count": 19
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "This was always-- only good things.",
      "word_count": 6
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Very much.",
      "word_count": 2
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "As a matter of fact, [LAUGHS] sometimes she didn't like it.",
      "word_count": 11
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "Because on a Saturday afternoon, [LAUGHS] I-- I-- I-- when she moved out with us, she was in a-- in a-- in a apartment from herself, I-- Shabbos, I bothered her when she was sleeping.",
      "word_count": 35
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "I-- I went for-- for whatever this is.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "It used to be that-- that you go for something, like if something-- some goodies.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "So this was the way it was.",
      "word_count": 7
    }
  ],
