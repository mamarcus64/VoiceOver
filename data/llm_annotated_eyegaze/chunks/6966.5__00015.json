  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 6,
      "text": "And I said to a Frenchman next to me-- the Frenchman could talk English.",
      "word_count": 14
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 7,
      "text": "He was a translator of films in English-- French, and French into English.",
      "word_count": 13
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 8,
      "text": "I said, when the soup comes, you can have my soup.",
      "word_count": 11
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "He said, aren't you hungry anymore?",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "I said no.",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "I'm-- I'm-- I'll stop eating.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "He said, well, tell me then.",
      "word_count": 6
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 4,
      "text": "What's the matter?",
      "word_count": 3
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "I said, I had a dream.",
      "word_count": 6
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 1,
      "text": "And I'm now sure my wife and child is no more alive.",
      "word_count": 12
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 2,
      "text": "And I don't want to go on.",
      "word_count": 7
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 3,
      "text": "And I told him my dream.",
      "word_count": 6
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "He said, suppose your wife and child is alive, and you're not there.",
      "word_count": 13
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "That's not fair, is it?",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And I came to my senses again.",
      "word_count": 7
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I ate my soup.",
      "word_count": 5
    }
  ],
