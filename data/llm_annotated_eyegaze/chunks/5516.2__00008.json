{
  "stem": "5516.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.7,
  "sentences_input": [
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And if somebody brought in money, you know, like they had dollars, or gold, or silver, you know, they put tables once in a while, and they say, put on the table everything you got.",
      "word_count": 35
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "If you don't put it, they'll find it, will kill you on the spot.",
      "word_count": 14
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "So people put everything, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "But yeah, everything.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "We were official.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "We had marks, you know, the German marks.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "We had connections sometime.",
      "word_count": 4
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "The brother where we had now, he took very high risks, you know.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "The younger brother-- who is now in Israel-- he was in Los Angeles.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "He used to go out as a Christian, without the stars.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 13,
      "text": "And he used to bring connection with Lithuanian people, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 14,
      "text": "He used to sell, sometime, a watch.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 15,
      "text": "He was in a airport with my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 16,
      "text": "He used to go out even sometime and buy products from the farmers.",
      "word_count": 13
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 17,
      "text": "We had a good commandant, you know, from the German commandant.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 18,
      "text": "He was a fisherman by trade, an old man.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 19,
      "text": "But he was good to the Jewish people.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 20,
      "text": "He used to, he used to buy us to send out a truck, and used to bring in this stuff for the people.",
      "word_count": 23
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 21,
      "text": "They should have a little bit better food.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "This is-- from the ghetto, they took out when the Lithuanian and Germans used to control.",
      "word_count": 16
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "But after this, after two years, I think, the SS come over.",
      "word_count": 12
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And they took over the ghetto.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "They had no staff, you know.",
      "word_count": 6
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They used to go 500 people each day from the ghetto to work on the airfield near Shavel, there-- a mile from Shavel.",
      "word_count": 23
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "They say, no more.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "He build barracks there, and they have to stay there.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "When they have to stay there-- I didn't work there, in this time.",
      "word_count": 13
    }
  ],
