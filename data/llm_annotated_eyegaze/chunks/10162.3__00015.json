  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Said, well, from the house across the street, they are pushing out a gun toward us.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Where?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "How?",
      "word_count": 1
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "She says right from the top of the house, the similar round hole, she saw they're pushing out a gun.",
      "word_count": 20
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "So I remember I creeped up, kind of look out through this hole.",
      "word_count": 13
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And they're really pushing something.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And it comes out and it's a white flag.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, it was just incredible.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "And then right after that, we saw the Americans and the jeeps coming in and standing up.",
      "word_count": 17
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "And they were throwing the rations.",
      "word_count": 6
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "What-- we didn't know what it was, but chocolate bars and cheese and everything right and left to the Germans, which a little bit bothered us.",
      "word_count": 26
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "You know, there, we are still starving.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And to these Germans who we were hoping they were just-- I don't know, to just annihilate everything-- they were throwing out the food right and left.",
      "word_count": 27
    }
  ],
