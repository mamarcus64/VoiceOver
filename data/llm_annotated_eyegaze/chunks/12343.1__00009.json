  "sentences_input": [
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "And I see after there, they-- there are other times, they do-- they used to get people to work.",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Not to work.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "[INAUDIBLE] we never come back.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "A long time after, I see the [INAUDIBLE].",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I said to Mother, what can I do now?",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "Then I said to Mother, [INAUDIBLE] the floor or [INAUDIBLE] on the floor.",
      "word_count": 13
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "She covered it all-- took off in the bed, [INAUDIBLE] the floor, to show the people, the Germans, there was other Germans already messed us up.",
      "word_count": 26
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "And I was underneath, [? in the barn. ?]",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Then when they went out, I said to Mother, come on.",
      "word_count": 11
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I dress in for a woman.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "My sister [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "My mother's-- and I walk out.",
      "word_count": 6
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "Another place, I work the assembly line.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "I work-- I work the assembly place.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "Around December, [INAUDIBLE] a friend.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "I learned to use-- on-- on-- on a roof.",
      "word_count": 9
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 8,
      "text": "A roof attic like this, is in over there two days, two days.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 9,
      "text": "In a heat like this, it's summertime.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 10,
      "text": "Oh, boy.",
      "word_count": 2
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 11,
      "text": "After a while, they said, they already-- they already left.",
      "word_count": 10
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 12,
      "text": "You come down.",
