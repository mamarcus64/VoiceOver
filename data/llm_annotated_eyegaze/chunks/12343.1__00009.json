    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 13,
      "text": "I had too much trouble.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "My friend, he's-- he's there.",
