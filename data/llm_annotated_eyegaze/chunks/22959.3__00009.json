  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.2,
  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "He graduated from the gymnasium and they list Vilna, where he attended the university in Vilna, Stefana Batorego.",
      "word_count": 18
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 4 SECONDS] He was in Vilna till [PAUSES FOR 5 SECONDS] the Germans, till-- till the pact that was concluded between Russia and Germany.",
      "word_count": 26
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "And then he-- for the same reason that I didn't feel [BACKROUND NOISE] like going back to Vilna, he did not feel like going back to-- to Vilna.",
      "word_count": 28
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "So he was in the ghetto in Novogrudok.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] When the Germans started--",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "At that time, I didn't know my husband.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "I was at that time in-- in Zdzieciol.",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "But when he was in Novogrudok, I would like to mention that, he-- when the Germans, when they got into Novogrudok, they came to his place, and they asked for Nochem Scelubski, Norman Shelub.",
      "word_count": 34
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "His father came out, and he said that he's Nochim [?",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "Shelubski. ?] And the Germans did not want to accept it.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "They said, how could it be?",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 6,
      "text": "He was a young person and you're already an elderly person with gray hair.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 7,
      "text": "But he insisted that he is Nochim [?",
      "word_count": 8
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 8,
      "text": "Shelubski. ?] And they took him, and they never saw his father again.",
      "word_count": 13
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 9,
      "text": "And my husband, the future husband-- I didn't know him at that point-- he walked around with guilty feelings, because he felt that he's the cause of his father's death.",
      "word_count": 30
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "Used to tell me that all the time.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "And he walked around with these guilt feelings.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "I did not experience the guilt feelings.",
      "word_count": 7
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "But he experienced it.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "He-- he had-- one second.",
      "word_count": 5
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "He had feelings what they-- what we are constantly reading in these different books about this survivor's guilt feeling.",
      "word_count": 19
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "That's what he experienced.",
      "word_count": 4
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 3,
      "text": "He-- he-- he-- at that point, he came-- he was in the ghetto.",
      "word_count": 13
    }
  ],
