{
  "stem": "13213.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.4,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "I think I had, already-- I was a rich man-- $2,000 saved with me I kept bringing from my worked in Germany.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And I was independent man.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "When immigration came over in Montreal, to meet me, I said that I'm not going to Winnipeg.",
      "word_count": 17
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "They had a ticket for me, to Winnipeg.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "I said, I'm going to stay in Montreal.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "They were quite upset.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "They said, you're on your own.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 11,
      "text": "I said that's fine.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 12,
      "text": "I took a taxi.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 13,
      "text": "Fortunately, it was a Jewish man in the taxi.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 14,
      "text": "And I asked him if he knows somebody I can rent a room.",
      "word_count": 13
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 15,
      "text": "And he took me over to some Hungarian religious family, and I rented a room from them on Hutchison Street in Montreal.",
      "word_count": 22
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 16,
      "text": "And the next day I went to the employment to look for a job.",
      "word_count": 14
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 17,
      "text": "I-- I went to the employment, and they said they didn't have any jobs in Montreal, but they had some in Saint-Jeans, Quebec.",
      "word_count": 23
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 18,
      "text": "It was a requirement for an aircraft mechanic.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 19,
      "text": "Before I went to apply for a job Saint-Jeans, Quebec, I had a close friend, Michael [NON-ENGLISH] that lived in Toronto.",
      "word_count": 21
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 20,
      "text": "So he invited me over.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 21,
      "text": "I came by train to Toronto.",
      "word_count": 6
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 22,
      "text": "I visited him, and I also went to apply for a job at Air Canada here in Toronto.",
      "word_count": 18
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 23,
      "text": "And they didn't have any openings.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So I went back to Montreal, and went to the job that I was offered in Saint-Jeans, Quebec.",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I moved to Saint-Jeans, Quebec.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "The Immigration Department-- Canadian immigration-- were very nice to me.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "They right away came to visit me to see if I'm being treated well.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I lived in Richelieu Hotel there.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I worked for the aircraft industry, so I had to pass an exam.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "I remember Chief Inspector Jackson, Mr.",
      "word_count": 6
    }
  ],
