  "sentences_input": [
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "There was-- it was quite a wealthy little town.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "And they thought they were buying their life.",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And, of course, a week later came this placard.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "And that one-- well, the ones-- they will establish a ghetto for those able, useful, fit, young, skilled people, and they didn't say anything about the rest.",
      "word_count": 27
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "For them there would be the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "So the German Reich will now have to work more efficiently, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "With everybody being together, all the contributors being together.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "So a week later, there was an order for the whole community.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "Is it stopped?",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Already another half hour?",
      "word_count": 4
    }
  ],
