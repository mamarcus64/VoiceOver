{
  "stem": "6076.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 2.8,
  "sentences_input": [
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And I says, why are you carrying-- I says to my mother, why are you carrying the candlesticks?",
      "word_count": 18
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "She says, Rachela, wherever we're going to be-- she thought we will get into another house-- that we will hide.",
      "word_count": 20
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "We will burn.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "It's Friday night.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "She was thinking that she wouldn't be able to get back before Shabbas.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "It's too late.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "She will be able to light these candles somebody else's house.",
      "word_count": 11
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "Go figure it this out.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "I never thought what my mother was thinking.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "We walked and walked.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "We saw a lake.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "All of the neighbors, we sat-- we sat down.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "Watching these flames from one mile away, the loud cracking from the glass was unbelievable.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 10,
      "text": "The smoke was so black.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 11,
      "text": "Waves of smoke were coming.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 12,
      "text": "And my father was still praying.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 13,
      "text": "My mother's tears, I will never forget.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 14,
      "text": "She was only begging to God that her belongings-- the clothes should be saved, and perhaps her little house and a few houses.",
      "word_count": 23
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 15,
      "text": "I was sitting on that wet, damp-- it's September.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 16,
      "text": "The grass was damp.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 17,
      "text": "We all sat, me and Moishele and Shmulek.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 18,
      "text": "Zisman with Leibl were on the farm.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 19,
      "text": "They were afraid when the Germans will come in they take young men.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 20,
      "text": "So my father sent them to a farmer, a Jewish farmer, to hide over there.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 21,
      "text": "And, of course, kids, they cannot do no harm.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 22,
      "text": "So we stayed with our parents.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 23,
      "text": "And we are sitting next to our parents and watching the smoke, without a stop a whole night.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 24,
      "text": "The morning arrived-- Saturday morning.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 25,
      "text": "It lingered down.",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 26,
      "text": "The smoke was less and less.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 27,
      "text": "We could see the sky clear.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 28,
      "text": "We picked ourselves up in the morning.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 29,
      "text": "But on a Friday night, when it started to get in the evening, I will never forget.",
      "word_count": 17
    }
  ],
