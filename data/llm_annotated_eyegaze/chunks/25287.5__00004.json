    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "And what we did, close the door, and put a-- a table and a bucket of water, to somebody want to come in.",
      "word_count": 23
    },
    {
      "segment_idx": 10,
