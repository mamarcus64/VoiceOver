  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.7,
  "sentences_input": [
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 7,
      "text": "He's working for a big firm in Washington.",
      "word_count": 8
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 8,
      "text": "And he's got two children.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 9,
      "text": "And he's married.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And his name-- the name is Daniel, the oldest boy.",
      "word_count": 10
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "And the daughter is Elise.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "19-- He was born in '58. '58.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "And I have a daughter, Risa.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She graduated.",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She went here to a good school, too, [?",
      "word_count": 9
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "College ?] [?",
      "word_count": 3
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 5,
      "text": "Prep, ?] which is a private school.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 6,
      "text": "And she went to George Washington.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 7,
      "text": "She graduated in George Washington.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 8,
      "text": "She's a special education teacher.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 9,
      "text": "She works in Washington.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 10,
      "text": "She's a daycare center director.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 11,
      "text": "And she's still available.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 12,
      "text": "She's my only worry, now.",
      "word_count": 5
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 13,
      "text": "I'd like to see her get married and get off my back.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 14,
      "text": "[LAUGHS] I still have to help her.",
      "word_count": 7
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 15,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "We were a little too, what do you say, too careful with them, you know, especially my wife-- over-protective.",
      "word_count": 19
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "It's most of the survivors have the same thing, probably, very over-protective.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "I think that was-- that's-- it was a little problem, that we're too over-protective.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "But they all turned out to be good kids and never had any problem.",
      "word_count": 14
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "And they always give us only joy.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "And we had no problems with them.",
      "word_count": 7
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "Definitely.",
      "word_count": 1
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 1,
      "text": "My daughter, and my children-- they cannot hear.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 2,
      "text": "If they hear the word, any [? sometimes ?] remark about blacks, she gets angry.",
      "word_count": 15
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 3,
      "text": "Even though I don't mean anything by that.",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "She said, why do you say she's black?",
      "word_count": 8
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "She's American.",
      "word_count": 2
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 6,
      "text": "Why do you say she's black or something like that?",
      "word_count": 10
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 7,
      "text": "She don't like to hear that.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Twice.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "Twice.",
      "word_count": 1
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "I took my children in 19-- it was eight years ago.",
      "word_count": 11
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "Must have been 1987 or '88.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "We went to Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "I wanted to see my hometown.",
      "word_count": 6
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "I took them to Auschwitz.",
      "word_count": 5
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 7,
      "text": "And I wanted to see how life was there.",
      "word_count": 9
    }
  ],
