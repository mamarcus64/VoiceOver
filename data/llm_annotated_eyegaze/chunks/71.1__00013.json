  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 7,
      "text": "And I met there a woman that her children were my friends.",
      "word_count": 12
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 8,
      "text": "And she introduced me to a restaurant owner, and I got a job there.",
      "word_count": 14
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 9,
      "text": "And people were very wonderful.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 10,
      "text": "Really they-- a brother of hers came and-- I don't know if you know what bankis are?",
      "word_count": 17
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 11,
      "text": "Mm-hmm.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "You know what those-- and he came--",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Glass, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "And he-- he put this on, and they wouldn't let me come the next day to work.",
      "word_count": 17
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "They're little-- they're very little and like a glass.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And they put alcohol in-- with a light in it.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And they put on the back.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "And this apparently takes out infection or whatever that is.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "And the next day I was well.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "So from-- my parents found out the time in Warsaw and I cannot continue.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "And I made up my mind not to go back to the Lodz again.",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I wanted my parents and my sisters to come to Warsaw and go back to Brest-Litovsk where I came from that time.",
      "word_count": 22
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "But my mother came to Warsaw.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And she forced me to come back, and that's when I came back to the-- back into the ghetto.",
      "word_count": 19
    }
  ],
