{
  "stem": "14687.1",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 2,
      "text": "They used to hit the people, you know?",
      "word_count": 8
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 3,
      "text": "And you used to cry.",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 4,
      "text": "In the meantime, they hit!",
      "word_count": 5
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 5,
      "text": "People died there.",
      "word_count": 3
    },
    {
      "segment_idx": 124,
      "sentence_idx_in_seg": 6,
      "text": "Many people.",
      "word_count": 2
    },
    {
      "segment_idx": 125,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 0,
      "text": "They had bastones, you know?",
      "word_count": 5
    },
    {
      "segment_idx": 126,
      "sentence_idx_in_seg": 1,
      "text": "[NON-ENGLISH] They had-- ooh, it was very strong when they used to hit you, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 1,
      "text": "Yes, they hit me also.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 2,
      "text": "Because-- [NON-ENGLISH].",
      "word_count": 2
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 3,
      "text": "They used to say, run!",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 4,
      "text": "They tell we could run.",
      "word_count": 5
    },
    {
      "segment_idx": 127,
      "sentence_idx_in_seg": 5,
      "text": "But the old people, they couldn't run, like my auntie.",
      "word_count": 10
    },
    {
      "segment_idx": 128,
      "sentence_idx_in_seg": 0,
      "text": "I was about 24, nearly-- 23 and a half. 24, say.",
      "word_count": 11
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 0,
      "text": "But I looked like 17 at the time, you know?",
      "word_count": 10
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 1,
      "text": "I was thin.",
      "word_count": 3
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 2,
      "text": "And we were happy.",
      "word_count": 4
    },
    {
      "segment_idx": 129,
      "sentence_idx_in_seg": 3,
      "text": "And yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 130,
      "sentence_idx_in_seg": 1,
      "text": "After, when we went to Chaidari--",
      "word_count": 6
    },
    {
      "segment_idx": 131,
      "sentence_idx_in_seg": 0,
      "text": "We stayed, I told you, like, two hours, three hours.",
      "word_count": 10
    },
    {
      "segment_idx": 132,
      "sentence_idx_in_seg": 0,
      "text": "And then we stopped there for three days.",
      "word_count": 8
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 0,
      "text": "And after, they took us again to-- to the trains where they carried the animals, you know?",
      "word_count": 17
    },
    {
      "segment_idx": 133,
      "sentence_idx_in_seg": 1,
      "text": "The truck for the--",
      "word_count": 4
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 134,
      "sentence_idx_in_seg": 1,
      "text": "We didn't know where they're taking us, you see?",
      "word_count": 9
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 0,
      "text": "Everybody was crying, everybody-- come here, [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 135,
      "sentence_idx_in_seg": 1,
      "text": "And everybody, we went through there, you see?",
      "word_count": 8
    },
    {
      "segment_idx": 136,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, the leaders.",
      "word_count": 3
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 1,
      "text": "And they put there, there is the-- there were a barrel of water, something like this.",
      "word_count": 16
    },
    {
      "segment_idx": 137,
      "sentence_idx_in_seg": 2,
      "text": "And we sit in the floor with the suitcases what we had--",
      "word_count": 12
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 0,
      "text": "--with us, in the truck.",
      "word_count": 5
    },
    {
      "segment_idx": 138,
      "sentence_idx_in_seg": 1,
      "text": "And every-- the train, it was already full.",
      "word_count": 8
    },
    {
      "segment_idx": 139,
      "sentence_idx_in_seg": 0,
      "text": "It was, like, a track for the animals-- what do you call them.",
      "word_count": 13
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 0,
      "text": "Cattle train, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 1,
      "text": "And everybody sitting the floor, and it was dirty and everything.",
      "word_count": 11
    },
    {
      "segment_idx": 140,
      "sentence_idx_in_seg": 2,
      "text": "And then we had the journey--",
      "word_count": 6
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 0,
      "text": "Maybe, I don't know, four, five, six, or eight days?",
      "word_count": 10
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember, really.",
      "word_count": 4
    },
    {
      "segment_idx": 141,
      "sentence_idx_in_seg": 2,
      "text": "Because myself, these days, I'm getting for forget everything, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 142,
      "sentence_idx_in_seg": 0,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 143,
      "sentence_idx_in_seg": 0,
      "text": "Maybe two weeks, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 144,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, they used to stop for water.",
      "word_count": 7
    },
    {
      "segment_idx": 145,
      "sentence_idx_in_seg": 0,
      "text": "And they used to come--",
      "word_count": 5
    },
    {
      "segment_idx": 146,
      "sentence_idx_in_seg": 0,
      "text": "Water-- drinking water.",
      "word_count": 3
    }
  ],
