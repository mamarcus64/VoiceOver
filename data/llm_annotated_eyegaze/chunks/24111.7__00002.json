  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 12,
      "text": "Avien, ?] the cook, my mother, Joschko, you know, a few left, and only Chichibo stayed with us.",
      "word_count": 18
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 13,
      "text": "They had an very emotional good-bye with the nuns.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 14,
      "text": "And they made their way, miraculously, the same way, with open freight cars and the-- the most horrifying situations to Modena, and from Modena to Milano, from Milano to Como, [?",
      "word_count": 31
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 15,
      "text": "Chiasso ?] to [?",
      "word_count": 4
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 16,
      "text": "Varese. ?] I think it took them two days.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 17,
      "text": "And in [?",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 18,
      "text": "Varese, ?] Joschko asked Chichibo to come with us, to come with him to Switzerland.",
      "word_count": 15
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 19,
      "text": "And Chichibo refused.",
      "word_count": 3
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 20,
      "text": "And Chichibo said, there are more Jews left in the northern part of Italy which need me to guide them to this spot.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 21,
      "text": "And he said good-bye, and he went back to help other refugees interned in small communities in the northern part of-- of Italy.",
      "word_count": 23
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 22,
      "text": "Unfortunately, we found out later on the Germans caught him and put him on the wall and just shot him.",
      "word_count": 20
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 23,
      "text": "So Chichibo, Pacifici, our savior of the group, died a few days later.",
      "word_count": 13
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 24,
      "text": "To come back to our group, it was night.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 25,
      "text": "The day of Kol Nidrei, one of the most holy days in-- Jewish life, and the few adults, [PAUSES FOR 3 SECONDS] when they came to the water, it was at nighttime.",
      "word_count": 32
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 26,
      "text": "And the smugglers told them, the Germans are not here right now.",
      "word_count": 12
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 27,
      "text": "The German frontier-- now is the time to cross.",
      "word_count": 9
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 28,
      "text": "They could only see very-- under very difficult circumstances, the two feet of [? all ?] under the water.",
      "word_count": 19
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 29,
      "text": "I must tell you that I came back to the same spot three years ago and showed it to my wife.",
      "word_count": 21
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 30,
      "text": "I wanted to see her where the children crossed.",
      "word_count": 9
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "So the adults, [PAUSES FOR 4 SECONDS] Mr.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    }
  ],
