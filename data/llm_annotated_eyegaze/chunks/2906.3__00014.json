{
  "stem": "2906.3",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.8,
  "sentences_input": [
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "It's unbelievable the way that-- there was one man, with his wife, by us, and he couldn't eat meat, because when he was in-- in the concentration camp, they-- he was-- his work was to take the people and put it in the oven to burn.",
      "word_count": 46
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Well, he couldn't help it, you know?",
      "word_count": 7
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "They put him there.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And he put the people.",
      "word_count": 5
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "So he never could eat meat.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "And he get-- and he couldn't stand it, because it was so terrible.",
      "word_count": 13
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 0,
      "text": "[SIGHS] We stayed there till 1946.",
      "word_count": 6
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 1,
      "text": "We went to Canada.",
      "word_count": 4
    },
    {
      "segment_idx": 90,
      "sentence_idx_in_seg": 2,
      "text": "Cousins took us to Canada.",
      "word_count": 5
    },
    {
      "segment_idx": 91,
      "sentence_idx_in_seg": 0,
      "text": "My-- [SIGHS] When we were in Hallein, my husband find his brother.",
      "word_count": 12
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 0,
      "text": "My husband's family.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 2,
      "text": "Only he-- he survived.",
      "word_count": 4
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 3,
      "text": "There was a little girl, nine years old, and she-- she lived till-- till they liberate.",
      "word_count": 16
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 4,
      "text": "And then she drank the water that they poisoned-- [?Hitler?] poisoned the water.",
      "word_count": 13
    },
    {
      "segment_idx": 92,
      "sentence_idx_in_seg": 5,
      "text": "She was the only-- first one who took a little bit of water, and she-- she died.",
      "word_count": 17
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 0,
      "text": "So my husband remembered the name from his uncle in the United States.",
      "word_count": 13
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 1,
      "text": "And he wrote a letter to this uncle.",
      "word_count": 8
    },
    {
      "segment_idx": 93,
      "sentence_idx_in_seg": 2,
      "text": "And he find out that his brother is alive.",
      "word_count": 9
    }
  ],
