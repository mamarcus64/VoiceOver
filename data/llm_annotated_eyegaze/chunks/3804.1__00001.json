{
  "stem": "3804.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.3,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "And the one-- the-- the man who always I bought from him candy in a very small place, a round face I remember, was dead.",
      "word_count": 25
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "And the-- the Polish people killed him because already it was kind of feeling of the war is near to Poland.",
      "word_count": 21
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "And all these anti-Semites-- anti-Semitic people started to kill a Jew, and the Polish have never been, you know, late in killing Jews.",
      "word_count": 23
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "So it was not-- it was not new.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "But to me as a child, that was the first time that I felt it something new to me.",
      "word_count": 19
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And I felt very-- As a small boy, and I remember my mother running, and it was a very big thing in the-- in the small shtetl that they call it.",
      "word_count": 31
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And my mother decided to leave.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "To leave-- there was a big dispute between my father, that normally the rabbi was the-- the one to  who has to ask if you can move or not.",
      "word_count": 29
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "And my mother didn't believe in nobody but her senses.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "Like, she was really very strong, and she decided we leave-- we leave Poland.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "But we could never bring back our-- our sister and her three children and my small brother and our relatives.",
      "word_count": 20
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "But mostly, it was terrible that my sister has to stay there.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "And after a year, she decided to come back and to bring my sister, but never happened.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "David.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "He was a-- working, you know, in commerce, wheat.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "You know, buying from the Polish, bringing into town.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "That was the most of the work, to bring wheat into-- into the big city from the farm-- farmers.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "That what he's doing.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "My mother has a small-- a small grocery, something like this, selling, you know, in the-- in the small shtetl.",
      "word_count": 20
    }
  ],
