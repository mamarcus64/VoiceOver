  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.2,
  "sentences_input": [
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No, I'm an only child.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was--",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Well, I went to elementary school, then-- then I went to high school in Tel Aviv.",
      "word_count": 16
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Keula ?] High School, which was a private school.",
      "word_count": 9
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "Because my grades were not that great.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "[LAUGHS] I couldn't get into a-- in Israel, it was different.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "Public school was the best, and private school was the second best.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "So I couldn't get into public school, and I went to private school.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And I really became a good student in high school for some reason.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And when I graduated at the age of 18 from high school, [PAUSES FOR 3 SECONDS] I went to the Army.",
      "word_count": 21
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "I served for two years in [?",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "Sahan ?].",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And then when I-- Did you ever encoun-- were part of a war there?",
      "word_count": 14
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "During my time, during my service, there was no war.",
      "word_count": 10
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "It was peacetime.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And I--",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "--ended-- I finished my military service as a Sergeant.",
      "word_count": 9
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "[LAUGHS] And-- but--",
      "word_count": 3
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Then I-- you know, after two years in-- in the Army, which was, really, I have to say, it was a tremendous [PAUSES FOR 3 SECONDS] experience that-- that really made me a responsible adult and also clarified to me what I really want.",
      "word_count": 44
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "Because when I finished high school-- high school in Israel is quite difficult.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "There is these finals, and then-- and I didn't want to go on with school.",
      "word_count": 15
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "I thought, that's it.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "I don't want to ever see another book.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah, definitely.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Well, he was-- when we came to Israel, he was already married then.",
      "word_count": 13
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "You know, he was a young man, but he was out of the house, and he was married.",
      "word_count": 18
    }
  ],
