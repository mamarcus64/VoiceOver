{
  "stem": "9471.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "But I didn't have nothing to give her to eat anymore, you know?",
      "word_count": 13
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "She was-- I don't know how she, uh, did.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "In beginning, somebody brought me some milk.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "I could give it to her.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "And then after month, they took us in other camp.",
      "word_count": 10
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "That was Jaska, J-A-S-K-A.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "We were there, I don't know how many-- uh, almost thousand people already there from all over Yugoslavia.",
      "word_count": 18
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "And we were there maybe three weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "Then one day, they told us all to come out, women on one side and the men on other side.",
      "word_count": 20
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And they came with-- with, uh-- with, uh-- uh-- [NON-ENGLISH]-- with guns pointed on us and says, the men have to go in one line and go.",
      "word_count": 27
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "They separated us.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "That was the worst moment on my life.",
      "word_count": 8
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "Everybody was screaming, the women, because we couldn't even say goodbye to them.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "I remember my father, he took, uh-- then my husband already was bad.",
      "word_count": 13
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "He hardly could walk, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And my father took him by hand and then other-- my brother.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "And they went.",
      "word_count": 3
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "We were looking how they went.",
      "word_count": 6
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "It was horrible.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "And after about two weeks later, they took us in other camp, only women-- Kruscica.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "That was the worst.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "That was in Bosnia.",
      "word_count": 4
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "Kruscica-- should I spell it?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "K-R-U-S-C-I-A, Kruscica.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "We were beaten there.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Some of them were raped.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "We were in barracks without anything, you know-- no food, no water.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Once in day, maybe, have potatoes, what we had.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "I didn't-- we were there one month.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "I didn't see the water.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "I couldn't wash my baby.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "She made everything in diaper, and I couldn't even wash, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "She was already starting to cry-- all the time crying.",
      "word_count": 10
    }
  ],
