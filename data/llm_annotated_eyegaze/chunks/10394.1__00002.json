{
  "stem": "10394.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Tobel Raizel.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "But I don't remember the name for her-- from her husband.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "I don't.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "And we went over there to her.",
      "word_count": 7
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "When we went-- yeah-- when the war-- then was in 1939.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 5,
      "text": "And I says to my first husband, you go.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Leon.",
      "word_count": 1
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Leon Gams.",
      "word_count": 2
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "And I says to him, you know what?",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I can't go.",
      "word_count": 3
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "I'm not gonna leave my parents.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "I staying with my parents and you go.",
      "word_count": 8
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "Where he want.",
      "word_count": 3
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "Everybody left on Lvov.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "Lvov.",
      "word_count": 1
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "This was in the Russia-- us belong with-- for-- to Poland-- you know, Lvov.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "But they went over there.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 5,
      "text": "He was over there.",
      "word_count": 4
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 6,
      "text": "And then my brother, my youngest brother, was in--",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "--the army.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "Moishe.",
      "word_count": 1
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "So he was over there, and they saw each other.",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "Then they lived together by Ukraine.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "And she-- they used to work.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "This was a long, long time when they wanna come back to Poland.",
      "word_count": 13
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "And I said, for what?",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 1,
      "text": "They wanna send him to Russia to bury and to this.",
      "word_count": 11
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 2,
      "text": "He says, no.",
      "word_count": 3
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 3,
      "text": "I want to go.",
      "word_count": 4
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 4,
      "text": "He want to go home.",
      "word_count": 5
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 5,
      "text": "He left me and my parent.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "It was one day.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "The Ukrainian got one day they can do with the Jewish people what they want.",
      "word_count": 15
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "She bringed the-- the-- [NON-ENGLISH], you know-- the [NON-ENGLISH] to the room.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "She said she has Jewish people.",
      "word_count": 6
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 4,
      "text": "And then the--",
      "word_count": 3
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "She was a Ukrainian.",
      "word_count": 4
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 0,
      "text": "A woman.",
      "word_count": 2
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "She was a superintendent.",
      "word_count": 4
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 1,
      "text": "This is like she take care of the house, you know, everything.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "So she bringed everybody over there, the Ukrainian.",
      "word_count": 8
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 3,
      "text": "They got the one day they can do with the Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 4,
      "text": "What they did-- my oldest brother was over there, too, but not in the same place.",
      "word_count": 16
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 5,
      "text": "Then he talks from them to-- he take his head on the wall.",
      "word_count": 13
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 6,
      "text": "He couldn't hear.",
      "word_count": 3
    }
  ],
