{
  "stem": "20083.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.9,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "My name is Paul Kuttner.",
      "word_count": 5
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "K-U-T-T-N-E-R.",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "No, I do not.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Berlin, Germany.",
      "word_count": 6
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "B-E-R-L-I-N.",
      "word_count": 1
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "September 20, 1922.",
      "word_count": 3
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Also Paul Kuttner.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "Margarete Kuttner, and her maiden name was Margarete Fraenkel.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "He was a medical doctor.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "My mother was a nurse in World War I.",
      "word_count": 9
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "But then she became a housewife and mother.",
      "word_count": 8
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "She taught piano lessons, private piano lessons.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I had one sister, Anne Marie, who was born in 1912.",
      "word_count": 12
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And I had another brother who was born 1918 or 1919, but he died a few weeks after his birth.",
      "word_count": 20
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "Well, first of all, what I remember is that I lived in the [GERMAN] 14.",
      "word_count": 15
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And my father and my mother were still together there.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And around 1929 or so, he left my mother for another woman by the name of Ida, or Ida, Kasper-- a very nice woman, I must say.",
      "word_count": 27
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But I was very, very unhappy about that separation.",
      "word_count": 9
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "And my mother suffered terribly-- that I remember.",
      "word_count": 8
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 5,
      "text": "But after a few years, she got used to that too, I suppose.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 6,
      "text": "And we moved from the [GERMAN] to the Kaiser Allee.",
      "word_count": 10
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 7,
      "text": "Which is just a few blocks away.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 8,
      "text": "And that's where I live for the rest of my stay in Germany until I left in 1939.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 9,
      "text": "And I lived with my mother and my sister, Anne Marie, in the Kaiser Allee.",
      "word_count": 15
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Very much so.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "Every weekend, either on Saturdays or Sundays, and sometimes on Saturdays and Sundays, I had to visit him and his wife, Ida.",
      "word_count": 22
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But I must say they were wonderful to me in every respect.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "They never said anything against my mother, who was the greatest love of my life, as a matter of fact.",
      "word_count": 20
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 4,
      "text": "And I must say they were just wonderful to me in every respect.",
      "word_count": 13
    }
  ],
