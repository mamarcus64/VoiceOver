  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "And the only thing I can tell you is if this tape tells anybody-- any man, woman, or child-- what I went through, that's OK.",
      "word_count": 25
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "You see, in 10, 15 years, I'll be gone.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "I figure I'm about the youngest alive.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "So all the people ahead of me are going to be gone.",
      "word_count": 12
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 3 SECONDS] So if you don't have this tape to tell people [PAUSES FOR 3 SECONDS] what the world went through when everybody kept quiet, including the United States, [PAUSES FOR 3 SECONDS] please let this be a remembrance.",
      "word_count": 41
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "Thank you.",
      "word_count": 2
    }
  ],
