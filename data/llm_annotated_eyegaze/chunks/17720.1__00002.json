  "sentences_input": [
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "It was the capital of Bulgaria.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "So was crossroad of number of cultures that were going in, in the town.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "They were speaking in the time more than eight, nine languages at the time currently in, in the street.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "For this period of Ruse speaks very much my uncle, who, was also born there, in his book, What was his name?",
      "word_count": 22
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "His name was Elias Canetti.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He was the Nobel Prize winner of 1981.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "The relation was in-- from my mother's side.",
      "word_count": 8
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "And I think that is something like [PAUSES FOR 4 SECONDS] generation of his grandmother and my aunts or my grandmother sides connected.",
      "word_count": 23
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "Of course, he left Ruse very early in his own childhood, when he was five or six years old, and never, never came back there.",
      "word_count": 25
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "You",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "My father also left Ruse.",
      "word_count": 5
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "And actually, I think that he met my wife already in the capital.",
      "word_count": 13
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "Maybe they knew each other very little.",
      "word_count": 7
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "But they were very young in their native city, which was the same for my mother and father.",
      "word_count": 18
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 4,
      "text": "My mother also was born in Ruse.",
      "word_count": 7
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "Her name was Zelma Cohen.",
      "word_count": 5
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "She was born-- she was considerably younger to him.",
      "word_count": 9
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "She was born something-- somewhere around '11 or '12 of 19-- 1912, I guess.",
      "word_count": 14
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "So [PAUSES FOR 6 SECONDS] I was born in Sofia in one environment that was, in the time, I'm able to say, pretty happy, pretty well settled, was one world, world of [PAUSES FOR 3 SECONDS] economic and financial security in which the parents were making plans for the future of their children, of their grandchildren, [PAUSES FOR 3 SECONDS] was one world of [PAUSES FOR 5 SECONDS] quite active cultural life, quite active social life.",
      "word_count": 76
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Can you describe that for me a little bit more?",
      "word_count": 10
    }
  ],
