{
  "stem": "11611.5",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.1,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "By this time, we had a small Czech liaison office in Nuremberg, we had a couple of Yugoslavs who were fairly ostracized because the United States had broken relations with Yugoslavia in this period.",
      "word_count": 34
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "We had some Dutch liaison office.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "We had some of the remains of what had been the British staff at the big trial.",
      "word_count": 17
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "The Russians were nowhere in evidence-- nothing, that is the Soviets.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "That was about it.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "Documentary, very heavily documentary.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "I mean, as I said, I had 1,000 documents translated at hand during the trial.",
      "word_count": 15
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "I actually introduced several hundred.",
      "word_count": 5
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "I had, I don't know, something like 10, 12 document books full of documents.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "I can't remember anything-- the-- the only thing that I remember very distinctly is the endless lies of Rasch.",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I remember a commission hearing with some young girl who testified on behalf of Puhl, and she was the most difficult witness I ever dealt with because she was loyal to the hilt.",
      "word_count": 33
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I think she was a housemaid-- and smart.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "And I do have a vague impression of her as a very tenacious witness whom I did not make any headway with.",
      "word_count": 22
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "No, they weren't convincing.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I think Rasch's lies convicted him.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Somebody sat up with earphones, picked up the-- the questioning was usually done in English.",
      "word_count": 15
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The witness would hear it in German.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "It would be translated by an interpreter sitting in a booth.",
      "word_count": 11
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "And the answers would come back in German, and you'd get them in English.",
      "word_count": 14
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "By the-- by this time, of course, while the English interpretation simultaneously was helpful, I could pick up a fair amount on direct listening.",
      "word_count": 24
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "It was extremely good.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "These were people who were fluent in both languages.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Most of the interpreters were German or Austrian born.",
      "word_count": 9
    }
  ],
