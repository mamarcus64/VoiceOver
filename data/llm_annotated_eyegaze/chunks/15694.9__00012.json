  "elapsed_s": 3.9,
  "sentences_input": [
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 49,
      "text": "I should have had a conscience to take his half portion of bread, but I didn't, because it was no time for having a conscience.",
      "word_count": 25
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "So we had a bit more bread.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And really, we did not suffer.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "We had an easy job after the six weeks, and we got our strength back.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Now, winter came.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "And it was cold, very cold.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "End of '44.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Now, there comes another episode, which probably will have to go into the next reel.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My father once took me behind the barracks, some barracks, and according-- as I say, practical, forever practical-- he has shown me a new underwear.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "They were turned inside out turned cement sacks with the necessary holes, which we then put on as underwear.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "[AUDIO OUT]",
      "word_count": 2
    }
  ],
