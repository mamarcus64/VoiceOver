{
  "stem": "2074.3",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 13.5,
  "sentences_input": [
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "So she was not afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "She kept me in the house for few weeks, maybe longer.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "Maybe-- I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "Sitting on top.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "And she had the barrel, would make bread in front of me.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And I was sitting in the back on top of-- of an oven.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And evidently, her father knew whatever.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "So she kept me a while.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And the Hitler picture was hanging right big in front of the dining room table.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "So I knew that he was-- was a Nazi leader.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And I stayed there.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "It was a Christmas Eve one night.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And then when they would-- I-- they didn't go to me when he was home.",
      "word_count": 15
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "She brought me to eat only when he was gone.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "So-- but I didn't question it.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "So he was home and then they're eating the Christmas dinner.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "And then I see the Hitler picture is rolling, rolling, rolling, rolling, and fell right down on the floor.",
      "word_count": 19
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And I say-- and then the next day, that [?",
      "word_count": 10
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "Manka ?] comes up to me.",
      "word_count": 6
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "She says, you know what that means?",
      "word_count": 7
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "That means that Hitler is gonna go down and you're still gonna be alive.",
      "word_count": 14
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "See, the father was a Nazi leader.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "He was killed.",
      "word_count": 3
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "He never lived to see the door-- the war.",
      "word_count": 9
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Never the end of the was.",
      "word_count": 6
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 4,
      "text": "He a big there.",
      "word_count": 4
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 5,
      "text": "When they captured my parents for hiding 15 months, they brought it back to him.",
      "word_count": 15
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 6,
      "text": "He was the officer.",
      "word_count": 4
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "Safka ?] [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 2,
      "text": "[?",
      "word_count": 1
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 3,
      "text": "Safka ?] [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "But his daughter was hiding me.",
      "word_count": 6
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "His wife knew.",
      "word_count": 3
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "They were hiding me.",
      "word_count": 4
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "So [?",
      "word_count": 2
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "Safka ?] feel-- felt bad, they told me now, that my parents were captured.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "But he did my parents a big favor.",
      "word_count": 8
    }
  ],
