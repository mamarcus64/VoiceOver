{
  "stem": "18397.2",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 111.4,
  "sentences_input": [
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 15,
      "text": "Ponar was the place where they used to kill the people, the Jewish people.",
      "word_count": 14
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 16,
      "text": "My father had-- we had this-- the whiskey, in the house, you know, under a curtain.",
      "word_count": 16
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 17,
      "text": "And then the Germans came in.",
      "word_count": 6
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 18,
      "text": "They came in maybe four or five, you know, in the house.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 19,
      "text": "They used to take away the men.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 20,
      "text": "When he saw the-- the-- the place with the whiskey over there.",
      "word_count": 12
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 21,
      "text": "He says, I want to take it, he says.",
      "word_count": 9
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 22,
      "text": "But I cannot take it.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 23,
      "text": "Because I have the men.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 24,
      "text": "And my father said, come later.",
      "word_count": 6
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "So he-- he didn't take the men with him.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "We had a couple-- a couple of plating-- [NON-ENGLISH], we call it, who escaped from Poland to us, you know, to Vilna.",
      "word_count": 22
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "So they used to live with us too.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "Because he was a friend of my brother.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "They didn't take no men from our apartment.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "And when they took us to the ghettos, you know, we had to take any bundles you could-- you could carry and take it with you.",
      "word_count": 26
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "How much can you carry from your house with people?",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "But we took it.",
      "word_count": 4
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "When we went out, we were sitting on a-- on the sidewalk, and waiting to somebody to show us how to go to-- to the ghetto.",
      "word_count": 26
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "All of a sudden, we had so many tenants, no men.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 3,
      "text": "We were the only [PAUSES FOR 3 SECONDS] house who had a man, you know, we had three or four men.",
      "word_count": 21
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 4,
      "text": "And the doctor was upstairs, and he had two-- two men.",
      "word_count": 11
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 5,
      "text": "This was from the whole house.",
      "word_count": 6
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 6,
      "text": "This was an apartment house, a new apartment house.",
      "word_count": 9
    }
  ],
