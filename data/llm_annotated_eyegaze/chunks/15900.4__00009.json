{
  "stem": "15900.4",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 21,
      "text": "Instead of arriving at 7 o'clock, I arrive at 1 o'clock in the morning.",
      "word_count": 14
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 22,
      "text": "I went up to my brother, and I called her.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 23,
      "text": "She said, she'll waiting.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 24,
      "text": "I took the-- the subway, and I went there to Yonkers.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 25,
      "text": "She lives in Yonkers at the time.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 26,
      "text": "And I took the bus.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 27,
      "text": "I came over.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 28,
      "text": "I rang the bell.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 29,
      "text": "Her mother open.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 30,
      "text": "She went in, a one-bedroom apartment.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 31,
      "text": "She was dressed, eyes beautiful, beautiful girl.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "I went in there and stayed, I said, what are you going to do?",
      "word_count": 14
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "Let's go out.",
      "word_count": 3
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "I work seven days.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 3,
      "text": "I said, let's go out because of Thanksgiving.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 4,
      "text": "And we saw a picture, movies.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 5,
      "text": "I think the movie was the movies.",
      "word_count": 7
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 6,
      "text": "Then we went to a restaurant and had coffee.",
      "word_count": 9
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "And I went back about 3 or 4 o'clock, took her home.",
      "word_count": 12
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "And her mother called up.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "Why don't you send him home?",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "He's not for you.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "Who said that?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Her mother.",
      "word_count": 2
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "He said, he's not for you.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "He's not for you.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "What are you going to-- why don't you send him home.",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "She's said, Mom, keep quiet.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And I left there.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And I went right back to-- to work.",
      "word_count": 8
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "I didn't sleep, at night time, Sunday I work.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "Saturday I worked.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "And later on, she liked me.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "And I went back the following week for a date.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "And I told her, look.",
      "word_count": 5
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "I like you, everything, but I can offer you nothing.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 11,
      "text": "I'm a hard-working man.",
      "word_count": 4
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 12,
      "text": "And my brother used to tell to me, if you bring in a girl to my house, and I make a party in the house and everything, and you quit the girl and you go with another one, if you bring in somebody you should be sure you're going to marry her.",
      "word_count": 52
    }
  ],
