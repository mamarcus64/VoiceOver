{
  "stem": "25938.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Oh, that was-- that was when we-- when we were-- we had to be seen for the-- for the leaders of the underground.",
      "word_count": 23
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "I think there were doctors there.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 2,
      "text": "It was a place-- it was-- like kind of a hospital or something-- something.",
      "word_count": 14
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 3,
      "text": "So-- so we had to do that.",
      "word_count": 7
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 4,
      "text": "I remember that was the sign.",
      "word_count": 6
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 5,
      "text": "To-- and that was-- that was a sign that we-- that we had from the movement.",
      "word_count": 16
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "That-- That man reminded me about that.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "No, no, no.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "I don't think of it.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "No one-- no one knew.",
      "word_count": 5
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "Even my own brother didn't know.",
      "word_count": 6
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 4,
      "text": "No one, but no one knew that.",
      "word_count": 7
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 5,
      "text": "I-- I think I'm the only one who-- who belonged to the underground.",
      "word_count": 13
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 6,
      "text": "I don't-- I don't-- I never even met a person who-- who was in the underground.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "I never met a person who-- who-- who went-- who was operated on and they survived.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "I was operated in Birkenau.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "I was very sick.",
      "word_count": 4
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And when I was lying on the board where-- where we had to go to sleep.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 2,
      "text": "There were boards, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 3,
      "text": "And-- with my brother, we-- with him together, my brother.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 4,
      "text": "In all the camps, we managed to be together in all the camps, in Dachau, in Kielbasin, in-- in Auschwitz, in [INAUDIBLE].",
      "word_count": 22
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 5,
      "text": "So felt-- I had a wound, and the pus was-- was-- was coming from my shoulder.",
      "word_count": 16
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 6,
      "text": "And it touched the board.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 7,
      "text": "It was terrible.",
      "word_count": 3
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 8,
      "text": "I had to wake up in the morning, and the-- and the-- and the-- and they oversee us to shower, did all kinds of [INAUDIBLE] to get up and to go to work.",
      "word_count": 33
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 9,
      "text": "And sometimes, maybe, they used to beat us too.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 10,
      "text": "But not-- not too often.",
      "word_count": 5
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 11,
      "text": "I remember here, and [INAUDIBLE], here was the pus.",
      "word_count": 9
    }
  ],
