    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 15,
      "text": "But they arrested my brother in law and two of my older nephews, and just to be shoved in buses.",
      "word_count": 20
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 16,
      "text": "And I didn't know where they were.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 17,
      "text": "And I went back to my-- to my mother.",
      "word_count": 9
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 18,
      "text": "I said, Jean and Marcelle and Bernard were-- they were arrested.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 19,
      "text": "They were sent.",
      "word_count": 3
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 20,
      "text": "And they were sent to Drancy.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 21,
      "text": "Drancy was a transit camp outside of Paris.",
      "word_count": 8
