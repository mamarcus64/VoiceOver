{
  "stem": "8703.6",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.9,
  "sentences_input": [
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "As a matter of fact, we came after about a-- five or six days traveling in the-- in the cattle cars, they brought us to a place, Terezin-- Theresienstadt in Czechoslovakia.",
      "word_count": 31
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "We came to Theresienstadt.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "We were very surprised.",
      "word_count": 4
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 2,
      "text": "People were dressed-- were dressed nice, clean.",
      "word_count": 7
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 3,
      "text": "They looked good, not bad, not like us in our camps.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "And we didn't know what, what it means.",
      "word_count": 8
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "What-- why-- how come there was a place like this in existence-- a camp like this, the concentration camp?",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "We learned later on that this was the model camp that the SS, the German Nazis, created to show for the Red Cross and for anybody who was asking, who was brought-- who brought up that the Jewish people are not treated right, or they're getting killed.",
      "word_count": 47
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "They said, come on, I'll show you.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "I have here a camp.",
      "word_count": 5
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And I'll show you how nice we are treating the Jewish people.",
      "word_count": 12
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 3,
      "text": "And especially for the Red Cross, they showed off.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 4,
      "text": "And that's why they kept-- and people-- the living quarters were not bad.",
      "word_count": 13
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 5,
      "text": "And the food was not bad.",
      "word_count": 6
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 6,
      "text": "And there were no beating like at the other camps.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] We were the first transport who came in from the people from the [NON-ENGLISH].",
      "word_count": 18
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 8,
      "text": "And we were happy, like I said, we came by trains.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 9,
      "text": "And they-- the way we were treated is properly.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 10,
      "text": "I would never forget.",
      "word_count": 4
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 11,
      "text": "We had to go in to a-- take a shower and leave all our old clothes.",
      "word_count": 16
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 12,
      "text": "They threw away.",
      "word_count": 3
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 13,
      "text": "And they gave us, after the shower, new-- not new, but old, clean clothes.",
      "word_count": 14
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 14,
      "text": "What they-- then there were-- they came.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 15,
      "text": "They started to come a lot of people from all over.",
      "word_count": 11
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 16,
      "text": "In the thousands they came from the [NON-ENGLISH].",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 17,
      "text": "They came exhausted, sick, half-dead.",
      "word_count": 5
    }
  ],
