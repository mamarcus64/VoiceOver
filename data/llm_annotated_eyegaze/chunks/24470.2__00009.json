{
  "stem": "24470.2",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.2,
  "sentences_input": [
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "And there were no, uh-- uh, there was some killing there, you know, by shooting, but no-- no-- just labor camp.",
      "word_count": 21
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 4,
      "text": "We worked.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, that I can describe.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Uh, interestingly enough, that I remember very vividly, from that moment on.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We were living in barracks.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "The barracks had women separated from men.",
      "word_count": 7
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "There were barracks for men and barracks for women.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "Uh, in my barrack where I lived, there were 16-- there was a long board like you saw in the Washington museum, if you went there-- those long, wooden-- uh, I don't know what they call them in English.",
      "word_count": 39
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Uh, not beds, but wooden boards.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "One's on top of the--",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "Bunks.",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "Not bunks, but-- but there were bunks.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Wood, on top of us another wood, and on top of us a third one.",
      "word_count": 15
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "There were three layers.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "I was on the bottom.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "My friends were on the top, whom I met in concentration-- in that camp, not before.",
      "word_count": 16
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "We lived together.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And there were a few hundreds of women in that barrack.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "That was within-- yes.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 1,
      "text": "That was within the camp-- within the factory, uh, area.",
      "word_count": 10
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 2,
      "text": "There was a large, large area outside.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "Uh, we slept on those bunks without any bedding.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 1,
      "text": "We didn't have any pillows or sheets or anything.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 2,
      "text": "We had, after a while, a lot of, uh, animal friends-- bugs and, uh-- and fleas, and, uh-- what do you call them?",
      "word_count": 23
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "Uh, lice, bed bugs.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Oh, I remember sleeping covered with my coat, uh, which I left-- by the way, I left my apartment house in a skirt and a top and a sweater and a coat, a very warm coat.",
      "word_count": 36
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Blue coat that was from home.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "That was from our home, when we never returned.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "Everybody was dressed.",
      "word_count": 3
    }
  ],
