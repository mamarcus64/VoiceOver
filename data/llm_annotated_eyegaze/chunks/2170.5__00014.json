{
  "stem": "2170.5",
  "chunk_idx": 14,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.5,
  "sentences_input": [
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 13,
      "text": "You put the stamp on the ink to make, they call it [? bichat ?].",
      "word_count": 15
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 14,
      "text": "So he had ink in a bottle, you know, because you write, you write with a pen over there.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 15,
      "text": "And you put in.",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "So he put the ink on that thing.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "But he didn't put it right because he forgot it's liquid.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "And he puts the stamp, he opens my passport, and he puts the [INAUDIBLE], and he puts in my passport, and the whole thing is black.",
      "word_count": 26
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "You don't see no stamp.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And he made it on three, four pages of my passport.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And when I-- when I saw this, I said there's gonna be trouble.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "He apologized and he wrote that document that I have over here.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "Because of technical things, he spoiled.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "But it does not matter.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I'm going to Odessa.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "He-- he gives the orders to transfer me on the train to Odessa on this and this date.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "And over there, I should show it to the KGB over there, and they will let me through.",
      "word_count": 18
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "And that's how it was.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "Couple days later I said goodbye Zhmerinka.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "The whole city was near the railroad in the morning at 6 o'clock.",
      "word_count": 13
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "People which were with me in the ghetto.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "Some of them are over here.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "Many, some of them, many of them, already came after.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "And I left Zhmerinka to go to America.",
      "word_count": 8
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "That was in the morning.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 15,
      "text": "I left 6 o'clock, I came in at night to Odessa.",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "In the embassy, in Moscow, the secretary told me I should put my passport and sew it up in my jacket in the back because in Odessa, there's-- you've gotta be very careful, a lot of crooks, hooligans.",
      "word_count": 38
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "They can steal by you the passport.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "That's what I did.",
      "word_count": 4
    }
  ],
