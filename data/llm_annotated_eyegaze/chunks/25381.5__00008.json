{
  "stem": "25381.5",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.6,
  "sentences_input": [
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "And after she left, I take the bread with butter.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "So the whole butter, from the water, melted all over my few clothes, the few pieces that I had, and all over the bread.",
      "word_count": 24
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "And she comes, and I started to cry.",
      "word_count": 8
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "I was crying like a baby.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "I say, Mrs.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "Grushkin-- her name was Mrs.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "Grushkin-- she was so good to me, like an angel.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "She said that I am her stepdaughter.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 18,
      "text": "She liked me like her own child.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "I say, take a look, what I did.",
      "word_count": 8
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Now I have nothing to wear.",
      "word_count": 6
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "I had a nightgown.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I had a slip.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "I had underwear and everything.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And everything got melted from the-- from the butter.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "What can I do now?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "I have nothing to wear.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "Where should I wash?",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "Where should I go?",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "I'm afraid of her, of this lady, the owner.",
      "word_count": 9
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "She says, don't be afraid.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "I'll take care.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "She took the clothes to her daughter, and she washed it.",
      "word_count": 11
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 3,
      "text": "And this, we throw away in garbage.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 4,
      "text": "And she brought it back to me, and she didn't know about it.",
      "word_count": 13
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 5,
      "text": "That was-- we came in February, March, April.",
      "word_count": 8
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 6,
      "text": "It's before Passover.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 7,
      "text": "And before Passover, it's April.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 8,
      "text": "We go to the uncle, and he says he's giving her more-- like he paid $50 a week-- you know, room and board and food.",
      "word_count": 25
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 9,
      "text": "Now he's giving her $10 more, because Passover it costs more money to buy the food.",
      "word_count": 16
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 10,
      "text": "He sat on the porch, and the children sat on the porch, and I burst in tears.",
      "word_count": 17
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 11,
      "text": "And I fell on the floor.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And I said, uncle.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I say, you have no idea.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I beg every day, my day, I should die.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And why did I have to?",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "I say, I survived Hitler.",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Now I have another Hitler.",
      "word_count": 5
    }
  ],
