{
  "stem": "27543.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.8,
  "sentences_input": [
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 1,
      "text": "The war is over.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 2,
      "text": "And everything is gone.",
      "word_count": 4
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 3,
      "text": "And I had two cousins there who was in the white band.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "They were-- they were half Jews or Catholic or their mother, father.",
      "word_count": 12
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "But they-- those boys said-- they said, everybody can go how they want to.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "But I says-- I went over to there.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I said, Stevie, George, come on.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "In a half hour, you free.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "We are-- we were hearding from-- from Schachendorf how long they were-- that was right next to [INAUDIBLE], where we went out first, by the border.",
      "word_count": 26
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "We were holding all the guns and everything.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "I says, commander, what are you going for, there?",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "Oh, they not going to hurt us no more.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "So what did they do?",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "There was about 120 of these white band.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "Those son-of-a-bitches Hungarians-- Hungarian Germans, they were.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "They put them in a barn.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "Now, this is the truth.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "This is true worst thing I ever heard in my life.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "They put them in a barn.",
      "word_count": 6
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "They threw around, gasoline.",
      "word_count": 4
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "And while they were running around, they shot every 120 of them.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "This is the truth.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "After liberation.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My cousins' two kids.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] boys.",
      "word_count": 2
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 2,
      "text": "Where I told you, beautiful, big, tall guy-- they said, [INAUDIBLE], they're not going to hurt us.",
      "word_count": 17
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 3,
      "text": "We're the [INAUDIBLE].",
      "word_count": 3
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 4,
      "text": "We always-- we're-- we got a white band.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 5,
      "text": "They were maybe eight years old when they convert.",
      "word_count": 9
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 6,
      "text": "That was the worst.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Then we work--",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "I lost everything.",
      "word_count": 3
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I-- I said, there is no God.",
      "word_count": 7
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "How did-- how could they kill those little kids there, 2 to 10 years old?",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "How could they kill them?",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "What did they do?",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Did they hurt you? you? you?",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "They didn't hurt nobody.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "They're born in the right-- wrong place at the wrong time.",
      "word_count": 11
    }
  ],
