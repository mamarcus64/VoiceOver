{
  "stem": "15645.2",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.9,
  "sentences_input": [
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 5,
      "text": "And-- but-- [PAUSES FOR 3 SECONDS] yes.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 6,
      "text": "And when I come back, and I meet some-- a Jew with a boy.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 7,
      "text": "And we go together to the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 8,
      "text": "And the ghetto was burned.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 9,
      "text": "It was on fire.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 10,
      "text": "And we stay in a shed opposite-- opposite the street in a shed.",
      "word_count": 13
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 11,
      "text": "Here was a local person.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 12,
      "text": "He know exactly everything, because he was born there.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 13,
      "text": "He lived his whole life in Janow Podlaski in the-- in the little town.",
      "word_count": 14
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 14,
      "text": "So he knows everything.",
      "word_count": 4
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 15,
      "text": "And He told me, come with me.",
      "word_count": 7
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 16,
      "text": "And I went with him.",
      "word_count": 5
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 17,
      "text": "And we went in the shed.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 18,
      "text": "And we just stayed in the shed until late night.",
      "word_count": 10
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 19,
      "text": "And we saw the ghetto burning.",
      "word_count": 6
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 20,
      "text": "And we saw the-- the-- the machine guns around.",
      "word_count": 9
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 21,
      "text": "And the shot-- we heard shots and burning the ghetto, and shots [INAUDIBLE] because the people are running from the fire.",
      "word_count": 21
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 22,
      "text": "And they shot everybody.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "And later on, he say, come with me I know-- I know here a person, because he made a business with some local people, and then-- and then-- called Hala.",
      "word_count": 30
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "Come with me.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "He'll give us a place to stay overnight and tomorrow [INAUDIBLE] what to do.",
      "word_count": 14
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "So we went-- I went with him.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "And he opened the shed and put us in the shed.",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "And in the straw, we lie in the straw, and we lie through the night.",
      "word_count": 15
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "And in the-- in the early morning, we hear, like, soldiers are walking on the-- on the-- on the stones, because everything was stones in the-- the yard.",
      "word_count": 28
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And we hear the soldiers are coming.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "And he opened the-- the-- the gate-- the gate.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And they are staying with the-- with the rifles and the bayonets.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "[GERMAN].",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "So they took us.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    }
  ],
