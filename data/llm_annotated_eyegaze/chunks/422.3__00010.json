{
  "stem": "422.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "You could talk to a person this minute, and a few minutes later you could see him laying in street covered up with a newspaper-- with newspapers, dead.",
      "word_count": 28
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "And waiting for the street-- people that they picked up, the street people, the people-- the dead people from the street to be buried.",
      "word_count": 24
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 18,
      "text": "All my neighbors died like this.",
      "word_count": 6
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 19,
      "text": "My family died, from my family-- aunts, cousins died.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 20,
      "text": "Died this way.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 21,
      "text": "I'm the only survivor.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 22,
      "text": "I have no-- beside my immediate family, I have no family, like I would be born out of a stone.",
      "word_count": 20
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 23,
      "text": "And I miss them.",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 24,
      "text": "I  still miss them.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "I couldn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't go to hiding.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, we were-- we were hiding.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Sometimes, when we heard the Germans yelling that we have to come down in the backyard, I hide a few times.",
      "word_count": 21
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "But I heard the marching, the boots, and my heart was pounding.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And it's still up to now.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "I have to live on pills, on those pressure pills.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And this is from this time.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "Then I didn't tell you still this story about Auschwitz, about my running away.",
      "word_count": 14
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "The ghetto, to live through the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "To live a few days in the ghetto was a big, terrible thing.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Not everybody could live in the ghetto.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Because-- because the conditions of living over there, they were inhuman.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "They were inhuman.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Not created for human beings to live.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "You had to settle to live in dirt, and with hunger.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "You couldn't go-- I couldn't go on the Aryan side to hide, because I was a typical Jewish-looking girl-- black eyes and black hair.",
      "word_count": 24
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And olive skin makes you-- right away, they know you're Jewish.",
      "word_count": 11
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "And if the Germans would not, the Poles would point on you that this is a Jew in hiding.",
      "word_count": 19
    }
  ],
