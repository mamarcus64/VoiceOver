{
  "stem": "3874.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "[INTERPOSING VOICES]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "My name is now Arthur Kern.",
      "word_count": 6
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "I was born in Vienna, Austria, October 19, 1928.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "I grew up in a family where I had one brother by the name of Fritz, and my parents.",
      "word_count": 19
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I had aunts, uncles, cousins.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "So for the first 10 years of my life, everything was very, very nice, as far as we were concerned.",
      "word_count": 20
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "We had-- we-- my father had a knitting factory.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "We were semi-religious.",
      "word_count": 3
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "He, although he worked on Saturday, on Shabbos, we went to-- we went to synagogue-- not all the time, but occasionally.",
      "word_count": 21
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "We had a kosher home.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "But it was a very close type of family.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "Went to school for the first four years of my life.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "Had private lessons in piano, had private lessons in Hebrew.",
      "word_count": 10
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "I played a lot of soccer at that time.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "I was a fairly good student.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "It was just a very normal, what I would-- what I would say is a middle-class type of life.",
      "word_count": 19
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "My brother was three years older.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "He was, at the time of occupation-- which was in March of 1938, this was when the Germans entered Austria with the Anschluss-- I was 10 and he was-- he was 13.",
      "word_count": 32
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "OK, sure.",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "We lived in an apartment which had-- it was huge.",
      "word_count": 10
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "It was a huge apartment.",
      "word_count": 5
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 3,
      "text": "It had like six or seven bedrooms.",
      "word_count": 7
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 4,
      "text": "It had a room for a-- we had a maid, we had a room for her.",
      "word_count": 16
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 5,
      "text": "In fact, one of things I used to do, against my mother's wishes, I had a bicycle-- I think from my sixth or seventh birthday, and we had a long hall.",
      "word_count": 31
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 6,
      "text": "And I would open all the doors to connecting rooms, and take my bicycle and ride down the hall.",
      "word_count": 19
    }
  ],
