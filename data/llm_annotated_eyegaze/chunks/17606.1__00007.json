  "elapsed_s": 30.3,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 5,
      "text": "[POLISH] for children.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 6,
      "text": "[PAUSES FOR 4 SECONDS] Then besides that, we had first of all the institutions.",
      "word_count": 14
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 7,
      "text": "The voluntary institutions.",
      "word_count": 3
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 8,
      "text": "The welfare institutions, we would call it now.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 9,
      "text": "[SPEAKING HEBREW].",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 10,
      "text": "Every district, every neighborhood.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 11,
      "text": "Even mine, which was a non-Jewish one, had a [SPEAKING HEBREW].",
      "word_count": 11
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 12,
      "text": "And [INAUDIBLE] as a welfare-- a-- loans to give, a-- this [HEBREW], which was to--",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "--to marry off and to make a-- make endowments for the-- for--",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, for poor brides.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And this [SPEAKING HEBREW], which on Warsaw, the-- in-- on some holidays, Jewish holidays, you allowed to bury, like Rosh Hashanah, [HEBREW], Shabbat, and Yom-- and Yom Kippur.",
      "word_count": 28
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "But you couldn't wheel them or drive them.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "So people who were-- volunteered to carry them from the house to the cemetery.",
      "word_count": 14
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "[PAUSES FOR 4 SECONDS] You name it.",
      "word_count": 7
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "We had the biggest-- this orphanage house, [POLISH] orphanage house.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "On [POLISH] 92.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "I visited them quite often.",
      "word_count": 5
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "I visited [POLISH] when he was taken to the [GERMAN].",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 9,
      "text": "So he was carrying the-- the children-- two children in his arms.",
      "word_count": 12
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 10,
      "text": "We had synagogues.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 11,
      "text": "All kind of synagogues.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 12,
      "text": "Ultra orthodox, orthodox synagogues, more conservative.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 13,
      "text": "Not conservative in our sense of now, but modern orthodox.",
      "word_count": 10
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 14,
      "text": "We had the Professor Balaban and the [INAUDIBLE], and the [INAUDIBLE] where my sister was married, and my brother was married there.",
      "word_count": 22
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 15,
      "text": "And Professor Balaban, one of the best well-known Jewish historians was the-- the chief rabbi of it.",
      "word_count": 17
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 16,
      "text": "And [POLISH] school had Professional Shur, who was a professor at the Warsaw University of the theological-- this-- department.",
      "word_count": 19
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "It didn't crack.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "We didn't feel it's cracking.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "But we felt the anti-Semitism on the government level.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "After Pilsudski's death.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "After 1935.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 4 SECONDS] That something is cracking.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "Did we have [POLISH] with his [POLISH] yes.",
      "word_count": 8
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "Economic breakout, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 5,
      "text": "But hooliganism, no.",
      "word_count": 3
    }
  ],
