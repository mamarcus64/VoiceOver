{
  "stem": "17374.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 264.5,
  "sentences_input": [
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "I mean, it was Niusia Horowitz come with the cake from the-- Herr Schindler.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "And he kiss her.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "He kiss her, but was-- he wasn't allowed.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "He was-- some other German was watching.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 22,
      "text": "And he went to jail, I think, for a day or two-- Schindler.",
      "word_count": 13
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 23,
      "text": "He wasn't allowed to kiss.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 24,
      "text": "But she did it.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 25,
      "text": "Niusia did, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 26,
      "text": "She's now in Poland.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 27,
      "text": "She lives in Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 28,
      "text": "We visit Krakow five months-- five years ago.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 29,
      "text": "She is beautician, and she's a lovely woman.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 30,
      "text": "She married a Christian.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 31,
      "text": "She married a Catholic boy.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "So he said that they were-- they made a striped uniform for Schindler.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "How many what?",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "What I can tell you, I-- again, it's hazy.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Very hazy.",
      "word_count": 2
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "I knew that was a big car, and the Jewish people put in.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I know that there was one woman, Helen, what's her name.",
      "word_count": 11
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Helen.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "She was a maid for, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "She was in the building, but she used to be maid for Goeth.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "And he get her to Brunnlitz.",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "She was saved this way.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 9,
      "text": "And I know they disappeared.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 10,
      "text": "They left in a car, Schindler with his wife.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 11,
      "text": "And I think some Jewish, two Jewish men, as well.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 12,
      "text": "I don't know their name.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 13,
      "text": "I heard his name, but I forgotten it.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 14,
      "text": "One was Pollack.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 15,
      "text": "He was cleaning his shoes.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 16,
      "text": "He had shoes, and was in list as well.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 17,
      "text": "And then where left-- we'd been alone.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 18,
      "text": "No one was there for a day, I think.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 19,
      "text": "There was no German.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 20,
      "text": "It was no one.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 21,
      "text": "We were-- we didn't looking.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 22,
      "text": "No one from-- [INAUDIBLE] no one from Brunnlitz, from the country come closer to the camp side where we were.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 23,
      "text": "[PAUSES FOR 3 SECONDS] And-- ah, yes.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 24,
      "text": "And before he left, this Schindler, he make a speech.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 25,
      "text": "He call us all.",
      "word_count": 4
    }
  ],
