  "sentences_input": [
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "A man's voice said-- croaky, old man's voice-- please.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "Try and get up.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "So-- [LAUGHS] --when you are subjected to [NON-ENGLISH], are you going to answer the call of a nice, gentle old man?",
      "word_count": 21
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "Get stuffed.",
      "word_count": 2
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 7,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "We turned around.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And-- [LAUGHS] --we thought, what is this?",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And he said, the SS has left.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "They took the kapos with them.",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "That is the infamy of the Polish kapos.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "They all went with the henchmen together.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "They took them with them for the services done to them.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "And they took them.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "And we were alone.",
      "word_count": 4
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "Leave the gentleman a--",
      "word_count": 4
    }
  ],
