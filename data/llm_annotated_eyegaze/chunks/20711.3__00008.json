{
  "stem": "20711.3",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 7,
      "text": "Immediately, I pulled my money out-- more what I was supposed to pay for the services.",
      "word_count": 16
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 8,
      "text": "And I said to the lady, I want to leave right now.",
      "word_count": 12
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 9,
      "text": "She knew it must have been trouble, and she was sensitive enough to cooperate.",
      "word_count": 14
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 10,
      "text": "And she took the iron out of my hair, and she let me go.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "So by the time the police came back, I was no longer in that beauty shop.",
      "word_count": 16
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 1,
      "text": "I was afraid to go out to the street.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 2,
      "text": "I didn't which way he went.",
      "word_count": 6
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "I didn't know which way I can run away.",
      "word_count": 9
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "So I went through the backyard, and I ran through everybody's backyard to reach the villa I was staying and to go back to my mom.",
      "word_count": 26
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And when I got close to the villa, I saw the other gendarme was guarding my mom.",
      "word_count": 17
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 6,
      "text": "And there I was sitting under the tree.",
      "word_count": 8
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 7,
      "text": "And it took me time to make up my mind what should I do.",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 8,
      "text": "Should I stay in hiding?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 9,
      "text": "Or should I walk up?",
      "word_count": 5
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 10,
      "text": "I was afraid they would beat my mom, to try to beat out of her where is your daughter?",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 11,
      "text": "She must have told them I am in a beauty shop, and that's how they came.",
      "word_count": 16
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Now the other one coming back saying I am no longer there.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "They're just going to beat my mother till she tells where my friends are or who is my friends.",
      "word_count": 19
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I didn't know what to do.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "I don't remember how long I was sitting there.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "But once I heard my mom was crying and there were some screaming, and it scared me.",
      "word_count": 17
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "And I decided whatever happened, we do it together.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "And I walked up to my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "By that time, the other gendarme came back and was already reporting me missing.",
      "word_count": 14
    }
  ],
