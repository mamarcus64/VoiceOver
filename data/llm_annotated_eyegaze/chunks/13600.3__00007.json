{
  "stem": "13600.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "For one period, the source of my income was, I used to come to the post office and write letters for illiterate Russians who wanted to write to their sons on the front.",
      "word_count": 33
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "There were women who couldn't write Russian.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "And I used to sit, write for them the letters.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And I used to get an onion, a couple of potatoes, a piece of bread, you know.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "[INAUDIBLE] And that was--",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "Additional food.",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "And then I came to hospital.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "And in the hospital, I had [PAUSES FOR 3 SECONDS] the bare minimum.",
      "word_count": 13
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "They didn't feed like here in a hospital.",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "You got a soup that was made of water and salt and some leaves, and the bread ration, which was the same.",
      "word_count": 22
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "That was quite a long time.",
      "word_count": 6
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "Six months.",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Approximately six months.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "And when I came out of hospital, I found a new vocation.",
      "word_count": 12
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "I started polishing shoes, boots.",
      "word_count": 5
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "My clients were the local people, the Asians who were living on-- on the collective villages, you know.",
      "word_count": 18
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "And these were mostly communist party members.",
      "word_count": 7
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "They used to come for gatherings.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 4,
      "text": "And it was a dusty place.",
      "word_count": 6
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 5,
      "text": "They used to come.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "A shoe polishing outfit.",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "And they used to call me professor, because I had glasses.",
      "word_count": 11
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "That was a sign.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 0,
      "text": "The shoe polishing professor.",
      "word_count": 4
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 1,
      "text": "And this was already-- this time started already to get easier.",
      "word_count": 11
    },
    {
      "segment_idx": 78,
      "sentence_idx_in_seg": 2,
      "text": "Because with-- with the time-- as a matter of fact, by the beginning of 1944, the situation got easier with food.",
      "word_count": 21
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 0,
      "text": "Increased, so the food situation was-- why, I don't know.",
      "word_count": 10
    },
    {
      "segment_idx": 79,
      "sentence_idx_in_seg": 1,
      "text": "But--",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 80,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 1,
      "text": "Weak, but healthy.",
      "word_count": 3
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 2,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 3,
      "text": "I came out and started working in this shoe business, which was.",
      "word_count": 12
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "This was additional.",
      "word_count": 3
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "The watchman was at night, and this was the day.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    }
  ],
