{
  "stem": "19242.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 2,
      "text": "And they didn't maybe want to give it to you.",
      "word_count": 10
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 3,
      "text": "But they put on the potatoes outside.",
      "word_count": 7
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 4,
      "text": "So if something happened, they're going to tell, you know, the German catch them?",
      "word_count": 14
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 5,
      "text": "They're going to tell, he had the potatoes laid out for the-- for the animals to feed them.",
      "word_count": 18
    },
    {
      "segment_idx": 102,
      "sentence_idx_in_seg": 6,
      "text": "And, well, in the beginning, it was very tough till we got organized.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 0,
      "text": "In a bunker.",
      "word_count": 3
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 1,
      "text": "And they built a big bunker and dug up a lot of dirt.",
      "word_count": 13
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 2,
      "text": "And you were-- you know?",
      "word_count": 5
    },
    {
      "segment_idx": 103,
      "sentence_idx_in_seg": 3,
      "text": "It wasn't bad under there.",
      "word_count": 5
    },
    {
      "segment_idx": 104,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 0,
      "text": "Are you kidding?",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 1,
      "text": "It just a-- a double or triple bed, whatever you could arrange it.",
      "word_count": 13
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 2,
      "text": "Wouldn't be anything.",
      "word_count": 3
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 3,
      "text": "But I don't know what they put on the top because it didn't leak, though.",
      "word_count": 15
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 4,
      "text": "The water didn't come through.",
      "word_count": 5
    },
    {
      "segment_idx": 105,
      "sentence_idx_in_seg": 5,
      "text": "I don't know what [INAUDIBLE].",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 0,
      "text": "There were-- they had three of them, not all in this, in the same area.",
      "word_count": 15
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 1,
      "text": "But one didn't have a connection with the other.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 2,
      "text": "Let's see, I think about 25, 30 people in each, in each bunker.",
      "word_count": 13
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 3,
      "text": "Everybody-- but there was nothing, was no-- I think they had one table, yeah, one table.",
      "word_count": 16
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 4,
      "text": "And there's no bedding, if that's what you mean.",
      "word_count": 9
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 5,
      "text": "You sleep with your clothes.",
      "word_count": 5
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 6,
      "text": "You have to sleep.",
      "word_count": 4
    },
    {
      "segment_idx": 106,
      "sentence_idx_in_seg": 7,
      "text": "[BACKGROUND NOISE] Uh-oh.",
      "word_count": 3
    }
  ],
