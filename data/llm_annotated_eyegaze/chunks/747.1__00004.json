{
  "stem": "747.1",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "Every Thursday night, it was-- and we had a beautiful park in the middle of town, and there was a band playing-- so we used to go to walk with my friends and enjoy the music.",
      "word_count": 36
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "Occasionally, a theater group came to town.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "And we had a steady movie theater.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "We had to get permission from the principal to go to the movie.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "Books, mainly.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 15,
      "text": "And then we got together with friends, and we walked.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 16,
      "text": "We lived in a foot of a big mountain.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 17,
      "text": "And that was the most pleasure-- pleasant experience, to go up in the mountains and pick flowers, and just walk around.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 18,
      "text": "That was the summertime.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 19,
      "text": "We had no-- anything like summer camp.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 20,
      "text": "When we got restless, my father just put us on the train-- when we were older-- and sent us to Grandpa's.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 21,
      "text": "And we spent one summer at one grandparent's home, who lived in another town.",
      "word_count": 14
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 22,
      "text": "And then by the other grandparents'.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 23,
      "text": "And there we met all the cousins, and we had a great time, just to be together with them.",
      "word_count": 19
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 24,
      "text": "Our needs-- I mean, we didn't know that we missed anything.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 25,
      "text": "We had a happy-- quite happy, contented life.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 26,
      "text": "My father made a comfortable living, and my mother was a good homemaker, and we were well fed, had good friends.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 27,
      "text": "And that was it.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "It wasn't too-- too large, but it was a very close, close-knit.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "And we knew everyone.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "If there was a wedding, or it was a sad occasion, everybody was involved.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "So it was not too large-- I mean, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "About 10,000.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "It had the biggest chocolate-- sugar chocolate factory, but it belonged to the-- it was government-sponsored.",
      "word_count": 16
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "And that was the biggest sugar factory in Hungary.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 3,
      "text": "So it was quite a large population of workers-- worked.",
      "word_count": 10
    }
  ],
