{
  "stem": "3449.3",
  "chunk_idx": 11,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 0,
      "text": "No, because even the farmers, they had a radio that half the time it didn't work, and how far did it carry, you know?",
      "word_count": 24
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 1,
      "text": "And that was the problem, rumor of rumor.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "Well, I heard-- I heard that the Russians starting to beat back the Germans.",
      "word_count": 14
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "We heard.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "We don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "Somebody told them that somebody said that somebody mentioned, you know?",
      "word_count": 11
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "So never any concrete news from--",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "And that was the scary part.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "We didn't know how long.",
      "word_count": 5
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "And that's why the farmer, the Czech person, he-- he didn't know how long.",
      "word_count": 14
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "How long.",
      "word_count": 2
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 5,
      "text": "And that was it was the problem.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 6,
      "text": "Two months, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 7,
      "text": "Three months, OK.",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 8,
      "text": "But how long?",
      "word_count": 3
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 9,
      "text": "And every time they couldn't sleep at night [INAUDIBLE].",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 10,
      "text": "The little guy, they had a little guy there of six years old.",
      "word_count": 13
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 11,
      "text": "He didn't know we were there.",
      "word_count": 6
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 12,
      "text": "Every time they send us food, they made sure that they kept him busy, kept him in the house.",
      "word_count": 19
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 13,
      "text": "And that went on for nine months, never knew.",
      "word_count": 9
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We wore, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "Oh yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 3,
      "text": "We wore the yellow stars.",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "No point in it.",
      "word_count": 4
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "In our situation no point.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "No, in the ghetto-- oh yeah, there were some people that tried.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "They tried. they live with a Polish family, and they said that this is my cousin, come-- came from [NON-ENGLISH].",
      "word_count": 20
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "You know what I mean.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "But that was very unique, very little.",
      "word_count": 7
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "My uncle did, as a matter of fact, my-- my mother's brother.",
      "word_count": 12
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "Most of the time he hid out with some Polish friend that he went to school when he was a little boy-- one of them especially to cut papers for him.",
      "word_count": 31
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 6,
      "text": "And he kept him.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 7,
      "text": "He was on the-- on the Polish papers.",
      "word_count": 8
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Back ahead where I'm still--",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "A manger?",
      "word_count": 2
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "I'm sorry?",
      "word_count": 2
    }
  ],
