  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "We got a radio, but we didn't work with the radio.",
      "word_count": 11
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 1,
      "text": "We didn't tie up the radio at all.",
      "word_count": 8
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 2,
      "text": "The only thing when we need to have some news, in the market, in [? central ?] market from the city, he was advertising, and he was telling over the microphone the situation, which it was in Warsaw, it was here, it was there.",
      "word_count": 44
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Before.",
      "word_count": 1
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "During--",
      "word_count": 1
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Before 1939.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "I saw several movies.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "My parents didn't, because normally, very, very religious people don't go to movies.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "And I was with the maid several times to see Jewish movies.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "She didn't understand, but I-- I was.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "I saw-- I don't remember what kind of movies, but it was nice-- nice-- nice movies.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "Nice, Jewish movies made-- made in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "Poland has got 3 and 1/2 million Jews, and most of the Jews was religious, because the-- the atmosphere from the country in the-- in the bringing up the religion was religious people.",
      "word_count": 33
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "You have got plenty of rabbis, big ones, Bobov rabbi, Belz rabbi, all kind of rabbis.",
      "word_count": 16
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "Each congregation was for himself.",
      "word_count": 5
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "It was-- it was a good life, a very good life.",
      "word_count": 11
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Simple and good life.",
      "word_count": 4
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "They came to Oswiecim, but whenever I've got time or I can get away from my house, I-- I-- I saw it.",
      "word_count": 22
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "In this particular time, it cost 50 [? groszy-- ?] 50-- 50-- a zloty-- 50 [? groszy ?] is a-- is a half a zloty.",
      "word_count": 25
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "Five zloty was a dollar.",
      "word_count": 5
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "'Dzigan and Schumaker' was the two biggest comics not only in Poland, but in all over the world. 'Dzigan and Schumaker' was very famous, and I don't remember the rest of them.",
      "word_count": 32
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 1,
      "text": "I-- I remember, but I couldn't remember now.",
      "word_count": 8
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Poland was very big anti-Semitism.",
      "word_count": 5
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 1,
      "text": "I find in the school, in the [?",
      "word_count": 8
    }
