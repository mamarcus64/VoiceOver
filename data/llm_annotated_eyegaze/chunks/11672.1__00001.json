{
  "stem": "11672.1",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No, my mother-- when I'm born, my mother 40 years old.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "And she gets sick of asthma.",
      "word_count": 6
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "Asthma.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "And my father's a very poor man, and they cannot afford to go somewhere.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "You understand what I mean?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "I remember [PAUSES FOR 5 SECONDS] a lot of days I get up in the morning, no bread.",
      "word_count": 18
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[PAUSES FOR 5 SECONDS] Now, my older sister had five sons-- the older sister.",
      "word_count": 14
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "And she moved to Warsaw in 1930.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "She moved to Warsaw with her husband, with their five sons.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "The other sister lived together with my mother and father and with me.",
      "word_count": 13
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "And she have a twin, a boy and a girl.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "And then, by Hitler, she born a other baby, a-- a son.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "When I'm not in the home, I'm in Russia at this time.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "[PAUSES FOR 6 SECONDS] What I can tell you-- my brother-in-law was live together with-- with my parents, and worked with my father to get a tailor.",
      "word_count": 27
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "No, work for somebody, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "And my father work only three months in the year.",
      "word_count": 10
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "That's it.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "In the season.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "In the season, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Tailor.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "This is he worked for the stores what saved clothes for wintertime and for spring.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Summer time, nothing to do.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Very orthodox.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Kosher-- this is normal.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "My father has the special uniform.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "A special black suit with a special hat.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "My mother wear a-- a wig, a sheitel.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Jewish--",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "I saw her, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "Natural, I saw her.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I'm the son.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "I can see.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "No, she had blonde hair.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "She's a very tall woman.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "I'm very happy my father is five foot, a little man and skinny-- a very skinny man.",
      "word_count": 17
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "And my mother is tall and the-- no.",
      "word_count": 8
    }
  ],
