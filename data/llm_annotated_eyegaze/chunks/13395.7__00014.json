  "elapsed_s": 2.1,
  "sentences_input": [
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "And sewing saved my life in camp as well.",
      "word_count": 9
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Because I was-- would repair things for the girls when they needed something changed or sewn or made from two blouses, one blouse, and for a piece of bread.",
      "word_count": 29
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "And then I shared it with my sister and with my mother.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "And we always had a little bit of bread, a little more bread than somebody else, because of my sewing.",
      "word_count": 20
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "And in Israel, I was working as a-- in a-- in a couturiere's very elegant place.",
      "word_count": 16
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 6,
      "text": "And my husband was a carpenter, worked as a carpenter.",
      "word_count": 10
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 7,
      "text": "I became pregnant.",
      "word_count": 3
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 8,
      "text": "I was so worried about the Arabs wanting to throw us into the ocean.",
      "word_count": 14
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 9,
      "text": "I felt I paid my dues.",
      "word_count": 6
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 10,
      "text": "I wanted to live in a country in freedom.",
      "word_count": 9
    }
  ],
