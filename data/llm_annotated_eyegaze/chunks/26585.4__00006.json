{
  "stem": "26585.4",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.7,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "They had a room in the back of the house where they kept their library.",
      "word_count": 15
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "And you said, good morning, and, yeah.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "And one day, I heard my mother say to them, what's the matter?",
      "word_count": 13
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "You look like Germany has lost the war?",
      "word_count": 8
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "And he said, no, that's not it.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "But yesterday, he said, I don't think I'll ever sleep again.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "We had to go to a village-- and he mentioned the name of the village.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "There was not a man left in the village.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 6,
      "text": "They were all with the Partisans.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 7,
      "text": "They rounded up all the women and children, and we had to round up all the women and children, and put them in the church, barricaded the church, and then lit it on all four ends.",
      "word_count": 36
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 8,
      "text": "And he said, and we had to stand there and watch it and smell it.",
      "word_count": 15
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 9,
      "text": "He said, how can I go home and have children?",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Well, anyhow, this was everyday occurrences.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "So my mother spent the night in [?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "Mitrovica ?] with the driver of Major [?",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "Rank ?].",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And the next morning-- in the meantime, she found out-- she couldn't get to him.",
      "word_count": 15
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "In the meantime, she found out that they were to be shot.",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "They were leading them up that little hill and my mother said, where is-- which one is Tomic, because there were a lot of uniforms standing there.",
      "word_count": 27
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 7,
      "text": "And somebody pointed out, this is him.",
      "word_count": 7
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 8,
      "text": "My mother didn't speak Serbian.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 9,
      "text": "And that dumb ox didn't, of course, speak any other language.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 10,
      "text": "She went over to him and she said, [NON ENGLISH].",
      "word_count": 10
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 11,
      "text": "And she said, you know, you do things.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 12,
      "text": "You don't plan to do things.",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 13,
      "text": "There are so many things, they just come over you and you do.",
      "word_count": 13
    }
  ],
