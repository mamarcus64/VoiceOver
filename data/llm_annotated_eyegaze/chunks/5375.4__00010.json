{
  "stem": "5375.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "There is nobody.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "She told me that in Auschwitz, she was chosen to the right, and the rest were all going to the left.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "So whoever went to the left went straight to the gas chambers, and that is the finale.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "So one morning, I'm going to bring her home.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "I'm supposed to bring her into the camp already, because she was already recuperating and everything was all right.",
      "word_count": 19
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "I didn't see her.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "She wasn't already in.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 11,
      "text": "Her next bed, a friend of hers tells me she left this morning, 5 o'clock.",
      "word_count": 15
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 12,
      "text": "I says, where to?",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 13,
      "text": "She went away.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 14,
      "text": "They're supposed to be her husband.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "I says, I never knew that she was married.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "And she never told me.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I used to go to the hospital every day to see her, and I was a nobody.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And she didn't tell me.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "And she didn't want to go home.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "She said no, no, no, there is nobody, nobody, nobody.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "We have to go somewhere else.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "This godforsaken country, we don't want to go back.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "She disappeared, because she was afraid that I'm going to force her to come home.",
      "word_count": 15
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "I went.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "On the way, I found the tracks where she was going, but I didn't know her married name.",
      "word_count": 18
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "Wherever I came, they asked me what is his name.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "In Europe, you cannot go on your maiden name.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "Everything goes under my husband's name.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "Guttman-- oh, that were if you were a girl, so you went on your family name.",
      "word_count": 16
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "The end of the story was I came to south of France, Vichy.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 17,
      "text": "They told me that there is a camp where they're going to America.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 18,
      "text": "I stayed there for about two weeks.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 19,
      "text": "And nothing doing.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 20,
      "text": "I didn't see her.",
      "word_count": 4
    }
  ],
