  "sentences_input": [
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And I came to United States-- everything I looked at, it was, was great.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "I loved everything.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "Especially when I came to New York, the first six months before we move to Vineland, everything was so great.",
      "word_count": 20
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "Everything was good.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "I loved it.",
      "word_count": 3
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 3 SECONDS] And I still love it.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Life has been good to us.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We are very happy.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "We have a nice-- we have a nice family.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We're well-to-do, we're well off, and we are very happy, that's the main thing.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "And we survived.",
      "word_count": 3
    },
    {
