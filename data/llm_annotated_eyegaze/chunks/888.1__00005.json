{
  "stem": "888.1",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.8,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I was the second, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Well, the family was-- you know, I mean, I remember most of their births, you know?",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 1,
      "text": "My brother and I and my two sisters were still born on the-- no.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 2,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 3,
      "text": "I think we were born yet in the small town of Csaholc, you know?",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 4,
      "text": "And the rest of the three children were born already in Satmar.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "They were all born at home.",
      "word_count": 6
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I remember.",
      "word_count": 3
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I don't remember my, my sister's birth-- the first one, my first sister.",
      "word_count": 15
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 2,
      "text": "But my second sister I remember, you know--",
      "word_count": 8
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Well, I remember the time that, you know, that she was born, you know, not really too many particular-- I mean, too many details.",
      "word_count": 24
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "I mean, I wasn't by the actual birth, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 2,
      "text": "I didn't attend the birth, you know.",
      "word_count": 7
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 3,
      "text": "But I remember, you know, the event, you know, that she was-- you know, she was born.",
      "word_count": 17
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 4,
      "text": "And yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 1,
      "text": "Well, we all-- of course, you know, let's say breakfast.",
      "word_count": 10
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 2,
      "text": "You know, my mother used to fuss around, you know, about the girls, and us, you know, when we were smaller.",
      "word_count": 21
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 3,
      "text": "And you know, send us off to school, give us breakfast.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 4,
      "text": "And you know, I mean, it was an apartment.",
      "word_count": 9
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 5,
      "text": "You know, we had an apartment over there.",
      "word_count": 8
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 6,
      "text": "And the kitchen, everything-- actually, everything mostly was conducted in the kitchen.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 7,
      "text": "And then there was a little, small little foyer or a den.",
      "word_count": 12
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 8,
      "text": "And that's where things happened.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 9,
      "text": "And-- but yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 10,
      "text": "Well, everything-- you know, I mean-- and then, of course, lunch.",
      "word_count": 11
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 11,
      "text": "Lunch was-- everybody was home for lunch.",
      "word_count": 7
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 12,
      "text": "And sometimes, of course, you know, there were certain days of school where they kept us a little longer.",
      "word_count": 19
    }
  ],
