  "sentences_input": [
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 11,
      "text": "It was-- first of all, Jewish youth, you can't compare American Jewish youth, or American-- or Jewish youth in any country, except maybe Israel.",
      "word_count": 24
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 12,
      "text": "The Jewish youth is organized.",
      "word_count": 5
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 13,
      "text": "Every Jewish kid belong to some kind of a Jewish youth organization.",
      "word_count": 12
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 0,
      "text": "Is it left or right or center?",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 1,
      "text": "But they belong.",
      "word_count": 3
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 2,
      "text": "Every Friday night, we could go in.",
      "word_count": 7
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 3,
      "text": "I remember a street in the strictly Jewish neighborhood, [INAUDIBLE], and the building was 14.",
      "word_count": 15
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "You found all organizations at one building.",
      "word_count": 7
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "The Borhov youth, the party Zion, the left, the right party Zion, the Betar, the Hashomer Hatzair.",
      "word_count": 17
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "Every in that building, we were going to each other to interrupt.",
      "word_count": 12
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 2,
      "text": "It was we had what to do with ourselves.",
      "word_count": 9
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 3,
      "text": "We were not engaged in a hoo ha.",
      "word_count": 8
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 4,
      "text": "We were-- they were really had a dream.",
      "word_count": 8
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "It was at the-- the famous Jewish theater, the [HEBREW] Theater or [HEBREW] Theater.",
      "word_count": 14
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "Then it was the [HEBREW].",
      "word_count": 5
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Then it was a [HEBREW] theater.",
      "word_count": 6
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "There were plenty of Jewish-- of Jewish entertainment.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "Jewish restaurants.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 5,
      "text": "I remember we're going at-- sometimes Saturday for a treat with my father to Gatner's restaurant to have [INAUDIBLE].",
      "word_count": 19
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 6,
      "text": "It was on [INAUDIBLE] right by the synagogue.",
      "word_count": 8
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 7,
      "text": "[PAUSES FOR 4 SECONDS] That's where I first I made [INAUDIBLE], was at Gatner's restaurant.",
      "word_count": 15
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 8,
      "text": "Then I had my grandparents.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "Jewish life in Warsaw was something impossible to grasp.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "It was a rich life.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "And first of all, how beautifully they were organized.",
      "word_count": 9
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 2,
      "text": "The social welfare.",
      "word_count": 3
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 3,
      "text": "We had-- you name it.",
      "word_count": 5
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 4,
      "text": "For every purpose, we had an organization.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "Just there.",
      "word_count": 2
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "One of the best hospital, which later was taken away by the city because they envied us, that we have one of the best school for nurses, and the best doctors.",
      "word_count": 31
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "Doctors who got a world-- were world-renowned.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 4,
      "text": "That Dr.",
      "word_count": 2
    }
  ],
