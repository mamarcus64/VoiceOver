{
  "stem": "322.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.6,
  "sentences_input": [
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 16,
      "text": "And then in 1955 or '56 I got a job at the United, United Nations.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 17,
      "text": "I worked as a temporary, you know, employee, but I loved it.",
      "word_count": 12
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 18,
      "text": "I mean, you know, I could have worked for the United Nations maybe forever [PAUSES FOR 3 SECONDS] for nothing.",
      "word_count": 20
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "An uncle of mine, in 1957, [PAUSES FOR 4 SECONDS] who wasn't, wasn't married-- he was 48 years old, lived in Connecticut.",
      "word_count": 22
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "And he got a massive heart attack.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "And he asked me to come to assist him, to help him.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 3,
      "text": "He had a big business there and what have you.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 4,
      "text": "But he died very shortly after.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 5,
      "text": "He died, and he left a sizable estate.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 6,
      "text": "And so between myself-- because I took my mother's share-- the uncle that met me at the, at the boat, and another uncle that I had that I didn't know who was living in South America, the three of us inherited his estate.",
      "word_count": 43
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 7,
      "text": "And from then on, I decided that New York is not a place where you can make money.",
      "word_count": 18
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 8,
      "text": "You can spend a lot of money there.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 9,
      "text": "And I heard of a lot of survivors being on, on the West Coast.",
      "word_count": 14
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 10,
      "text": "And I decided to come out to the West Coast.",
      "word_count": 10
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 11,
      "text": "And I was very well received here.",
      "word_count": 7
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 12,
      "text": "I didn't do anything for a whole year.",
      "word_count": 8
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 13,
      "text": "I did have some money, and I didn't want to sponge it.",
      "word_count": 12
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 14,
      "text": "I didn't want to get rid of it.",
      "word_count": 8
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "1961.",
      "word_count": 1
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "I held onto the few dollars that I still held, had left, because I was married, married, and came--",
      "word_count": 19
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "Right then, in, you know--",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes, I got married in New York.",
      "word_count": 7
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "And my wife and I, since my wife is an American born and I wanted her to know what she's going to have to live with, so--",
      "word_count": 27
    }
  ],
