      "text": "I went to church with her.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 7,
      "text": "I did everything that what they did and I walked there.",
      "word_count": 11
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 8,
      "text": "There are so many stories, so many.",
