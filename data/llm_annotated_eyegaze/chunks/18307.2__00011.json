    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 9,
      "text": "So many.",
      "word_count": 2
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 10,
      "text": "But we are the lucky ones.",
      "word_count": 6
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 11,
      "text": "We are the lucky ones.",
      "word_count": 5
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 12,
      "text": "[PAUSES FOR 5 SECONDS]",
