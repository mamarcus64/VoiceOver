{
  "stem": "2830.1",
  "chunk_idx": 0,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.2,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 0,
      "text": "Well-- [LAUGHTER]",
      "word_count": 2
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "It's hot.",
      "word_count": 2
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "There's things about Florida that I like and things that I don't.",
      "word_count": 12
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "The things that I like is I can wear shorts all the time-- [LAUGHS]",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Comfortable clothes.",
      "word_count": 2
    },
    {
      "segment_idx": 5,
      "sentence_idx_in_seg": 0,
      "text": "And-- am I on or what?",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 0,
      "text": "Florida is-- if I wouldn't be allergic to the sun and bug bites, then Florida is a excellent place.",
      "word_count": 19
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "You and my wife-- the bugs and the sun.",
      "word_count": 9
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "The bugs and the sun.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "I have to be protected.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "Because I'm allergic to the sun.",
      "word_count": 6
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 0,
      "text": "But it's a nice life in Florida.",
      "word_count": 7
    },
    {
      "segment_idx": 11,
      "sentence_idx_in_seg": 1,
      "text": "It's--",
      "word_count": 1
    },
    {
      "segment_idx": 12,
      "sentence_idx_in_seg": 0,
      "text": "I'll be nine years in September.",
      "word_count": 6
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "So I-- I enjoyed when my husband worked, because it was a normal life.",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "He went to work, and I did my thing.",
      "word_count": 9
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "Good morning, Lola.",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "Good morning, Chaim.",
      "word_count": 3
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "I was born in Lublin, Poland.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "September the 23rd, 1925.",
      "word_count": 4
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "My mother and my father-- we were sort of religious-- not-- not real Hasidic--",
      "word_count": 14
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 0,
      "text": "--but Orthodox--",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "--house.",
      "word_count": 1
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "I was brought up.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "I went to a Bais Yaakov.",
      "word_count": 6
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "And I had-- we were four sisters and three brothers.",
      "word_count": 10
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "I was the youngest.",
      "word_count": 4
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 5,
      "text": "Most of them were married when I, you know, grew up.",
      "word_count": 11
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "And they had children on their own.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "They weren't living in the house.",
      "word_count": 6
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "My mother, and my father, and one sister.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "She survived.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "Her name is Gitel.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "And she lives in the States on Staten Island.",
      "word_count": 9
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "As a young girl, it was difficult for me to go to a public school, because of my name.",
      "word_count": 19
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Rabinowitz.",
      "word_count": 1
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "And the children, you know, the gentile children, they were very cruel.",
      "word_count": 12
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "They call you names, things like this.",
      "word_count": 7
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 2,
      "text": "In the beginning, I had gentile friends, because of the neighbors--",
      "word_count": 11
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "--very close friends.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "And-- but then, when it starts getting worse, near the, you know--",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Before 1939.",
      "word_count": 2
    }
  ],
