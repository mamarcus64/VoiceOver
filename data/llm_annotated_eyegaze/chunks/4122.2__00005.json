{
  "stem": "4122.2",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.4,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "And then after this aksia, they build the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "The ghetto was--",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "The life in the ghetto was-- it was boarded all around with boards and wires, and I was on the end with my mother when we, when we had to come from there from our city.",
      "word_count": 36
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "So they gave us a room in the ghetto where five families were living in one small room.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "Everybody had a bed, and this was where we had to live.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I lived then with my mother.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "There was another family, which, which I recall as only a sister and a brother.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "And they had three children-- three small children, like, three, five, and seven.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And they put-- there was a box.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "The two children were sleeping in a box because at this time, when we were in the ghetto, an epidemic started-- the typhus.",
      "word_count": 23
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "And his brother was sick with typhus, so she separated the children.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "They slept two in a box and one on top of the box.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "It has a door, so she put a pull, a pull, that they shall have air-- like slender.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "There was another child, and she was sitting every night and watching the brother and those three children of hers.",
      "word_count": 20
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "On every, in every bed was some, another family.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "And the life in ghetto was so terrible.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "We were at night, every time, building some different bunkers.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 16,
      "text": "And we were on posts watching if an aksia doesn't start again.",
      "word_count": 12
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 17,
      "text": "We were hungry.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 18,
      "text": "We didn't have food.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I was with, just with my mother.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "There was another cousin.",
      "word_count": 4
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Another cousin.",
      "word_count": 2
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "There were thousands of people from all around, yeah.",
      "word_count": 9
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "It was, like, a few blocks.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "Let's say about three blocks surrounded with board and this.",
      "word_count": 10
    }
  ],
