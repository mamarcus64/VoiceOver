{
  "stem": "9702.2",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 7.3,
  "sentences_input": [
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 2,
      "text": "Meantime, my late husband, who was Morris Resnick, he was hiding in another town, another village, just over-- it's like, when one village, and then the school, and then was another village.",
      "word_count": 32
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Morris Resnick.",
      "word_count": 2
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "And he was hiding with his brother in the place.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "And he used to go every middle of the night, go out and look for Jews, because you heard some people-- there is Jews.",
      "word_count": 24
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "And where he stayed-- that was an aunt to the woman that where we stayed.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And she told her aunt that we are with her.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "Her aunt didn't tell her.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "The other one didn't tell anybody that she  has anybody.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "In the middle of the night, my late husband came.",
      "word_count": 10
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 9,
      "text": "The first time after what must have been about almost a year that we didn't see a Jew.",
      "word_count": 18
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, from the city, yeah.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "From the city, from the Sienkiewiczowka, from the ghetto.",
      "word_count": 9
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 1,
      "text": "I knew him from the ghetto, actually.",
      "word_count": 7
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 2,
      "text": "In fact, he had a brother, an older brother, in another town, [INAUDIBLE], and his daughter used to come for vacation to, to-- my late husband was married.",
      "word_count": 28
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 3,
      "text": "He had a wife and a baby for a few months.",
      "word_count": 11
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 4,
      "text": "And she used to come.",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 5,
      "text": "And this girl was a friend of mine.",
      "word_count": 8
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 6,
      "text": "His niece was my friend.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, she was already dead.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "She was killed also in the ghetto with a baby.",
      "word_count": 10
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "Well, we knew through this woman.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "That he-- that aunt told him.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "How was it?",
      "word_count": 3
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 2,
      "text": "Yeah, she told him most probably that we are down there.",
      "word_count": 11
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 3,
      "text": "So he came to see us.",
      "word_count": 6
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 4,
      "text": "He knew exactly--",
      "word_count": 3
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 0,
      "text": "No, just a few hours-- an hour or two.",
      "word_count": 9
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "And we went back to his hiding place.",
      "word_count": 8
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "And from then on, we were, like, in touch a little bit.",
      "word_count": 12
    }
  ],
