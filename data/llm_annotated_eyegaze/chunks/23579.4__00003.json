  "sentences_input": [
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "What is it?",
      "word_count": 3
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "He said, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "They took away all the food, and took away all the food.",
      "word_count": 12
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 7,
      "text": "And they took away all the [NON-ENGLISH], no?",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "The ammunition.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "And what now?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "So he says, what now?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "You give away the ammunition, and the bread, and everything?",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 4,
      "text": "You are partisans?",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 5,
      "text": "You too partisans.",
      "word_count": 3
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "What the matter with you?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "You give away your life?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "To whom did you give?",
      "word_count": 5
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 9,
      "text": "He said, they say, they're all in the house.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 10,
      "text": "And this was Zusia's very good friends.",
      "word_count": 7
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 11,
      "text": "The partisan, [PAUSES FOR 4 SECONDS] a Russian partisan.",
      "word_count": 9
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 12,
      "text": "Wait, I will tell you what's his name.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 13,
      "text": "Panchenko.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 14,
      "text": "Panchenko.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 15,
      "text": "And they were sitting.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 16,
      "text": "They're drinking.",
      "word_count": 2
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 17,
      "text": "And they had all the ammunition from them.",
      "word_count": 8
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 18,
      "text": "And nothing.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Zusia came in.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "I didn't go.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "I was with the others outside.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And he said to him, what did you do with my partisans?",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "He said, that's not your partisans.",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "That's from the Naliboki.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "He said, mine too.",
      "word_count": 4
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "What did you?",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "We took away.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 9,
      "text": "Because they robbed too much the paisanos.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 10,
      "text": "What?",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 11,
      "text": "You took away from my partisans?",
      "word_count": 6
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 12,
      "text": "You took away the ammunition and everything?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 13,
      "text": "Who gave it to you the right?",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 14,
      "text": "So Panchenko took right away the [NON-ENGLISH].",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 15,
      "text": "You know what is [NON-ENGLISH]?",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 16,
      "text": "This is something what they make about 60 rounds, with a round.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 17,
      "text": "Is that the machine gun?",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "A machine gun.",
      "word_count": 3
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "And he point there in a machine gun to Zusia.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "So we had-- in [NON-ENGLISH] we had a Russian commander.",
      "word_count": 10
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I forgot his name.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "And he clubbed the-- and this stopped.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 6,
      "text": "He said, listen, Panchenko.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 7,
      "text": "You better give to Alex everything if you know what's good for you.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 8,
      "text": "And in two minutes, they drank together.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 9,
      "text": "And he gave away everything.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 10,
      "text": "And he said, Zusia to him, remember we were two years very good friends.",
      "word_count": 14
    }
  ],
