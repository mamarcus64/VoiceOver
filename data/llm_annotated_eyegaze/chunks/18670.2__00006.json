{
  "stem": "18670.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "And I put it in deep and my hand came out dripping.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "And I looked at the priest and said, by god, he knows I'm not a Christian.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 21,
      "text": "He knows I'm a Jew.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 22,
      "text": "Didn't stop us.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 23,
      "text": "We got into the pew.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 24,
      "text": "When they knelt down, we knelt down.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 25,
      "text": "Then after dark a cute little blonde came in, Gentile, Christian girl.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 26,
      "text": "And she knew, because we were the only two left in the church.",
      "word_count": 13
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 27,
      "text": "They took us to their hotel-- they had a small hotel-- into the kitchen.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 28,
      "text": "They fed us.",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 29,
      "text": "And we sat there 'til about 11 o'clock at night.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 30,
      "text": "Then she told us she's going to take us across the fields.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 31,
      "text": "And--",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "She's going to take us across the fields.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And I don't remember what town she said.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "That's where we going to meet the bus.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "It's going to be a couple of hours we're going to walk during the night across the fields and they're going to take us to a bus.",
      "word_count": 27
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "And she's going to get the tickets for us, put us on the bus.",
      "word_count": 14
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 6,
      "text": "She's going to be with us on the bus 'til the next town.",
      "word_count": 13
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 7,
      "text": "We're going to get the railroad tickets and send us to Brussel. in Brussel, we have a contact.",
      "word_count": 18
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 8,
      "text": "OK?",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "So time came.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "We were walking.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "Naturally, it felt like it's endless at night, in strange country.",
      "word_count": 11
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "We got to the bus stop.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "There were big searchlights at the bus stop.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "The bus pulled up about 5 minutes, 10 minutes later.",
      "word_count": 10
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "And she said to-- spoke to the driver.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "And the driver said he had three checkups already.",
      "word_count": 9
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "He doesn't think there'd be any more checkups.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "Got on the bus.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "We walked all the way to the back.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "That's where she wanted us to sit.",
      "word_count": 7
    }
  ],
