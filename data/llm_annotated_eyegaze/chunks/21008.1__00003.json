{
  "stem": "21008.1",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 4,
      "text": "It was different later, when we moved to another place.",
      "word_count": 10
    },
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 5,
      "text": "But at that time, no, I don't think so.",
      "word_count": 9
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Yes, yes.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "This apartment building was mostly non-Jewish, so-- didn't make any difference.",
      "word_count": 11
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Nobody cared.",
      "word_count": 2
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "Everyone.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "All the kids in kindergarten were my friend.",
      "word_count": 8
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "I was invited-- and attached to that kindergarten was a girl's high school.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And the-- the senior class had to take care of the little girls in the kindergarten sometimes.",
      "word_count": 17
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "And I was invited to their homes-- very elegant homes, you know?",
      "word_count": 12
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 5,
      "text": "Nobody cared whether I was Jewish or not Jewish.",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 6,
      "text": "Nobody asked.",
      "word_count": 2
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The first thing I-- I remember was that my father was kicked out of one of his positions, and that he said we have to give up this luxury apartment.",
      "word_count": 30
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "We can't afford it.",
      "word_count": 4
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 2,
      "text": "And in 1933, we moved.",
      "word_count": 5
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 3,
      "text": "We moved to Marienfelde, into a small house, which was like little houses in-- in a row, like you find in Queens or Brooklyn.",
      "word_count": 24
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 4,
      "text": "They're private houses, but you rented them.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 5,
      "text": "It was very small and very cheap.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 6,
      "text": "And that's where we moved in '33-- in December of '33 already.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Right away, because he was-- he was representing the German textile industry.",
      "word_count": 12
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "Now, how can a Jew represent the German textile-- so he-- he was cut off right away-- right away in April, when Hitler came to power.",
      "word_count": 26
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 2,
      "text": "They kept him on for a while for other jobs, but we can talk about that.",
      "word_count": 16
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 3,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Of-- of course.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Of course, yes.",
      "word_count": 3
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 1,
      "text": "Of course, yes, my grandma lived with us always.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "I started school in April of 1934 in Marienfelde, yeah, which was also part of Berlin.",
      "word_count": 16
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "It's just a section.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "It was public school, yes.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Well, I was the only Jewish child in that school.",
      "word_count": 10
    }
  ],
