{
  "stem": "323.3",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 4,
      "text": "And then we were put into barracks-- and this is where Dieter and I were separated-- and I don't know what happened anymore, because then I got sick, and I was too-- and we were sleeping about eight to 10 people on a bunk, foot, foot, together like this.",
      "word_count": 49
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 5,
      "text": "And every morning, we got up.",
      "word_count": 6
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 6,
      "text": "And we saw who was dead, and took the dead out, and dumped them on top of the pile, and then somebody new came in.",
      "word_count": 25
    },
    {
      "segment_idx": 65,
      "sentence_idx_in_seg": 7,
      "text": "And this went on for a month, every single day.",
      "word_count": 10
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 66,
      "sentence_idx_in_seg": 1,
      "text": "They just stayed there.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 0,
      "text": "We dragged them out.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 1,
      "text": "We couldn't carry them.",
      "word_count": 4
    },
    {
      "segment_idx": 67,
      "sentence_idx_in_seg": 2,
      "text": "And then we had no food for the last two weeks at all, and no water.",
      "word_count": 16
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 0,
      "text": "Six weeks.",
      "word_count": 2
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 1,
      "text": "And-- not even.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 2,
      "text": "Probably five weeks.",
      "word_count": 3
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 3,
      "text": "And then we had no water, and I drank water from a puddle-- rain water-- and that's when I got sick.",
      "word_count": 21
    },
    {
      "segment_idx": 68,
      "sentence_idx_in_seg": 4,
      "text": "I really got really sick.",
      "word_count": 5
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 0,
      "text": "I didn't really have typhoid, but I had dysentery so badly that I couldn't-- I couldn't move anymore.",
      "word_count": 18
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 1,
      "text": "I couldn't walk anymore.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 2,
      "text": "I was completely dehydrated.",
      "word_count": 4
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 3,
      "text": "And then the-- then we heard the shooting, more, and more, and more.",
      "word_count": 13
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 4,
      "text": "And we-- we knew that the end was in sight, because the SS people were trying to put down their guns.",
      "word_count": 21
    },
    {
      "segment_idx": 69,
      "sentence_idx_in_seg": 5,
      "text": "And this woman I told you about, Bubi, put on one of our uniforms, and somebody else did--",
      "word_count": 18
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 0,
      "text": "Oh, yeah.",
      "word_count": 2
    },
    {
      "segment_idx": 70,
      "sentence_idx_in_seg": 1,
      "text": "She was with us there.",
      "word_count": 5
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "From Hamburg, with us.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "In Bergen-Belsen?",
      "word_count": 2
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "Nothing.",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "And I still crawled out of bed so every day, because I didn't want to be among the-- the dead to be dumped out on those piles.",
      "word_count": 27
    }
  ],
