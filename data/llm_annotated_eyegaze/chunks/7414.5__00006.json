{
  "stem": "7414.5",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 10.5,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 16,
      "text": "You are telling me that I remember.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 17,
      "text": "There was things that you can't erase from your mind.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "So I left and I started to walk again.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "Of course, I did not dare to ask anybody where I have to go, where is the street.",
      "word_count": 18
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "Because once you started to ask, you are suspicious.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "It means you are stranger here.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "You-- you are suspicious.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And there were many strangers then trying to get out of the ghetto and things.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "So I found the place.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "And [PAUSES FOR 3 SECONDS] everybody was at home.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "My brother was at home.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Of course, in this millions of people around, he could not see me.",
      "word_count": 13
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And he was distressed.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "He did not know if I were fine.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "But I found the place.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "I come there.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "There was the people, Mr. and Mrs.",
      "word_count": 7
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Prowiszak.",
      "word_count": 1
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "They had two small rooms and a kitchen on the fourth floor-- fourth floor in the very old part of Warsaw.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "So old that the toilet was in the yard.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You had to go the four floors down and up every time.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "The place was full of people.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 6,
      "text": "Really full.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 7,
      "text": "There was the two hosts.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 8,
      "text": "There's my sister, my brother-in-law, their daughter, a cousin, Niunka, some few other people, and my brother.",
      "word_count": 17
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 9,
      "text": "It was crowded.",
      "word_count": 3
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 10,
      "text": "And I walked in, it was-- it is.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So in meantime, we had to find a story, a new story how come that they are so interested in me, and how come that I have a child under my maiden name.",
      "word_count": 33
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "So my brother-in-law got a story together that my husband was an officer in his regiment, and we were very friendly.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "But as the-- first the Russian and then the Gestapo was looking for my husband for some other thing.",
      "word_count": 19
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I don't know.",
      "word_count": 3
    }
  ],
