    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 2,
      "text": "But for the Oppenheimer, I forgot to tell you that again with my bike, when I was at my grandparents, I went to see them in the-- in the Alps.",
      "word_count": 30
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 3,
      "text": "I was the only visitor they, they had.",
      "word_count": 8
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 4,
      "text": "And they lived in something like a barn, you know.",
      "word_count": 10
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 5,
      "text": "It still had hay in the back.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 6,
      "text": "And Mrs.",
      "word_count": 2
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 7,
      "text": "Oppenheimer looked like the typical German hausfrau.",
      "word_count": 7
    },
    {
      "segment_idx": 64,
      "sentence_idx_in_seg": 8,
      "text": "She had blonde hair in waves in a bun.",
      "word_count": 9
    }
