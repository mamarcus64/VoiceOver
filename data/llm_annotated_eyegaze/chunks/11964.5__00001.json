  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 16,
      "text": "One of the episodes I didn't describe to you that was also very devastating to me, when I was still living with my landlady, one of the things she did to compensate, as much as she could, for a lack of work-- she wanted to earn some money.",
      "word_count": 48
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "So there was no way of getting flour in Warsaw.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "Flour, plain flour.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And they said that there is enough flour in Krakow.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "So there were people who would actually, daily or nightly actually, take a night train, go to Krakow, get the flour, and the following day returned, having five pounds of flour on the rope here, five pounds of flour in the back, five pounds here, and five pounds here, and five pounds in one hand.",
      "word_count": 55
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "So she would take me with her, and she would say, you want to make yourself some money?",
      "word_count": 18
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "Come with me.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "And I you would.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "So we would bring 25 pounds of flour each trip.",
      "word_count": 10
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "And we would make quite a bit-- we would make on it.",
      "word_count": 12
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "One time when we were in Krakow, we got there in the morning, and we wouldn't leave until that evening, and we got already the flour.",
      "word_count": 26
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "And I remembered from the times that I was studying in Krakow there was a little restaurant there that served a specialty for just students.",
      "word_count": 25
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "It was Polish kielbasa with sauerkraut and potatoes.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "We call it [NON-ENGLISH] in Polish, which means fork in English.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And I said to my landlady, I said, you know what, I would like to just take off-- I knew the streets very well-- and go and have some lunch.",
      "word_count": 30
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "And I left her behind me.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "And I went there and ordered it.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "And lo and behold, two Gestapo men come up to me.",
      "word_count": 11
    }
  ],
