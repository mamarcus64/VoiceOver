{
  "stem": "15115.3",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 27,
      "text": "So I used to divide it to my brothers, because I was in-- my stomach shrunk so bad that I couldn't eat much, you know.",
      "word_count": 25
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 28,
      "text": "I was a young kid.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 29,
      "text": "But my brothers kind of, you know, they were really had appetite.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 30,
      "text": "And for a long time, the blockalteste give me a lot of food, and I was giving it to my brothers.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 31,
      "text": "And next thing you know, I kept going in camp, you know.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 32,
      "text": "It's routine.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 33,
      "text": "Routine, dead people coming daily.",
      "word_count": 5
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 34,
      "text": "And finally, towards I already was there a few months, I believe it was August, August of '43, a new selection.",
      "word_count": 21
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 35,
      "text": "We don't know what it is.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "So they picked my number.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "I start crying.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "I go to my kapo.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "I says, they took my number.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "I don't-- says, stupid.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "You go to Warschau.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "Go.",
      "word_count": 1
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "You know, you should go.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "No, I says, I'm good here.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "Because I was-- so-- so bad everyone else.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "And I-- I-- I was good there, so I didn't want to move.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "No, no, no, he says.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 12,
      "text": "That's where I come from.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 13,
      "text": "I am from Warschau.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 14,
      "text": "Over there there's no gas chambers.",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 15,
      "text": "He knew, you know.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 16,
      "text": "You go.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "Finally, he made me go.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "He pushed me, you know.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He said, you should go.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So OK.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "A day later, they took us and took us to Auschwitz.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "Auschwitz was like paradise compared to Birkenau.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Auschwitz only sleeping two in a bed.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "We were seven in Birkenau.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "We were there for only 48 hours.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "They give us a bath, and they give us civilian clothes.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "And they put a big red-- red paint on the back of the jacket, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "But the only thing they give us bad was wooden shoes.",
      "word_count": 11
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 12,
      "text": "Wooden-- wooden shoes.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 13,
      "text": "That was bad.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 14,
      "text": "That was really bad.",
      "word_count": 4
    }
  ],
