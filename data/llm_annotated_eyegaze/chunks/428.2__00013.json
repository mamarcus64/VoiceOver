  "model": "openai/gpt-oss-120b",
  "elapsed_s": 9.6,
  "sentences_input": [
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 0,
      "text": "The children.",
      "word_count": 2
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 1,
      "text": "Two-- two are in Poland-- yeah.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 2,
      "text": "Two are in Poland, and the one is in Canada.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 3,
      "text": "I just have-- I just have a letter from Poland from Saturday.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 4,
      "text": "If you want a letter with a picture, I could show it to you, a letter from her.",
      "word_count": 18
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 5,
      "text": "She is still in Poland.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 6,
      "text": "There used to be one was 11 years old, the other one was eight years old.",
      "word_count": 16
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 7,
      "text": "And the other one, the older one, was working already in Germany because they took the Polish girls to work-- to work to Germany on the farms.",
      "word_count": 27
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 8,
      "text": "They got it good.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 9,
      "text": "They work and they-- after the war, they came back.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 10,
      "text": "So that two girls used to go stealing from other apples and fruit, things, to bring me up there in the attic-- on the attic to eat.",
      "word_count": 27
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 11,
      "text": "And it was-- this was very nice, very nice people.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 12,
      "text": "They do everything I should be alive.",
      "word_count": 7
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 13,
      "text": "But I went-- they didn't tell me to go away.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 14,
      "text": "I went away by myself, because it's a very small town.",
      "word_count": 11
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 15,
      "text": "I know this is young children.",
      "word_count": 6
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 16,
      "text": "No matter how smart she is, she's eight years old.",
      "word_count": 10
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 17,
      "text": "She could tell somebody, [POLISH], my Polish name, [POLISH] is hiding by.",
      "word_count": 12
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 18,
      "text": "So I know if they find out, they're going to kill the whole Polish family and me.",
      "word_count": 17
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 19,
      "text": "So I went by myself.",
      "word_count": 5
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 20,
      "text": "I went to Krakow.",
      "word_count": 4
    },
    {
      "segment_idx": 49,
      "sentence_idx_in_seg": 21,
      "text": "Because I had, in this time, I know my-- my sister's husband was already in that camp in [INAUDIBLE], so I walk into that camp by myself.",
      "word_count": 27
    }
  ],
