{
  "stem": "16571.5",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.3,
  "sentences_input": [
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 16,
      "text": "And we finished up in London.",
      "word_count": 6
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 17,
      "text": "And they mostly found-- they found accommodation for us with women and kids who lost their husbands in the war, overly-- all Jewish.",
      "word_count": 23
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 18,
      "text": "The Jewish Suffragette Committee paid about three pounds a week for food, board.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 19,
      "text": "And by then, I had already been-- found a job in Hadley Garden.",
      "word_count": 13
    },
    {
      "segment_idx": 6,
      "sentence_idx_in_seg": 20,
      "text": "I was working for a-- a company called Gilded Jewelers.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 0,
      "text": "The-- the Jewish Suffragette Committee.",
      "word_count": 5
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 1,
      "text": "In fact, they sent me and my friend, Bernard, who was an-- who lived in Australia for the last 40 years, which I went-- my wife and I went to see him about-- on our 40th wedding anniversary.",
      "word_count": 38
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 2,
      "text": "And I reminded him.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 3,
      "text": "He stayed there.",
      "word_count": 3
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 4,
      "text": "They made good jewelry.",
      "word_count": 4
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 5,
      "text": "And he was making diamond rings and all that.",
      "word_count": 9
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 6,
      "text": "And I was making the cheap jewelry-- gold, but cheap jewelry.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 7,
      "text": "And about a month before he left Australia, I got him a job at my place because I was earning double what he was.",
      "word_count": 24
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 8,
      "text": "Because I was making charms and lockets and earrings, all gold.",
      "word_count": 11
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 9,
      "text": "But I had to make so many dozen a day.",
      "word_count": 10
    },
    {
      "segment_idx": 7,
      "sentence_idx_in_seg": 10,
      "text": "So I was sort of well above him.",
      "word_count": 8
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 0,
      "text": "So I took him to our place.",
      "word_count": 7
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 1,
      "text": "And he worked in our place four or six weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 8,
      "sentence_idx_in_seg": 2,
      "text": "And had a few pounds in his pocket before he went off to Australia.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 0,
      "text": "And gradually-- as I said, gradually, we started going out, cinema, dancing, met girls.",
      "word_count": 14
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 1,
      "text": "And I met my wife in the Astoria in Charing Cross Road.",
      "word_count": 12
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 2,
      "text": "And we were-- I was living in Willesden at the time.",
      "word_count": 11
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 3,
      "text": "She was living in Tottenham.",
      "word_count": 5
    },
    {
      "segment_idx": 9,
      "sentence_idx_in_seg": 4,
      "text": "It was--",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 0,
      "text": "--not easy.",
      "word_count": 2
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 1,
      "text": "She was a-- a Tottenham-Stamford Hill girl.",
      "word_count": 7
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 2,
      "text": "She was born in England.",
      "word_count": 5
    },
    {
      "segment_idx": 10,
      "sentence_idx_in_seg": 3,
      "text": "Some of our-- some of our boys married girls who were also from the-- the camps.",
      "word_count": 16
    }
  ],
