{
  "stem": "18960.2",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.1,
  "sentences_input": [
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 24,
      "text": "It was quite-- we were pretty-- I was pretty much occupied with studies.",
      "word_count": 13
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 25,
      "text": "And they benefited really for me.",
      "word_count": 6
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 26,
      "text": "I still remember a lot of-- a lot of-- of-- of subjects that I took up those-- at those days, particularly Latin and physics, math, and so forth.",
      "word_count": 28
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 27,
      "text": "Sciences.",
      "word_count": 1
    },
    {
      "segment_idx": 0,
      "sentence_idx_in_seg": 28,
      "text": "And we-- we were very well prepared for-- for further education.",
      "word_count": 11
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 0,
      "text": "Well, usually I was-- I was staying with a family, with a Jewish family.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 1,
      "text": "And I was-- they were-- they were inviting me, of course, for their sabbath meals.",
      "word_count": 15
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 2,
      "text": "And they were-- they were cooking for me, and-- and I was participating together.",
      "word_count": 14
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 3,
      "text": "But it was not the same like at home.",
      "word_count": 9
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 4,
      "text": "It was different.",
      "word_count": 3
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 5,
      "text": "The-- the family atmosphere was really missing, and I was lonely as far as that concerned.",
      "word_count": 16
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 6,
      "text": "I miss my home.",
      "word_count": 4
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 7,
      "text": "And I was very glad to come for the holidays and for vacations to my house, and refresh my-- my acquaintances and see my family, stay with my family.",
      "word_count": 29
    },
    {
      "segment_idx": 1,
      "sentence_idx_in_seg": 8,
      "text": "We were very happy-- happy days for me to come home for vacation or for the holidays.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 0,
      "text": "Well, Poland was a pretty anti-Semitic country.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "The Jews never felt welcome in Poland.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "I could never acquire a-- a true friend, a Polish friend, or even less a Ukrainian friend.",
      "word_count": 17
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "So my social life was really limited to-- to having Jewish friends, whether male or female.",
      "word_count": 16
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "And being that my-- my school was Jewish.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "So those days, I didn't have much contact with the-- with the outside population.",
      "word_count": 14
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "I was limited to my friends, my circle of friends.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "I saw--",
      "word_count": 2
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 1,
      "text": "I was very well aware of the clouds that were coming down on Europe.",
      "word_count": 14
    },
    {
      "segment_idx": 4,
      "sentence_idx_in_seg": 2,
      "text": "I still remember when Hitler came to power in 1933, I was only 10 years old.",
      "word_count": 16
    }
  ],
