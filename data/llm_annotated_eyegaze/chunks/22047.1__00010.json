{
  "stem": "22047.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.3,
  "sentences_input": [
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, I-- Marge and I attend the First United Methodist in Pacific Grove, right down the street a ways, and we've-- we been at that-- in that church for three years now.",
      "word_count": 36
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "We-- we-- we were married in the Episcopal church.",
      "word_count": 9
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "And we went to that church for awhile, but the liturgy was a little bit much for-- for us, and so we looked for another church and have-- have now wound up at a Methodist Church.",
      "word_count": 36
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Not really.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "My-- my mother occasionally was, and she got into Christian Science, and primarily because she wanted to-- to not let her-- her illness get in the way of her-- she wanted to-- to make sure there wasn't a-- a mind thing, so she chose Christian Science.",
      "word_count": 46
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And-- but they were not really what you'd term church goers.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "Just occasionally.",
      "word_count": 2
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "My dad really-- didn't really go to church much.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "He became very, very much so though later in the Presbyterian Church after my mother passed away.",
      "word_count": 17
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Pardon me?",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "No, that-- this was after he retired.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And after my mother had passed away, and he-- he remarried this Ruth, that you saw the picture of her.",
      "word_count": 20
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "He got very involved in the Presbyterian Church in Sherman Oaks and did a lot of good work with the church.",
      "word_count": 21
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "He was an elder, as a matter of fact, until he passed away in '76-- '77.",
      "word_count": 16
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Yes, ma'am.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "I-- I do a lot of things for the church.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "As a matter of fact, I just recently redid the doors to the sanctuary.",
      "word_count": 14
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "They're huge, 10-foot doors, and-- and-- they were getting pretty-- pretty dilapidated, cracks in them.",
      "word_count": 15
    }
  ],
