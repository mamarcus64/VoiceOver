  "elapsed_s": 8.9,
  "sentences_input": [
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 6,
      "text": "The old timer men and the SS men were walking around with naked women very naturally.",
      "word_count": 16
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 7,
      "text": "Of course, later we found out that it was an everyday scene for them, but it wasn't for us.",
      "word_count": 19
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 8,
      "text": "And we were so embarrassed.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 9,
      "text": "We tried to hide between each other, but it was nothing we could do.",
      "word_count": 14
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 10,
      "text": "Then we went to the next room, and there was a group of girls-- old timers-- and they were sitting on chairs.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 11,
      "text": "No, they were standing there with chairs, and they shaved our hair from our head, and other parts of the body, too.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 12,
      "text": "So here we were, naked, without hair, only with our shoes.",
      "word_count": 11
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 13,
      "text": "Then we went to the third part, and we were told, put your shoes at the walls and go in the middle.",
      "word_count": 22
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 14,
      "text": "And we went in the middle, and we were the lucky ones.",
      "word_count": 12
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 15,
      "text": "We received some lukewarm water.",
      "word_count": 5
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 16,
      "text": "Because later, we found out that the other people who went to left, they went through the same procedure, but their doors were hermetically closed, and they got the Zyklon gas, not the water.",
      "word_count": 34
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 17,
      "text": "After this we went to the next, went outside, we put on our shoes, on our bare feet.",
      "word_count": 18
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 18,
      "text": "We received one set of underwear, a group of girls, [INAUDIBLE]",
      "word_count": 11
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 1,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 2,
      "text": "Before we received our clothing, there were a group of girls with-- disinfecting us with those little machines under our arms and other places, so we will be real clean.",
      "word_count": 30
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 3,
      "text": "Then, the next place, a group of girls, it was their job.",
      "word_count": 12
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 4,
      "text": "We received one set of underwear and one dress, a regular summer dress.",
      "word_count": 13
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 5,
      "text": "They didn't have any more striped clothing, so we didn't have striped clothing.",
      "word_count": 13
    }
  ],
