{
  "stem": "21259.2",
  "chunk_idx": 4,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.4,
  "sentences_input": [
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 6,
      "text": "And-- and I was there two weeks, I think, three weeks.",
      "word_count": 11
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 7,
      "text": "I-- I don't remember.",
      "word_count": 4
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 8,
      "text": "They took us to work, the German.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "In September. 1st September, the 2nd September.",
      "word_count": 7
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "They were there on--",
      "word_count": 4
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "There was--",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "I was the 2nd, the 3rd, about two, three weeks.",
      "word_count": 10
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "After they took a woman in this to work.",
      "word_count": 9
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "We work, you know?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "This-- the streets, you know, the streets.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "Everything's down.",
      "word_count": 2
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "And this is the reason we run away.",
      "word_count": 8
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "This was in the night, I remember, about two-- two weeks, three weeks.",
      "word_count": 13
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, after this.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "Oh, the life changed.",
      "word_count": 4
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "The two weeks when I run away on the road, I saw on the road, a lot run away, you understand?",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And the Germans with the 36 planes, you know, they shot off the people, you know, with-- with [INAUDIBLE], you know?",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "They-- and a lot they kill horses.",
      "word_count": 7
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 4,
      "text": "That make many violence, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 5,
      "text": "And very bad, very bad.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 6,
      "text": "All-- all the road, all the road you should have seen where they killed them all-- all from-- from the plane.",
      "word_count": 21
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 7,
      "text": "And-- and they shot them.",
      "word_count": 5
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 8,
      "text": "In we were-- and I-- I went away.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 9,
      "text": "I went to [INAUDIBLE], Skarzysko-- not Skarzysko, [?",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 10,
      "text": "Krasnik, ?] Lubelski.",
      "word_count": 3
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 11,
      "text": "We all stayed over there, Janow Lubelski you know, in-- in there.",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "We running.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE].",
      "word_count": 1
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "But-- but the rabbi they was-- we was coming Friday night, I remember.",
      "word_count": 13
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "They used to give us challah and fish.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And we-- and we run away.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And a lot-- a lot is sitting in Janow Lubelski you know?",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "But we don't know where-- where we went.",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "We run.",
      "word_count": 2
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "So you don't know where.",
      "word_count": 5
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "You just ran?",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "Just ran.",
      "word_count": 2
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 0,
      "text": "Nothing, just like clothes.",
      "word_count": 4
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 1,
      "text": "I got nothing, with nothing.",
      "word_count": 5
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 2,
      "text": "I got a--",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "Huh?",
      "word_count": 1
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "With friends, a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "Three friends, three friends.",
      "word_count": 4
    }
  ],
