{
  "stem": "1704.3",
  "chunk_idx": 7,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.0,
  "sentences_input": [
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "And I was lucky enough to get in a truck again, to the station.",
      "word_count": 14
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "And the cattle train was standing already.",
      "word_count": 7
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 3,
      "text": "And all prisoners-- non-Jewish prisoners in the uniforms, striped jackets-- were unloaded out of the train.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 4,
      "text": "And we were put in, not clean, there were lice in already in the wagons.",
      "word_count": 15
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 5,
      "text": "They were, outside, there were heaps of beetroot, raw beetroot, and kohlrabi, which is like sweet-- you know, when you put in soup, those white things.",
      "word_count": 26
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 6,
      "text": "Sprouts?",
      "word_count": 1
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "No, no.",
      "word_count": 2
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "But they're raw, like carrots.",
      "word_count": 5
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "No, something like it.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Turnips, like turnips, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 1,
      "text": "Heaps of them, and you could take that to take in the train.",
      "word_count": 13
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 2,
      "text": "We could-- later on we got a piece of bread.",
      "word_count": 10
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 3,
      "text": "That was it.",
      "word_count": 3
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 4,
      "text": "And so we went with about, I don't know, about 75 I think, in one wagon, sitting on the floor.",
      "word_count": 20
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 5,
      "text": "And I was still, coming out of the hospital, still to look after them.",
      "word_count": 14
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 6,
      "text": "And we went riding.",
      "word_count": 4
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 7,
      "text": "And every day, somebody died.",
      "word_count": 5
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 8,
      "text": "People died, left, right, and center of me.",
      "word_count": 8
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 9,
      "text": "The train would stop, and we would kind of throw them out, more or less.",
      "word_count": 15
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 10,
      "text": "They were buried on the spot or left there.",
      "word_count": 9
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "We had to go to the toilet, we were sitting at the side of the road, and the Germans just looking on with the gun on the shoulder.",
      "word_count": 28
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "And we could hear-- I had my 25th birthday on  the train.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "Don't ask me, did I have a calendar, did I know the date?",
      "word_count": 13
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "I can't remember, but I knew it was my birthday.",
      "word_count": 10
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "I don't know why.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "And sometimes the train had to stop because the airplanes were going over.",
      "word_count": 13
    }
  ],
