  "sentences_input": [
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "The most-- the worst we feared was get into the Russian hands.",
      "word_count": 12
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "Because we were running away from there, you see?",
      "word_count": 9
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "And if they catch us and they can identify us, we are lost.",
      "word_count": 13
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "So we try to avoid.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "So this was the only way to avoid, because Austria-- Austria was then divided in four zones.",
      "word_count": 17
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "There was the-- you saw there was the Americans, the French, the English, and the Russians.",
      "word_count": 16
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "Four quarter-- four-- they had everyone a section of Vienna.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "[INAUDIBLE]",
      "word_count": 1
    }
