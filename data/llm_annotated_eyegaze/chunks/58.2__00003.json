{
  "stem": "58.2",
  "chunk_idx": 3,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.3,
  "sentences_input": [
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 0,
      "text": "And I took his hat, and I walked to the village.",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 1,
      "text": "And you used to say, praise God, you know, in Polish, you know, [POLISH].",
      "word_count": 14
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 2,
      "text": "And they asked-- some of them asked you, where's your family?",
      "word_count": 11
    },
    {
      "segment_idx": 13,
      "sentence_idx_in_seg": 3,
      "text": "Where's your parents?",
      "word_count": 3
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 0,
      "text": "I said, they shipped us out from Silesia.",
      "word_count": 8
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 1,
      "text": "I don't know where my parents are.",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 2,
      "text": "I'm alone-- they shipped us apart.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 3,
      "text": "They shipped in a different direction [INAUDIBLE].",
      "word_count": 7
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 4,
      "text": "Oh, they felt sorry for me.",
      "word_count": 6
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 5,
      "text": "They gave me some food.",
      "word_count": 5
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 6,
      "text": "And I walked around there all day, and I came home.",
      "word_count": 11
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 7,
      "text": "Some days I came home with a lot of food.",
      "word_count": 10
    },
    {
      "segment_idx": 14,
      "sentence_idx_in_seg": 8,
      "text": "So bread, potatoes, anything you could get to eat.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 0,
      "text": "Then, one day, my father-- I walk out to the village.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 1,
      "text": "I see my father on the road.",
      "word_count": 7
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 2,
      "text": "I say, what are you do-- how do you come here?",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 3,
      "text": "He says he also escaped.",
      "word_count": 5
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 4,
      "text": "So I had two in the family already here.",
      "word_count": 9
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 5,
      "text": "So-- and this was going on-- and my mother came, and my younger sister came.",
      "word_count": 15
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 6,
      "text": "My two brothers were working in a factory out of Warsaw for the Germans, and my sisters were working on a big farm, also, out of-- around outskirts of Warsaw.",
      "word_count": 30
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 7,
      "text": "Anyway, I walked to these villages for-- everyday you had to change your village.",
      "word_count": 14
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 8,
      "text": "You couldn't go every day to the same people, you see?",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 9,
      "text": "One day my mother said, she wants to go with me.",
      "word_count": 11
    },
    {
      "segment_idx": 15,
      "sentence_idx_in_seg": 10,
      "text": "I say, the only thing is it's going to be-- for me is a hardship, because they'll recognize you as a middle-aged person, and you wouldn't be able to keep up with me.",
      "word_count": 33
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 0,
      "text": "She insisted she wants to go.",
      "word_count": 6
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 1,
      "text": "So I say, OK.",
      "word_count": 4
    },
    {
      "segment_idx": 16,
      "sentence_idx_in_seg": 2,
      "text": "You want to go, you can go.",
      "word_count": 7
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 0,
      "text": "We go across the bridge.",
      "word_count": 5
    },
    {
      "segment_idx": 17,
      "sentence_idx_in_seg": 1,
      "text": "We go into the first village.",
      "word_count": 6
    }
  ],
