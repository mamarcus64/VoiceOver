{
  "stem": "1491.1",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.0,
  "sentences_input": [
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "Everything, whatever you did, you risked your life.",
      "word_count": 8
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "If it went through, fine, You were OK, you were a hero.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "So he pulls us from ghetto B in the last minute.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "And he dressed us up in my mother coats, long coats with high heels, that we should look older, they shouldn't stop us at the gate going to Plaszow because Goth was watching every face.",
      "word_count": 35
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Goth was the biggest murderer in Plaszow.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "So me, such a spoiled child, I went to take-- you wouldn't believe it worked-- a strainer.",
      "word_count": 17
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "What is a strainer?",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 9,
      "text": "In Poland, you boiled milk, so there was always a skin on top of the milk a skin foam from boiling.",
      "word_count": 21
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 10,
      "text": "And I wouldn't drink milk if the skin was floating.",
      "word_count": 10
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 11,
      "text": "So I had my personal strainer over a glass, which you put it, and you poured the milk through so whole skin was left on the strainer.",
      "word_count": 27
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 12,
      "text": "I took with me to Plaszow in case I get milk.",
      "word_count": 11
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 13,
      "text": "How will I be able to drink it?",
      "word_count": 8
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "[LAUGHS]",
      "word_count": 1
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "I think couple miles.",
      "word_count": 4
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember.",
      "word_count": 3
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "It was a long walk, but how long, far, I really don't know.",
      "word_count": 13
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "Maybe 20,000 or more.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "I don't know.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "March 13, yeah.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 1,
      "text": "They liquidated Krakow.",
      "word_count": 3
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 2,
      "text": "So Saturday, we went.",
      "word_count": 4
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 3,
      "text": "They took us-- we managed to get to Plaszow.",
      "word_count": 9
    }
  ],
