{
  "stem": "22836.2",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 5.8,
  "sentences_input": [
    {
      "segment_idx": 81,
      "sentence_idx_in_seg": 0,
      "text": "There was coming in, maybe, maybe run away, another 7, 8, 10 people-- there, from them.",
      "word_count": 16
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 0,
      "text": "Well, it was my brother, the older brother.",
      "word_count": 8
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 1,
      "text": "It was the younger brother, my wife, and there was another girl, another three boys-- friend too with us.",
      "word_count": 19
    },
    {
      "segment_idx": 82,
      "sentence_idx_in_seg": 2,
      "text": "We ran away, like, all together, like 12 people.",
      "word_count": 9
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 0,
      "text": "The parents was passing away in that Osowa-- passing away.",
      "word_count": 10
    },
    {
      "segment_idx": 83,
      "sentence_idx_in_seg": 1,
      "text": "And we brought them to the right place.",
      "word_count": 8
    },
    {
      "segment_idx": 84,
      "sentence_idx_in_seg": 0,
      "text": "Natural, natural die in that Osowa.",
      "word_count": 6
    },
    {
      "segment_idx": 85,
      "sentence_idx_in_seg": 0,
      "text": "Right at the court-- buried in the--",
      "word_count": 7
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 0,
      "text": "--in the cemetery, right.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 1,
      "text": "I remember the mother, me and mine two brothers, and my brother-in-law.",
      "word_count": 12
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 2,
      "text": "We carried the mother.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 3,
      "text": "It was very religious.",
      "word_count": 4
    },
    {
      "segment_idx": 86,
      "sentence_idx_in_seg": 4,
      "text": "And the father was pass away in four days-- in four weeks--",
      "word_count": 12
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 0,
      "text": "--after that.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 1,
      "text": "And we-- we put them away, even one next to the other one-- on the cemetery in Osowa.",
      "word_count": 18
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 2,
      "text": "This-- this I remember.",
      "word_count": 4
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 3,
      "text": "They're lucky.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 4,
      "text": "They lucky, what they pass away.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 5,
      "text": "They lucky.",
      "word_count": 2
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 6,
      "text": "Then we went to the woods.",
      "word_count": 6
    },
    {
      "segment_idx": 87,
      "sentence_idx_in_seg": 7,
      "text": "When we--",
      "word_count": 2
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 0,
      "text": "After we ran away.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 1,
      "text": "We went to the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 2,
      "text": "We see in the woods.",
      "word_count": 5
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 3,
      "text": "You have to eat.",
      "word_count": 4
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 4,
      "text": "Then we went in that-- Matejko.",
      "word_count": 6
    },
    {
      "segment_idx": 88,
      "sentence_idx_in_seg": 5,
      "text": "Matejko got a lot of good-- good people, too-- not all of them, but I got good people there-- where I can trust him.",
      "word_count": 24
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 0,
      "text": "Ukraine-- Ukraine.",
      "word_count": 2
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 1,
      "text": "I can trust them, because I was-- I have the grocery there.",
      "word_count": 12
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 2,
      "text": "And I help him a lot.",
      "word_count": 6
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 3,
      "text": "And we was friend-- like friend-- everything friend.",
      "word_count": 8
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 4,
      "text": "And I left him a lot of things there.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 5,
      "text": "I left them there, say, maybe sometime I come.",
      "word_count": 9
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 6,
      "text": "He help me out.",
      "word_count": 4
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 7,
      "text": "And some places, I couldn't go, because they be-- kill me.",
      "word_count": 11
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 8,
      "text": "Because like now, one place I have, I know I'm sure there they wouldn't kill me.",
      "word_count": 16
    },
    {
      "segment_idx": 89,
      "sentence_idx_in_seg": 9,
      "text": "They don't go for the thing.",
      "word_count": 6
    }
  ],
