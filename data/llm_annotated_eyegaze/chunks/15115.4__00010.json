{
  "stem": "15115.4",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 14.2,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 12,
      "text": "Namias ?] that I was telling you about.",
      "word_count": 8
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 13,
      "text": "I took him to work with me.",
      "word_count": 7
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 14,
      "text": "All of a sudden, And two weeks later, they throw him out.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 15,
      "text": "You know?",
      "word_count": 2
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 16,
      "text": "And all of a sudden, he went to work in the baustelle.",
      "word_count": 12
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 17,
      "text": "He was a young kid.",
      "word_count": 5
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 18,
      "text": "And this Leon Yachiel, the guy who was in Birkenau-- you remember, I told you Birkenau, he was the Polish Jew-- you know, from Polish decent?",
      "word_count": 26
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 19,
      "text": "He became an [INAUDIBLE] an [INAUDIBLE], the big chief [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 20,
      "text": "He had a big position.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And a few of the Greeks became-- Jewish Greeks became kapos.",
      "word_count": 11
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "Which is, you know, normal.",
      "word_count": 5
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And this particular [?",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "Zakiniko, ?] he got into-- put him into work in the baustelle.",
      "word_count": 12
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "In the meantime, this Leon Yachiel used to come during the day after everybody went to work, used to come to the kitchen.",
      "word_count": 23
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I used to prepare different foods for him, make some potatoes into the oven, you know.",
      "word_count": 16
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "And I used to make potato latkes.",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 3,
      "text": "You know what a potato latke is?",
      "word_count": 7
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 4,
      "text": "I used to [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 5,
      "text": "I made potato latkes with the kitchen, you know.",
      "word_count": 9
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "It was pretty good.",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "Because I slept in the kitchen.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "I didn't sleep in the camp.",
      "word_count": 6
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 3,
      "text": "So that was pretty good.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 4,
      "text": "It was habit.",
      "word_count": 3
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 5,
      "text": "And all of a sudden, it's like, you know, he got sick.",
      "word_count": 12
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 6,
      "text": "And he has to go work night shift.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I went to Leon.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 1,
      "text": "I went to the camp.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 2,
      "text": "Leon?",
      "word_count": 1
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 3,
      "text": "I says, he's sick.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 4,
      "text": "He's a young kid.",
      "word_count": 4
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 5,
      "text": "He's going to die, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 6,
      "text": "He's got fever.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 7,
      "text": "You're going to send him to the baustelle.",
      "word_count": 8
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 8,
      "text": "He started screaming at me.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 9,
      "text": "He forgot how much I did for him during the day.",
      "word_count": 11
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 10,
      "text": "He was nervous.",
      "word_count": 3
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 11,
      "text": "He says, well, I can't do it.",
      "word_count": 7
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 12,
      "text": "I can't take him out.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 13,
      "text": "I says, put somebody else.",
      "word_count": 5
    }
  ],
