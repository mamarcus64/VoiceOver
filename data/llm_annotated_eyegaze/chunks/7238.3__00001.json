{
  "stem": "7238.3",
  "chunk_idx": 1,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 3.4,
  "sentences_input": [
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 1,
      "text": "[INTERPOSING VOICES] I had no name anymore.",
      "word_count": 7
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 2,
      "text": "And I had to go to where they-- I was assigned.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 3,
      "text": "There was a long table a lot of women worked around.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 4,
      "text": "Our supervisor was a young woman.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 5,
      "text": "She was a Volksdeutsch.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 6,
      "text": "She-- she favored the German, because she probably was born German.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 7,
      "text": "And-- [PAUSES FOR 5 SECONDS] and she watched us.",
      "word_count": 9
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 8,
      "text": "The other women who worked with me were very simple persons.",
      "word_count": 11
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 9,
      "text": "And they found a way to please her.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 10,
      "text": "They gave her complements.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 11,
      "text": "[PAUSES FOR 3 SECONDS] And she liked it.",
      "word_count": 8
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 12,
      "text": "And they spoke German.",
      "word_count": 4
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 13,
      "text": "I, in my pride, could not dare to speak a word in German, only Polish.",
      "word_count": 15
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 14,
      "text": "She knew who I am.",
      "word_count": 5
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 15,
      "text": "She knew about my higher education.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 16,
      "text": "She knew that I know German.",
      "word_count": 6
    },
    {
      "segment_idx": 2,
      "sentence_idx_in_seg": 17,
      "text": "And she really found a way to be my nemesis.",
      "word_count": 10
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 0,
      "text": "Mrs.",
      "word_count": 1
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 1,
      "text": "Koch, Koch.",
      "word_count": 2
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 2,
      "text": "She used to come and give me the hardest work that was-- [BACKGROUND NOISE] And-- [BACKGROUND NOISE] Now, she found out all to make my life very, very hard.",
      "word_count": 29
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 3,
      "text": "She assigned me to a machine.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 4,
      "text": "And it was sabotage to stop the machine.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 5,
      "text": "The machine worked from morning to evening.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 6,
      "text": "[BACKGROUND NOISE] [SIGHS] [DRINKS] It was very hot.",
      "word_count": 8
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 7,
      "text": "One summer day, it was so hot, I wanted a drink of water.",
      "word_count": 13
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 8,
      "text": "The fountain was outside the building.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 9,
      "text": "And I asked the other girl who worked at the other machine to work on both machines.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 10,
      "text": "Unfortunately, she came in when I left.",
      "word_count": 7
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 11,
      "text": "And she took me for punishment.",
      "word_count": 6
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 12,
      "text": "We had to go to the-- to a place where-- where a guy, a Ukrainian, was sitting there waiting with his whip to give as many as ordered.",
      "word_count": 28
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 13,
      "text": "I brought in there.",
      "word_count": 4
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 14,
      "text": "I saw only a guy in the corner sitting and drinking some vodka and a big table.",
      "word_count": 17
    },
    {
      "segment_idx": 3,
      "sentence_idx_in_seg": 15,
      "text": "He said, lie down.",
      "word_count": 4
    }
  ],
