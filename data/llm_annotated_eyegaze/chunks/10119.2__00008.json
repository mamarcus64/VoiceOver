{
  "stem": "10119.2",
  "chunk_idx": 8,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.6,
  "sentences_input": [
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 15,
      "text": "They put us in a room, which the floor was wet.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 16,
      "text": "They had washed it before, in cement.",
      "word_count": 7
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 17,
      "text": "And you better sit down or lay down.",
      "word_count": 8
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 18,
      "text": "If not, you are being shot.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 19,
      "text": "That's all what we had.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 20,
      "text": "There was a little window.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 21,
      "text": "The little window was there.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 22,
      "text": "They had a light constantly going on us, round and round, to check how everybody is.",
      "word_count": 16
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 23,
      "text": "And they were sitting and having a good time, the Germans.",
      "word_count": 11
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 24,
      "text": "And they were telling us, you better have a good time tonight.",
      "word_count": 12
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 25,
      "text": "That's the last night you're here.",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "They were drinking and eating, the SS men, in that little room-- at the guard house.",
      "word_count": 16
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "Whatev-- well, they made fun of us, all right?",
      "word_count": 9
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "They made fun of us, you know, called us all kind of a names.",
      "word_count": 14
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "This is the last night.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "Tomorrow, you will see.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "You will have a nice [INAUDIBLE].",
      "word_count": 6
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "So, now they had there--",
      "word_count": 5
    },
    {
      "segment_idx": 54,
      "sentence_idx_in_seg": 0,
      "text": "That was in German.",
      "word_count": 4
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 0,
      "text": "In German-- we understood German.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 1,
      "text": "We speak Yiddish.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 2,
      "text": "We understood German.",
      "word_count": 3
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 3,
      "text": "But we thought it was our last night.",
      "word_count": 8
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 4,
      "text": "And there was a few religious women.",
      "word_count": 7
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 5,
      "text": "And they said prayers with us.",
      "word_count": 6
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 6,
      "text": "All night long, we're praying.",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 7,
      "text": "They all said the [?",
      "word_count": 5
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 8,
      "text": "Viduy-- ?] you know, if you know, before the dying.",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 9,
      "text": "I don't know-- and the religious people, you say [?",
      "word_count": 10
    },
    {
      "segment_idx": 55,
      "sentence_idx_in_seg": 10,
      "text": "Viduy ?] before-- If you know you are going, you are ready to accept.",
      "word_count": 14
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 0,
      "text": "So we were not allowed to sing, but quietly, whispering, were praying all night long.",
      "word_count": 15
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 1,
      "text": "Nobody slept.",
      "word_count": 2
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 2,
      "text": "As it happened, the next morning they took us all out.",
      "word_count": 11
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 3,
      "text": "And they lined us up outside.",
      "word_count": 6
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 4,
      "text": "And they called.",
      "word_count": 3
    },
    {
      "segment_idx": 56,
      "sentence_idx_in_seg": 5,
      "text": "And they told us, line up according to your alphabet, what your name is with.",
      "word_count": 15
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 0,
      "text": "At that time, we just didn't think straight.",
      "word_count": 8
    },
    {
      "segment_idx": 57,
      "sentence_idx_in_seg": 1,
      "text": "It was just so numb.",
      "word_count": 5
    }
  ],
