{
  "stem": "5225.3",
  "chunk_idx": 6,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.1,
  "sentences_input": [
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And the same guy takes me says, what are you doing here?",
      "word_count": 12
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "I said, what do you mean what I'm doing here?",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "You give me yesterday 500 zloties.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "Sure, I gave it to you.",
      "word_count": 6
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "But so I thought I was going to the restaurant to eat the supper, and they told me to pay 500 zloties.",
      "word_count": 22
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Who told you to go to the restaurant?",
      "word_count": 8
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 7,
      "text": "So where I should go that's not my business.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 8,
      "text": "That's your business.",
      "word_count": 3
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 9,
      "text": "OK, I give you another five, don't pull any more.",
      "word_count": 10
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 10,
      "text": "He said, I'm going to come as long as you know because I don't know where to go.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 11,
      "text": "You tell me.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 0,
      "text": "But going down from over there I found a cousin.",
      "word_count": 10
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 1,
      "text": "A cousin which he is here and one is in Israel.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 2,
      "text": "And he tells me, oh, fine, well, come on let's go home.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 3,
      "text": "He takes me home.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 4,
      "text": "There were two brothers and a cousin.",
      "word_count": 7
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 5,
      "text": "This one.",
      "word_count": 2
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 6,
      "text": "And they have two brothers.",
      "word_count": 5
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 7,
      "text": "The two cousins got their wives, and one is a single.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 8,
      "text": "OK.",
      "word_count": 1
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 9,
      "text": "Very good, they got two rooms, a kitchen, and a room.",
      "word_count": 11
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 10,
      "text": "And by talking to us he said, Abe, you can every thing you can have with what is here.",
      "word_count": 19
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 11,
      "text": "But the one thing you cannot sleep here.",
      "word_count": 8
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 12,
      "text": "I said, oh wait a minute.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 13,
      "text": "I forgot something.",
      "word_count": 3
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 14,
      "text": "And I was going down and never showed up again to them.",
      "word_count": 12
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 15,
      "text": "Never showed up again.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 16,
      "text": "The single boy, he understood me.",
      "word_count": 6
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 17,
      "text": "And after three days he found me in the [SPEAKING YIDDISH], in the guest house.",
      "word_count": 15
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 18,
      "text": "And he said to me, I know why you're angry, but believe me if you would go in their situation, you wouldn't be angry.",
      "word_count": 24
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 19,
      "text": "There are two couples.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 20,
      "text": "There are two beds.",
      "word_count": 4
    },
    {
      "segment_idx": 31,
      "sentence_idx_in_seg": 21,
      "text": "I sleep on the floor.",
      "word_count": 5
    }
  ],
