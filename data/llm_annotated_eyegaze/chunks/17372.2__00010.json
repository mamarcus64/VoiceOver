{
  "stem": "17372.2",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 248.1,
  "sentences_input": [
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 4,
      "text": "We wanted to go to Cracow.",
      "word_count": 6
    },
    {
      "segment_idx": 50,
      "sentence_idx_in_seg": 5,
      "text": "What do you mean by 'good train'?",
      "word_count": 7
    },
    {
      "segment_idx": 51,
      "sentence_idx_in_seg": 0,
      "text": "Good train is for carrying goods, you know, open of-- or cattle train, open, open completely without a-- not with the doors.",
      "word_count": 22
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 0,
      "text": "Well, what I had.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 1,
      "text": "Therefore we left Brunnlitz.",
      "word_count": 4
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 2,
      "text": "Schindler had the magazine with some materials, some clothing materials, some sleepers, some pajamas.",
      "word_count": 14
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 3,
      "text": "He give all-- each of us, he give us a pajama and pair of slippers and three yards of material for suit, which-- my grandson gots the suit still here.",
      "word_count": 30
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 4,
      "text": "Very good material, it was.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 5,
      "text": "And that we had with us.",
      "word_count": 6
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 6,
      "text": "And I had the accordion.",
      "word_count": 5
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 7,
      "text": "And I had the violin of my brother because he was taken away from Brunnlitz.",
      "word_count": 15
    },
    {
      "segment_idx": 52,
      "sentence_idx_in_seg": 8,
      "text": "So why are we going--",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 0,
      "text": "My wife, some friends.",
      "word_count": 4
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 1,
      "text": "And while we're going, in middle of nowhere, train stopped.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 2,
      "text": "Some Russian soldiers started to take away things from us.",
      "word_count": 10
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 3,
      "text": "And [PAUSES FOR 3 SECONDS] I thought, oh, my accordion will go.",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 4,
      "text": "And just one wagon before us, I heard the train whistle, [WHISTLING].",
      "word_count": 12
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 5,
      "text": "And train moved.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 6,
      "text": "I jumped out.",
      "word_count": 3
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 7,
      "text": "And my accordion was saved.",
      "word_count": 5
    },
    {
      "segment_idx": 53,
      "sentence_idx_in_seg": 8,
      "text": "And violin was saved.",
      "word_count": 4
    }
  ],
