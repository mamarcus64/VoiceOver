  "elapsed_s": 4.2,
  "sentences_input": [
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "And we saw, haggard, a number of people filing in.",
      "word_count": 10
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 0,
      "text": "And then after that a lot of men coming in from the outside.",
      "word_count": 13
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 1,
      "text": "Nobody was permitted to go to the window.",
      "word_count": 8
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 2,
      "text": "And somehow we found out that these people are put on a death march, because they are moving them away from a camp-- we didn't know where that camp was-- from the advancing Russians.",
      "word_count": 34
    },
    {
      "segment_idx": 29,
      "sentence_idx_in_seg": 3,
      "text": "And they have to march more to the west, because the Russians were moving in from the east.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 0,
      "text": "And I just had to go to the window and just look, because I saw that-- I was hoping, I probably wasn't sure, that I saw one of my uncles.",
      "word_count": 30
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 1,
      "text": "And I went to the window and looked down.",
      "word_count": 9
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 2,
      "text": "And then the kitchen chef, who was called [GERMAN] came up, yelling and screaming, with a stick, who dared to go to the window?",
      "word_count": 24
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 3,
      "text": "So I stepped forward.",
      "word_count": 4
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 4,
      "text": "And then she started beating me up.",
      "word_count": 7
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 5,
      "text": "And then pushed me to the ground, and I had lacerations and bleeding and wounds and all that.",
      "word_count": 18
    },
    {
      "segment_idx": 30,
      "sentence_idx_in_seg": 6,
      "text": "Unfortunately, it wasn't my uncle, neither one.",
      "word_count": 7
    }
  ],
