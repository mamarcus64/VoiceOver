{
  "stem": "3631.5",
  "chunk_idx": 13,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.9,
  "sentences_input": [
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 1,
      "text": "That your sister had-- had been interested in your sister and stayed with them for two months.",
      "word_count": 17
    },
    {
      "segment_idx": 58,
      "sentence_idx_in_seg": 2,
      "text": "We all-- no, we all stayed with that family.",
      "word_count": 9
    },
    {
      "segment_idx": 59,
      "sentence_idx_in_seg": 0,
      "text": "For two months, yeah.",
      "word_count": 4
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 0,
      "text": "And the woman, she wouldn't let us go.",
      "word_count": 8
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 1,
      "text": "The woman had to cook.",
      "word_count": 5
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 2,
      "text": "And-- and of course, we tried-- from the little money we got, we tried to contribute to-- to-- to whatever we could, until we went on our own then.",
      "word_count": 29
    },
    {
      "segment_idx": 60,
      "sentence_idx_in_seg": 3,
      "text": "And I got a job with the-- with the British Army unit, a civil labor unit, the British Civilian Labor Office.",
      "word_count": 21
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 0,
      "text": "Office.",
      "word_count": 1
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 1,
      "text": "I started as a-- as an office clerk.",
      "word_count": 8
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 2,
      "text": "And before I came to America I was a senior administrative assistant.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 3,
      "text": "That was the office work.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 4,
      "text": "And by that time, with my English, it-- it-- it got-- got better.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 5,
      "text": "And-- and besides this, I had a job with the Universal International, the American film company, or Universal Pictures, it was called again.",
      "word_count": 23
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 6,
      "text": "They had an office in Rome, the Italian distributorship for-- for their movies.",
      "word_count": 13
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 7,
      "text": "They needed somebody who could talk fluently, who knew English shorthand fluently.",
      "word_count": 12
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 8,
      "text": "Well, I didn't know English shorthand fluently, but-- I didn't know English fluently, but I know German shorthand fluently.",
      "word_count": 19
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 9,
      "text": "And I was able to adjust it.",
      "word_count": 7
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 10,
      "text": "And-- and I became-- was the secretary, a temporary secretary for the Italian manager of Universal.",
      "word_count": 16
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 11,
      "text": "And it was really interesting.",
      "word_count": 5
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 12,
      "text": "They exported Universal Pictures there, and we dubbed them there in their own dubbing office.",
      "word_count": 15
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 13,
      "text": "And the-- the-- the distributor through the country came around.",
      "word_count": 10
    },
    {
      "segment_idx": 61,
      "sentence_idx_in_seg": 14,
      "text": "And I worked these two-- two jobs, until we-- we finally could come to America.",
      "word_count": 15
    },
    {
      "segment_idx": 62,
      "sentence_idx_in_seg": 0,
      "text": "We came to America in February, '45.",
      "word_count": 7
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 1,
      "text": "[INAUDIBLE] I'm sorry. '47.",
      "word_count": 4
    },
    {
      "segment_idx": 63,
      "sentence_idx_in_seg": 2,
      "text": "February-- February, 20, we arrived in 1947.",
      "word_count": 7
    }
  ],
