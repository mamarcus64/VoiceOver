{
  "stem": "311.3",
  "chunk_idx": 9,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 11.3,
  "sentences_input": [
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 0,
      "text": "It's a work camp.",
      "word_count": 4
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 1,
      "text": "But becomes-- later, it became concentration camp.",
      "word_count": 7
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 2,
      "text": "And the same one, there was no change.",
      "word_count": 8
    },
    {
      "segment_idx": 71,
      "sentence_idx_in_seg": 3,
      "text": "They put more wires, more electric wires.",
      "word_count": 7
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 0,
      "text": "No, it was not.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 1,
      "text": "It was the same thing.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 2,
      "text": "And then, the first day, they brought in all the dead ones.",
      "word_count": 12
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 3,
      "text": "And there was 15,000.",
      "word_count": 4
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 4,
      "text": "They brought them to bury.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 5,
      "text": "You see, they're sent out.",
      "word_count": 5
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 6,
      "text": "Then the rest didn't-- couldn't assemble.",
      "word_count": 6
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 7,
      "text": "They didn't have enough trains, so whatever it is, they shot them on the spot.",
      "word_count": 15
    },
    {
      "segment_idx": 72,
      "sentence_idx_in_seg": 8,
      "text": "[PAUSES FOR 3 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 0,
      "text": "And what happened?",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 1,
      "text": "We came in.",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 2,
      "text": "When was it?",
      "word_count": 3
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 3,
      "text": "Monday?",
      "word_count": 1
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 4,
      "text": "Right the next day, they're taking people to bury the people.",
      "word_count": 11
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 5,
      "text": "They don't grab me.",
      "word_count": 4
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 6,
      "text": "Oh, my father said, oh, no.",
      "word_count": 6
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 7,
      "text": "He know what I'd never make it, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 73,
      "sentence_idx_in_seg": 8,
      "text": "Where was your mother and your two sisters?",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 0,
      "text": "My mother, they took away.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 1,
      "text": "But that sister, Berta, what they took away the baby and smashed against the wall, came in, and she made it.",
      "word_count": 21
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 2,
      "text": "She came into the concentration-- to the arbeitslager with us.",
      "word_count": 10
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 3,
      "text": "But I remember like now.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 4,
      "text": "She was sitting like this.",
      "word_count": 5
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 5,
      "text": "She had a nervous breakdown like this.",
      "word_count": 7
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 6,
      "text": "Her husband was just sitting next to her and every-- And the woman, over there, they knew that she won't eat.",
      "word_count": 21
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 7,
      "text": "They used to give her, spoon by spoon.",
      "word_count": 8
    },
    {
      "segment_idx": 74,
      "sentence_idx_in_seg": 8,
      "text": "She-- [CRYING]",
      "word_count": 2
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 0,
      "text": "[SOBBING] And I went to see her, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 1,
      "text": "She never recognized me.",
      "word_count": 4
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 2,
      "text": "The funny thing is they did the work for her.",
      "word_count": 10
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 3,
      "text": "She had to do work on a sewing machine.",
      "word_count": 9
    },
    {
      "segment_idx": 75,
      "sentence_idx_in_seg": 4,
      "text": "You know, [SIGHS] we are still Jews, you know?",
      "word_count": 9
    },
    {
      "segment_idx": 76,
      "sentence_idx_in_seg": 0,
      "text": "[PAUSES FOR 4 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 0,
      "text": "And-- and you know what?",
      "word_count": 5
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 1,
      "text": "When I used to-- you know, it took more than a-- a year, I used to go there, you know?",
      "word_count": 20
    },
    {
      "segment_idx": 77,
      "sentence_idx_in_seg": 2,
      "text": "And she'd never recognize me, you know?",
      "word_count": 7
    }
  ],
