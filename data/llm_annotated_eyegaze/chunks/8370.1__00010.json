  "elapsed_s": 3.2,
  "sentences_input": [
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 3,
      "text": "So there was a villa, a house, in the forest, in the birch forest behind the crematorium, which they transformed into a gas chamber.",
      "word_count": 24
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 4,
      "text": "And then they digged big trenches.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 5,
      "text": "And when they gassed the people in the-- we called this white villa-- in the white villa, white house, then we, they put the layer of corpses, wood, corpses, wood, diesel in on, and fire.",
      "word_count": 35
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 6,
      "text": "And it was burning like that.",
      "word_count": 6
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 7,
      "text": "Is that it?",
      "word_count": 3
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 8,
      "text": "And then I remember one story from this time, from 1944, arrived many of transport.",
      "word_count": 15
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 9,
      "text": "But when they arrive at transport, and they sent prisoners always to clean the trucks from the luggage, suitcases, and corpses.",
      "word_count": 21
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 10,
      "text": "And among them, they found two children.",
      "word_count": 7
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 11,
      "text": "Already, the people went away.",
      "word_count": 5
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 12,
      "text": "They loaded the corpses on the truck to take to crematorium.",
      "word_count": 11
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 13,
      "text": "And they have been instructed to put the children as well on top.",
      "word_count": 13
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 14,
      "text": "And the children, the two, one girl of about three, four, and same age a young, little boy of [? four or ?] five, had been sitting on the corpses, seeing us.",
      "word_count": 32
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 15,
      "text": "They greeted us with hands and smiling to us.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 16,
      "text": "And they arrived to the big ditches with fire.",
      "word_count": 9
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 17,
      "text": "They tipped the truck.",
      "word_count": 4
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 18,
      "text": "And like snow that fell, the children came to the fire.",
      "word_count": 11
    }
  ],
