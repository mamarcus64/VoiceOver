{
  "stem": "27767.7",
  "chunk_idx": 10,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 8.2,
  "sentences_input": [
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 8,
      "text": "And one of a grandchild has my little younger sister's name, Chana, Chana Vider.",
      "word_count": 14
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 9,
      "text": "So I think-- I think God help me, because I never-- I never imagined I was going to survive.",
      "word_count": 19
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 10,
      "text": "And it was really very few people who survived.",
      "word_count": 9
    },
    {
      "segment_idx": 32,
      "sentence_idx_in_seg": 11,
      "text": "And I think God wanted me to survive to be able to tell the story, and to have a family, and--",
      "word_count": 21
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "If I dream?",
      "word_count": 3
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "Yes, I was dreaming for a-- for a long years.",
      "word_count": 10
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "I was-- I was dreaming I'm in the camp.",
      "word_count": 9
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "And I'm-- I was dreaming for months and months, having dreams about it, not anymore.",
      "word_count": 15
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 4,
      "text": "I'm not dreaming any more about the concentration camp, about-- sometimes, I'm dreaming with my father.",
      "word_count": 16
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 5,
      "text": "I see him, and sometimes about my mother, not my sisters.",
      "word_count": 11
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 6,
      "text": "I don't know, not my sisters.",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 7,
      "text": "But sometimes my father and my mother comes back to me in dream.",
      "word_count": 13
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "Yeah, I tell you.",
      "word_count": 4
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "I was thinking to tell the story-- first, when I-- when I find out, you know, about the deniers, and I saw on television something.",
      "word_count": 25
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "And I was ready to grab this guy and kill him, you know, when he was telling nothing happened.",
      "word_count": 19
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 3,
      "text": "It's a hoax, and this kind of things.",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "I said to myself, where are my parents?",
      "word_count": 8
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "Where are my sisters, my relatives?",
      "word_count": 6
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "At least 30 or 40 people from my family So I decided I have to talk, number one.",
      "word_count": 18
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "And, number two, I have to talk to people, the children, the new generation.",
      "word_count": 14
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "They must know what's happened.",
      "word_count": 5
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 2,
      "text": "They must know what mankind could do.",
      "word_count": 7
    }
  ],
