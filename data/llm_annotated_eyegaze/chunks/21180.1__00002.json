{
  "stem": "21180.1",
  "chunk_idx": 2,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 6.6,
  "sentences_input": [
    {
      "segment_idx": 18,
      "sentence_idx_in_seg": 3,
      "text": "But a Jewish lady, girl, I should say, she watched the kosher.",
      "word_count": 12
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 0,
      "text": "Of course.",
      "word_count": 2
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 1,
      "text": "Was a very Alexandria steeple.",
      "word_count": 5
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 2,
      "text": "Next the building was it.",
      "word_count": 5
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 1,
      "text": "This was a small synagogue, about three, four [YIDDISH].",
      "word_count": 9
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 2,
      "text": "But was a-- a synagogue-- I should say two minutes from our house.",
      "word_count": 13
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 3,
      "text": "And was a big, big [YIDDISH].",
      "word_count": 6
    },
    {
      "segment_idx": 20,
      "sentence_idx_in_seg": 4,
      "text": "Lodz was a very Jewish type of school, and [PAUSES FOR 3 SECONDS] where we lived was a special Jewish neighborhood.",
      "word_count": 21
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 0,
      "text": "The-- the-- the janitor was a goy.",
      "word_count": 7
    },
    {
      "segment_idx": 21,
      "sentence_idx_in_seg": 1,
      "text": "The rest around in this neighborhood was not living goyim.",
      "word_count": 10
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 0,
      "text": "Please.",
      "word_count": 1
    },
    {
      "segment_idx": 22,
      "sentence_idx_in_seg": 1,
      "text": "For the Shabbat.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 1,
      "text": "The baking.",
      "word_count": 2
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 2,
      "text": "My mother make it Tuesday.",
      "word_count": 5
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 3,
      "text": "And in our house was a bakery.",
      "word_count": 7
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 4,
      "text": "The people, the girls, one of the girls took it to the bakery to bake it in the bakery.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 5,
      "text": "We had our-- we-- we also had a special big stove with six-- how do I say-- cook places.",
      "word_count": 19
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 6,
      "text": "It was divided.",
      "word_count": 3
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 7,
      "text": "Was special one side for milk and the other side for flesh.",
      "word_count": 12
    },
    {
      "segment_idx": 23,
      "sentence_idx_in_seg": 8,
      "text": "Was a strictly religious home.",
      "word_count": 5
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "She was a good cook, but she only prepared it, I should say.",
      "word_count": 13
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "But I had a sister which she was the oldest, before she married she always helped-- I should say, to me I called her Mother Zelda.",
      "word_count": 26
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "I was the youngest.",
      "word_count": 4
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "This is what they say when I was small.",
      "word_count": 9
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "But she took care on the household before she married.",
      "word_count": 10
    },
    {
      "segment_idx": 25,
      "sentence_idx_in_seg": 0,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 0,
      "text": "No.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 1,
      "text": "Not close by.",
      "word_count": 3
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 2,
      "text": "I had-- the grandparents are from a little town which called Peshischa.",
      "word_count": 12
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 3,
      "text": "And Mother was related to one of the biggest rabbi in the world, which call Simcha Bunim from Peshischa.",
      "word_count": 19
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He was a very big known rabbi, which he died long time ago.",
      "word_count": 13
    }
  ],
