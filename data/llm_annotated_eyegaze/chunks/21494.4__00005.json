{
  "stem": "21494.4",
  "chunk_idx": 5,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 12.4,
  "sentences_input": [
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 0,
      "text": "And I told, I think [INAUDIBLE], I told that he took away everything and he-- he almost killed me, which was-- was-- was true.",
      "word_count": 24
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 1,
      "text": "And he got death penalty, and then he-- he-- he told who killed, yes.",
      "word_count": 14
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 2,
      "text": "He told who killed, you know?",
      "word_count": 6
    },
    {
      "segment_idx": 33,
      "sentence_idx_in_seg": 3,
      "text": "He gave out everyone who killed.",
      "word_count": 6
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 0,
      "text": "And then I came to my shtetl.",
      "word_count": 7
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 1,
      "text": "They told me that Kowalski, the commandant from the shtetl, the Ukrainian, which, you know, organized to rape and to-- and to kill and to take away, he was there.",
      "word_count": 30
    },
    {
      "segment_idx": 34,
      "sentence_idx_in_seg": 2,
      "text": "They-- they caught him and I was another witness.",
      "word_count": 9
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 0,
      "text": "For that trial and some others, I was, I was.",
      "word_count": 10
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 1,
      "text": "I did my-- my job.",
      "word_count": 5
    },
    {
      "segment_idx": 35,
      "sentence_idx_in_seg": 2,
      "text": "[PAUSES FOR 7 SECONDS]",
      "word_count": 4
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 36,
      "sentence_idx_in_seg": 1,
      "text": "No, on there-- in Munich.",
      "word_count": 5
    },
    {
      "segment_idx": 37,
      "sentence_idx_in_seg": 0,
      "text": "I stayed in Munich from '45 to '49.",
      "word_count": 8
    },
    {
      "segment_idx": 38,
      "sentence_idx_in_seg": 0,
      "text": "To Israel.",
      "word_count": 2
    },
    {
      "segment_idx": 39,
      "sentence_idx_in_seg": 0,
      "text": "I go by airplane.",
      "word_count": 4
    },
    {
      "segment_idx": 40,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 41,
      "sentence_idx_in_seg": 0,
      "text": "I found my brother's brother-in-law in Israel.",
      "word_count": 7
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 0,
      "text": "No, there was no need to sponsor right away.",
      "word_count": 9
    },
    {
      "segment_idx": 42,
      "sentence_idx_in_seg": 1,
      "text": "I had-- I was nurse in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 0,
      "text": "Yes.",
      "word_count": 1
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 1,
      "text": "I-- I finished nursing school in Germany.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 2,
      "text": "And there was a [INAUDIBLE] from Israel, a [INAUDIBLE] which know only Hebrew and he broke a leg, and nobody could understand him.",
      "word_count": 23
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 3,
      "text": "And they had-- they know that I speak Hebrew.",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 4,
      "text": "They took me and I translated.",
      "word_count": 6
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 5,
      "text": "And he say, what?",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 6,
      "text": "We saw Hebrew, you want to go to America?",
      "word_count": 9
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 7,
      "text": "I'll send you [INAUDIBLE].",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 8,
      "text": "What day you want?",
      "word_count": 4
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 9,
      "text": "And I say-- and I say, OK.",
      "word_count": 7
    },
    {
      "segment_idx": 43,
      "sentence_idx_in_seg": 10,
      "text": "And he influenced on me that I go to Israel.",
      "word_count": 10
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 0,
      "text": "No, there was no pay.",
      "word_count": 5
    },
    {
      "segment_idx": 44,
      "sentence_idx_in_seg": 1,
      "text": "The Joint helped us out.",
      "word_count": 5
    },
    {
      "segment_idx": 45,
      "sentence_idx_in_seg": 0,
      "text": "Yes, gave us packages and the German-- we had [INAUDIBLE].",
      "word_count": 10
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 0,
      "text": "One moment.",
      "word_count": 2
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 1,
      "text": "I'm so [INAUDIBLE]. '25, '49.",
      "word_count": 5
    },
    {
      "segment_idx": 46,
      "sentence_idx_in_seg": 2,
      "text": "A 24-year-old.",
      "word_count": 2
    },
    {
      "segment_idx": 47,
      "sentence_idx_in_seg": 0,
      "text": "I meet a lot.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 0,
      "text": "Someone special?",
      "word_count": 2
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 1,
      "text": "I-- I meet-- I was engaged to a doctor, but didn't go.",
      "word_count": 12
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 2,
      "text": "I changed my mind.",
      "word_count": 4
    },
    {
      "segment_idx": 48,
      "sentence_idx_in_seg": 3,
      "text": "And then I met my husband.",
      "word_count": 6
    }
  ],
