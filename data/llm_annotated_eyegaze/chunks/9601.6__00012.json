{
  "stem": "9601.6",
  "chunk_idx": 12,
  "model": "openai/gpt-oss-120b",
  "elapsed_s": 4.0,
  "sentences_input": [
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 4,
      "text": "He ordered from the waiter for me-- toast, and sunny side up, and something else, and-- well.",
      "word_count": 17
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 5,
      "text": "You like sunny side up?",
      "word_count": 5
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 6,
      "text": "Who knows.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 7,
      "text": "Yeah.",
      "word_count": 1
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 8,
      "text": "My father said, yeah, he'll eat it.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 9,
      "text": "Well, the sunny side up came, and there's two floating eyes, you know, these two egg-- the yolks are still jiggling.",
      "word_count": 21
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 10,
      "text": "It's floating in this pool of butter.",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 11,
      "text": "[THUMP AND SPLASH] This-- this is eggs?",
      "word_count": 7
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 12,
      "text": "Who eats raw eggs?",
      "word_count": 4
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 13,
      "text": "Not me.",
      "word_count": 2
    },
    {
      "segment_idx": 26,
      "sentence_idx_in_seg": 14,
      "text": "So I just ate, you know, the whites and the toast.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 0,
      "text": "We went to the train.",
      "word_count": 5
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 1,
      "text": "I don't remember what my brother ate, or my parents, but I was fascinated by those yolks.",
      "word_count": 17
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 2,
      "text": "You know, it's floating in this-- and supposed to eat them.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 3,
      "text": "We came to Detroit.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 4,
      "text": "I have a picture when we arrived at Michigan Central, which was the big station.",
      "word_count": 15
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 5,
      "text": "It was different.",
      "word_count": 3
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 6,
      "text": "They took us home with them at-- on Burlingame Street.",
      "word_count": 10
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 7,
      "text": "We lived with them for about a month, or maybe more.",
      "word_count": 11
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 8,
      "text": "It was different, let me tell you.",
      "word_count": 7
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 9,
      "text": "Nice beds with mattresses and blankets.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 10,
      "text": "And one person to a bed.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 11,
      "text": "Wow.",
      "word_count": 1
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 12,
      "text": "When we were in Ulm, you know, the DP camp, we slept on those canvas army bag, you know, canvas, like folding bed, they used to use in the Army.",
      "word_count": 30
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 13,
      "text": "Oh, those are murder.",
      "word_count": 4
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 14,
      "text": "They're only good for one night.",
      "word_count": 6
    },
    {
      "segment_idx": 27,
      "sentence_idx_in_seg": 15,
      "text": "After that, you throw them out.",
      "word_count": 6
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 0,
      "text": "I used to work down the-- down Dexter Boulevard.",
      "word_count": 9
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 1,
      "text": "Every day, I would go two or three blocks, you know.",
      "word_count": 11
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 2,
      "text": "Like I-- I expanded my territory, like one of those young wolfs.",
      "word_count": 12
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 3,
      "text": "I used to really like stories about wolfs.",
      "word_count": 8
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 4,
      "text": "You know the story It's a very nice, interesting book.",
      "word_count": 10
    },
    {
      "segment_idx": 28,
      "sentence_idx_in_seg": 5,
      "text": "You know, you expand your territory.",
      "word_count": 6
    }
  ],
