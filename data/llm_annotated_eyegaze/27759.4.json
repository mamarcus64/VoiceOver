      "narrative_structure": "complicating_action",
      "narrative_valence": "positive",
      "present_day_valence": "positive",
      "topics": []
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 3,
      "text": "Got his degree in architecture.",
      "memory_type": "internal",
      "content_domain": "present-day",
      "temporal_syntax": "strict_past",
      "narrative_structure": "complicating_action",
      "narrative_valence": "positive",
      "present_day_valence": "positive",
      "topics": []
    },
    {
      "segment_idx": 19,
      "sentence_idx_in_seg": 4,
      "text": "Then he got his master's in ecology from Slippery Rock University.",
