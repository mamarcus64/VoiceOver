      "content_domain": "present-day",
      "temporal_syntax": "strict_past",
      "narrative_structure": "orientation",
      "narrative_valence": "negative",
      "present_day_valence": "negative",
      "topics": [
        "Health"
      ]
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 0,
      "text": "About four years now.",
      "memory_type": "external",
      "content_domain": "present-day",
      "temporal_syntax": "present_reflection",
      "narrative_structure": "orientation",
      "narrative_valence": "neutral",
      "present_day_valence": "neutral",
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 1,
      "text": "Seeing this Dr.",
      "memory_type": "external",
      "content_domain": "present-day",
      "temporal_syntax": "present_reflection",
      "narrative_structure": "orientation",
      "narrative_valence": "neutral",
      "present_day_valence": "neutral",
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 2,
      "text": "Danowski, who was in charge of research.",
      "memory_type": "external",
      "content_domain": "present-day",
      "temporal_syntax": "strict_past",
      "narrative_structure": "orientation",
      "narrative_valence": "neutral",
      "present_day_valence": "neutral",
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 3,
      "text": "He was under his direct observation.",
      "memory_type": "internal",
      "content_domain": "present-day",
      "temporal_syntax": "strict_past",
      "narrative_structure": "orientation",
      "narrative_valence": "neutral",
      "present_day_valence": "neutral",
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 4,
      "text": "And Dr.",
      "memory_type": "external",
      "content_domain": "present-day",
      "temporal_syntax": "present_reflection",
      "narrative_structure": "other",
      "narrative_valence": "neutral",
      "present_day_valence": "neutral",
      "topics": []
    },
    {
      "segment_idx": 24,
      "sentence_idx_in_seg": 5,
      "text": "Danowski had told me the type of muscular dystrophy that he had.",
      "memory_type": "internal",
      "content_domain": "present-day",
      "temporal_syntax": "strict_past",
      "narrative_structure": "complicating_action",
      "narrative_valence": "neutral",
